:title("C (subset) interpreter") ;
:description("Parses a C subset and executes it directly, without generating code.

The language is a real C subset, richer than TinyC: the types int, int* and int[N]
(globals and locals, globals with constant initializers), address-of (&x, &a[i]),
dereferencing (*p, also as assignment target), pointer arithmetic (p + i steps whole
ints), pre and post ++/--, assignment as an expression with = += -= *= /= %=, the
ternary operator, || and && with real C short circuit evaluation, the bitwise operators
| ^ & << >> and unary - ! ~, char literals ('A', '\n'), comparisons, function calls and
recursion, switch with real C fallthrough (stacked case labels, default, break), and
putchar()/getchar(). int is 32 bit, / and % truncate towards zero.
Not in the subset: structs, typedef, sizeof, strings, casts, and multi level
pointers (int**).

The interpreter uses one flat, word addressed memory array: every variable lives at an
address, scopes map names to addresses, and pointers are plain indexes. That makes the
semantics exactly match the compiled version (c-to-llvm-ir.abnf), where the same programs
run as LLVM IR.

Every tag composes a small JS closure (a 'thunk') out of the thunks of its children.
Lvalue thunks return an address, expression thunks return the value, statement thunks
return undefined or a signal (return/break/continue) that the enclosing statements route.

The exit code of the metacompiler run is the value that main() returns, so C test
programs are self checking: they return 0 on success.") ;


// --- main rules

:startRule(Program) ;
:whitespace(Whitespace) ;

Program     = { FuncDef | Proto | GlobalDecl } ;

// A function prototype (int putchar(int c);) is accepted and ignored: the callees
// are resolved by name anyway. It keeps the test programs valid for a real C compiler.
Proto       <~~ pop(); pop() /* Drop the collected name and parameters. */ ~~>
            = TypeInt [ "*" ] Id <~~ push(up.in) ~~> ParamList ";" ;

// The merged pushes: [name, [params...], bodyThunk]. A parameter is {name, ptr}.
FuncDef     <~~ defineFunction() ~~>
            = TypeInt Id <~~ push(up.in) ~~> ParamList Block ;

ParamList   <~~ push(takeAll()) ~~>
            = "(" [ ( "void" KwEnd | Param { "," Param } ) ] ")" ;
Param       <~~ push(makeParam(takeAll())) ~~>
            = TypeInt [ "*" <~~ push("*") ~~> ] Id <~~ push(up.in) ~~> ;

// Globals are declared like locals but registered at build time.
GlobalDecl  <~~ defineGlobals(takeAll()) ~~>
            = TypeInt GDeclarator { "," GDeclarator } ";" ;
GDeclarator <~~ push(makeGDecl(takeAll())) ~~>
            = [ "*" <~~ push("*") ~~> ] Id <~~ push(up.in) ~~>
              [ ArraySize | "=" Number <~~ push({init: pop()}) ~~> ] ;
ArraySize   <~~ push({size: pop()}) ~~>
            = "[" Number "]" ;

// Every statement production pushes exactly one thunk: function() -> undefined | signal.
Statement   = Block | If | While | Do | For | Switch | Return | Break | Continue | Decl | Empty | ExprStmt ;

Block       <~~ push(makeBlockStmt(takeAll())) ~~>
            = "{" { Statement } "}" ;

If          <~~ push(makeIf(takeAll())) ~~>
            = KwIf "(" Expression ")" Statement [ KwElse Statement ] ;

While       <~~ push(makeWhile(pop(), pop())) ~~>
            = KwWhile "(" Expression ")" Statement ;

Do          <~~ push(makeDo(pop(), pop())) ~~>
            = KwDo Statement KwWhile "(" Expression ")" ";" ;

For         <~~ push(makeFor(takeAll())) ~~>
            = KwFor "(" [ ForInit ] ";" [ ForCond ] ";" [ ForPost ] ")" Statement ;
ForInit     <~~ push({k:"init", t:pop()}) ~~> = ForVar | ForExpr ;
ForVar      = DeclCore ;
ForExpr     <~~ push(exprToStmt(pop())) ~~> = Expression ;
ForCond     <~~ push({k:"cond", t:pop()}) ~~> = Expression ;
ForPost     <~~ push({k:"post", t:exprToStmt(pop())}) ~~> = Expression ;

Return      <~~ push(makeReturn(takeAll())) ~~>
            = KwReturn [ Expression ] ";" ;

Break       <~~ push(makeBreak()) ~~>   = KwBreak ";" ;
Continue    <~~ push(makeContinue()) ~~> = KwContinue ";" ;

// C switch with fallthrough: execution starts at the first matching case (or default)
// and runs until a break or the end of the switch. Labels may stack (case 1: case 2:).
Switch      <~~ push(makeSwitch(takeAll())) ~~>
            = KwSwitch "(" Expression ")" "{" { SwitchCase } "}" ;
SwitchCase  = Case | Default ;
Case        <~~ push(makeCase(takeAll())) ~~>
            = KwCase CondExpr ":" { Statement } ;
Default     <~~ push(makeDefault(takeAll())) ~~>
            = KwDefault ":" { Statement } ;

Decl        = DeclCore ";" ;
DeclCore    <~~ push(makeSeq(takeAll())) ~~>
            = TypeInt InitDecl { "," InitDecl } ;
InitDecl    <~~ push(makeDecl(takeAll())) ~~>
            = [ "*" <~~ push("*") ~~> ] Id <~~ push(up.in) ~~>
              [ ArraySize | "=" AssignExpr ] ;

Empty       <~~ push(function() {}) ~~>
            = ";" ;

ExprStmt    <~~ push(exprToStmt(pop())) ~~>
            = Expression ";" ;

// Every expression production pushes exactly one thunk: function() -> 32 bit value.
Expression  = AssignExpr ;

// Assignment is an expression: the target is an lvalue (a variable, *expr or a[i]).
AssignExpr  = Assignment | CondExpr ;
Assignment  <~~ push(makeAssign(takeAll())) ~~>
            = Lvalue ( "+=" | "-=" | "*=" | "/=" | "%=" | "=" ) <~~ push(up.in) ~~> AssignExpr ;

// An lvalue thunk evaluates to an address.
Lvalue      = Deref | VarPlace ;
Deref       <~~ push(makeDerefPlace(pop())) ~~>
            = "*" UnaryExpr ;
VarPlace    <~~ push(makeVarPlace(takeAll())) ~~>
            = Id <~~ push(up.in) ~~> [ "[" Expression "]" ] ;

CondExpr    <~~ push(makeCond(takeAll())) ~~>
            = OrExpr [ "?" AssignExpr ":" AssignExpr ] ;

OrExpr      <~~ push(makeOrAnd(takeAll(), "||")) ~~>
            = AndExpr { "||" AndExpr } ;

AndExpr     <~~ push(makeOrAnd(takeAll(), "&&")) ~~>
            = BitOrExpr { "&&" BitOrExpr } ;

BitOrExpr   <~~ push(foldBinary(takeAll())) ~~>
            = BitXorExpr { "|" <~~ push("|") ~~> BitXorExpr } ;
BitXorExpr  <~~ push(foldBinary(takeAll())) ~~>
            = BitAndExpr { "^" <~~ push("^") ~~> BitAndExpr } ;
// The & operator must not match the start of &&: && with an addressable right side
// (0 && bump()) would otherwise parse as 0 & (&bump) and poison the parse.
BitAndExpr  <~~ push(foldBinary(takeAll())) ~~>
            = EqExpr { "&" <~~ push("&") ~~> NotAmp EqExpr } ;
NotAmp = :script(~~
    (function() {
        return (c.peek(0) === 38) ? abnf.newToken("\x01single-amp-only", 0) : undefined
    })()
~~) ;

EqExpr      <~~ push(foldBinary(takeAll())) ~~>
            = RelExpr { ( "==" | "!=" ) <~~ push(up.in) ~~> RelExpr } ;

RelExpr     <~~ push(foldBinary(takeAll())) ~~>
            = ShiftExpr { ( "<=" | ">=" | "<" | ">" ) <~~ push(up.in) ~~> ShiftExpr } ;

ShiftExpr   <~~ push(foldBinary(takeAll())) ~~>
            = AddExpr { ( "<<" | ">>" ) <~~ push(up.in) ~~> AddExpr } ;

AddExpr     <~~ push(foldBinary(takeAll())) ~~>
            = MulExpr { ( "+" | "-" ) <~~ push(up.in) ~~> MulExpr } ;

MulExpr     <~~ push(foldBinary(takeAll())) ~~>
            = UnaryExpr { ( "*" | "/" | "%" ) <~~ push(up.in) ~~> UnaryExpr } ;

// Prefix operators. ++/-- work on lvalues; & takes the address of an lvalue;
// * dereferences (as an expression it loads the pointed to value).
UnaryExpr   = PreIncDec | AddrOf | DerefLoad | Neg | Not | BitNot | PostfixExpr ;
PreIncDec   <~~ push(makePreIncDec(pop(), pop())) ~~>
            = ( "++" | "--" ) <~~ push(up.in) ~~> Lvalue ;
AddrOf      <~~ push(pop() /* The lvalue thunk already yields the address. */) ~~>
            = "&" Lvalue ;
DerefLoad   <~~ push(makeLoad(makeDerefPlace(pop()))) ~~>
            = "*" UnaryExpr ;
Neg         <~~ push(makeNeg(pop())) ~~>
            = "-" UnaryExpr ;
Not         <~~ push(makeNot(pop())) ~~>
            = "!" UnaryExpr ;
BitNot      <~~ push(makeBitNot(pop())) ~~>
            = "~" UnaryExpr ;

PostfixExpr = PostIncDec | Call | Primary ;
PostIncDec  <~~ push(makePostIncDec(pop(), pop())) ~~>
            = Lvalue ( "++" | "--" ) <~~ push(up.in) ~~> ;

Call        <~~ push(makeCall(takeAll())) ~~>
            = Id <~~ push(up.in) ~~> "(" [ AssignExpr { "," AssignExpr } ] ")" ;

// A plain variable reference loads the value; an array name yields its address.
Primary     = "(" Expression ")" | NumberLit | CharLit | IndexedRef | VarRef ;
IndexedRef  <~~ push(makeLoad(makeVarPlace(takeAll()))) ~~>
            = Id <~~ push(up.in) ~~> "[" Expression "]" ;
NumberLit   <~~ push(makeInt(pop())) ~~>
            = Number ;
CharLit     = "'" :whitespace() CChar <~~ push(makeInt(charCode(unescapeC(up.in)))) ~~> "'" :whitespace(Whitespace) ;
CChar       = "\\" "\x20"..b"\x7e" | "\x20"..."\x26" | "\x28"..."\x5b" | "\x5d"..."\x7e" ;
VarRef      <~~ push(makeVarRef(up.in)) ~~>
            = Id ;

Number      <~~ push(parseInt(up.in)) ~~>
            = ( "0" | "1"..."9" ) :whitespace() { "0"..."9" } :whitespace(Whitespace) ;

Id          = ( "a"..."z" | "A"..."Z" | "_" ) :whitespace() { "a"..."z" | "A"..."Z" | "0"..."9" | "_" } :whitespace(Whitespace) ;

TypeInt     = "int" KwEnd ;
KwIf        = "if" KwEnd ;
KwElse      = "else" KwEnd ;
KwWhile     = "while" KwEnd ;
KwDo        = "do" KwEnd ;
KwFor       = "for" KwEnd ;
KwReturn    = "return" KwEnd ;
KwBreak     = "break" KwEnd ;
KwContinue  = "continue" KwEnd ;
KwSwitch    = "switch" KwEnd ;
KwCase      = "case" KwEnd ;
KwDefault   = "default" KwEnd ;

KwEnd = :script(~~
    (function() {
        var cc = c.peek(0)
        return ((cc >= 48 && cc <= 57) || (cc >= 65 && cc <= 90) || cc === 95 || (cc >= 97 && cc <= 122))
            ? abnf.newToken("\x01keyword-boundary", 0)
            : undefined
    })()
~~) ;

Whitespace  = { @+" \t\r\n" | Comment } ;
Comment     = LineComment | BlockComment ;
LineComment = "//" :whitespace() { NotNewline } :whitespace(Whitespace) ;
BlockComment = "/*" :whitespace() { NotStar | "*" { "*" } NotStarSlash } "*" { "*" } "/" :whitespace(Whitespace) ;
NotNewline  = "\x00"..."\x09" | "\x0b"..."\U0010ffff" ;
NotStar     = "\x00"..."\x29" | "\x2b"..."\U0010ffff" ;
NotStarSlash = "\x00"..."\x29" | "\x2b"..."\x2e" | "\x30"..."\U0010ffff" ;

// ---


:startScript(~~

    function takeAll() {
        var items = []
        var v
        while ((v = pop()) != null) items.unshift(v)
        return items
    }

    function fail(msg) {
        println("c interpreter error: " + msg)
        exit(1)
    }

    function charCode(s) { return s.charCodeAt(0) }
    function unescapeC(s) {
        if (s.charCodeAt(0) != 92) return s
        var e = s.charCodeAt(1)
        if (e == 110) return "\n"
        if (e == 116) return "\t"
        if (e == 114) return "\r"
        if (e == 48) return String.fromCharCode(0)
        return String.fromCharCode(e) // \\ \' and everything else: the char itself.
    }

    // ----- The machine: one flat, word addressed memory -----
    // Address 0 stays unused so that 0 can act as a null pointer.
    var mem = [0]
    function alloc(words) {
        var base = mem.length
        for (var i = 0; i < words; i++) mem.push(0)
        return base
    }
    function load(addr) {
        if (addr <= 0 || addr >= mem.length) fail("invalid load at address " + addr)
        return mem[addr]
    }
    function store(addr, v) {
        if (addr <= 0 || addr >= mem.length) fail("invalid store at address " + addr)
        mem[addr] = v | 0
        return mem[addr]
    }

    // ----- Scopes map names to {addr, arr} (arr marks array names: they yield their address) -----
    var globalScope = {}
    var scopes = [globalScope]
    function declVar(name, addr, arr) {
        scopes[scopes.length - 1][name] = {addr: addr, arr: arr}
    }
    function findVar(name) {
        for (var i = scopes.length - 1; i >= 0; i--) {
            if (scopes[i][name] != undefined) return scopes[i][name]
        }
        fail("variable not defined: " + name)
    }

    // All user defined functions by name: {params: [{name, ptr}...], body: thunk}.
    var funcs = {}

    function callFunction(name, argValues) {
        if (name == "putchar") {
            printf("%c", argValues[0] & 255)
            return argValues[0]
        }
        if (name == "getchar") {
            return -1 // No stdin in the interpreter run (matches llvm.Run without input).
        }
        var f = funcs[name]
        if (f == undefined) fail("function not defined: " + name)
        var callerScopes = scopes
        scopes = [globalScope, {}]
        for (var i = 0; i < f.params.length; i++) {
            var a = alloc(1)
            mem[a] = (i < argValues.length ? argValues[i] : 0) | 0
            declVar(f.params[i].name, a, false)
        }
        var r = f.body()
        scopes = callerScopes
        return (r != undefined && r.isRet) ? r.v : 0
    }

    // ----- Expression thunks: function() -> 32 bit int. Lvalue thunks -> address. -----

    function makeInt(n) { return function() { return n | 0 } }
    function makeVarRef(name) {
        return function() {
            var v = findVar(name)
            return v.arr ? v.addr : load(v.addr) // An array name decays to its address.
        }
    }
    // Id [index] as a place: x -> its address; a[i] -> element address (a can be an array or a pointer).
    function makeVarPlace(items) {
        var name = items[0]
        var idxT = items.length > 1 ? items[1] : null
        return function() {
            var v = findVar(name)
            if (idxT == null) {
                if (v.arr) fail("an array is not assignable: " + name)
                return v.addr
            }
            var base = v.arr ? v.addr : load(v.addr) // Pointer variables hold the base address.
            return base + idxT()
        }
    }
    function makeDerefPlace(t) { return function() { return t() } }
    function makeLoad(placeT) { return function() { return load(placeT()) } }
    function makeNeg(t) { return function() { return (0 - t()) | 0 } }
    function makeNot(t) { return function() { return t() == 0 ? 1 : 0 } }
    function makeBitNot(t) { return function() { return ~t() } }

    function binOp(op, l, r) {
        if (op == "+") return (l + r) | 0
        if (op == "-") return (l - r) | 0
        if (op == "*") return Math.imul(l, r)
        if (op == "/") return (l / r) | 0
        if (op == "%") return (l % r) | 0
        if (op == "==") return (l == r) ? 1 : 0
        if (op == "!=") return (l != r) ? 1 : 0
        if (op == "<")  return (l < r) ? 1 : 0
        if (op == ">")  return (l > r) ? 1 : 0
        if (op == "<=") return (l <= r) ? 1 : 0
        if (op == ">=") return (l >= r) ? 1 : 0
        if (op == "|")  return l | r
        if (op == "^")  return l ^ r
        if (op == "&")  return l & r
        if (op == "<<") return l << r
        if (op == ">>") return l >> r
    }
    function foldBinary(items) {
        if (items.length == 1) return items[0]
        return function() {
            var v = items[0]()
            for (var i = 1; i < items.length; i += 2) {
                v = binOp(items[i], v, items[i + 1]())
            }
            return v
        }
    }
    // Real C short circuit: the right side only runs if it can still change the result.
    function makeOrAnd(items, op) {
        if (items.length == 1) return items[0]
        return function() {
            var v = items[0]() != 0
            for (var i = 1; i < items.length; i++) {
                if (op == "||") { if (v) return 1; v = items[i]() != 0 }
                else            { if (!v) return 0; v = items[i]() != 0 }
            }
            return v ? 1 : 0
        }
    }
    function makeCond(items) {
        if (items.length == 1) return items[0]
        return function() { return items[0]() != 0 ? items[1]() : items[2]() }
    }
    function applyOp(op, a, b) {
        if (op == "+=") return (a + b) | 0
        if (op == "-=") return (a - b) | 0
        if (op == "*=") return Math.imul(a, b)
        if (op == "/=") return (a / b) | 0
        if (op == "%=") return (a % b) | 0
    }
    // items = [placeThunk, opString, valueThunk]. Value of the assignment: the stored value.
    function makeAssign(items) {
        var placeT = items[0]
        var op = items[1]
        var valT = items[2]
        return function() {
            var addr = placeT()
            var v = valT()
            if (op != "=") v = applyOp(op, load(addr), v)
            return store(addr, v)
        }
    }
    function makePreIncDec(placeT, op) {
        var d = (op == "++") ? 1 : -1
        return function() {
            var addr = placeT()
            return store(addr, load(addr) + d)
        }
    }
    function makePostIncDec(op, placeT) {
        var d = (op == "++") ? 1 : -1
        return function() {
            var addr = placeT()
            var old = load(addr)
            store(addr, old + d)
            return old
        }
    }
    // items = [name, argThunk...].
    function makeCall(items) {
        var name = items[0]
        var args = items.slice(1)
        return function() {
            var argValues = []
            for (var i = 0; i < args.length; i++) argValues.push(args[i]())
            return callFunction(name, argValues)
        }
    }

    // ----- Statement thunks -----

    function exprToStmt(t) { return function() { t() } }
    // items = ["*"?] name [{size}|initThunk] -> declaration thunk.
    function makeDecl(items) {
        var i = 0
        if (items[i] == "*") i++ // A pointer is just an int sized cell holding an address.
        var name = items[i]
        var opt = items[i + 1]
        return function() {
            if (opt != undefined && opt.size != undefined) {
                declVar(name, alloc(opt.size), true)
            } else {
                var a = alloc(1)
                if (opt != undefined) mem[a] = opt() | 0
                declVar(name, a, false)
            }
        }
    }
    function makeSeq(items) {
        return function() {
            for (var i = 0; i < items.length; i++) {
                var r = items[i]()
                if (r != undefined) return r
            }
        }
    }
    function makeBlockStmt(items) {
        var seq = makeSeq(items)
        return function() {
            scopes.push({})
            var r = seq()
            scopes.pop()
            return r
        }
    }
    function makeIf(items) {
        var cond = items[0]
        var thenT = items[1]
        var elseT = items.length > 2 ? items[2] : null
        return function() {
            if (cond() != 0) return thenT()
            if (elseT != null) return elseT()
        }
    }
    var BRK = {sig: "break"}
    var CONT = {sig: "continue"}
    function makeWhile(bodyT, condT) {
        return function() {
            while (condT() != 0) {
                var r = bodyT()
                if (r != undefined) {
                    if (r === BRK) break
                    if (r !== CONT) return r
                }
            }
        }
    }
    function makeDo(condT, bodyT) {
        return function() {
            do {
                var r = bodyT()
                if (r != undefined) {
                    if (r === BRK) break
                    if (r !== CONT) return r
                }
            } while (condT() != 0)
        }
    }
    function makeFor(items) {
        var bodyT = items.pop()
        var init = null, cond = null, post = null
        for (var i = 0; i < items.length; i++) {
            if (items[i].k == "init") init = items[i].t
            if (items[i].k == "cond") cond = items[i].t
            if (items[i].k == "post") post = items[i].t
        }
        return function() {
            scopes.push({})
            var res = undefined
            if (init != null) init()
            while (cond == null || cond() != 0) {
                var r = bodyT()
                if (r != undefined) {
                    if (r === BRK) break
                    if (r !== CONT) { res = r; break }
                }
                if (post != null) post()
            }
            scopes.pop()
            return res
        }
    }
    // items = [valueThunk, stmtThunk...] resp. [stmtThunk...] -> one case descriptor.
    function makeCase(items) { return {isDefault: false, v: items[0], body: items.slice(1)} }
    function makeDefault(items) { return {isDefault: true, body: items} }
    // items = [scrutineeThunk, caseDescriptor...]: C switch with fallthrough.
    function makeSwitch(items) {
        var scrut = items[0]
        var cases = items.slice(1)
        return function() {
            var v = scrut()
            var start = -1
            var dflt = -1
            for (var i = 0; i < cases.length; i++) {
                if (cases[i].isDefault) { dflt = i; continue }
                if (start < 0 && cases[i].v() == v) { start = i }
            }
            if (start < 0) { start = dflt }
            if (start < 0) { return undefined }
            for (var i = start; i < cases.length; i++) {
                var body = cases[i].body
                for (var j = 0; j < body.length; j++) {
                    var r = body[j]()
                    if (r === BRK) { return undefined }        // break leaves the switch
                    if (r != undefined) { return r }           // return/continue propagate
                }
            }
            return undefined
        }
    }
    function makeReturn(items) {
        var t = items.length > 0 ? items[0] : makeInt(0)
        return function() { return {isRet: true, v: t()} }
    }
    function makeBreak() { return function() { return BRK } }
    function makeContinue() { return function() { return CONT } }

    // ----- Top level -----

    function makeParam(items) {
        if (items[0] == "*") return {name: items[1], ptr: true}
        return {name: items[0], ptr: false}
    }
    // Global declarator: ["*"?] name [{size}|{init: n}] -> registered immediately.
    function makeGDecl(items) {
        var i = 0
        if (items[i] == "*") i++
        var name = items[i]
        var opt = items[i + 1]
        if (opt != undefined && opt.size != undefined) {
            declVar(name, alloc(opt.size), true)
        } else {
            var a = alloc(1)
            if (opt != undefined) mem[a] = opt.init | 0
            declVar(name, a, false)
        }
    }
    function defineGlobals(items) {} // makeGDecl already registered them.

    function defineFunction() {
        var bodyT = pop()
        var params = pop()
        var name = pop()
        funcs[name] = {params: params, body: bodyT}
    }

    c.compile(c.asg)

    if (funcs["main"] == undefined) {
        println("Error: C programs need a main() function.")
        exit(1)
    }
    var ret = callFunction("main", [])
    println("c interpreter: main() returned " + ret)
    exit(ret)

~~) ;
