:title("Python (subset) to LLVM IR compiler") ;
:description("Compiles a Python subset - with significant indentation - to an LLVM IR
module and runs it with the built-in IR interpreter and the MetaJS handle runtime
(llvm.RunJS).

The blocks are recognized with real INDENT/DEDENT handling: :script() rules keep an
indentation stack on the persistent parser stack, a suite is ':' NEWLINE INDENT
statements DEDENT, and every statement checks that it starts at the level of its block.
Comments (#) and blank lines are skipped by the newline rule. Indentation must use
spaces (no tabs).

The language: def functions (top level, with positional parameters), if/elif/else,
while, for x in <list or range(a[,b])>, break/continue/pass/return, assignment and
+= -= *= /= (assignment creates a variable in the current function if none exists in
scope - there is no 'global' keyword; use a mutable list like fails = [0] for counters),
lists with negative indexing, element assignment, .append()/.pop(), len(), print() with
Python style rendering (True/None/[1, 2]), True/False/None, and/or/not with Python
truthiness (empty lists are falsy) and operand values, comparisons (no chaining),
+ - * % with float semantics, / as true division (7/2 == 3.5), // as floor division
(-7//2 == -4), % as floor modulo (-7%2 == 1), unary -, int and float literals, and
single or double quoted strings with escapes.

Not in the subset: classes, dicts, tuples, nested def/lambdas/closures, the global
keyword, comparison chaining, slices, for-else, f-strings, imports, exceptions, and
list equality by value (== compares lists by identity).

Functions become IR functions jsf_N(env, args); Python scoping (assignment creates a
function local unless the name exists) goes through the js_pyset_var external, negative
indexing through js_pyget/js_pyset, floor division and modulo through js_fdiv/js_fmod,
truthiness (empty lists are falsy) through js_pytruthy, and print through js_pyprint.
The whole file becomes jsmain(env, args) and simply runs top to bottom. Self checking
programs end with exit(fails[0]).
The same language with the same semantics is interpreted directly by
python-interpreter.abnf.") ;


// --- main rules

:startRule(Program) ;
:whitespace(Whitespace) ;

// The leading NL swallows any comment/blank lines at the top of the file.
Program     <~~ buildMain(takeAll()) ~~>
            = [ NL ] { TopStmt } ;
TopStmt     = SameLevel Statement ;

// Compound statements own their suites; small statements end with a newline.
Statement   = If | While | For | Def | SmallLine ;

SmallLine   = ( Return | Break | Continue | Pass | AugAssign | Assign | ExprSmall ) NL ;

// A suite: ':' NEWLINE INDENT statements DEDENT. Every further statement of the
// suite starts at the same level; the first one defined the level via Indent.
Suite       <~~ push(makeSeq(takeAll())) ~~>
            = ":" NL Indent Statement { SameLevel Statement } Dedent ;

If          <~~ push(makeIf(takeAll())) ~~>
            = "if" KwEnd Expression Suite { Elif } [ Else ] ;
Elif        <~~ push(makeElif(pop(), pop())) ~~>
            = SameLevel "elif" KwEnd Expression Suite ;
Else        <~~ push(makeElse(pop())) ~~>
            = SameLevel "else" KwEnd Suite ;

While       <~~ push(makeWhile(pop(), pop())) ~~>
            = "while" KwEnd Expression Suite ;

For         <~~ push(makeFor(pop(), pop(), pop())) ~~>
            = "for" KwEnd Id <~~ push(up.in) ~~> "in" KwEnd Expression Suite ;

Def         <~~ push(makeDef(pop(), pop(), pop())) ~~>
            = "def" KwEnd Id <~~ push(up.in) ~~> ParamList Suite ;
ParamList   <~~ push({params: takeAll()}) ~~>
            = "(" [ Id <~~ push(up.in) ~~> { "," Id <~~ push(up.in) ~~> } ] ")" ;

Return      <~~ push(makeReturn(takeAll())) ~~>
            = "return" KwEnd [ Expression ] ;
Break       <~~ push(makeBreak()) ~~>    = "break" KwEnd ;
Continue    <~~ push(makeContinue()) ~~> = "continue" KwEnd ;
Pass        <~~ push(function(b) { return b }) ~~>  = "pass" KwEnd ;

AugAssign   <~~ push(makeAugAssign(takeAll())) ~~>
            = Target ( "+=" | "-=" | "*=" | "/=" ) <~~ push({op: up.in}) ~~> Expression ;
Assign      <~~ push(makeAssign(pop(), pop())) ~~>
            = Target "=" Expression ;
Target      <~~ push(makeTargetRef(takeAll())) ~~>
            = Id <~~ push(up.in) ~~> { TIndex } ;
TIndex      <~~ push({idx: pop()}) ~~>
            = "[" Expression "]" ;

ExprSmall   <~~ push(exprToStmt(pop())) ~~>
            = Expression ;

// Every expression production pushes exactly one thunk: function() -> value.
Expression  = OrExpr ;

OrExpr      <~~ push(makeOrAnd(takeAll(), true)) ~~>
            = AndExpr { "or" KwEnd AndExpr } ;
AndExpr     <~~ push(makeOrAnd(takeAll(), false)) ~~>
            = NotExpr { "and" KwEnd NotExpr } ;
NotExpr     = Not | Comparison ;
Not         <~~ push(makeNot(pop())) ~~>
            = "not" KwEnd NotExpr ;

Comparison  <~~ push(foldBinary(takeAll())) ~~>
            = Arith [ ( "==" | "!=" | "<=" | ">=" | "<" | ">" ) <~~ push(up.in) ~~> Arith
                    | ( "not" KwEnd "in" KwEnd ) <~~ push("not in") ~~> Arith
                    | ( "in" KwEnd ) <~~ push("in") ~~> Arith ] ;

Arith       <~~ push(foldBinary(takeAll())) ~~>
            = Term { ( "+" | "-" ) <~~ push(up.in) ~~> Term } ;

// The floor division // must be tried before /.
Term        <~~ push(foldBinary(takeAll())) ~~>
            = Factor { ( "*" | "//" | "/" | "%" ) <~~ push(up.in) ~~> Factor } ;

Factor      = Neg | PostfixExpr ;
Neg         <~~ push(makeNeg(pop())) ~~>
            = "-" Factor ;

// f(a), s[i], lst.append(x).
PostfixExpr = CallMember ;
CallMember  <~~ push(foldCallMember(takeAll())) ~~>
            = Primary { CallSfx | MethodSfx | IndexSfx } ;
CallSfx     <~~ push({kind:"call", args: takeAll()}) ~~>
            = "(" [ Expression { "," Expression } ] ")" ;
MethodSfx   <~~ push({kind:"mcall", name: popName(), args: takeAll()}) ~~>
            = "." Id <~~ push({mname: up.in}) ~~> "(" [ Expression { "," Expression } ] ")" ;
IndexSfx    <~~ push({kind:"index", idx: pop()}) ~~>
            = "[" Expression "]" ;

Primary     = "(" Expression ")" | FString | StringLit | NumberLit | True | False | None | ListLit | VarRef ;

// f-string: literal chunks and {expression} parts; every expression renders like str().
FString     <~~ push(makeFString(takeAll())) ~~>
            = ( 'f"' | 'F"' ) :whitespace() { FExpr | FChunk } '"' :whitespace(Whitespace) ;
FExpr       = "{" :whitespace(Whitespace) Expression "}" :whitespace() ;
FChunk      <~~ push({chunk: unescapeJs(up.in)}) ~~>
            = FChar { FChar } ;
FChar       = StrEsc | FPlain ;
// Everything printable except the quote, the braces and the backslash.
FPlain      = "\x20"..."\x21" | "\x23"..."\x5b" | "\x5d"..."\x7a" | "|" | "\x7e" | @"\t" | "\x7f"..."\U0010ffff" ;

ListLit     <~~ push(makeList(takeAll())) ~~>
            = "[" [ Expression { "," Expression } ] "]" ;

StringLit   = DqString | SqString ;
DqString    = '"' :whitespace() { StrEsc | DqPlain } <~~ push(makeConst(unescapeJs(up.in))) ~~> '"' :whitespace(Whitespace) ;
SqString    = "'" :whitespace() { StrEsc | SqPlain } <~~ push(makeConst(unescapeJs(up.in))) ~~> "'" :whitespace(Whitespace) ;
StrEsc      = "\\" "\x20"..b"\x7e" ;
DqPlain     = "\x20"..."\x21" | "\x23"..."\x5b" | "\x5d"..."\x7e" | @"\t" | "\x7f"..."\U0010ffff" ;
SqPlain     = "\x20"..."\x26" | "\x28"..."\x5b" | "\x5d"..."\x7e" | @"\t" | "\x7f"..."\U0010ffff" ;

NumberLit   <~~ push(makeConst(parseFloat(up.in))) ~~>
            = ( "0" | "1"..."9" ) :whitespace() { "0"..."9" } [ "." "0"..."9" { "0"..."9" } ] :whitespace(Whitespace) ;

True        <~~ push(makeConst(true)) ~~>      = "True" KwEnd ;
False       <~~ push(makeConst(false)) ~~>     = "False" KwEnd ;
None        <~~ push(makeConst(undefined)) ~~> = "None" KwEnd ;

VarRef      <~~ push(makeVarRef(up.in)) ~~>
            = Id ;

Id          = ( "a"..."z" | "A"..."Z" | "_" ) :whitespace() { "a"..."z" | "A"..."Z" | "0"..."9" | "_" } :whitespace(Whitespace) ;

// A logical line break: one or more newlines (blank and comment lines collapse,
// because the whitespace skip eats spaces and # comments), or the end of the file.
NL          = RealNL | AtEOF ;
RealNL      = "\n" { "\n" } ;

KwEnd = :script(~~
    (function() {
        var cc = c.peek(0)
        return ((cc >= 48 && cc <= 57) || (cc >= 65 && cc <= 90) || cc === 95 || (cc >= 97 && cc <= 122))
            ? abnf.newToken("\x01keyword-boundary", 0)
            : undefined
    })()
~~) ;

AtEOF = :script(~~
    (function() {
        return (c.peek(0) === -1) ? undefined : abnf.newToken("\x01not-at-eof", 0)
    })()
~~) ;

// The indentation machinery. The persistent parser stack holds the indentation
// levels; the scripts scan the spaces of the current line with c.peek().
// Indent: the line is deeper than the current level - push the new level.
Indent = :script(~~
    (function() {
        var n = 0
        while (c.peek(n) === 32) n++
        if (c.peek(n) === -1) n = -1
        var top = pop()
        if (top == null) top = 0
        push(top)
        if (n > top) { push(n); return undefined }
        return abnf.newToken("\x01expected-an-indented-block", 0)
    })()
~~) ;
// Dedent: the line (or the end of file) is shallower - pop one level.
Dedent = :script(~~
    (function() {
        var n = 0
        while (c.peek(n) === 32) n++
        if (c.peek(n) === -1) n = -1
        var top = pop()
        if (top == null) top = 0
        if (n < top) { return undefined }
        push(top)
        return abnf.newToken("\x01expected-a-dedent", 0)
    })()
~~) ;
// SameLevel: the line starts exactly at the current level.
SameLevel = :script(~~
    (function() {
        var n = 0
        while (c.peek(n) === 32) n++
        if (c.peek(n) === -1) n = -1
        var top = pop()
        if (top == null) top = 0
        push(top)
        return (n == top) ? undefined : abnf.newToken("\x01wrong-indentation-level", 0)
    })()
~~) ;

// Whitespace never includes newlines: they are structure, not noise.
Whitespace  = { @+" \t" | Comment } ;
Comment     = "#" :whitespace() { NotNewline } :whitespace(Whitespace) ;
NotNewline  = "\x00"..."\x09" | "\x0b"..."\U0010ffff" ;

// ---


:startScript(~~

    function takeAll() {
        var items = []
        var v
        while ((v = pop()) != null) items.unshift(v)
        return items
    }
    function popName() {
        var items = takeAll()
        var name = ""
        for (var i = 0; i < items.length; i++) {
            if (items[i] != undefined && items[i].mname != undefined) { name = items[i].mname }
            else { push(items[i]) }
        }
        return name
    }
    function hexAt(s, pos, len) {
        var v = 0
        for (var i = 0; i < len; i++) {
            var c = s.charCodeAt(pos + i)
            var d = (c >= 48 && c <= 57) ? c - 48 : (c >= 97 ? c - 87 : c - 55)
            v = v * 16 + d
        }
        return v
    }
    function unescapeJs(s) {
        var out = ""
        var i = 0
        while (i < s.length) {
            var c = s.charCodeAt(i)
            if (c != 92) { out += String.fromCharCode(c); i++; continue }
            var e = s.charCodeAt(i + 1)
            if (e == 110) { out += "\n"; i += 2; continue }
            if (e == 116) { out += "\t"; i += 2; continue }
            if (e == 114) { out += "\r"; i += 2; continue }
            if (e == 117) { out += String.fromCharCode(hexAt(s, i + 2, 4)); i += 6; continue }
            out += String.fromCharCode(e)
            i += 2
        }
        return out
    }

    // ----- The emitter -----

    var i64 = llvm.types.I64
    var m = llvm.ir.NewModule()
    function handle(n) { return llvm.constant.NewInt(i64, n) }
    var hUndef = handle(0)
    var hFalse = handle(2)
    var hTrue = handle(3)

    var externs = {}
    function getExtern(name, paramCount) {
        var f = externs[name]
        if (f != undefined) return f
        var params = []
        if (name == "js_str_mem") {
            params.push(llvm.ir.NewParam("", llvm.types.I8Ptr))
            params.push(llvm.ir.NewParam("", i64))
        } else {
            for (var i = 0; i < paramCount; i++) params.push(llvm.ir.NewParam("", i64))
        }
        f = m.NewFunc(name, i64, params)
        externs[name] = f
        return f
    }
    function callExt(b, name, args) {
        return b.NewCall(getExtern(name, args.length), args)
    }
    var strGlobals = {}
    var strCount = 0
    function emitStr(b, s) {
        var g = strGlobals[s]
        if (g == undefined) {
            strCount++
            g = {}
            g.glob = m.NewGlobalDef("str." + strCount, llvm.constant.NewCharArrayFromString(s))
            g.len = handle(s.length)
            g.ptr = llvm.constant.NewGetElementPtr(g.glob.ContentType, g.glob, [handle(0), handle(0)])
            strGlobals[s] = g
        }
        return callExt(b, "js_str_mem", [g.ptr, g.len])
    }
    function emitNum(b, n) {
        if (n % 1 == 0) return callExt(b, "js_num_i", [handle(n)])
        return callExt(b, "js_num_str", [emitStr(b, "" + n)])
    }

    var curF = null
    var curScopeV = null
    var loopStack = []
    var funcCount = 0
    var deadCount = 0
    var hidCount = 0
    function deadBlock() {
        deadCount++
        return curF.NewBlock("dead" + deadCount)
    }
    // Python truthiness for branches.
    function pytruthy(b, v) {
        return b.NewICmp(llvm.enum.IPredNE, callExt(b, "js_pytruthy", [v]), handle(0))
    }

    // ----- Expression thunks: function(block) -> {b, v} -----

    function makeConst(v) {
        return function(b) {
            if (v === true) return {b: b, v: hTrue}
            if (v === false) return {b: b, v: hFalse}
            if (v === undefined) return {b: b, v: hUndef}
            if (typeof v == "string") return {b: b, v: emitStr(b, v)}
            return {b: b, v: emitNum(b, v)}
        }
    }
    function makeVarRef(name) {
        return function(b) {
            return {b: b, v: callExt(b, "js_scope_get", [curScopeV, emitStr(b, name)])}
        }
    }
    function makeNeg(t) {
        return function(b) {
            var r = t(b)
            return {b: r.b, v: callExt(r.b, "js_neg", [r.v])}
        }
    }
    // not: True exactly when the Python truthiness is 0.
    function makeNot(t) {
        return function(b) {
            var r = t(b)
            b = r.b
            var c = b.NewICmp(llvm.enum.IPredEQ, callExt(b, "js_pytruthy", [r.v]), handle(0))
            return {b: b, v: b.NewSelect(c, hTrue, hFalse)}
        }
    }

    // items = [{chunk: text} | expression thunk, ...] -> the f-string value, built by
    // concatenating the chunks and the str() rendering (js_pystr) of the expressions.
    function makeFString(items) {
        return function(b) {
            var v = emitStr(b, "")
            for (var i = 0; i < items.length; i++) {
                var it = items[i]
                if (typeof it == "function") {
                    var r = it(b)
                    b = r.b
                    v = callExt(b, "js_jadd", [v, callExt(b, "js_pystr", [r.v])])
                } else {
                    v = callExt(b, "js_jadd", [v, emitStr(b, it.chunk)])
                }
            }
            return {b: b, v: v}
        }
    }

    var binExt = {"+": "js_add", "-": "js_sub", "*": "js_mul", "/": "js_div",
                  "//": "js_fdiv", "%": "js_fmod",
                  "==": "js_seq", "!=": "js_sne",
                  "<": "js_lt", ">": "js_gt", "<=": "js_le", ">=": "js_ge",
                  "in": "js_pyin",
                  "+=": "js_add", "-=": "js_sub", "*=": "js_mul", "/=": "js_div"}
    function foldBinary(items) {
        if (items.length == 1) return items[0]
        return function(b) {
            var r = items[0](b)
            b = r.b
            var v = r.v
            for (var i = 1; i < items.length; i += 2) {
                var rr = items[i + 1](b)
                b = rr.b
                if (items[i] == "not in") {
                    v = callExt(b, "js_not", [callExt(b, "js_pyin", [v, rr.v])])
                } else {
                    v = callExt(b, binExt[items[i]], [v, rr.v])
                }
            }
            return {b: b, v: v}
        }
    }
    // and/or keep the deciding operand, with Python truthiness.
    function makeOrAnd(items, isOr) {
        if (items.length == 1) return items[0]
        return function(b) {
            var r = items[0](b)
            b = r.b
            var v = r.v
            for (var i = 1; i < items.length; i++) {
                var rightB = curF.NewBlock("")
                var mergeB = curF.NewBlock("")
                var c = pytruthy(b, v)
                if (isOr) { b.NewCondBr(c, mergeB, rightB) }
                else      { b.NewCondBr(c, rightB, mergeB) }
                var r2 = items[i](rightB)
                r2.b.NewBr(mergeB)
                var phi = mergeB.NewPhi([llvm.ir.NewIncoming(v, b), llvm.ir.NewIncoming(r2.v, r2.b)])
                b = mergeB
                v = phi
            }
            return {b: b, v: v}
        }
    }

    function emitArgs(b, args) {
        var argsV = callExt(b, "js_arr_new", [])
        for (var j = 0; j < args.length; j++) {
            var ar = args[j](b)
            b = ar.b
            callExt(b, "js_arr_push", [argsV, ar.v])
        }
        return {b: b, v: argsV}
    }
    function foldCallMember(items) {
        if (items.length == 1) return items[0]
        var primary = items[0]
        var suffixes = items.slice(1)
        return function(b) {
            var r = primary(b)
            b = r.b
            var cur = r.v
            for (var i = 0; i < suffixes.length; i++) {
                var s = suffixes[i]
                if (s.kind == "call") {
                    var ea = emitArgs(b, s.args)
                    b = ea.b
                    cur = callExt(b, "js_call", [cur, hUndef, ea.v])
                } else if (s.kind == "mcall") {
                    var ea2 = emitArgs(b, s.args)
                    b = ea2.b
                    cur = callExt(b, "js_mcall", [cur, emitStr(b, s.name), ea2.v])
                } else {
                    var ir2 = s.idx(b)
                    b = ir2.b
                    cur = callExt(b, "js_pyget", [cur, ir2.v])
                }
            }
            return {b: b, v: cur}
        }
    }

    function makeList(items) {
        return function(b) {
            var arr = callExt(b, "js_arr_new", [])
            for (var i = 0; i < items.length; i++) {
                var r = items[i](b)
                b = r.b
                callExt(b, "js_arr_push", [arr, r.v])
            }
            return {b: b, v: arr}
        }
    }

    function makeTargetRef(items) {
        return {name: items[0], path: items.slice(1)}
    }
    function emitRefRead(b, ref) {
        var o = callExt(b, "js_scope_get", [curScopeV, emitStr(b, ref.name)])
        for (var i = 0; i < ref.path.length; i++) {
            var r = ref.path[i].idx(b)
            b = r.b
            o = callExt(b, "js_pyget", [o, r.v])
        }
        return {b: b, v: o}
    }
    function emitRefWrite(b, ref, v) {
        if (ref.path.length == 0) {
            callExt(b, "js_pyset_var", [curScopeV, emitStr(b, ref.name), v])
            return b
        }
        var o = callExt(b, "js_scope_get", [curScopeV, emitStr(b, ref.name)])
        for (var i = 0; i < ref.path.length - 1; i++) {
            var r = ref.path[i].idx(b)
            b = r.b
            o = callExt(b, "js_pyget", [o, r.v])
        }
        var kr = ref.path[ref.path.length - 1].idx(b)
        b = kr.b
        callExt(b, "js_pyset", [o, kr.v, v])
        return b
    }
    // Pops reversed: value, target.
    function makeAssign(valT, ref) {
        return function(b) {
            var r = valT(b)
            b = r.b
            return emitRefWrite(b, ref, r.v)
        }
    }
    function makeAugAssign(items) {
        var ref = items[0]
        var op = items[1].op
        var valT = items[2]
        return function(b) {
            var rr = emitRefRead(b, ref)
            b = rr.b
            var rv = valT(b)
            b = rv.b
            return emitRefWrite(b, ref, callExt(b, binExt[op], [rr.v, rv.v]))
        }
    }

    // ----- Statement thunks: function(block) -> block -----

    function exprToStmt(t) {
        return function(b) { return t(b).b }
    }
    function makeSeq(items) {
        return function(b) {
            for (var i = 0; i < items.length; i++) b = items[i](b)
            return b
        }
    }
    function makeElif(suite, cond) { return {elifCond: cond, suite: suite} }
    function makeElse(suite) { return {elseSuite: suite} }
    // The if/elif/else chain becomes a chain of tests, all meeting in one merge block.
    function makeIf(items) {
        var cond = items[0]
        var thenT = items[1]
        var elifs = []
        var elseT = null
        for (var i = 2; i < items.length; i++) {
            if (items[i].elifCond != undefined) elifs.push(items[i])
            if (items[i].elseSuite != undefined) elseT = items[i].elseSuite
        }
        return function(b) {
            var mergeB = curF.NewBlock("")
            var r = cond(b)
            b = r.b
            var thenB = curF.NewBlock("")
            var nextB = curF.NewBlock("")
            b.NewCondBr(pytruthy(b, r.v), thenB, nextB)
            thenT(thenB).NewBr(mergeB)
            b = nextB
            for (var k = 0; k < elifs.length; k++) {
                var r2 = elifs[k].elifCond(b)
                b = r2.b
                var armB = curF.NewBlock("")
                var next2 = curF.NewBlock("")
                b.NewCondBr(pytruthy(b, r2.v), armB, next2)
                elifs[k].suite(armB).NewBr(mergeB)
                b = next2
            }
            if (elseT != null) { elseT(b).NewBr(mergeB) }
            else { b.NewBr(mergeB) }
            return mergeB
        }
    }
    function makeWhile(bodyT, condT) {
        return function(b) {
            var headB = curF.NewBlock("")
            var bodyB = curF.NewBlock("")
            var exitB = curF.NewBlock("")
            b.NewBr(headB)
            var r = condT(headB)
            r.b.NewCondBr(pytruthy(r.b, r.v), bodyB, exitB)
            loopStack.push({cont: headB, brk: exitB})
            bodyT(bodyB).NewBr(headB)
            loopStack.pop()
            return exitB
        }
    }
    // for x in <list>: a hidden index drives the loop; x is a normal Python variable
    // (function scoped, survives the loop).
    function makeFor(bodyT, listT, name) {
        return function(b) {
            hidCount++
            var iName = "$i" + hidCount
            var aName = "$a" + hidCount
            var r = listT(b)
            b = r.b
            callExt(b, "js_scope_decl", [curScopeV, emitStr(b, aName), r.v])
            callExt(b, "js_scope_decl", [curScopeV, emitStr(b, iName), emitNum(b, 0)])
            var headB = curF.NewBlock("")
            var bodyB = curF.NewBlock("")
            var postB = curF.NewBlock("")
            var exitB = curF.NewBlock("")
            b.NewBr(headB)
            var iV = callExt(headB, "js_scope_get", [curScopeV, emitStr(headB, iName)])
            var aV = callExt(headB, "js_scope_get", [curScopeV, emitStr(headB, aName)])
            var lenV = callExt(headB, "js_get", [aV, emitStr(headB, "length")])
            headB.NewCondBr(pytruthy(headB, callExt(headB, "js_lt", [iV, lenV])), bodyB, exitB)
            var iV2 = callExt(bodyB, "js_scope_get", [curScopeV, emitStr(bodyB, iName)])
            var aV2 = callExt(bodyB, "js_scope_get", [curScopeV, emitStr(bodyB, aName)])
            callExt(bodyB, "js_pyset_var", [curScopeV, emitStr(bodyB, name), callExt(bodyB, "js_get", [aV2, iV2])])
            loopStack.push({cont: postB, brk: exitB})
            bodyT(bodyB).NewBr(postB)
            loopStack.pop()
            var iV3 = callExt(postB, "js_scope_get", [curScopeV, emitStr(postB, iName)])
            callExt(postB, "js_scope_set", [curScopeV, emitStr(postB, iName), callExt(postB, "js_add", [iV3, emitNum(postB, 1)])])
            postB.NewBr(headB)
            return exitB
        }
    }
    function makeReturn(items) {
        var t = items.length > 0 ? items[0] : null
        return function(b) {
            var v = hUndef
            if (t != null) {
                var r = t(b)
                b = r.b
                v = r.v
            }
            b.NewRet(v)
            return deadBlock()
        }
    }
    function makeBreak() {
        return function(b) {
            b.NewBr(loopStack[loopStack.length - 1].brk)
            return deadBlock()
        }
    }
    function makeContinue() {
        return function(b) {
            b.NewBr(loopStack[loopStack.length - 1].cont)
            return deadBlock()
        }
    }

    // def: an own IR function; the body shares one function scope (no block scopes).
    function makeDef(bodyT, plist, name) {
        var params = plist.params
        return function(b) {
            funcCount++
            var idx = funcCount
            var f = m.NewFunc("jsf_" + idx, i64, [llvm.ir.NewParam("env", i64), llvm.ir.NewParam("args", i64)])
            var savedF = curF
            var savedScope = curScopeV
            var savedLoops = loopStack
            curF = f
            loopStack = []
            var fb = f.NewBlock("entry")
            curScopeV = callExt(fb, "js_scope_new", [f.Params[0]])
            for (var i = 0; i < params.length; i++) {
                callExt(fb, "js_scope_decl", [curScopeV, emitStr(fb, params[i]),
                                              callExt(fb, "js_arg", [f.Params[1], handle(i)])])
            }
            var endB = bodyT(fb)
            endB.NewRet(hUndef)
            curF = savedF
            curScopeV = savedScope
            loopStack = savedLoops
            callExt(b, "js_pyset_var", [curScopeV, emitStr(b, name),
                                        callExt(b, "js_closure", [handle(idx), curScopeV])])
            return b
        }
    }

    // jsmain: declare the builtins, then run the file top to bottom.
    function buildMain(items) {
        var f = m.NewFunc("jsmain", i64, [llvm.ir.NewParam("env", i64), llvm.ir.NewParam("args", i64)])
        curF = f
        var b = f.NewBlock("entry")
        curScopeV = callExt(b, "js_scope_new", [f.Params[0]])
        // print(...): hand the argument array to the Python renderer.
        funcCount++
        var prIdx = funcCount
        var pf = m.NewFunc("jsf_" + prIdx, i64, [llvm.ir.NewParam("env", i64), llvm.ir.NewParam("args", i64)])
        var pb = pf.NewBlock("entry")
        pb.NewCall(getExtern("js_pyprint", 1), [pf.Params[1]])
        pb.NewRet(hUndef)
        callExt(b, "js_scope_decl", [curScopeV, emitStr(b, "print"), callExt(b, "js_closure", [handle(prIdx), curScopeV])])
        // len(x)
        funcCount++
        var lenIdx = funcCount
        var lf = m.NewFunc("jsf_" + lenIdx, i64, [llvm.ir.NewParam("env", i64), llvm.ir.NewParam("args", i64)])
        var lb = lf.NewBlock("entry")
        var lArg = lb.NewCall(getExtern("js_arg", 2), [lf.Params[1], handle(0)])
        lb.NewRet(lb.NewCall(getExtern("js_get", 2), [lArg, emitStr(lb, "length")]))
        callExt(b, "js_scope_decl", [curScopeV, emitStr(b, "len"), callExt(b, "js_closure", [handle(lenIdx), curScopeV])])
        // range(a[, b])
        funcCount++
        var rgIdx = funcCount
        var rf = m.NewFunc("jsf_" + rgIdx, i64, [llvm.ir.NewParam("env", i64), llvm.ir.NewParam("args", i64)])
        var rb = rf.NewBlock("entry")
        var rA = rb.NewCall(getExtern("js_arg", 2), [rf.Params[1], handle(0)])
        var rB = rb.NewCall(getExtern("js_arg", 2), [rf.Params[1], handle(1)])
        rb.NewRet(rb.NewCall(getExtern("js_pyrange", 2), [rA, rB]))
        callExt(b, "js_scope_decl", [curScopeV, emitStr(b, "range"), callExt(b, "js_closure", [handle(rgIdx), curScopeV])])
        // abs from Math.
        var mathV = callExt(b, "js_scope_get", [curScopeV, emitStr(b, "Math")])
        callExt(b, "js_scope_decl", [curScopeV, emitStr(b, "abs"), callExt(b, "js_get", [mathV, emitStr(b, "abs")])])
        b = makeSeq(items)(b)
        b.NewRet(hUndef)
    }

    c.compile(c.asg)

    println(m)

    var res = llvm.RunJS(m, "jsmain")
    println("python compiler: program ran to completion")
    exit(res.Ret)

~~) ;
