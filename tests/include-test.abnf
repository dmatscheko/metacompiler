:title("Include test") ;
:description("Demonstrates the file operations: the :include() command merges the rules of
include-test-lib.abnf into this grammar before parsing, and the start script uses
include() to run a JS file, load() to read a file, store() to write one
(include-test-create.out) and moduleName(). All paths are relative to this grammar
file.") ;

// This includes the rule that can resolve include-test.txt:
:include("include-test-lib.abnf") ;

:startRule(Test) ;
Test = "A" | Foo <~~ println("The included rule found: " + up.in) ~~> ; // Foo would be missing if it would not be included.

:startScript(~~

    println("I am " + moduleName())

    c.compile(c.asg)

    // require("foo.js")

    include("include-test.js")

    println("The file should be included now.")

    println(something())

    println("include-test.txt contains: " + load("include-test.txt"))

    store("include-test-create.out", "something")

~~) ;
