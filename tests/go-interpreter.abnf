:title("Go (subset) interpreter") ;
:description("Parses a Go subset and executes it directly, without generating code.

The subset: package and import clauses (parsed, ignored), functions with typed
parameters and multiple return values (func divmod(a int, b int) (int, int)), methods
with value receivers (func (p Point) manhattan() int), struct types with positional
composite literals (Point{3, 4}), field access and assignment, := short declarations
(also multiple: q, r := divmod(7, 2)), var declarations with zero values, parallel
assignment (a, b = b, a) and the blank identifier _, slices ([]int{...}, append, len,
indexing, element assignment), maps (map[K]V{...} literals and make(map[K]V); reads
of missing keys yield the zero value of the value type - int/string/bool -, m[k] = v,
len, delete(m, k), the comma ok idiom v, ok := m[k], and range over the entries),
function literals as values (func(x int) int { ... }) with real closures over their
scope, defer for plain and pkg.fn calls (arguments evaluate at defer time, the calls
run LIFO at function exit), the three for forms (classic, condition only, and
for i, v := range s - also over an int like range 5, Go 1.22, and over maps), switch
with subject
(case 2, 3: compares ==) and without (the first true case wins; no fallthrough, an
implicit break ends every case), Go style if/else without parentheses (else if works), break,
continue, i++ and i-- as statements, assignment operators += -= *= /= %=, fmt.Println
and fmt.Print, os.Exit, and string concatenation. int arithmetic is 32 bit, / truncates.

Deviations and limits: structs behave like references (as if every value were a *T),
append mutates in place (write s = append(s, v) as usual), composite literals must not
appear in if/for/switch headers, map iteration and printing follow the insertion order
(real Go randomizes resp. sorts), 'var m map[K]V' is not a usable map (create maps with
a literal or make), defer cannot take struct methods, there are no pointers,
interfaces,
goroutines, fallthrough, or method values, and s[i] on strings is not supported.

The entry point is func main(); self checking programs end with os.Exit(failures).") ;


// --- main rules

:startRule(Program) ;
:whitespace(Whitespace) ;

Program     = PackageClause { Import } { TypeDecl | FuncDecl | TopVar } ;

PackageClause = "package" KwEnd Id ;
Import      = "import" KwEnd ( ImportStr | "(" { ImportStr } ")" ) ;
ImportStr   = '"' :whitespace() { "\x20"..."\x21" | "\x23"..."\x7e" } '"' :whitespace(Whitespace) ;

// type Point struct { x int; y int }
TypeDecl    <~~ buildStruct(takeAll()) ~~>
            = "type" KwEnd Id <~~ push(up.in) ~~> "struct" KwEnd
              "{" { Id <~~ push(up.in) ~~> Type [ ";" ] } "}" ;

// func name(params) rets { } and func (r Type) name(params) rets { }
FuncDecl    <~~ buildFunc(takeAll()) ~~>
            = "func" KwEnd [ Receiver ] Id <~~ push(up.in) ~~> ParamList [ RetTypes ] Block ;
Receiver    <~~ push({recv: takeAll()}) ~~>
            = "(" Id <~~ push(up.in) ~~> Id <~~ push(up.in) ~~> ")" ;
ParamList   <~~ push({params: takeAll()}) ~~>
            = "(" [ Id <~~ push(up.in) ~~> Type { "," Id <~~ push(up.in) ~~> Type } ] ")" ;
RetTypes    = Type | "(" Type { "," Type } ")" ;

// A package level var, registered right away.
TopVar      <~~ var t = pop(); t() ~~>
            = VarDecl ;

Type        = "[" "]" Type | MapTypeT | FuncTypeT
            | ( "int" KwEnd | "string" KwEnd | "bool" KwEnd | Id ) ;
MapTypeT    = "map" KwEnd "[" Type "]" Type ;
FuncTypeT   = "func" KwEnd "(" [ Type { "," Type } ] ")" [ Type | "(" Type { "," Type } ")" ] ;

// Every statement production pushes exactly one thunk: function() -> undefined | signal.
Statement   = Block | If | For | Switch | Return | Break | Continue | Defer | VarDecl
            | SimpleStmt | Empty ;

// defer f(args) / defer pkg.fn(args): the function value and the arguments are
// evaluated now, the call runs when the surrounding function returns (LIFO).
Defer       <~~ push(makeDefer(takeAll())) ~~>
            = "defer" KwEnd Id <~~ push(up.in) ~~> [ "." Id <~~ push({mname: up.in}) ~~> ]
              "(" [ Expression { "," Expression } ] ")" [ ";" ] ;

Block       <~~ push(makeBlockStmt(takeAll())) ~~>
            = "{" { Statement } "}" ;

// var x int = 5 / var s string -- the zero value depends on the type.
VarDecl     <~~ push(makeVarDecl(takeAll())) ~~>
            = "var" KwEnd Id <~~ push(up.in) ~~> [ VType ] [ "=" Expression ] [ ";" ] ;
VType       <~~ push({ty: up.in}) ~~>
            = Type ;

// Short declarations, assignments, ++/-- and expression statements. The cores do
// not eat the separator themselves: for headers reuse them between the semicolons.
// MapOk (v, ok := m[k]) must come first: as a ShortDecl it would miss the flag.
SimpleStmt  = ( MapOk | ShortDecl | IncDecStmt | Assign | ExprOnly ) [ ";" ] ;

// The comma ok idiom: the value (or the zero value) plus the key presence flag.
MapOk       <~~ push(makeMapOk(takeAll())) ~~>
            = Id <~~ push(up.in) ~~> "," Id <~~ push(up.in) ~~> ":=" Primary "[" Expression "]" ;
ExprOnly    <~~ push(exprToStmt(pop())) ~~>
            = Expression ;

ShortDecl   <~~ push(makeShortDecl(takeAll())) ~~>
            = Id <~~ push(up.in) ~~> { "," Id <~~ push(up.in) ~~> } ":=" ExprList ;

IncDecStmt  <~~ push(makeIncDec(takeAll())) ~~>
            = Target ( "++" | "--" ) <~~ push(up.in) ~~> ;

// a = e / a, b = b, a / p.x = e / s[i] = e / a += e
Assign      <~~ push(makeAssign(takeAll())) ~~>
            = Target { "," Target } ( "+=" | "-=" | "*=" | "/=" | "%=" | "=" ) <~~ push({op: up.in}) ~~> ExprList ;

Target      <~~ push(makeTargetRef(takeAll())) ~~>
            = Id <~~ push(up.in) ~~> { "." Id <~~ push({key: up.in}) ~~> | TIndex } ;
TIndex      <~~ push({idx: pop()}) ~~>
            = "[" Expression "]" ;

ExprList    = Expression { "," Expression } ;

Empty       <~~ push(function() {}) ~~>
            = ";" ;

// Go style headers without parentheses. Composite literals are gated off inside.
If          <~~ push(makeIf(takeAll())) ~~>
            = "if" KwEnd CondOn Expression CondOff Block [ "else" KwEnd ( If | Block ) ] ;

// ForCond is tried before ForClassic: a classic header would leave the
// composite literal gate pushed when it fails at its first semicolon.
For         = ForRange | ForCond | ForClassic ;
// for i, v := range s / for _, v := range s / for i := range s
ForRange    <~~ push(makeForRange(takeAll())) ~~>
            = "for" KwEnd Id <~~ push(up.in) ~~> [ "," Id <~~ push(up.in) ~~> ] ":="
              "range" KwEnd CondOn Expression CondOff Block ;
ForClassic  <~~ push(makeForClassic(takeAll())) ~~>
            = "for" KwEnd CondOn [ FInit ] ";" [ FCond ] ";" [ FPost ] CondOff Block ;
FInit       <~~ push({k:"init", t:pop()}) ~~> = SimpleStmt2 ;
FCond       <~~ push({k:"cond", t:pop()}) ~~> = Expression ;
FPost       <~~ push({k:"post", t:pop()}) ~~> = SimpleStmt2 ;
SimpleStmt2 = ShortDecl | IncDecStmt | Assign ;
ForCond     <~~ push(makeForCond(pop(), pop())) ~~>
            = "for" KwEnd CondOn Expression CondOff Block ;

// Go switch: no fallthrough (an implicit break ends every case), several values per
// case, with a subject (compared ==) or without one (the first true condition wins).
Switch      <~~ push(makeSwitch(takeAll())) ~~>
            = "switch" KwEnd [ SwitchSubj ] "{" { CaseLabel | Statement } "}" ;
SwitchSubj  <~~ push({subj: pop()}) ~~>
            = CondOn Expression CondOff ;
// The body is parsed flat: the labels must be tried before Statement (a bare 'case'
// would parse as an identifier expression), and the builder groups the statements
// under the label they follow.
CaseLabel   <~~ push(makeCaseLabel(takeAll())) ~~>
            = ( "case" KwEnd Expression <~~ push({v: pop()}) ~~> { "," Expression <~~ push({v: pop()}) ~~> }
              | "default" KwEnd ) ":" ;

Return      <~~ push(makeReturn(takeAll())) ~~>
            = "return" KwEnd [ Expression { "," Expression } ] [ ";" ] ;

Break       <~~ push(makeBreak()) ~~>    = "break" KwEnd [ ";" ] ;
Continue    <~~ push(makeContinue()) ~~> = "continue" KwEnd [ ";" ] ;

// Every expression production pushes exactly one thunk: function() -> value.
Expression  = OrExpr ;

OrExpr      <~~ push(makeOrAnd(takeAll(), true)) ~~>
            = AndExpr { "||" AndExpr } ;

AndExpr     <~~ push(makeOrAnd(takeAll(), false)) ~~>
            = EqExpr { "&&" EqExpr } ;

EqExpr      <~~ push(foldBinary(takeAll())) ~~>
            = RelExpr { ( "==" | "!=" ) <~~ push(up.in) ~~> RelExpr } ;

RelExpr     <~~ push(foldBinary(takeAll())) ~~>
            = AddExpr { ( "<=" | ">=" | "<" | ">" ) <~~ push(up.in) ~~> AddExpr } ;

AddExpr     <~~ push(foldBinary(takeAll())) ~~>
            = MulExpr { ( "+" | "-" ) <~~ push(up.in) ~~> MulExpr } ;

MulExpr     <~~ push(foldBinary(takeAll())) ~~>
            = UnaryExpr { ( "*" | "/" | "%" ) <~~ push(up.in) ~~> UnaryExpr } ;

UnaryExpr   = Neg | Not | PostfixExpr ;
Neg         <~~ push(makeNeg(pop())) ~~>
            = "-" UnaryExpr ;
Not         <~~ push(makeNot(pop())) ~~>
            = "!" UnaryExpr ;

// p.manhattan(), fmt.Println(...), p.x, s[i].
PostfixExpr = CallMember ;
CallMember  <~~ push(foldCallMember(takeAll())) ~~>
            = Primary { MethodSfx | FieldSfx | IndexSfx } ;
MethodSfx   <~~ push({kind:"mcall", name: popName(), args: takeAll()}) ~~>
            = "." Id <~~ push({mname: up.in}) ~~> "(" [ Expression { "," Expression } ] ")" ;
FieldSfx    = "." Id <~~ push({kind:"field", name: up.in}) ~~> ;
IndexSfx    <~~ push({kind:"index", idx: pop()}) ~~>
            = "[" Expression "]" ;

Primary     = "(" Expression ")" | StringLit | IntLit | True | False | FuncLit | SliceLit
            | MapLit | MakeMap | StructLit | Call | VarRef ;

// func(x int) int { ... }: a function literal; a real closure over its scope.
FuncLit     <~~ push(makeFuncLit(pop(), pop())) ~~>
            = "func" KwEnd ParamList [ RetTypes ] Block ;

// []int{1, 2, 3}
SliceLit    <~~ push(makeSliceLit(takeAll())) ~~>
            = "[" "]" Type "{" [ Expression { "," Expression } ] "}" ;

// map[string]int{"a": 1} and make(map[string]int). The value type decides the
// zero value that a read of a missing key yields.
MapLit      <~~ push(makeMapLit(takeAll())) ~~>
            = MapTypeZ "{" [ MapEntry { "," MapEntry } ] "}" ;
MapEntry    <~~ var mv = pop(); push({mk: pop(), mv: mv}) ~~>
            = Expression ":" Expression ;
MakeMap     <~~ push(makeMakeMap(pop())) ~~>
            = "make" KwEnd "(" MapTypeZ ")" ;
MapTypeZ    = "map" KwEnd "[" Type "]" ZType ;
ZType       <~~ push({mzero: up.in}) ~~>
            = Type ;

// Point{3, 4} -- positional, at least one element, and not inside if/for headers.
StructLit   <~~ push(makeStructLit(takeAll())) ~~>
            = StructGate Id <~~ push(up.in) ~~> "{" Expression { "," Expression } "}" ;

// f(a, b): a function or a builtin.
Call        <~~ push(makeCall(takeAll())) ~~>
            = Id <~~ push(up.in) ~~> "(" [ Expression { "," Expression } ] ")" ;

StringLit   = '"' :whitespace() { StrEsc | DqPlain } <~~ push(makeConst(unescapeJs(up.in))) ~~> '"' :whitespace(Whitespace) ;
StrEsc      = "\\" "\x20"..b"\x7e" ;
DqPlain     = "\x20"..."\x21" | "\x23"..."\x5b" | "\x5d"..."\x7e" | @"\t" | "\x7f"..."\U0010ffff" ;

IntLit      <~~ push(makeConst(parseInt(up.in))) ~~>
            = ( "0" | "1"..."9" ) :whitespace() { "0"..."9" } :whitespace(Whitespace) ;

True        <~~ push(makeConst(true)) ~~>  = "true" KwEnd ;
False       <~~ push(makeConst(false)) ~~> = "false" KwEnd ;

VarRef      <~~ push(makeVarRef(up.in)) ~~>
            = Id ;

Id          = ( "a"..."z" | "A"..."Z" | "_" ) :whitespace() { "a"..."z" | "A"..."Z" | "0"..."9" | "_" } :whitespace(Whitespace) ;

KwEnd = :script(~~
    (function() {
        var cc = c.peek(0)
        return ((cc >= 48 && cc <= 57) || (cc >= 65 && cc <= 90) || cc === 95 || (cc >= 97 && cc <= 122))
            ? abnf.newToken("\x01keyword-boundary", 0)
            : undefined
    })()
~~) ;

// The composite literal gate: while an if/for header is being parsed (CondOn pushed
// a marker on the parser stack), StructGate fails, so 'if ok {' never starts a literal.
CondOn = :script(~~
    push("$nostruct")
    undefined
~~) ;
CondOff = :script(~~
    pop()
    undefined
~~) ;
StructGate = :script(~~
    (function() {
        var t = pop()
        if (t != null) push(t)
        return (t == "$nostruct") ? abnf.newToken("\x01no-composite-literal-in-header", 0) : undefined
    })()
~~) ;

Whitespace  = { @+" \t\r\n" | Comment } ;
Comment     = LineComment | BlockComment ;
LineComment = "//" :whitespace() { NotNewline } :whitespace(Whitespace) ;
BlockComment = "/*" :whitespace() { NotStar | "*" { "*" } NotStarSlash } "*" { "*" } "/" :whitespace(Whitespace) ;
NotNewline  = "\x00"..."\x09" | "\x0b"..."\U0010ffff" ;
NotStar     = "\x00"..."\x29" | "\x2b"..."\U0010ffff" ;
NotStarSlash = "\x00"..."\x29" | "\x2b"..."\x2e" | "\x30"..."\U0010ffff" ;

// ---


:startScript(~~

    function takeAll() {
        var items = []
        var v
        while ((v = pop()) != null) items.unshift(v)
        return items
    }
    function popName() {
        var items = takeAll()
        var name = ""
        for (var i = 0; i < items.length; i++) {
            if (items[i] != undefined && items[i].mname != undefined) { name = items[i].mname }
            else { push(items[i]) }
        }
        return name
    }

    function fail(msg) {
        println("go interpreter error: " + msg)
        exit(1)
    }

    function hexAt(s, pos, len) {
        var v = 0
        for (var i = 0; i < len; i++) {
            var c = s.charCodeAt(pos + i)
            var d = (c >= 48 && c <= 57) ? c - 48 : (c >= 97 ? c - 87 : c - 55)
            v = v * 16 + d
        }
        return v
    }
    function unescapeJs(s) {
        var out = ""
        var i = 0
        while (i < s.length) {
            var c = s.charCodeAt(i)
            if (c != 92) { out += String.fromCharCode(c); i++; continue }
            var e = s.charCodeAt(i + 1)
            if (e == 110) { out += "\n"; i += 2; continue }
            if (e == 116) { out += "\t"; i += 2; continue }
            if (e == 114) { out += "\r"; i += 2; continue }
            if (e == 117) { out += String.fromCharCode(hexAt(s, i + 2, 4)); i += 6; continue }
            out += String.fromCharCode(e)
            i += 2
        }
        return out
    }
    function hasOwn(o, name) { return Object.prototype.hasOwnProperty.call(o, name) }
    function concat2impl(a, b) {
        var out = []
        var i
        for (i = 0; i < a.length; i++) out.push(a[i])
        for (i = 0; i < b.length; i++) out.push(b[i])
        return out
    }

    // ----- Scopes -----
    var globalScope = {}
    var scopes = [globalScope]
    function declVar(name, value) { if (name != "_") scopes[scopes.length - 1][name] = value }
    function getVar(name) {
        for (var i = scopes.length - 1; i >= 0; i--) {
            if (hasOwn(scopes[i], name)) return scopes[i][name]
        }
        if (hasOwn(hostGlobals, name)) return hostGlobals[name]
        fail("unknown name: " + name)
    }
    function setVar(name, value) {
        if (name == "_") { return }
        for (var i = scopes.length - 1; i >= 0; i--) {
            if (hasOwn(scopes[i], name)) { scopes[i][name] = value; return }
        }
        fail("assignment to unknown name: " + name)
    }

    // ----- Maps: {__dict, keys, vals, zero} with two parallel arrays. The arrays keep
    // the insertion order; missing keys read as the zero value of the value type. -----
    function isMap(v) {
        return v !== undefined && v !== null && typeof v == "object" && v.__dict === true
    }
    function newMap(zero) { return {__dict: true, keys: [], vals: [], zero: zero} }
    function mapFind(m, k) {
        for (var i = 0; i < m.keys.length; i++) {
            if (m.keys[i] === k) return i
        }
        return -1
    }
    function mapGet(m, k) {
        var i = mapFind(m, k)
        return i >= 0 ? m.vals[i] : m.zero
    }
    function mapSet(m, k, v) {
        var i = mapFind(m, k)
        if (i >= 0) { m.vals[i] = v }
        else { m.keys.push(k); m.vals.push(v) }
    }
    // The zero value of a map's value type ('int', 'string', 'bool'; the captured
    // type text may carry trailing whitespace, so match the prefix).
    function zeroOfType(t) {
        if (t.indexOf("int") == 0) return 0
        if (t.indexOf("string") == 0) return ""
        if (t.indexOf("bool") == 0) return false
        return null
    }

    var hostGlobals = {}
    hostGlobals["fmt"] = {
        Println: function() {
            var out = ""
            for (var i = 0; i < arguments.length; i++) {
                if (i > 0) out += " "
                out += gstr(arguments[i])
            }
            println(out)
        },
        Print: function() {
            var out = ""
            for (var i = 0; i < arguments.length; i++) out += gstr(arguments[i])
            print(out)
        }
    }
    hostGlobals["os"] = { Exit: function(code) { exit(code | 0) } }
    hostGlobals["len"] = function(x) {
        if (isMap(x)) return x.keys.length
        return x.length
    }
    hostGlobals["append"] = function(arr, v) { arr.push(v); return arr }
    hostGlobals["delete"] = function(m, k) {
        if (!isMap(m)) fail("delete() needs a map")
        var i = mapFind(m, k)
        if (i < 0) { return }
        var nk = []
        var nv = []
        for (var j = 0; j < m.keys.length; j++) {
            if (j != i) { nk.push(m.keys[j]); nv.push(m.vals[j]) }
        }
        m.keys = nk
        m.vals = nv
    }

    function gstr(v) {
        if (v === undefined || v === null) return "<nil>"
        if (Array.isArray(v)) {
            var out = "["
            for (var i = 0; i < v.length; i++) {
                if (i > 0) out += " "
                out += gstr(v[i])
            }
            return out + "]"
        }
        if (isMap(v)) {
            var outm = "map["
            for (var j = 0; j < v.keys.length; j++) {
                if (j > 0) outm += " "
                outm += gstr(v.keys[j]) + ":" + gstr(v.vals[j])
            }
            return outm + "]" // Insertion order (real Go sorts the keys here).
        }
        if (typeof v == "object" && v.__class != undefined) {
            var out2 = "{"
            var fs = v.__class.__fields
            for (var k = 0; k < fs.length; k++) {
                if (k > 0) out2 += " "
                out2 += gstr(v[fs[k]])
            }
            return out2 + "}"
        }
        return "" + v
    }

    function mcall(target, name, args) {
        if (target === undefined || target === null) fail("method call ." + name + "() on nil")
        if (typeof target == "object" && target.__class != undefined) {
            var m = target.__class[name]
            if (typeof m != "function") fail("unknown method '" + name + "' on " + target.__class.__name)
            return m.apply(undefined, concat2impl([target], args))
        }
        var f = target[name]
        if (typeof f != "function") fail("unknown method '" + name + "'")
        return f.apply(undefined, args)
    }

    var BRK = {sig: "break"}
    var CONT = {sig: "continue"}

    // ----- Expression thunks -----

    function makeConst(v) { return function() { return v } }
    function makeVarRef(name) { return function() { return getVar(name) } }
    function makeNeg(t) { return function() { return (0 - t()) | 0 } }
    function makeNot(t) { return function() { return !t() } }

    function gadd(l, r) {
        if (typeof l == "string" || typeof r == "string") return l + r
        return (l + r) | 0
    }
    function binOp(op, l, r) {
        if (op == "+") return gadd(l, r)
        if (op == "-") return (l - r) | 0
        if (op == "*") return (l * r) | 0
        if (op == "/") return (l / r) | 0
        if (op == "%") return (l % r) | 0
        if (op == "==") return l === r
        if (op == "!=") return l !== r
        if (op == "<")  return l < r
        if (op == ">")  return l > r
        if (op == "<=") return l <= r
        if (op == ">=") return l >= r
    }
    function foldBinary(items) {
        if (items.length == 1) return items[0]
        return function() {
            var v = items[0]()
            for (var i = 1; i < items.length; i += 2) v = binOp(items[i], v, items[i + 1]())
            return v
        }
    }
    function makeOrAnd(items, isOr) {
        if (items.length == 1) return items[0]
        return function() {
            var v = items[0]()
            for (var i = 1; i < items.length; i++) {
                if (isOr) { if (v) return true }
                else      { if (!v) return false }
                v = items[i]()
            }
            return v ? true : false
        }
    }

    function foldCallMember(items) {
        if (items.length == 1) return items[0]
        var primary = items[0]
        var suffixes = items.slice(1)
        return function() {
            var cur = primary()
            for (var i = 0; i < suffixes.length; i++) {
                var s = suffixes[i]
                if (s.kind == "mcall") {
                    var argv = []
                    for (var j = 0; j < s.args.length; j++) argv.push(s.args[j]())
                    cur = mcall(cur, s.name, argv)
                } else if (s.kind == "field") {
                    if (cur === undefined || cur === null) fail("field ." + s.name + " of nil")
                    cur = cur[s.name]
                } else {
                    cur = isMap(cur) ? mapGet(cur, s.idx()) : cur[s.idx()]
                }
            }
            return cur
        }
    }

    function makeCall(items) {
        var name = items[0]
        var args = items.slice(1)
        return function() {
            var argv = []
            for (var i = 0; i < args.length; i++) argv.push(args[i]())
            var f = getVar(name)
            if (typeof f != "function") fail("call of a non function: " + name)
            return f.apply(undefined, argv)
        }
    }

    function makeSliceLit(items) {
        return function() {
            var a = []
            for (var i = 0; i < items.length; i++) a.push(items[i]())
            return a
        }
    }
    // items = [{mzero}, {mk, mv}...] -> a map built in source order.
    function makeMapLit(items) {
        var zero = zeroOfType(items[0].mzero)
        var entries = items.slice(1)
        return function() {
            var m = newMap(zero)
            for (var i = 0; i < entries.length; i++) mapSet(m, entries[i].mk(), entries[i].mv())
            return m
        }
    }
    function makeMakeMap(mz) {
        var zero = zeroOfType(mz.mzero)
        return function() { return newMap(zero) }
    }
    // items = [valueName, okName, baseThunk, keyThunk]: v, ok := m[k].
    function makeMapOk(items) {
        var vName = items[0]
        var okName = items[1]
        var baseT = items[2]
        var keyT = items[3]
        return function() {
            var m = baseT()
            if (!isMap(m)) fail("the comma ok form needs a map")
            var k = keyT()
            var i = mapFind(m, k)
            declVar(vName, i >= 0 ? m.vals[i] : m.zero)
            declVar(okName, i >= 0)
        }
    }
    // items = [{params}, bodyT] (an ignored RetTypes leaves no stack entry).
