:title("Brainfuck interpreter") ;
:description("Parses Brainfuck and executes it directly.

Each opcode tag pushes its character onto the global stack, so after c.compile() the
stack is the program in source order. The start script precomputes the matching bracket
of every '[' and ']' in one pass and then walks the program with an instruction pointer
and a char to handler dispatch table, so both loop opcodes jump in O(1). (The stack
holds characters, not handler functions: a function that is read back from the stack is
a fresh wrapper under goja and cannot be compared by identity.)

Cells are 8 bit and wrap around, like in the compiled version (brainfuck-to-llvm-ir.abnf).
',' and '?' read one char of the input; at the end of the input they read 0.") ;


// --- main rules

:startRule(Brainfuck) ;
// Everything that is not one of the opcode chars counts as a comment (real world
// Brainfuck files contain plain text between the opcodes).
:whitespace(Whitespace) ;

Brainfuck = { Statement } ;
Statement = Opcode | Lparen { Statement } Rparen ;

// Every opcode pushes its own character. The group is needed: a tag only annotates the
// term directly before it.
Opcode = ( ">" | "<" | "+" | "-" | "." | "," | "?" ) <~~ pushg(up.in) ~~> ;
Lparen = "[" <~~ pushg(up.in) ~~> ;
Rparen = "]" <~~ pushg(up.in) ~~> ;

// All chars except the opcode chars > < + - . , ? [ ].
Whitespace = { "\x00"..."\x2a" | "\x2f"..."\x3b" | "=" | "\x40"..."\x5a" | "\x5c" | "\x5e"..."\U0010ffff" } ;

// ---


:startScript(~~

    // The input that ',' and '?' read from (empty means every read returns 0).
    var input = ""
    var ipos = 0

    var data = []
    var dpos = 0

    function check() {
        if (data[dpos] == undefined) data[dpos] = 0
    }

    function next() {
        dpos++
    }
    function prev() {
        dpos--
    }
    function inc() {
        check()
        data[dpos] = (data[dpos] + 1) & 255 // The cells are 8 bit and wrap around.
    }
    function dec() {
        check()
        data[dpos] = (data[dpos] - 1) & 255
    }
    function write() {
        check()
        printf("%c", data[dpos])
    }
    function read() {
        data[dpos] = (ipos < input.length) ? input.charCodeAt(ipos++) & 255 : 0
    }
    function lparen() {
        check()
        if (data[dpos] == 0) cpos = jump[cpos] // To the matching ']'; the driver then steps behind it.
    }
    function rparen() {
        check()
        if (data[dpos] != 0) cpos = jump[cpos] // Back behind the matching '[' (the cell is known non-zero, so its check may be skipped).
    }

    // Fill the global stack with the program: one opcode character per instruction.
    c.compile(c.asg)
    var codeLength = ltr.stack.length

    // Precompute the matching bracket of every '[' and ']' in one pass.
    var jump = []
    var open = []
    for (var i = 0; i < codeLength; i++) {
        if (ltr.stack[i] == "[") { open.push(i) }
        if (ltr.stack[i] == "]") { var j = open.pop(); jump[j] = i; jump[i] = j }
    }

    // The dispatch table: opcode character -> handler function.
    var ops = {}
    ops[">"] = next; ops["<"] = prev
    ops["+"] = inc;  ops["-"] = dec
    ops["."] = write
    ops[","] = read; ops["?"] = read
    ops["["] = lparen; ops["]"] = rparen

    // Run the program.
    var cpos = 0
    while (cpos < codeLength) {
        ops[ltr.stack[cpos]]()
        cpos++
    }

~~) ;
