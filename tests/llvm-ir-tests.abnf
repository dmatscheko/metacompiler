:title("LLVM IR tests") ;
:description("Builds an LLVM IR module by hand and checks the built-in IR interpreter:
straight arithmetic (llvm.Eval), globals with loads and stores, external functions,
control flow with blocks and phi, putchar/getchar via llvm.Run, and the whole integer
instruction set (sub, div/rem, the bitwise group, shifts, select, trunc/zext/sext, all
ten icmp predicates, and getelementptr). Exits with 1 on a mismatch, so this file is a
self checking test.") ;


:startScript(~~

    println("LLVM IR tests:\n------------------------------------")

    var failures = 0
    function check(name, got, want) {
        if (got == want) {
            println("ok   " + name + " = " + got)
        } else {
            println("FAIL " + name + " = " + got + ", wanted " + want)
            failures++
        }
    }

    // Create convenience types and constants.
    var i32 = llvm.types.I32
    var zero = llvm.constant.NewInt(i32, 0)
    var one = llvm.constant.NewInt(i32, 1)

    // Create a new LLVM IR module.
    var m = llvm.ir.NewModule()

    // -----------------
    // A linear congruential PRNG around a global variable and the external abs():
    //
    //    int seed = 0;
    //    int rand(void) { seed = seed * 0x15A4E35 + 1; return abs(seed); }

    // The multiplier of the PRNG, 0x15A4E35 (MetaJS has no hex literals).
    var a = llvm.constant.NewInt(i32, 22695477)
    var c = one                                  // increment of the PRNG.

    var abs = m.NewFunc("abs", i32, llvm.ir.NewParam("x", i32))
    var seed = m.NewGlobalDef("seed", zero)

    var rand = m.NewFunc("rand", i32)
    var entry = rand.NewBlock("")
    var tmp1 = entry.NewLoad(i32, seed)
    var tmp2 = entry.NewMul(tmp1, a)
    var tmp3 = entry.NewAdd(tmp2, c)
    entry.NewStore(tmp3, seed)
    var tmp4 = entry.NewCall(abs, tmp3)
    entry.NewRet(tmp4)

    // -----------------
    //    int test(void) { return 32 + 7; }

    var test = m.NewFunc("test", i32)
    var entry = test.NewBlock("")
    var tmp = entry.NewAdd(llvm.constant.NewInt(i32, 32), llvm.constant.NewInt(i32, 7))
    entry.NewRet(tmp)

    // -----------------
    //    int sum(int n) { int s = 0; int i = 1; while (i <= n) { s += i; i++; } return s; }
    // Exercises alloca, load, store, icmp, br and condbr.

    var n = llvm.ir.NewParam("n", i32)
    var sum = m.NewFunc("sum", i32, n)
    var sumEntry = sum.NewBlock("entry")
    var sPtr = sumEntry.NewAlloca(i32)
    var iPtr = sumEntry.NewAlloca(i32)
    sumEntry.NewStore(zero, sPtr)
    sumEntry.NewStore(one, iPtr)
    var head = sum.NewBlock("head")
    sumEntry.NewBr(head)
    var iv = head.NewLoad(i32, iPtr)
    var cond = head.NewICmp(llvm.enum.IPredSLE, iv, n)
    var body = sum.NewBlock("body")
    var exit = sum.NewBlock("exit")
    head.NewCondBr(cond, body, exit)
    body.NewStore(body.NewAdd(body.NewLoad(i32, sPtr), body.NewLoad(i32, iPtr)), sPtr)
    body.NewStore(body.NewAdd(body.NewLoad(i32, iPtr), one), iPtr)
    body.NewBr(head)
    exit.NewRet(exit.NewLoad(i32, sPtr))

    // -----------------
    //    int max(int x, int y) { return (x > y) ? x : y; }
    // Exercises the phi instruction.

    var px = llvm.ir.NewParam("x", i32)
    var py = llvm.ir.NewParam("y", i32)
    var max = m.NewFunc("max", i32, px, py)
    var maxEntry = max.NewBlock("")
    var isGt = maxEntry.NewICmp(llvm.enum.IPredSGT, px, py)
    var takeX = max.NewBlock("")
    var takeY = max.NewBlock("")
    var merge = max.NewBlock("")
    maxEntry.NewCondBr(isGt, takeX, takeY)
    takeX.NewBr(merge)
    takeY.NewBr(merge)
    var phi = merge.NewPhi(llvm.ir.NewIncoming(px, takeX), llvm.ir.NewIncoming(py, takeY))
    merge.NewRet(phi)

    // -----------------
    // Wrappers with constant arguments, because Eval()/Run() start their function with
    // zero filled parameters:
    //    int callSum(void)  { return sum(10); }
    //    int callMax1(void) { return max(3, 9); }
    //    int callMax2(void) { return max(9, 3); }

    var callSum = m.NewFunc("callSum", i32)
    var csb = callSum.NewBlock("")
    csb.NewRet(csb.NewCall(sum, llvm.constant.NewInt(i32, 10)))

    var callMax1 = m.NewFunc("callMax1", i32)
    var cm1b = callMax1.NewBlock("")
    cm1b.NewRet(cm1b.NewCall(max, llvm.constant.NewInt(i32, 3), llvm.constant.NewInt(i32, 9)))

    var callMax2 = m.NewFunc("callMax2", i32)
    var cm2b = callMax2.NewBlock("")
    cm2b.NewRet(cm2b.NewCall(max, llvm.constant.NewInt(i32, 9), llvm.constant.NewInt(i32, 3)))

    // -----------------
    //    int main(void) { putchar(getchar()); putchar(getchar()); return 0; }

    var extPutchar = m.NewFunc("putchar", i32, llvm.ir.NewParam("", i32))
    var extGetchar = m.NewFunc("getchar", i32)
    var main = m.NewFunc("main", i32)
    var mb = main.NewBlock("")
    mb.NewCall(extPutchar, mb.NewCall(extGetchar))
    mb.NewCall(extPutchar, mb.NewCall(extGetchar))
    mb.NewRet(zero)

    // -----------------
    // Every remaining integer instruction once, in tiny functions with constant
    // operands, so the whole instruction set of the machine is checked.

    var i8 = llvm.types.I8
    var i32x4 = llvm.types.NewArray(4, i32)

    function opFunc(name, build) {
        var f = m.NewFunc(name, i32)
        var b = f.NewBlock("")
        b.NewRet(build(b))
    }
    function ci(v) { return llvm.constant.NewInt(i32, v) }

    opFunc("opSub",  function(b) { return b.NewSub(ci(50), ci(8)) })                     // 42
    opFunc("opSdiv", function(b) { return b.NewSDiv(ci(7), ci(2)) })                     // 3
    opFunc("opUdiv", function(b) { return b.NewUDiv(ci(9), ci(2)) })                     // 4
    opFunc("opSrem", function(b) { return b.NewSRem(ci(7), ci(3)) })                     // 1
    opFunc("opUrem", function(b) { return b.NewURem(ci(9), ci(4)) })                     // 1
    opFunc("opAnd",  function(b) { return b.NewAnd(ci(6), ci(3)) })                      // 2
    opFunc("opOr",   function(b) { return b.NewOr(ci(6), ci(3)) })                       // 7
    opFunc("opXor",  function(b) { return b.NewXor(ci(6), ci(3)) })                      // 5
    opFunc("opShl",  function(b) { return b.NewShl(ci(3), ci(2)) })                      // 12
    opFunc("opLshr", function(b) { return b.NewLShr(ci(12), ci(2)) })                    // 3
    opFunc("opAshr", function(b) { return b.NewAShr(ci(12), ci(1)) })                    // 6
    opFunc("opSelect", function(b) {
        return b.NewSelect(b.NewICmp(llvm.enum.IPredSLT, ci(1), ci(2)), ci(11), ci(22))  // 11
    })
    // 300 -> i8 (44) -> zext back to i32.
    opFunc("opTruncZext", function(b) { return b.NewZExt(b.NewTrunc(ci(300), i8), i32) })
    // 255 -> i8 (-1) -> sext to i32 (-1); + 2 keeps the expected value positive.
    opFunc("opTruncSext", function(b) { return b.NewAdd(b.NewSExt(b.NewTrunc(ci(255), i8), i32), ci(2)) })
    // All ten icmp predicates on (5, 7), summed as 0/1 bits: 0+1+1+1+0+0+1+1+0+0 = 5.
    opFunc("opPreds", function(b) {
        var preds = [llvm.enum.IPredEQ, llvm.enum.IPredNE, llvm.enum.IPredSLT, llvm.enum.IPredSLE,
                     llvm.enum.IPredSGT, llvm.enum.IPredSGE, llvm.enum.IPredULT, llvm.enum.IPredULE,
                     llvm.enum.IPredUGT, llvm.enum.IPredUGE]
        var v = ci(0)
        for (var i = 0; i < preds.length; i++) {
            v = b.NewAdd(v, b.NewZExt(b.NewICmp(preds[i], ci(5), ci(7)), i32))
        }
        return v
    })
    // A local array through getelementptr: store into [2], read it back.
    opFunc("opGep", function(b) {
        var aPtr = b.NewAlloca(i32x4)
        b.NewStore(llvm.constant.NewZeroInitializer(i32x4), aPtr)
        b.NewStore(ci(77), b.NewGetElementPtr(i32x4, aPtr, ci(0), ci(2)))
        return b.NewLoad(i32, b.NewGetElementPtr(i32x4, aPtr, ci(0), ci(2)))
    })

    // -----------------

    // Print the LLVM IR assembly of the module.
    println(m)

    println("GRAPH:\n------------------------------------")
    println(llvm.Callgraph(m))

    println("\nEVAL / RUN:\n------------------------------------")
    check("test()", llvm.Eval(m, "test"), 39)
    check("rand()", llvm.Eval(m, "rand"), 1)   // The global seed starts fresh for every Eval/Run.
    check("sum(10)", llvm.Eval(m, "callSum"), 55)
    check("max(3, 9)", llvm.Eval(m, "callMax1"), 9)
    check("max(9, 3)", llvm.Eval(m, "callMax2"), 9)
    var res = llvm.Run(m, "main", "Hi")
    check("main() echo", res.Out, "Hi")

    check("sub", llvm.Eval(m, "opSub"), 42)
    check("sdiv", llvm.Eval(m, "opSdiv"), 3)
    check("udiv", llvm.Eval(m, "opUdiv"), 4)
    check("srem", llvm.Eval(m, "opSrem"), 1)
    check("urem", llvm.Eval(m, "opUrem"), 1)
    check("and", llvm.Eval(m, "opAnd"), 2)
    check("or", llvm.Eval(m, "opOr"), 7)
    check("xor", llvm.Eval(m, "opXor"), 5)
    check("shl", llvm.Eval(m, "opShl"), 12)
    check("lshr", llvm.Eval(m, "opLshr"), 3)
    check("ashr", llvm.Eval(m, "opAshr"), 6)
    check("select", llvm.Eval(m, "opSelect"), 11)
    check("trunc + zext", llvm.Eval(m, "opTruncZext"), 44)
    check("trunc + sext + 2", llvm.Eval(m, "opTruncSext"), 1)
    check("icmp predicates", llvm.Eval(m, "opPreds"), 5)
    check("getelementptr", llvm.Eval(m, "opGep"), 77)

    if (failures > 0) { exit(1) }
    println("All LLVM IR tests OK")

~~) ;
