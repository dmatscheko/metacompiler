:title("Calculator interpreter (global stack)") ;
:description("Parses a formula with + - * /, unary minus and brackets and evaluates it during the
compile walk: the tag behind every operator pops the operand values from the global stack
(pushg/popg), computes, and pushes the result back, so after c.compile() the final value
is the only entry left on that stack. Numbers may use a dot or a comma as decimal
separator. This is the smallest example of the tag data flow; the same calculator built
on the local stacks is calculator-interpreter-2.abnf, and a compiling variant is
calculator-to-llvm-ir.abnf.") ;


:startRule(Expression) ;

Expression  =
    Term
    {
        ( "+" | "-" )           <~~pushg(up.in)~~>
        Term                    <~~
                                var t2 = popg()
                                var op = popg()
                                var t1 = popg()
                                println("calculating " + t1 + " " + op + " " + t2)
                                var res = (op=="+") ? t1 + t2 : t1 - t2
                                pushg(res)
                                ~~>
    }
    ;

Term        =
    Factor
    {
        ( "*" | "/" )           <~~pushg(up.in)~~>
        Factor                  <~~
                                var t2 = popg()
                                var op = popg()
                                var t1 = popg()
                                println("calculating " + t1 + " " + op + " " + t2)
                                var res = (op=="*") ? t1 * t2 : t1 / t2
                                pushg(res)
                                ~~>
    }
    ;

Factor      =
    (
        "("
        Expression
        ")"
    )
    |
    Neg
    |
    // The grammar allows a comma as decimal separator, parseFloat() does not.
    Number                      <~~pushg(parseFloat(up.in.replace(",", ".")))~~>
    ;

// Unary minus negates the factor behind it (and '- -x' works through the recursion).
Neg         = "-" Factor        <~~pushg(-popg())~~> ;

Number      = ( "0" | "1"..."9" { "0"..."9" } )
              [ ( "." | "," ) "0"..."9" { "0"..."9" } ] ;


:startScript(~~
    c.compile(c.asg)
    println("\nRESULT: " + popg() + "\nFormula was: " + ltr.in)
~~) ;
