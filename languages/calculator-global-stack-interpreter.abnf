:title("Calculator interpreter (global stack)") ;
:description("Parses a formula with + - * /, unary minus and brackets and evaluates it during the
compile walk: the tag behind every operator pops the operand values from the global stack
(pushg/popg), computes, and pushes the result back, so after c.compile() the final value
is the only entry left on that stack. Numbers may use a dot or a comma as decimal
separator. This is the smallest example of the tag data flow; the same calculator built
on the local stacks is calculator-local-stacks-interpreter.abnf, and a compiling variant is
calculator-to-llvm-ir.abnf.") ;


:startRule(Expression) ;

Expression  =
    Term
    {
        ( "+" | "-" )           <~~pushg(up.in)~~>
        Term                    <~~
                                var t2 = popg()
                                var op = popg()
                                var t1 = popg()
                                println("calculating " + t1.v + " " + op + " " + t2.v)
                                pushg(combine(t1, op, t2))
                                ~~>
    }
    ;

Term        =
    Factor
    {
        ( "*" | "/" )           <~~pushg(up.in)~~>
        Factor                  <~~
                                var t2 = popg()
                                var op = popg()
                                var t1 = popg()
                                println("calculating " + t1.v + " " + op + " " + t2.v)
                                pushg(combine(t1, op, t2))
                                ~~>
    }
    ;

Factor      =
    (
        "("
        Expression
        ")"
    )
    |
    Neg
    |
    // The grammar allows a comma as decimal separator, parseFloat() does not.
    Number                      <~~pushg(mkNum(parseFloat(up.in.replace(",", ".")), up.in))~~>
    ;

// Unary minus negates the factor behind it (and '- -x' works through the recursion).
Neg         = "-" Factor        <~~pushg(mkNeg(popg()))~~> ;

Number      = ( "0" | "1"..."9" { "0"..."9" } )
              [ ( "." | "," ) "0"..."9" { "0"..."9" } ] ;


:startScript(~~
    // A node carries the value v and the parenthesized text s of its sub-expression;
    // atom marks a leaf (a number) that needs no parentheses when nested. paren() wraps a
    // composite child, so the printed formula shows exactly how the input was parsed.
    function mkNum(v, txt) { return {v: v, s: txt, atom: true} }
    function paren(n) { return n.atom ? n.s : "(" + n.s + ")" }
    function mkNeg(n) { return {v: -n.v, s: "-" + paren(n), atom: false} }
    function combine(a, op, b) {
        var v = anytype
        if (op == "+") v = a.v + b.v
        else if (op == "-") v = a.v - b.v
        else if (op == "*") v = a.v * b.v
        else v = a.v / b.v
        return {v: v, s: paren(a) + " " + op + " " + paren(b), atom: false}
    }

    c.compile(c.asg)
    var top = popg()
    println("\nFormula was: " + top.s + "\nRESULT: " + top.v)
~~) ;
