    // A trailing statement modifier: STMT if/unless COND (run once when the guard
    // holds) or STMT while/until COND (a pre-condition loop). Break/next/return that
    // reach up from the statement thread through runLoopBody just like a plain loop.
    function applyMod(items) {
        if (items.length == 1) { return items[0] }
        var stmt = items[0]
        var mod = items[1].mod
        var cond = items[2]
        if (mod == "if") { return function() { if (rtest(cond())) { return stmt() } return null } }
        if (mod == "unless") { return function() { if (!rtest(cond())) { return stmt() } return null } }
        if (mod == "while") {
            return function() {
                while (rtest(cond())) {
                    var s = runLoopBody(stmt)
                    if (s.sig != undefined) { return s.sig }
                    if (s.stop) { return s.v }
                }
                return null
            }
        }
        return function() {
            while (!rtest(cond())) {
                var s = runLoopBody(stmt)
                if (s.sig != undefined) { return s.sig }
                if (s.stop) { return s.v }
            }
            return null
        }
    }

    // begin BODY end while/until COND: a post-condition loop; BODY always runs once,
    // then the guard decides whether to repeat (while: while truthy, until: until
    // truthy). No rescue/ensure here - a begin with those routes through makeTry.
    function makeDoWhile(items) {
        var body = items[0].body
        var op = items[1].dw
        var cond = items[2]
        return function() {
            while (true) {
                var s = runLoopBody(body)
                if (s.sig != undefined) { return s.sig }
                if (s.stop) { return s.v }
                var cv = cond()
                if (op == "while") { if (!rtest(cv)) { break } }
                else { if (rtest(cv)) { break } }
            }
            return null
        }
    }

    // cond ? a : b - short-circuiting.
    function makeTernary(items) {
        if (items.length == 1) { return items[0] }
        var condT = items[0]
        var thenT = items[1]
        var elseT = items[2]
        return function() {
            if (rtest(condT())) { return thenT() }
            return elseT()
        }
    }

    // arr << x: push and yield the array (so a << b << c chains).
    function appendOp(l, r) {
        if (Array.isArray(l)) { l.push(r); return l }
        fail("<< requires an array")
    }
    function makeShift(items) {
        if (items.length == 1) { return items[0] }
        return function() {
            var v = anytype
            v = items[0]()
            for (var i = 1; i < items.length; i++) { v = appendOp(v, items[i]()) }
            return v
        }
    }

    // a, b = x, y: evaluate every right-hand value first, then write each target.
    function assignTargetRef(ref, v) {
        if (ref.path.length == 0) { writeTarget(ref, v); return }
        var p = resolveRefRuby(ref)
        if (isDict(p.obj)) { dictSet(p.obj, p.key, v) } else { p.obj[p.key] = v }
    }
    function makeMultiAssign(items) {
        var targets = []
        var values = []
        for (var i = 0; i < items.length; i++) {
            if (typeof items[i] == "function") { values.push(items[i]) }
            else { targets.push(items[i]) }
        }
        return function() {
            var vals = []
            if (values.length == 1 && targets.length > 1) {
                var it = values[0]()
                for (var j = 0; j < it.length; j++) { vals.push(it[j]) }
            } else {
                for (var k = 0; k < values.length; k++) { vals.push(values[k]()) }
