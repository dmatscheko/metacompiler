    }

    // begin / rescue / else / ensure. items = [{trybody}, {handler,hname}*, {elsebody}?,
    // {finalbody}?]. makeExcept pairs a rescue's `=> Id` name (if any) with its body.
    // items = [name, bodyThunk] or [bodyThunk] (rescue with no binding).
    function makeExcept(items) {
        if (items.length > 1) { return {handler: items[1], hname: items[0]} }
        return {handler: items[0], hname: undefined}
    }
    // A raise in the body unwinds (a host throw) to the first rescue, which binds its
    // `=> Id` name to the value; else runs only when the body raised nothing AND produced
    // no return/break/next signal; ensure always runs and a control signal from it
    // overrides. A return/break/next signal from the body propagates as the begin's value.
    // The scope chain is restored to its begin-entry snapshot on the way out of a throw.
    function makeTry(items, pos) {
        var tryT = anytype, handlerT = anytype, hname = anytype, elseT = anytype, finallyT = anytype
        for (var i = 0; i < items.length; i++) {
            if (items[i].trybody != undefined) { tryT = items[i].trybody }
            else if (items[i].handler != undefined) {
                if (handlerT == undefined) { handlerT = items[i].handler; hname = items[i].hname }
            }
            else if (items[i].elsebody != undefined) { elseT = items[i].elsebody }
            else if (items[i].finalbody != undefined) { finallyT = items[i].finalbody }
        }
        return function() {
            var savedChain = scopes.slice()
            var box = {v: null}
            var threw = false
            try {
                box.v = tryT()
            } catch (e) {
                scopes = savedChain.slice()
                if (excIsUser(e) && handlerT != undefined) {
                    threw = true
                    scopes.push({})
                    if (hname != undefined) { declVar(hname, e.v) }
