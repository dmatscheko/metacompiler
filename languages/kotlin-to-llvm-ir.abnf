:title("Kotlin (subset) to LLVM IR compiler") ;
:description("Compiles a Kotlin subset to an LLVM IR module and runs it with the built-in
IR interpreter and the MetaJS handle runtime (llvm.RunJS).

The subset: top level functions with block or expression bodies (fun add(a: Int, b: Int)
: Int = a + b), val/var declarations with type inference (annotations are parsed and
ignored, val is not enforced), if/else as statement and as expression, when expressions
with and without subject (arms are expressions, multiple comma separated match values,
else required for a value, range branches with in 1..9 and !in 1..9), the elvis
operator a ?: b (b when a is null; short circuit), the safe calls x?.length and
obj?.m() (null when the receiver is null; skipped calls do not evaluate their
arguments), while, do-while, for over ranges (for (i in 1..n), 0 until n, n downTo 1,
each with an optional positive step)
and over lists, break/continue, lambdas as values ({ it * 2 }, { x: Int -> x * 2 },
multi parameter, real closures over the defining scope; the body is one expression)
with trailing lambda call syntax (list.map { it * 2 }), the list higher order methods
map/filter/sumOf/forEach/count/any, classes with primary constructor properties
(class Counter(val start: Int) { var value = start; fun next(): Int { ... } }) and
implicit property access inside methods (value += step resolves against this), object
creation without new (Counter(5)), string templates ('x=$x sum=${a+b}'), listOf() with
.size, indexing, .add()/.get()/.contains(), the builtins println/print/abs/max/min and
exitProcess. Int arithmetic is 32 bit and / truncates; + concatenates when one side is
a String; == compares structurally for strings and by identity for objects.

Not in the subset: inheritance, interfaces, generics, nullable types (? is parsed and
ignored), extension functions, named/default arguments, multi statement lambda bodies,
data class methods
(the data modifier is parsed), init blocks, secondary constructors, and bare method
calls (methods are called via this.m() or obj.m()).

Functions, methods and lambdas become IR functions jsf_N(env, args) (methods get the
instance prepended, lambdas close over their scope via js_closure), classes become
descriptor objects, implicit property access goes through the
js_kget/js_kset externals (locals first, then the properties of this), method calls
dispatch through js_mcall (which also implements the list higher order methods), and
?. compiles to a null test branching around the access (a phi merges the null).
The whole program becomes jsmain(env, args).
The entry point is fun main(); self checking programs end with exitProcess(failures).
The same language with the same semantics is interpreted directly by kotlin-interpreter.abnf.") ;


// --- main rules

// Shared token productions (languages/lib).
:include("lib/cstyle-comments.abnf") ;
:include("lib/ident.abnf") ;
:include("lib/numbers.abnf") ;
:include("lib/bools.abnf") ;

:startRule(Program) ;
:whitespace(Whitespace) ;

Program     <~~ buildMain(takeAll()) ~~>
            = { Annotation } [ Package ] { Import } { [ Modifiers ] ( UnsupType | FunDecl <~~ push(makeFunStmt(pop())) ~~> | UnsupFun | ClassDecl | TopProp ) } ;

// Modifiers and annotations before a declaration are parsed and ignored (they do
// not change what we lower). Annotations accept ALL forms: an argument list
// @Suppress("Unused") / @Deprecated("m", ReplaceWith("n")), qualified names
// @a.b.C, use-site targets @field:A / @get:A / @file:A, and annotation arrays
// @[A B C(x)]. Modifiers that would change the shape of the body
// (enum/annotation/companion) are NOT consumed here - those declaration forms
// route to notImplemented instead.
Modifiers   = { Modifier | Annotation } ;
Modifier    = ( "public" | "private" | "protected" | "internal" | "open" | "final"
              | "abstract" | "sealed" | "data" | "override" | "lateinit" | "const"
              | "inner" | "vararg" | "noinline" | "crossinline" | "tailrec"
              | "operator" | "infix" | "inline" | "external" | "suspend"
              | "expect" | "actual" | "reified" ) KwEnd ;
// An annotation: an optional use-site target, then either an @[...] set or a single
// entry (a possibly-qualified name with an optional balanced argument list).
Annotation  = "@" [ AnnTarget ":" ] ( AnnSet | AnnEntry ) ;
// Use-site targets are word-bounded, so @fieldOf stays a plain annotation named
// "fieldOf" rather than the target "field".
AnnTarget   = ( "field" | "property" | "get" | "set" | "receiver" | "param"
              | "setparam" | "delegate" | "file" ) KwEnd ;
AnnSet      = "[" { AnnEntry } "]" ;
AnnEntry    = Id { "." Id } [ SkipParen ] ;

// package / import headers. The package name is parsed and ignored. Each import
// is resolved against the runtime builtins (core.stdlibImports); one that does
// not resolve aborts the compile, unless -warn-imports downgrades it to a
// warning (see resolveImport in the startScript). QualName also accepts a
// trailing .* wildcard. Neither pushes a statement, so buildMain never sees them.
Package     <~~ pop() ~~> = KwPackage QualName [ ";" ] ;
Import      <~~ resolveImport(pop(), up.pos) ~~> = KwImport QualName [ KwAs Id ] [ ";" ] ;
QualName    <~~ push(stripWs(up.in)) ~~> = Id { "." Id } [ "." "*" ] ;

// A top level val/var: its declaration thunk becomes a top level statement.
TopProp     = DelegateDecl | Decl ;

FunDecl     <~~ push(makeFun(takeAll())) ~~>
            = KwFun [ SkipAngle ] Id <~~ push(up.in) ~~> ParamList [ ":" Type ] FunBody ;
FunBody     = Block | "=" ExprBody ;
ExprBody    <~~ push(makeExprBody(pop())) ~~>
            = Expression ;

// A function declaration outside the executable subset: an extension function
// (fun Receiver.name(...), receiver dispatch unsupported) or an abstract / bodiless
// declaration (abstract fun name(): R). The header - a possibly dotted, possibly
// generic name, a parameter list, an optional return type, and an optional body - is
// recognised and reported as not implemented; a present body is skipped. It follows
// FunDecl in every choice, so a normal `fun name(...) body` is matched there first.
UnsupFun    <~~ notImpl("extension or abstract function", up.pos) ~~>
            = KwFun [ SkipAngle ] FunName SkipParen [ ":" Type ] [ SkipBlock | "=" DiscardExpr ] ;
FunName     = Id [ SkipAngle ] { "." Id [ SkipAngle ] } ;

ParamList   <~~ push({params: takeAll()}) ~~>
            = "(" [ Param { "," Param } ] ")" ;
// Parameter modifiers (vararg/noinline/crossinline) and a default value are parsed
// and dropped - the default is not supplied at call sites, but the header parses.
Param       = [ Modifiers ] Id <~~ push(up.in) ~~> ":" Type [ "=" DiscardExpr ] ;

// class Counter(val start: Int, var step: Int) { var value = start; fun next() ... }
ClassDecl   <~~ push(makeClassStmt(takeAll())) ~~>
            = [ "data" KwEnd ] KwClass Id <~~ push(up.in) ~~> [ SkipAngle ] [ CtorParams ] [ ":" SuperList ] [ "{" { Member } "}" ] ;
CtorParams  <~~ push({cparams: takeAll()}) ~~>
            = "(" [ CtorParam { "," CtorParam } ] ")" ;
CtorParam   <~~ push(makeCtorParam(takeAll())) ~~>
            = [ Modifiers ] [ ( "val" | "var" ) <~~ push({vv: up.in}) ~~> KwEnd ] Id <~~ push(up.in) ~~> ":" Type ;

Member      = [ Modifiers ] ( InitBlock | CompanionObject | SecondaryCtor | PropAccessor | PropDelegate | PropDecl | FunDecl <~~ push({method: pop()}) ~~> | UnsupFun ) ;
PropDecl    <~~ push(makeProp(takeAll())) ~~>
            = ( "val" | "var" ) KwEnd Id <~~ push(up.in) ~~> [ ":" Type ] "=" Expression [ ";" ] ;
// A delegated property (val/var x [: T] by <expr>, e.g. `by lazy { ... }` or the
// Koin/DI `by inject()`): reading it dispatches through the delegate's getValue/
// setValue protocol, which is outside the subset. It parses and is reported as not
// implemented; the member contributes no field (like a property accessor).
PropDelegate <~~ notImpl("delegated property", up.pos) ~~>
            = ( "val" | "var" ) KwEnd Id [ ":" Type ] KwBy DiscardExpr [ SkipBlock ] [ ";" ] ;

// Type is parsed and (apart from steering as/is) ignored. Generics (<...>) and the
// nullable ? are accepted and dropped; dotted names and simple function types too.
Type        = ( "(" [ Type { "," Type } ] ")" "->" Type | Id [ SkipAngle ] { "." Id [ SkipAngle ] } ) [ "?" ] ;

// Every statement production pushes exactly one thunk: function() -> undefined | signal.
// A statement may carry a label (loop@ ...); the label is parsed and ignored, so the
// labelled statement still lowers. Labelled jumps (break@l / continue@l / return@l)
// route to notImpl (the target label cannot be resolved in the subset).
Statement   <~~ push(stmtPos(pop())) ~~>
            = { Annotation } ( ReturnAt | Return | BreakAt | Break | ContinueAt | Continue
            | [ LabelDef ] ( Block | Destructure | DelegateDecl | Decl | If | While | Do | For | TryStmt | Throw | Empty | ExprStmt ) ) ;

// try/catch/finally and throw are implemented: throw calls js_throw (a Go panic the
// runtime unwinds), and each try/catch/finally body is compiled to its own closure
// handed to js_try (see makeTry). The first catch clause wins (exception types are
// parsed but not discriminated). A return/break/continue that leaves a try or catch
// body becomes a control signal that excDispatch re-issues in the enclosing frame
// (compile-core). Each part is marked so makeTry can tell them apart.
TryStmt     <~~ push(makeTry(takeAll())) ~~>
            = KwTry TryBody { CatchClause } [ FinallyClause ] ;
TryBody     <~~ push({trybody: pop()}) ~~>
            = Block ;
CatchClause <~~ push(makeCatch(takeAll())) ~~>
            = KwCatch "(" Id <~~ push(up.in) ~~> [ ":" Type ] ")" Block ;
FinallyClause <~~ push({finbody: pop()}) ~~>
            = KwFinally Block ;
Throw       <~~ push(makeThrow(pop())) ~~>
            = KwThrow Expression [ ";" ] ;

Block       <~~ push(makeBlockStmt(takeAll())) ~~>
            = "{" { Statement } "}" ;

Decl        <~~ push(makeDecl(takeAll())) ~~>
            = ( "val" | "var" ) KwEnd Id <~~ push(up.in) ~~> [ ":" Type ] "=" Expression [ ";" ] ;
// A local or top-level delegated property (val x by lazy { ... }): same delegate
// protocol gap as PropDelegate; parsed and reported as not implemented, with a
// placeholder statement so the surrounding code still lowers under -warn-unsupported.
DelegateDecl <~~ push(notImplStmt("delegated property", up.pos)) ~~>
            = ( "val" | "var" ) KwEnd Id [ ":" Type ] KwBy DiscardExpr [ SkipBlock ] [ ";" ] ;

If          <~~ push(makeIf(takeAll())) ~~>
            = KwIf "(" Expression ")" Statement [ KwElse Statement ] ;

While       <~~ push(makeWhile(pop(), pop())) ~~>
            = KwWhile "(" Expression ")" Statement ;

Do          <~~ push(makeDo(pop(), pop())) ~~>
            = KwDo Statement KwWhile "(" Expression ")" [ ";" ] ;

// for (i in 1..n) and for (x in list); the range is tried first. Ranges come as
// 1..n (inclusive), 0 until n (exclusive) and n downTo 1, all with an optional
// positive step (soft keywords: until/downTo/step stay usable as names).
For         = ForRange | ForList ;
ForRange    <~~ push(makeForRange(takeAll())) ~~>
            = KwFor "(" Id <~~ push(up.in) ~~> KwIn Expression RangeOp Expression [ StepSfx ] ")" Statement ;
RangeOp     = ".." <~~ push({rop: ".."}) ~~>
            | KwUntil <~~ push({rop: "until"}) ~~>
            | KwDownTo <~~ push({rop: "downTo"}) ~~> ;
StepSfx     <~~ push({step: pop()}) ~~>
            = KwStep Expression ;
ForList     <~~ push(makeForList(pop(), pop(), pop())) ~~>
            = KwFor "(" Id <~~ push(up.in) ~~> KwIn Expression ")" Statement ;

Return      <~~ push(makeReturn(takeAll())) ~~>
            = KwReturn [ Expression ] [ ";" ] ;

Break       <~~ push(makeBreak()) ~~>    = KwBreak [ ";" ] ;
Continue    <~~ push(makeContinue()) ~~> = KwContinue [ ";" ] ;

Empty       <~~ push(function(b) { return b }) ~~>
            = ";" ;

ExprStmt    <~~ push(exprToStmt(pop())) ~~>
            = Expression [ ";" ] ;

// Every expression production pushes exactly one thunk: function() -> value.
Expression  = Assignment | CondLevel ;
Assignment  <~~ push(makeAssign(takeAll())) ~~>
            = Target ( "+=" | "-=" | "*=" | "/=" | "%=" | "=" ) <~~ push(up.in) ~~> Expression ;

Target      <~~ push(makeTargetRef(takeAll())) ~~>
            = Id <~~ push(up.in) ~~> { "." Id <~~ push({key: up.in}) ~~> | TIndex } ;
TIndex      <~~ push({idx: pop()}) ~~>
            = "[" Expression "]" ;

CondLevel   = IfExpr | WhenExpr | OrExpr ;

// if as an expression needs both arms.
IfExpr      <~~ push(makeIfExpr(pop(), pop(), pop())) ~~>
            = KwIf "(" Expression ")" Expression KwElse Expression ;

// when { c1 -> e1; else -> e } and when (x) { 1, 2 -> e1; else -> e }.
WhenExpr    <~~ push(makeWhen(takeAll())) ~~>
            = KwWhen [ "(" WhenSubj ")" ] "{"
              { WhenElse | WhenArm } "}" ;
// The subject is a plain expression, or a val/var binding - when (val x = e) { ... } -
// whose name is in scope in every arm body. The type annotation is parsed and ignored.
WhenSubj    = WhenBind | WhenExprSubj ;
WhenBind    <~~ var e = pop(); push({subj: e, subjName: pop()}) ~~>
            = ( "val" | "var" ) KwEnd Id <~~ push(up.in) ~~> [ ":" Type ] "=" Expression ;
WhenExprSubj <~~ push({subj: pop()}) ~~>
            = Expression ;
// The else arm must be tried first: otherwise 'else' would parse as a variable arm
// (and only fail at run time, when no other arm matches).
WhenElse    = KwElse "->" Expression <~~ push({els: pop()}) ~~> [ ";" ] ;
WhenArm     <~~ push(makeWhenArm(takeAll())) ~~>
            = WhenCond { "," WhenCond } "->" Expression [ ";" ] ;
// A branch condition: an inclusive range test (in / !in), a type test (is T / !is T,
// undecidable so it never matches and warns), or a value to compare with.
WhenCond    = WhenIn | WhenNotIn | WhenIs | WhenVal ;
WhenIs      <~~ push({isType: true, pos: up.pos}) ~~> = ( KwIs | KwNotIs ) Type ;
WhenIn      <~~ var h = pop(); push({lo: pop(), hi: h, neg: false}) ~~>
            = KwIn Expression ".." Expression ;
WhenNotIn   <~~ var h = pop(); push({lo: pop(), hi: h, neg: true}) ~~>
            = "!" KwIn Expression ".." Expression ;
WhenVal     <~~ push({v: pop()}) ~~>
            = Expression ;

OrExpr      <~~ push(makeOrAnd(takeAll(), true)) ~~>
            = AndExpr { "||" AndExpr } ;

AndExpr     <~~ push(makeOrAnd(takeAll(), false)) ~~>
            = EqExpr { "&&" EqExpr } ;

// Referential equality === / !== is lowered like structural == / != (in the untyped
// handle world both are identity for objects), so the operands still run and fold.
EqExpr      <~~ push(foldBinary(takeAll())) ~~>
            = RelExpr { EqOp RelExpr } ;
EqOp        = "===" <~~ push("==") ~~> | "!==" <~~ push("!=") ~~>
            | "==" <~~ push("==") ~~> | "!=" <~~ push("!=") ~~> ;

RelExpr     <~~ push(foldBinary(takeAll())) ~~>
            = TypeOp { ( "<=" | ">=" | "<" | ">" ) <~~ push(up.in) ~~> TypeOp } ;

// Type operators: x as T / x as? T lower to x (an unchecked identity cast in the
// untyped handle world); x is T / x !is T cannot be decided, so they are not
// implemented (makeIsCheck). The suffix is optional, so plain expressions are
// unaffected. Type is parsed and (apart from steering as/is) ignored.
TypeOp      <~~ push(applyTypeOp(takeAll())) ~~> = Elvis [ IsSfx | AsSfx ] ;
// A postfix `is T` must not fire when `->` immediately follows: there the `is T` leads
// the next `when` arm (is CellInfoGsm -> ...), and slurping it as a postfix would strand
// the arrow. `is T ->` occurs only at a when-arm boundary, so the guard is safe globally.
IsSfx       <~~ push({isType: true, pos: up.pos}) ~~> = ( KwIs | KwNotIs ) Type NotArrow ;
AsSfx       <~~ push({asType: true}) ~~> = ( KwAsSafe | KwAs ) Type ;
// A zero-width guard that fails when the next non-whitespace token is `->`.
NotArrow    = :script(~~
    (function() {
        var i = 0
        var cc = c.peek(i)
        while (cc === 32 || cc === 9 || cc === 10 || cc === 13) { i++; cc = c.peek(i) }
        return (cc === 45 && c.peek(i + 1) === 62)
            ? abnf.newToken("\x01arrow-follows", 0)
            : undefined
    })()
~~) ;

// a ?: b yields a unless it is null (the elvis operator; the right side only runs then).
Elvis       <~~ push(makeElvis(takeAll())) ~~>
            = InfixExpr { "?:" InfixExpr } ;

// A stdlib infix call - a to b (Pair), a and b / a shl b (bitwise) - binds tighter than
// elvis and looser than +/-, matching Kotlin. The operand types (Pair, bitwise Int) are
// outside the value subset, so the operands run and the result is reported as not
// implemented. Only these built-in infix names are recognised (not arbitrary user infix
// funs); the InfixOp token pushes nothing, so makeInfix just sees the operand thunks.
InfixExpr   <~~ push(makeInfix(takeAll(), up.pos)) ~~>
            = AddExpr { InfixOp AddExpr } ;
InfixOp     = ( "to" | "and" | "or" | "xor" | "shl" | "shr" | "ushr" ) KwEnd ;

AddExpr     <~~ push(foldBinary(takeAll())) ~~>
            = MulExpr { ( "+" | "-" ) <~~ push(up.in) ~~> MulExpr } ;

MulExpr     <~~ push(foldBinary(takeAll())) ~~>
            = UnaryExpr { ( "*" | "/" | "%" ) <~~ push(up.in) ~~> UnaryExpr } ;

UnaryExpr   = Neg | Not | PostfixExpr ;
Neg         <~~ push(makeNeg(pop())) ~~>
            = "-" UnaryExpr ;
Not         <~~ push(makeNot(pop())) ~~>
            = "!" UnaryExpr ;

PostfixExpr = IncDec | CallMember ;
IncDec      <~~ push(makeIncDec(takeAll())) ~~>
            = Target ( "++" | "--" ) <~~ push(up.in) ~~> ;

// Counter(5) is a constructor call, this.m() and list.add() are method calls,
// p.x is a property read, list[i] an indexed read. The ?. variants yield null
// (instead of failing) when their receiver is null. A method call may take a
// trailing lambda - list.map { it * 2 } - which becomes the last argument.
// A trailing "!!" (non-null assertion) is consumed and dropped: in the untyped handle
// world it is the identity, so x!! lowers exactly like x (and x!!.m() still chains).
CallMember  <~~ push(foldCallMember(takeAll())) ~~>
            = Primary { MethodSfx | SafeMethodSfx | FieldSfx | SafeFieldSfx | IndexSfx | "!!" } ;
MethodSfx   <~~ push({kind:"mcall", name: popName(), args: takeAll()}) ~~>
            = "." Id <~~ push({mname: up.in}) ~~> [ SkipAngle ] MArgs ;
SafeMethodSfx <~~ push({kind:"mcall", name: popName(), args: takeAll(), safe: true}) ~~>
            = "?." Id <~~ push({mname: up.in}) ~~> [ SkipAngle ] MArgs ;
FieldSfx    = "." Id <~~ push({kind:"field", name: up.in}) ~~> ;
SafeFieldSfx = "?." Id <~~ push({kind:"field", name: up.in, safe: true}) ~~> ;
IndexSfx    <~~ push({kind:"index", idx: pop()}) ~~>
            = "[" Expression "]" ;
MArgs       = "(" [ Expression { "," Expression } ] ")" [ Lambda ] | Lambda ;

// RawStr before Template (both open with "), FloatLit before IntLit (a plain integer
// falls through), AnonFun/CallableRef before Call/VarRef (they would otherwise eat the
// leading identifier). RawStr/FloatLit/CallableRef/AnonFun are recognised, not lowered.
Primary     = "(" Expression ")" | RawStr | Template | FloatLit | IntLit | True | False | Null | Lambda | AnonFun | CallableRef | ObjectExpr | ThisExpr | Call | VarRef ;

// An anonymous object expression - object [: Supertypes] { members } - in value
// position, e.g. passed as an argument (object : IHasComponent<Navigator> { ... }).
// Anonymous-class method dispatch is outside the subset, so the body is skipped and
// the expression is reported as not implemented (it yields undefined); it must come
// before Call/VarRef, which would otherwise read `object` as an identifier.
ObjectExpr  <~~ push(notImplExpr("object expression", up.pos)) ~~>
            = KwObject [ ":" SuperList ] SkipBlock ;

// A labelled receiver - this@Label (this@TriangleApplication). The subset has a single
// receiver, so it resolves to the nearest enclosing `this` exactly like a bare `this`;
// the label names an outer scope we do not model, so it is parsed and ignored. Bare
// `this` is a plain VarRef; this must precede Call/VarRef so `this` is not read as an
// identifier before the `@Label` is seen.
ThisExpr    <~~ push(makeVarRef("this")) ~~>
            = "this" KwEnd "@" Id ;

// A lambda: { it * 2 }, { x -> x * 2 }, { a: Int, b: Int -> a + b }. The body is
// one expression; without parameters the single argument is bound to 'it'.
Lambda      <~~ push(makeLambda(takeAll())) ~~>
            = "{" [ LambdaParams ] { LamStmt } "}" ;
// A lambda body is a sequence of statements whose value is its last expression
// (a single expression is the common case). Genuinely lowered, not notImpl.
// Keyword-led statements first; then any expression (if/when as an expression keep
// their value); then a bare if/when statement; then an empty statement.
LamStmt     = LamCtrl | LamExpr | LamIf | ";" ;
LamCtrl     <~~ push({stmt: pop()}) ~~>
            = ReturnAt | Return | BreakAt | Break | ContinueAt | Continue
            | [ LabelDef ] ( Decl | While | Do | For | TryStmt | Throw ) ;
LamExpr     <~~ push({expr: pop()}) ~~>
            = Expression [ ";" ] ;
LamIf       <~~ push({stmt: pop()}) ~~>
            = If ;
LambdaParams <~~ push({lparams: takeAll()}) ~~>
            = LParam { "," LParam } "->" ;
LParam      = Id <~~ push(up.in) ~~> [ ":" Type ] ;

// f(a, b): a top level function, a builtin, or a class constructor. A trailing lambda
// becomes the last argument (Kotlin): after a parenthesized list - f(a) { ... } - or on
// its own - f { ... } (the sole argument, e.g. module { single { ... } }). Either form
// works as a Primary anywhere, including as an argument to an outer call
// (modules(module(createdAtStart = true) { ... }, module { ... }, ...)).
Call        <~~ push(makeCall(takeAll())) ~~>
            = Id <~~ push(up.in) ~~> [ SkipAngle ] ( "(" [ Expression { "," Expression } ] ")" [ Lambda ] | Lambda ) ;

// String templates: "x=$x sum=${a + b}".
Template    <~~ push(makeTemplate(takeAll())) ~~>
            = '"' :whitespace() { TplExpr | TplVar | TplChunk } '"' :whitespace(Whitespace) ;
TplExpr     <~~ push({e: pop()}) ~~>
            = "${" :whitespace(Whitespace) Expression "}" ;
TplVar      = "$" TplName <~~ push({e: makeVarRef(up.in)}) ~~> ;
TplName     = ( "a"..."z" | "A"..."Z" | "_" ) { "a"..."z" | "A"..."Z" | "0"..."9" | "_" } ;
TplChunk    <~~ push({s: unescapeJs(up.in)}) ~~>
            = TplChar { TplChar } ;
TplChar     = TplEsc | TplPlain ;
TplEsc      = "\\" "\x20"..b"\x7e" ;
TplPlain    = "\x20"..."\x21" | "\x23"..."\x23" | "\x25"..."\x5b" | "\x5d"..."\x7e" | @"\t" | "\x7f"..."\U0010ffff" ;

Null        <~~ push(makeConst(null)) ~~>  = "null" KwEnd ;

VarRef      <~~ push(makeVarRef(up.in)) ~~>
            = Id ;

// ----- Widened surface: constructs accepted structurally but not lowered -----

// A balanced { ... } body consumed without interpreting it, so a construct can be
// ACCEPTED without being understood. Full string/char literals and ${...} templates
// are matched first, so braces inside them are never miscounted. No tags: nothing is
// pushed, so the consuming production is free to push its own placeholder.
SkipBlock   = "{" { SkipItem } "}" ;
SkipItem    = SkipStr | SkipChar | SkipBlock | SkipOther ;
SkipStr     = '"' :whitespace() { SkipTpl | SkipStrEsc | SkipStrChar } '"' :whitespace(Whitespace) ;
SkipTpl     = "${" :whitespace(Whitespace) { SkipItem } "}" ;
SkipStrEsc  = "\\" "\x00"..."\U0010ffff" ;
SkipStrChar = "\x00"..."\x21" | "\x23"..."\x5b" | "\x5d"..."\U0010ffff" ;
SkipChar    = "'" :whitespace() { SkipChEsc | SkipChChar } "'" :whitespace(Whitespace) ;
SkipChEsc   = "\\" "\x00"..."\U0010ffff" ;
SkipChChar  = "\x00"..."\x26" | "\x28"..."\x5b" | "\x5d"..."\U0010ffff" ;
SkipOther   = "\x00"..."\x21" | "\x23"..."\x26" | "\x28"..."\x7a" | "\x7c" | "\x7e"..."\U0010ffff" ;

// A balanced < ... > run (generic parameters / arguments), parsed and ignored.
SkipAngle   = "<" { SkipAngle | SkipAngleItem } ">" ;
SkipAngleItem = "\x00"..."\x3b" | "\x3d" | "\x3f"..."\U0010ffff" ;

// A balanced ( ... ) run (used to skip an anonymous function's parameter list, which
// may hold nested parens from function types). No tags: nothing is pushed.
SkipParen   = "(" { SkipParen | SkipParenItem } ")" ;
SkipParenItem = "\x00"..."\x27" | "\x2a"..."\U0010ffff" ;

// A statement label (loop@, outer@): parsed and ignored so the labelled statement
// still lowers. Labelled jumps carry a target we cannot resolve, so they notImpl.
LabelDef    = Id "@" ;
BreakAt     <~~ push(notImplStmt("labelled break", up.pos)) ~~>
            = KwBreak "@" Id [ ";" ] ;
ContinueAt  <~~ push(notImplStmt("labelled continue", up.pos)) ~~>
            = KwContinue "@" Id [ ";" ] ;
ReturnAt    <~~ push(notImplStmt("labelled return", up.pos)) ~~>
            = KwReturn "@" Id [ DiscardExpr ] [ ";" ] ;

// A floating-point literal (1.5, 2.0f, 1e9, 3.14E-2, digit-group underscores). The
// value model is 32-bit Int, so a float is recognised and reported as not implemented.
FloatLit    <~~ push(notImplExpr("floating-point literal", up.pos)) ~~>
            = ( "0" | "1"..."9" ) :whitespace() { "0"..."9" | "_" }
              ( "." "0"..."9" { "0"..."9" | "_" } [ FloatExp ] [ FloatSfx ]
              | FloatExp [ FloatSfx ]
              | FloatSfx ) :whitespace(Whitespace) ;
FloatExp    = ( "e" | "E" ) [ "+" | "-" ] "0"..."9" { "0"..."9" | "_" } ;
FloatSfx    = "f" | "F" ;

// A triple-quoted raw string: any content up to the closing """ (internal runs of one
// or two quotes are allowed). Recognised and reported as not implemented.
RawStr      <~~ push(notImplExpr("raw string literal", up.pos)) ~~>
            = '"""' :whitespace() { RawTwoQ | RawOneQ | RawPlain } '"""' :whitespace(Whitespace) ;
RawPlain    = "\x00"..."\x21" | "\x23"..."\U0010ffff" ;
RawOneQ     = '"' ( "\x00"..."\x21" | "\x23"..."\U0010ffff" ) ;
RawTwoQ     = '"' '"' ( "\x00"..."\x21" | "\x23"..."\U0010ffff" ) ;

// A callable reference (::fn, Type::member, pkg.Type::member). No first-class function
// values for methods here, so it is recognised and reported as not implemented.
CallableRef <~~ push(notImplExpr("callable reference", up.pos)) ~~>
            = [ Id { "." Id } ] "::" Id ;

// An anonymous function expression: fun(params): T { ... } or fun(params) = expr. The
// parameter list and body are skipped; recognised and reported as not implemented.
AnonFun     <~~ push(notImplExpr("anonymous function", up.pos)) ~~>
            = KwFun SkipParen [ ":" Type ] ( SkipBlock | "=" DiscardExpr ) ;

// A tag-less primary-constructor parameter list for headers we only skip.
CtorParamsSkip = "(" [ CParamSkip { "," CParamSkip } ] ")" ;
CParamSkip  = [ Modifiers ] [ ( "val" | "var" ) KwEnd ] Id ":" Type [ "=" DiscardExpr ] ;

// A supertype list (types with optional constructor-call args). No inheritance in
// the subset, so it is parsed and ignored; DiscardExpr drops the arg thunks.
SuperList   = SuperItem { "," SuperItem } ;
// A supertype is a class (optional constructor-call args), an interface, or an
// interface implemented by delegation (`: I by impl`). No inheritance in the
// subset, so all three parse and are ignored; the delegate expression is discarded.
SuperItem   = Type [ "(" [ DiscardExpr { "," DiscardExpr } ] ")" | KwBy DiscardExpr ] ;
DiscardExpr <~~ pop() ~~> = Expression ;

// Type declarations accepted structurally, then reported as not implemented (so a
// full Kotlin file parses; -warn-unsupported lets the rest compile). Body is skipped.
UnsupType   = Interface | ObjectDecl | EnumClass | AnnotationClass | TypeAlias ;
Interface   <~~ push(notImplStmt("interface", up.pos)) ~~>
            = KwInterface Id [ SkipAngle ] [ ":" SuperList ] SkipBlock ;
// object Name { ... } is a real singleton: its member body is lowered into a backing
// js_obj_new (properties initialized once at program start, methods reachable via the
// name and dispatched through js_mcall). A body outside the subset (e.g. a char
// literal) falls back to ObjectSkip (notImplemented), so the widened surface parses.
ObjectDecl  = ObjectReal | ObjectSkip ;
ObjectReal  <~~ push(makeObjectStmt(takeAll())) ~~>
            = KwObject Id <~~ push(up.in) ~~> [ ":" SuperList ] "{" { Member } "}" ;
ObjectSkip  <~~ push(notImplStmt("object declaration", up.pos)) ~~>
            = KwObject Id [ ":" SuperList ] SkipBlock ;
EnumClass   <~~ push(notImplStmt("enum class", up.pos)) ~~>
            = KwEnum KwClass Id [ SkipAngle ] [ CtorParamsSkip ] [ ":" SuperList ] SkipBlock ;
AnnotationClass <~~ push(notImplStmt("annotation class", up.pos)) ~~>
            = KwAnnotation KwClass Id [ SkipAngle ] [ CtorParamsSkip ] [ SkipBlock ] ;
TypeAlias   <~~ push(notImplStmt("typealias", up.pos)) ~~>
            = KwTypealias Id [ SkipAngle ] "=" Type [ ";" ] ;

// Member forms accepted structurally, then reported as not implemented. Each fires
// notImpl at compile time and pushes nothing, so makeClassStmt simply skips it.
InitBlock   <~~ notImpl("init block", up.pos) ~~>
            = KwInit SkipBlock ;
// companion object { ... } inside a class: its members are attached to the class
// descriptor (properties as fields, methods into a holder the descriptor's __class
// points at), so ClassName.member and ClassName.m() work. A body outside the subset
// falls back to CompanionSkip (notImplemented).
CompanionObject = CompanionReal | CompanionSkip ;
CompanionReal <~~ push({companion: takeAll()}) ~~>
            = KwCompanion KwObject [ Id ] [ ":" SuperList ] "{" { Member } "}" ;
CompanionSkip <~~ notImpl("companion object", up.pos) ~~>
            = KwCompanion KwObject [ Id ] [ ":" SuperList ] SkipBlock ;
SecondaryCtor <~~ notImpl("secondary constructor", up.pos) ~~>
            = KwConstructor "(" [ SParam { "," SParam } ] ")" [ ":" Id "(" [ DiscardExpr { "," DiscardExpr } ] ")" ] SkipBlock ;
SParam      = [ Modifiers ] Id ":" Type [ "=" DiscardExpr ] ;
PropAccessor <~~ notImpl("property accessor", up.pos) ~~>
            = ( "val" | "var" ) KwEnd Id [ ":" Type ] [ "=" DiscardExpr ] Accessor { Accessor } ;
Accessor    = ( KwGet | KwSet ) "(" [ Id [ ":" Type ] ] ")" [ ":" Type ] [ SkipBlock | "=" DiscardExpr ] [ ";" ] ;

// A destructuring declaration: accepted, reported as not implemented; the
// initializer still runs so its calls stay visible under -warn-unsupported.
Destructure <~~ push(makeDestructure(pop(), up.pos)) ~~>
            = ( "val" | "var" ) KwEnd "(" Id { "," Id } ")" [ ":" Type ] "=" Expression [ ";" ] ;

KwInterface = "interface" KwEnd ;
KwObject    = "object" KwEnd ;
KwEnum      = "enum" KwEnd ;
KwAnnotation = "annotation" KwEnd ;
KwCompanion = "companion" KwEnd ;
KwTypealias = "typealias" KwEnd ;
KwConstructor = "constructor" KwEnd ;
KwInit      = "init" KwEnd ;
KwGet       = "get" KwEnd ;
KwSet       = "set" KwEnd ;

KwFun       = "fun" KwEnd ;
KwImport    = "import" KwEnd ;
KwPackage   = "package" KwEnd ;
KwAs        = "as" KwEnd ;
KwAsSafe    = "as?" ;
KwTry       = "try" KwEnd ;
KwCatch     = "catch" KwEnd ;
KwFinally   = "finally" KwEnd ;
KwThrow     = "throw" KwEnd ;
KwIs        = "is" KwEnd ;
KwNotIs     = "!is" KwEnd ;
KwClass     = "class" KwEnd ;
KwIf        = "if" KwEnd ;
KwElse      = "else" KwEnd ;
KwWhile     = "while" KwEnd ;
KwDo        = "do" KwEnd ;
KwFor       = "for" KwEnd ;
KwIn        = "in" KwEnd ;
KwBy        = "by" KwEnd ;
KwWhen      = "when" KwEnd ;
KwReturn    = "return" KwEnd ;
KwBreak     = "break" KwEnd ;
KwContinue  = "continue" KwEnd ;
KwUntil     = "until" KwEnd ;
KwDownTo    = "downTo" KwEnd ;
KwStep      = "step" KwEnd ;

// ---


:startScript(~~

    // Shared emitter machinery (module, handle constants, externs, loopStack
    // protocol, expression/statement builders); see the `core` knobs below.
    include("lib/compile-core.js")

    var hidCount = 0     // Names hidden loop counters.
    var classNames = {}  // Known class names (constructor calls).

    // ----- Imports & errors -----
    function fail(msg) { println("kotlin compiler error: " + msg); exit(1) }

    // Import prefixes the runtime already satisfies: their symbols are provided
    // as builtins (abs/max/min, listOf, exitProcess, ...), so importing them is a
    // no-op. Anything else is an external library we cannot resolve.
    core.stdlibImports = ["kotlin", "kotlin.math", "kotlin.collections", "kotlin.system", "kotlin.text", "kotlin.ranges", "kotlin.sequences"]

    // stripWs, importResolvable, resolveImport and the notImpl / notImplStmt /
    // notImplExpr family now live in lib/compile-core.js (shared by all compiler
    // grammars). This grammar sets core.stdlibImports (above) and keeps the
    // Kotlin-specific builders below (they call notImpl from the lib).

    // try/catch/finally: each body becomes its own IR closure over the current scope;
    // js_try (jsrt.go) runs the try under a Go recover, routes a thrown value to the
    // catch closure (a one-parameter function bound to the catch name) and always runs
    // finally. The first catch clause wins. See the TryStmt LIMITATION note above.
    function makeCatch(items) {
        if (items.length > 1) { return {catchbody: items[1], catchname: items[0]} }
        return {catchbody: items[0], catchname: undefined}
    }
    function makeTry(items) {
        var tryT = anytype, catchT = anytype, catchName = anytype, finallyT = anytype
        for (var i = 0; i < items.length; i++) {
            if (items[i].trybody != undefined) { tryT = items[i].trybody }
            else if (items[i].catchbody != undefined) {
                if (catchT == undefined) { catchT = items[i].catchbody; catchName = items[i].catchname }
            }
            else if (items[i].finbody != undefined) { finallyT = items[i].finbody }
        }
        return function(b) {
            // The try and catch bodies are ctl closures (isCtl), so a return/break/
            // continue leaving them becomes a control signal that excDispatch re-issues.
            var tryClo = callExt(b, "js_closure", [handle(emitFunc([], tryT, false, true)), curScopeV])
            var catchClo = hUndef
            if (catchT != undefined) {
                var cn = (catchName != undefined) ? catchName : "__caught"
                catchClo = callExt(b, "js_closure", [handle(emitFunc([cn], catchT, false, true)), curScopeV])
            }
            var finClo = hUndef
            if (finallyT != undefined) {
                finClo = callExt(b, "js_closure", [handle(emitFunc([], finallyT, false, false)), curScopeV])
            }
            var ctl = callExt(b, "js_try", [tryClo, catchClo, finClo])
            return excDispatch(b, ctl)
        }
    }
    // throw e: evaluate e and raise it with js_throw (a Go panic the runtime unwinds).
    function makeThrow(e) {
        return function(b) {
            var r = e(b)
            callExt(r.b, "js_throw", [r.v])
            r.b.NewRet(hUndef) // Never reached: js_throw unwinds on the host side.
            return deadBlock()
        }
    }
    // x is T / x !is T: undecidable without runtime types; evaluate x, yield undefined.
    function makeIsCheck(operand, pos) { notImpl("is type check", pos); return function(b) { var r = operand(b); return {b: r.b, v: hUndef} } }
    // A curated stdlib infix call (a to b, a and b, ...). Recognised, not lowered: the
    // operands are emitted (side effects, nested warnings) and the value is undefined.
    // items holds only operand thunks (InfixOp pushes nothing).
    function makeInfix(items, pos) {
        if (items.length == 1) { return items[0] }
        notImpl("infix operator", pos)
        return function(b) { for (var i = 0; i < items.length; i++) { var r = items[i](b); b = r.b } return {b: b, v: hUndef} }
    }
    // TypeOp collects the operand thunk and (if present) an is/as marker at
    // production level (a sibling inline tag cannot pop the operand). as = identity.
    function applyTypeOp(items) {
        if (items.length == 1) { return items[0] }
        var operand = items[0]
        var m = items[1]
        if (m.asType) { return operand }
        return makeIsCheck(operand, m.pos)
    }

    // ----- Expression thunks: function(block) -> {b, v} -----

    // Implicit property access: locals first, then the properties of this.
    // Pops reversed: else, then, cond.
    function makeIfExpr(elseT, thenT, condT) {
        return function(b) {
            var r = condT(b)
            var thenB = curF.NewBlock("")
            var elseB = curF.NewBlock("")
            var mergeB = curF.NewBlock("")
            r.b.NewCondBr(truthy(r.b, r.v), thenB, elseB)
            var rt = thenT(thenB)
            rt.b.NewBr(mergeB)
            var re = elseT(elseB)
            re.b.NewBr(mergeB)
            var phi = mergeB.NewPhi([llvm.ir.NewIncoming(rt.v, rt.b), llvm.ir.NewIncoming(re.v, re.b)])
            return {b: mergeB, v: phi}
        }
    }
    function makeWhenArm(items) {
        var body = items.pop()
        return {conds: items, body: body}
    }
    // A when compiles to a test chain; the result travels in a hidden scope variable.
    // items = [thunk, thunk, ...]: a ?: b yields a unless it is null. Each step only
    // runs the right side in its own block when the left value was null (phi merge).
    function makeElvis(items) {
        if (items.length == 1) return items[0]
        return function(b) {
            var r = items[0](b)
            b = r.b
            var v = r.v
            for (var i = 1; i < items.length; i++) {
                var rightB = curF.NewBlock("")
                var mergeB = curF.NewBlock("")
                var isNull = callExt(b, "js_seq", [v, hNull])
                b.NewCondBr(truthy(b, isNull), rightB, mergeB)
                var r2 = items[i](rightB)
                r2.b.NewBr(mergeB)
                var phi = mergeB.NewPhi([llvm.ir.NewIncoming(v, b), llvm.ir.NewIncoming(r2.v, r2.b)])
                b = mergeB
                v = phi
            }
            return {b: b, v: v}
        }
    }
    function makeWhen(items) {
        var subj = null
        var subjName = null
        var els = null
        var arms = []
        for (var i = 0; i < items.length; i++) {
            if (items[i].subj != undefined) {
                subj = items[i].subj
                if (items[i].subjName != undefined) subjName = items[i].subjName
            }
            else if (items[i].els != undefined) els = items[i].els
            else arms.push(items[i])
        }
        // An `is T` / `!is T` arm is undecidable (no runtime types): warn once now; it
        // never matches at run time, so a following else arm handles it.
        for (var a1 = 0; a1 < arms.length; a1++) {
            for (var c1 = 0; c1 < arms[a1].conds.length; c1++) {
                if (arms[a1].conds[c1].isType) notImpl("is type check", arms[a1].conds[c1].pos)
            }
        }
        return function(b) {
            hidCount++
            var wName = "$w" + hidCount
            var rName = "$wr" + hidCount
            var saved = curScopeV
            curScopeV = callExt(b, "js_scope_new", [curScopeV])
            if (subj != null) {
                var rs = subj(b)
                b = rs.b
                callExt(b, "js_scope_decl", [curScopeV, emitStr(b, wName), rs.v])
                // when (val x = e): x is visible to every arm body.
                if (subjName != null) callExt(b, "js_scope_decl", [curScopeV, emitStr(b, subjName), rs.v])
            }
            callExt(b, "js_scope_decl", [curScopeV, emitStr(b, rName), hUndef])
            var endB = curF.NewBlock("")
            for (var a = 0; a < arms.length; a++) {
                var matchB = curF.NewBlock("")
                for (var v2 = 0; v2 < arms[a].conds.length; v2++) {
                    var cond = arms[a].conds[v2]
                    var nextB = curF.NewBlock("")
                    if (cond.isType) {
                        // undecidable type test: an always-false branch, so it never
                        // matches yet matchB keeps a predecessor (an orphan block with no
                        // predecessor is malformed IR and panics when the module prints).
                        b.NewCondBr(truthy(b, hFalse), matchB, nextB)
                    } else if (cond.v != undefined) {
                        var rv = cond.v(b)
                        b = rv.b
                        var condV
                        if (subj != null) {
                            var subjV = callExt(b, "js_scope_get", [curScopeV, emitStr(b, wName)])
                            condV = callExt(b, "js_seq", [subjV, rv.v])
                        } else {
                            condV = rv.v
                        }
                        b.NewCondBr(truthy(b, condV), matchB, nextB)
                    } else {
                        // in lo..hi (or !in): both bounds are evaluated, like in Kotlin.
                        var rl = cond.lo(b)
                        b = rl.b
                        var rh = cond.hi(b)
                        b = rh.b
                        var subjV2 = callExt(b, "js_scope_get", [curScopeV, emitStr(b, wName)])
                        var inRange = b.NewAnd(truthy(b, callExt(b, "js_ge", [subjV2, rl.v])),
                                               truthy(b, callExt(b, "js_le", [subjV2, rh.v])))
                        if (cond.neg) { b.NewCondBr(inRange, nextB, matchB) }
                        else          { b.NewCondBr(inRange, matchB, nextB) }
                    }
                    b = nextB
                }
                var rb = arms[a].body(matchB)
                callExt(rb.b, "js_scope_set", [curScopeV, emitStr(rb.b, rName), rb.v])
                rb.b.NewBr(endB)
            }
            if (els != null) {
                var re = els(b)
                b = re.b
                callExt(b, "js_scope_set", [curScopeV, emitStr(b, rName), re.v])
            }
            b.NewBr(endB)
            var out = callExt(endB, "js_scope_get", [curScopeV, emitStr(endB, rName)])
            curScopeV = saved
            return {b: endB, v: out}
        }
    }

    foldCallMember = function(items) {
        if (items.length == 1) return items[0]
        var primary = items[0]
        var suffixes = items.slice(1)
        function emitSuffix(b, cur, s) {
            if (s.kind == "mcall") {
                var ea = emitArgs(b, s.args)
                return {b: ea.b, v: callExt(ea.b, "js_mcall", [cur, emitStr(ea.b, s.name), ea.v])}
            }
            if (s.kind == "field") {
                var fname = s.name == "size" ? "length" : s.name
                return {b: b, v: callExt(b, "js_get", [cur, emitStr(b, fname)])}
            }
            var ir2 = s.idx(b)
            return {b: ir2.b, v: callExt(ir2.b, "js_get", [cur, ir2.v])}
        }
        return function(b) {
            var r = primary(b)
            b = r.b
            var cur = r.v
            for (var i = 0; i < suffixes.length; i++) {
                var s = suffixes[i]
                if (s.safe) {
                    // ?. : the suffix (and the arguments of a skipped call) only runs
                    // in its own block when the receiver is not null; a phi merges.
                    var doB = curF.NewBlock("")
                    var mergeB = curF.NewBlock("")
                    var isNull = callExt(b, "js_eq", [cur, hNull])
                    b.NewCondBr(truthy(b, isNull), mergeB, doB)
                    var rs = emitSuffix(doB, cur, s)
                    rs.b.NewBr(mergeB)
                    var phi = mergeB.NewPhi([llvm.ir.NewIncoming(hNull, b), llvm.ir.NewIncoming(rs.v, rs.b)])
                    b = mergeB
                    cur = phi
                } else {
                    var r2 = emitSuffix(b, cur, s)
                    b = r2.b
                    cur = r2.v
                }
            }
            return {b: b, v: cur}
        }
    }

    // Lambda items = [{lparams}?, {stmt}|{expr}...]. A lambda becomes an own IR
    // function closed over the current scope (js_closure); the body is a sequence of
    // statements and its value is the last expression (a trailing non-expression
    // yields Unit). Without a parameter list the single argument is bound to 'it'.
    function makeLambda(items) {
        var params = ["it"]
        var start = 0
        if (items.length > 0 && items[0] != undefined && items[0].lparams != undefined) {
            params = items[0].lparams
            start = 1
        }
        var body = items.slice(start)
        var bodyStmt = function(b) {
            var v = hUndef
            for (var k = 0; k < body.length; k++) {
                if (body[k].expr != undefined) {
                    var r = body[k].expr(b)
                    b = r.b
                    v = r.v
                } else {
                    b = body[k].stmt(b)
                    v = hUndef
                }
            }
            b.NewRet(v)
            return deadBlock()
        }
        return function(b) {
            var idx = emitFunc(params, bodyStmt, false)
            return {b: b, v: callExt(b, "js_closure", [handle(idx), curScopeV])}
        }
    }
    // A destructuring declaration is not lowered; evaluate the initializer (so its
    // calls stay visible) and bind nothing.
    function makeDestructure(init, pos) {
        notImpl("destructuring declaration", pos)
        return function(b) { var r = init(b); return r.b }
    }

    // f(args): a class constructor (known at compile time) or a function value.
    function makeCall(items) {
        var name = items[0]
        var args = items.slice(1)
        return function(b) {
            if (classNames[name] == 1) {
                var clsV = callExt(b, "js_scope_get", [curScopeV, emitStr(b, name)])
                var objV = callExt(b, "js_obj_new", [])
                callExt(b, "js_set", [objV, emitStr(b, "__class"), clsV])
                var argsV = callExt(b, "js_arr_new", [])
                callExt(b, "js_arr_push", [argsV, objV])
                for (var i = 0; i < args.length; i++) {
                    var r = args[i](b)
                    b = r.b
                    callExt(b, "js_arr_push", [argsV, r.v])
                }
                var ctorV = callExt(b, "js_get", [clsV, emitStr(b, "__ctor")])
                callExt(b, "js_call", [ctorV, hUndef, argsV])
                return {b: b, v: objV}
            }
            var fV = callExt(b, "js_kget", [curScopeV, emitStr(b, name)])
            var ea = emitArgs(b, args)
            b = ea.b
            return {b: b, v: callExt(b, "js_call", [fV, hUndef, ea.v])}
        }
    }

    function emitRefPath(b, ref) {
        var o = callExt(b, "js_kget", [curScopeV, emitStr(b, ref.name)])
        for (var i = 0; i < ref.path.length - 1; i++) {
            var s = ref.path[i]
            if (s.key != undefined) {
                o = callExt(b, "js_get", [o, emitStr(b, s.key)])
            } else {
                var r = s.idx(b)
                b = r.b
                o = callExt(b, "js_get", [o, r.v])
            }
        }
        var last = ref.path[ref.path.length - 1]
        if (last.key != undefined) return {b: b, obj: o, key: emitStr(b, last.key)}
        var kr = last.idx(b)
        return {b: kr.b, obj: o, key: kr.v}
    }
    function makeAssign(items) {
        var ref = items[0]
        var op = items[1]
        var valT = items[2]
        return function(b) {
            var r = valT(b)
            b = r.b
            var v = r.v
            if (ref.path.length == 0) {
                var nameV = emitStr(b, ref.name)
                if (op != "=") {
                    var old = callExt(b, "js_kget", [curScopeV, nameV])
                    v = emitBin(b, op, old, v)
                }
                callExt(b, "js_kset", [curScopeV, nameV, v])
            } else {
                var p = emitRefPath(b, ref)
                b = p.b
                if (op != "=") {
                    var oldM = callExt(b, "js_get", [p.obj, p.key])
                    v = emitBin(b, op, oldM, v)
                }
                callExt(b, "js_set", [p.obj, p.key, v])
            }
            return {b: b, v: v}
        }
    }
    function makeIncDec(items) {
        var ref = items[0]
        var extName = (items[1] == "++") ? "js_jadd" : "js_sub"
        return function(b) {
            var oneV = emitNum(b, 1)
            if (ref.path.length == 0) {
                var nameV = emitStr(b, ref.name)
                var oldV = callExt(b, "js_kget", [curScopeV, nameV])
                callExt(b, "js_kset", [curScopeV, nameV, intWrap(b, callExt(b, extName, [oldV, oneV]))])
                return {b: b, v: oldV}
            }
            var p = emitRefPath(b, ref)
            b = p.b
            var oldM = callExt(b, "js_get", [p.obj, p.key])
            callExt(b, "js_set", [p.obj, p.key, intWrap(b, callExt(b, extName, [oldM, oneV]))])
            return {b: b, v: oldM}
        }
    }

    // items = [{s: chunk} | {e: thunk}...] -> js_jadd fold starting from "".
    function makeTemplate(items) {
        return function(b) {
            var v = emitStr(b, "")
            for (var i = 0; i < items.length; i++) {
                var pv
                if (items[i].s != undefined) { pv = emitStr(b, items[i].s) }
                else {
                    var r = items[i].e(b)
                    b = r.b
                    pv = r.v
                }
                v = callExt(b, "js_jadd", [v, pv])
            }
            return {b: b, v: v}
        }
    }

    // ----- Statement thunks -----

    function makeDecl(items) {
        var name = items[0]
        var init = items[1]
        return function(b) {
            var r = init(b)
            b = r.b
            callExt(b, "js_scope_decl", [curScopeV, emitStr(b, name), r.v])
            return b
        }
    }
    function makeDo(condT, bodyT) {
        return function(b) {
            var bodyB = curF.NewBlock("")
            var condB = curF.NewBlock("")
            var exitB = curF.NewBlock("")
            b.NewBr(bodyB)
            loopStack.push({cont: condB, brk: exitB})
            bodyT(bodyB).NewBr(condB)
            loopStack.pop()
            var r = condT(condB)
            r.b.NewCondBr(truthy(r.b, r.v), bodyB, exitB)
            return exitB
        }
    }
    // items = [name, fromT, {rop}, toT, {step}?, bodyT]. The bounds and the step are
    // evaluated once (until subtracts one from the bound up front); downTo flips the
    // condition to >= and steps backwards. The loop variable drives the loop.
    function makeForRange(items) {
        var name = items[0]
        var fromT = items[1]
        var rop = items[2].rop
        var toT = items[3]
        var stepT = items.length > 5 ? items[4].step : null
        var bodyT = items[items.length - 1]
        return function(b) {
            hidCount++
            var tName = "$to" + hidCount
            var sName = "$st" + hidCount
            var saved = curScopeV
            curScopeV = callExt(b, "js_scope_new", [curScopeV])
            var rf = fromT(b)
            b = rf.b
            callExt(b, "js_scope_decl", [curScopeV, emitStr(b, name), rf.v])
            var rt = toT(b)
            b = rt.b
            var boundV = rt.v
            if (rop == "until") boundV = callExt(b, "js_sub", [boundV, emitNum(b, 1)])
            callExt(b, "js_scope_decl", [curScopeV, emitStr(b, tName), boundV])
            var stepV = emitNum(b, 1)
            if (stepT != null) {
                var rs = stepT(b)
                b = rs.b
                stepV = rs.v
            }
            callExt(b, "js_scope_decl", [curScopeV, emitStr(b, sName), stepV])
            var headB = curF.NewBlock("")
            var bodyB = curF.NewBlock("")
            var postB = curF.NewBlock("")
            var exitB = curF.NewBlock("")
            b.NewBr(headB)
            var iV = callExt(headB, "js_scope_get", [curScopeV, emitStr(headB, name)])
            var tV = callExt(headB, "js_scope_get", [curScopeV, emitStr(headB, tName)])
            var condExt = (rop == "downTo") ? "js_ge" : "js_le"
            headB.NewCondBr(truthy(headB, callExt(headB, condExt, [iV, tV])), bodyB, exitB)
            loopStack.push({cont: postB, brk: exitB})
            bodyT(bodyB).NewBr(postB)
            loopStack.pop()
            var iV2 = callExt(postB, "js_scope_get", [curScopeV, emitStr(postB, name)])
            var sV2 = callExt(postB, "js_scope_get", [curScopeV, emitStr(postB, sName)])
            var stepExt = (rop == "downTo") ? "js_sub" : "js_jadd"
            callExt(postB, "js_scope_set", [curScopeV, emitStr(postB, name), callExt(postB, stepExt, [iV2, sV2])])
            postB.NewBr(headB)
            curScopeV = saved
            return exitB
        }
    }
    function makeForList(bodyT, listT, name) {
        return function(b) {
            hidCount++
            var iName = "$i" + hidCount
            var aName = "$a" + hidCount
            var saved = curScopeV
            curScopeV = callExt(b, "js_scope_new", [curScopeV])
            var r = listT(b)
            b = r.b
            callExt(b, "js_scope_decl", [curScopeV, emitStr(b, aName), r.v])
            callExt(b, "js_scope_decl", [curScopeV, emitStr(b, iName), emitNum(b, 0)])
            callExt(b, "js_scope_decl", [curScopeV, emitStr(b, name), hUndef])
            var headB = curF.NewBlock("")
            var bodyB = curF.NewBlock("")
            var postB = curF.NewBlock("")
            var exitB = curF.NewBlock("")
            b.NewBr(headB)
            var iV = callExt(headB, "js_scope_get", [curScopeV, emitStr(headB, iName)])
            var aV = callExt(headB, "js_scope_get", [curScopeV, emitStr(headB, aName)])
            var lenV = callExt(headB, "js_get", [aV, emitStr(headB, "length")])
            headB.NewCondBr(truthy(headB, callExt(headB, "js_lt", [iV, lenV])), bodyB, exitB)
            var iV2 = callExt(bodyB, "js_scope_get", [curScopeV, emitStr(bodyB, iName)])
            var aV2 = callExt(bodyB, "js_scope_get", [curScopeV, emitStr(bodyB, aName)])
            callExt(bodyB, "js_scope_set", [curScopeV, emitStr(bodyB, name), callExt(bodyB, "js_get", [aV2, iV2])])
            loopStack.push({cont: postB, brk: exitB})
            bodyT(bodyB).NewBr(postB)
            loopStack.pop()
            var iV3 = callExt(postB, "js_scope_get", [curScopeV, emitStr(postB, iName)])
            callExt(postB, "js_scope_set", [curScopeV, emitStr(postB, iName), callExt(postB, "js_jadd", [iV3, emitNum(postB, 1)])])
            postB.NewBr(headB)
            curScopeV = saved
            return exitB
        }
    }
    function makeReturn(items) {
        var t = items.length > 0 ? items[0] : null
        return function(b) {
            var v = hUndef
            if (t != null) {
                var r = t(b)
                b = r.b
                v = r.v
            }
            return retStmt(b, v) // plain ret, or a control signal when leaving a try body
        }
    }
    function makeExprBody(t) {
        return function(b) {
            var r = t(b)
            r.b.NewRet(r.v)
            return deadBlock()
        }
    }

    // ----- Functions and classes -----

    // isCtl marks a try/catch body closure: a return/break/continue leaving it emits a
    // control signal instead of a ret/br (see compile-core inCtlBody / excDispatch).
    function emitFunc(params, body, isInstance, isCtl) {
        funcCount++
        var idx = funcCount
        var f = m.NewFunc("jsf_" + idx, i64, [llvm.ir.NewParam("env", i64), llvm.ir.NewParam("args", i64)])
        var savedF = curF
        var savedScope = curScopeV
        var savedLoops = loopStack
        var savedTag = curFTag
        curF = f
        curFTag = idx
        loopStack = []
        if (isCtl) { ctlEnter(idx) }
        var b = f.NewBlock("entry")
        curScopeV = callExt(b, "js_scope_new", [f.Params[0]])
        var off = 0
        if (isInstance) {
            callExt(b, "js_scope_decl", [curScopeV, emitStr(b, "this"), callExt(b, "js_arg", [f.Params[1], handle(0)])])
            off = 1
        }
        for (var i = 0; i < params.length; i++) {
            callExt(b, "js_scope_decl", [curScopeV, emitStr(b, params[i]),
                                         callExt(b, "js_arg", [f.Params[1], handle(i + off)])])
        }
        var endB = body(b)
        endB.NewRet(hUndef)
        if (isCtl) { ctlLeave() }
        curF = savedF
        curScopeV = savedScope
        loopStack = savedLoops
        curFTag = savedTag
        return idx
    }
    function makeFun(items) {
        return {name: items[0], params: items[1].params, body: items[2]}
    }
    function makeFunStmt(f) {
        return function(b) {
            var idx = emitFunc(f.params, f.body, false)
            callExt(b, "js_scope_decl", [curScopeV, emitStr(b, f.name),
                                         callExt(b, "js_closure", [handle(idx), curScopeV])])
            return b
        }
    }
    function makeCtorParam(items) {
        if (items.length > 1) return {name: items[1], prop: true}
        return {name: items[0], prop: false}
    }
    function makeProp(items) {
        return {prop: items[0], init: items[1]}
    }

    // The constructor: bind the primary constructor parameters, store the property
    // parameters on this, then run the property initializers.
    function emitCtor(cparams, props) {
        funcCount++
        var idx = funcCount
        var f = m.NewFunc("jsf_" + idx, i64, [llvm.ir.NewParam("env", i64), llvm.ir.NewParam("args", i64)])
        var savedF = curF
        var savedScope = curScopeV
        var savedLoops = loopStack
        curF = f
        loopStack = []
        var b = f.NewBlock("entry")
        curScopeV = callExt(b, "js_scope_new", [f.Params[0]])
        var thisV = callExt(b, "js_arg", [f.Params[1], handle(0)])
        callExt(b, "js_scope_decl", [curScopeV, emitStr(b, "this"), thisV])
        for (var k = 0; k < cparams.length; k++) {
            var pv = callExt(b, "js_arg", [f.Params[1], handle(k + 1)])
            callExt(b, "js_scope_decl", [curScopeV, emitStr(b, cparams[k].name), pv])
            if (cparams[k].prop) callExt(b, "js_set", [thisV, emitStr(b, cparams[k].name), pv])
        }
        for (var p = 0; p < props.length; p++) {
            var r = props[p].init(b)
            b = r.b
            callExt(b, "js_set", [thisV, emitStr(b, props[p].prop), r.v])
        }
        b.NewRet(hUndef)
        curF = savedF
        curScopeV = savedScope
        loopStack = savedLoops
        return idx
    }

    // items = [name, {cparams}?, ({prop}|{method})...]
    function makeClassStmt(items) {
        var name = items[0]
        var i = 1
        var cparams = []
        if (items.length > 1 && items[1] != undefined && items[1].cparams != undefined) {
            cparams = items[1].cparams
            i = 2
        }
        var props = []
        var methods = []
        var comp = null
        for (; i < items.length; i++) {
            if (items[i].companion != undefined) { comp = items[i].companion }
            else if (items[i].prop != undefined && items[i].init != undefined) props.push(items[i])
            else if (items[i].method != undefined) methods.push(items[i].method)
        }
        classNames[name] = 1
        return function(b) {
            var clsV = callExt(b, "js_obj_new", [])
            callExt(b, "js_set", [clsV, emitStr(b, "__isclass"), hTrue])
            callExt(b, "js_set", [clsV, emitStr(b, "__name"), emitStr(b, name)])
            callExt(b, "js_scope_decl", [curScopeV, emitStr(b, name), clsV])
            var ctorIdx = emitCtor(cparams, props)
            callExt(b, "js_set", [clsV, emitStr(b, "__ctor"), callExt(b, "js_closure", [handle(ctorIdx), curScopeV])])
            for (var k = 0; k < methods.length; k++) {
                var idx = emitFunc(methods[k].params, methods[k].body, true)
                callExt(b, "js_set", [clsV, emitStr(b, methods[k].name), callExt(b, "js_closure", [handle(idx), curScopeV])])
            }
            if (comp != null) { b = emitCompanion(b, clsV, comp) }
            return b
        }
    }

    // A companion object attaches its members to the class descriptor clsV: methods go
    // into a holder that clsV.__class points at (so ClassName.m() dispatches through
    // js_mcall, which prepends clsV as the receiver), properties become fields of clsV
    // (so ClassName.prop reads them). The property initializers see clsV as 'this'.
    function emitCompanion(b, clsV, comp) {
        var cprops = []
        var cmethods = []
        for (var i = 0; i < comp.length; i++) {
            if (comp[i].prop != undefined && comp[i].init != undefined) { cprops.push(comp[i]) }
            else if (comp[i].method != undefined) { cmethods.push(comp[i].method) }
        }
        if (cmethods.length > 0) {
            var holderV = callExt(b, "js_obj_new", [])
            for (var k = 0; k < cmethods.length; k++) {
                var idx = emitFunc(cmethods[k].params, cmethods[k].body, true)
                callExt(b, "js_set", [holderV, emitStr(b, cmethods[k].name), callExt(b, "js_closure", [handle(idx), curScopeV])])
            }
            callExt(b, "js_set", [clsV, emitStr(b, "__class"), holderV])
        }
        var saved = curScopeV
        curScopeV = callExt(b, "js_scope_new", [curScopeV])
        callExt(b, "js_scope_decl", [curScopeV, emitStr(b, "this"), clsV])
        for (var p = 0; p < cprops.length; p++) {
            var r = cprops[p].init(b)
            b = r.b
            callExt(b, "js_set", [clsV, emitStr(b, cprops[p].prop), r.v])
        }
        curScopeV = saved
        return b
    }

    // object Name { ... }: lower to a singleton backing object bound to the name at
    // program start - a descriptor holding the methods, an instance whose __class is
    // the descriptor and whose fields are the once initialized properties. The property
    // initializers see the instance as 'this' (implicit member access works); method
    // calls dispatch through js_mcall exactly like class instances.
    function makeObjectStmt(items) {
        var name = items[0]
        var props = []
        var methods = []
        for (var i = 1; i < items.length; i++) {
            if (items[i].prop != undefined && items[i].init != undefined) props.push(items[i])
            else if (items[i].method != undefined) methods.push(items[i].method)
        }
        return function(b) {
            var clsV = callExt(b, "js_obj_new", [])
            callExt(b, "js_set", [clsV, emitStr(b, "__isclass"), hTrue])
            callExt(b, "js_set", [clsV, emitStr(b, "__name"), emitStr(b, name)])
            for (var k = 0; k < methods.length; k++) {
                var idx = emitFunc(methods[k].params, methods[k].body, true)
                callExt(b, "js_set", [clsV, emitStr(b, methods[k].name), callExt(b, "js_closure", [handle(idx), curScopeV])])
            }
            var objV = callExt(b, "js_obj_new", [])
            callExt(b, "js_set", [objV, emitStr(b, "__class"), clsV])
            var saved = curScopeV
            curScopeV = callExt(b, "js_scope_new", [curScopeV])
            callExt(b, "js_scope_decl", [curScopeV, emitStr(b, "this"), objV])
            for (var p = 0; p < props.length; p++) {
                var r = props[p].init(b)
                b = r.b
                callExt(b, "js_set", [objV, emitStr(b, props[p].prop), r.v])
            }
            curScopeV = saved
            callExt(b, "js_scope_decl", [curScopeV, emitStr(b, name), objV])
            return b
        }
    }

    // The program: jsmain(env, args) declares the builtins, the top level, then calls main().
    function buildMain(items) {
        var f = m.NewFunc("jsmain", i64, [llvm.ir.NewParam("env", i64), llvm.ir.NewParam("args", i64)])
        curF = f
        var b = f.NewBlock("entry")
        curScopeV = callExt(b, "js_scope_new", [f.Params[0]])
        // listOf/mutableListOf: an IR function that simply returns its argument array.
        funcCount++
        var loIdx = funcCount
        var lo = m.NewFunc("jsf_" + loIdx, i64, [llvm.ir.NewParam("env", i64), llvm.ir.NewParam("args", i64)])
        var lob = lo.NewBlock("entry")
        lob.NewRet(lo.Params[1])
        var loV = callExt(b, "js_closure", [handle(loIdx), curScopeV])
        callExt(b, "js_scope_decl", [curScopeV, emitStr(b, "listOf"), loV])
        callExt(b, "js_scope_decl", [curScopeV, emitStr(b, "mutableListOf"), loV])
        // abs/max/min from Math, exitProcess from exit.
        var mathV = callExt(b, "js_scope_get", [curScopeV, emitStr(b, "Math")])
        callExt(b, "js_scope_decl", [curScopeV, emitStr(b, "abs"), callExt(b, "js_get", [mathV, emitStr(b, "abs")])])
        callExt(b, "js_scope_decl", [curScopeV, emitStr(b, "max"), callExt(b, "js_get", [mathV, emitStr(b, "max")])])
        callExt(b, "js_scope_decl", [curScopeV, emitStr(b, "min"), callExt(b, "js_get", [mathV, emitStr(b, "min")])])
        callExt(b, "js_scope_decl", [curScopeV, emitStr(b, "exitProcess"),
                                     callExt(b, "js_scope_get", [curScopeV, emitStr(b, "exit")])])
        b = makeSeq(items)(b)
        var mainV = callExt(b, "js_scope_get", [curScopeV, emitStr(b, "main")])
        var argsV = callExt(b, "js_arr_new", [])
        b.NewRet(callExt(b, "js_call", [mainV, hUndef, argsV]))
    }

    // ----- Core library config (see lib/compile-core.js) -----
    core.scopeGetExt = "js_kget" // Scope read with fallback to properties of this.

    c.compile(c.asg)

    println(m)

    var res = llvm.RunJS(m, "jsmain")
    println("kotlin compiler: main() returned " + res.Ret)
    exit(res.Ret)

~~) ;
