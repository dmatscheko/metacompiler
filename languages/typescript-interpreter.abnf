    // new C(args): build the instance, attach __class, run the constructor as
    // __ctor(instance, args...).
    function makeNew(items) {
        var clsName = items[0].cls
        var argThunks = items.slice(1)
        return function() {
            var cls = getVar(clsName)
            if (cls == undefined || !cls.__isclass) fail("unknown class: " + clsName)
            var obj = {}
            obj["__class"] = cls
            obj["__keys"] = []
