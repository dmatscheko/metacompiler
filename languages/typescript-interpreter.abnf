    // parent class. The defining class is captured at build time (curClassName).
    function makeSuperCall(name, argThunks) {
        var defName = curClassName
        if (name == "") {
            return function() {
                var self = getVar("this")
                var supCls = getVar(defName).__super
                if (supCls == undefined) fail("super() with no superclass")
                var argv = [self]
                for (var i = 0; i < argThunks.length; i++) argv.push(argThunks[i]())
                supCls.__ctor.apply(undefined, argv)
