            }
        }
        return function() {
            var self = getVar("this")
            var m = undefined
            for (var cl = getVar(defName).__super; cl != undefined && m == undefined; cl = cl.__super) m = cl[name]
            if (typeof m != "function") fail("unknown super method '" + name + "'")
            var argv = [self]
