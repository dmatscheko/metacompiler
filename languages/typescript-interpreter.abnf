    binOp = function(op, l, r) {
        if (op == "+") return l + r
        if (op == "-") return l - r
        if (op == "*") return l * r
        if (op == "/") return l / r
        if (op == "%") return l % r
        if (op == "==") return l == r
        if (op == "!=") return l != r
        if (op == "===") return l === r
        if (op == "!==") return l !== r
        if (op == "<")  return l < r
        if (op == ">")  return l > r
        if (op == "<=") return l <= r
        if (op == ">=") return l >= r
        if (op == "|")  return l | r
        if (op == "^")  return l ^ r
        if (op == "&")  return l & r
        if (op == "<<") return l << r
        if (op == ">>") return l >> r
        if (op == ">>>") return l >>> r
    }
    // items = [thunk, op, thunk, op, thunk, ...] -> one left folded thunk.
    // || and && evaluate lazily and return the deciding operand, like in JS.
    function makeOr(items) {
        if (items.length == 1) return items[0]
        return function() {
            var v = anytype // The operands may be of mixed types.
            v = items[0]()
            for (var i = 1; i < items.length; i++) {
                if (v) return v
                v = items[i]()
            }
            return v
        }
    }
    function makeAnd(items) {
        if (items.length == 1) return items[0]
        return function() {
            var v = anytype // The operands may be of mixed types.
            v = items[0]()
            for (var i = 1; i < items.length; i++) {
