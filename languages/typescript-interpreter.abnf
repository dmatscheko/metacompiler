    // A binary/relational operator with no runtime primitive (??, **, instanceof, in):
    // with no operator present it is the identity; otherwise it warns and keeps the left
    // operand as the value, so the surrounding expression still produces something.
    function makeNiFold(items, pos, what) {
        if (items.length == 1) { return items[0] }
        notImpl(what, pos)
        return items[0]
    }
