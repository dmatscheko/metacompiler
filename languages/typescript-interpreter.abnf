    // makeEnum turns the member list into {name: value} pairs at parse time (the same
    // computation runs in the compiler), then binds an object of those pairs to the
    // enum name so that Color.Red reads the value.
    function makeEnum(items) {
        var ename = items[0].enumName
        var members = items.slice(1)
        var pairs = []
        var next = 0
        for (var i = 0; i < members.length; i++) {
