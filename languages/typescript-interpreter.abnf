    // Target items = [nameString, suffix marker...] -> reference descriptor.
    // Walks a target path (members and calls) up to the last element and returns
    // the assignable place {obj, key}. The last element must be a member.
    resolveRef = function(ref) {
        var cur = anytype     // The walked values and receivers
        var curThis = anytype // may be of mixed types.
        cur = getVar(ref.name)
        for (var i = 0; i < ref.path.length - 1; i++) {
            var s = ref.path[i]
            if (s.kind == "member") {
                curThis = cur
                cur = getMember(cur, s.key())
            } else {
                var argv = []
                for (var j = 0; j < s.args.length; j++) argv.push(s.args[j]())
                if (typeof cur != "function") fail("call of a non function value: " + cur)
                cur = cur.apply(curThis, argv)
                curThis = undefined
            }
        }
        var last = ref.path[ref.path.length - 1]
        if (last.kind != "member") fail("assignment target must end in a member")
        if (cur == undefined) fail("member assignment on " + cur)
        return {obj: cur, key: last.key()}
