        var cases = []
        var cur = null
        for (var i = 1; i < items.length; i++) {
            var p = items[i]
            if (p != undefined && (p.casev != undefined || p.isdflt != undefined)) {
                cur = {isDefault: p.isdflt != undefined, v: p.casev, body: []}
                cases.push(cur)
            } else {
                if (cur == null) fail("switch: a statement before the first case label")
                cur.body.push(p)
            }
        }
        return function() {
            var v = subj()
            var start = -1
            var dflt = -1
            for (var i = 0; i < cases.length; i++) {
                if (cases[i].isDefault) { if (dflt < 0) dflt = i; continue }
                if (start < 0 && cases[i].v() === v) { start = i }
