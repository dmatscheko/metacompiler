    applyOp = function(op, a, b) {
        if (op == "+=") return a + b
        if (op == "-=") return a - b
        if (op == "*=") return a * b
        if (op == "/=") return a / b
        if (op == "%=") return a % b
        if (op == "<<=") return a << b
        if (op == ">>=") return a >> b
        if (op == ">>>=") return a >>> b
        if (op == "&=") return a & b
        if (op == "^=") return a ^ b
        if (op == "|=") return a | b
