:title("Dart to LLVM IR compiler") ;
:description("Compiles a practical subset of Dart to an LLVM IR module and runs it with the
built-in IR interpreter.

The language is exactly the one of dart-interpreter.abnf; see there for a description. It
has top level and nested functions (block and arrow bodies), typed declarations whose type
is erased, var/final/const, classes with fields, methods, constructors and
field-initialising formals, construction with or without new, this.field and implicit field
access inside methods, List and Map literals, index/member access, string interpolation
($name and ${expr}) inside single and double quotes, if/else, while, C-style for and
for (x in coll), closures with real captured scopes, print(...), + - * / ~/ % , comparisons,
&& || ! and the ternary operator.

The emitted IR is handle-threaded code: every dynamic value is an i64 handle into the value
table of the shared Go side runtime (abnf/jsrt.go), and every operation with real semantics
is a call to one of its js_* externals (js_jadd, js_get, js_call, js_mcall, js_pyget, ...).
Only the control flow is real IR. Variables live in scope-chain objects (js_scope_* and the
this-aware js_kget/js_kset); a function/closure becomes an own IR function jsf_N(env, args)
plus a js_closure at the site of its creation. Classes become descriptor objects: an
instance is a js_obj_new carrying a __class handle, methods are closures on the descriptor,
and construction runs the __ctor closure with the fresh instance prepended, so a member call
dispatches through js_mcall (Go memberCall) exactly like the interpreter.

The top level becomes dartmain(env, args), which runs the program declarations and then
calls int main(); its return value is the exit code of the metacompiler run, so the test
programs are self checking (0 on success). The same subset is interpreted directly by
dart-interpreter.abnf. Constructs outside the subset (mixins/inheritance, async/await, named
constructors, the null-assertion !) are accepted structurally and reported as not
implemented under -warn-unsupported; the nullable type marker ? is erased.") ;


// --- main rules

// Shared token productions (languages/lib).
:include("lib/cstyle-comments.abnf") ;
:include("lib/ident.abnf") ;
:include("lib/numbers.abnf") ;
:include("lib/bools.abnf") ;

:startRule(Program) ;
:whitespace(Whitespace) ;

// The merged statement thunks of the top level become dartmain(env, args) in the module.
// Leading directives (import / export / part / library) are accepted and not implemented.
Program     <~~ buildMain(takeAll()) ~~>
            = { Directive } { Statement } ;

// Library directives: accepted, not implemented (there is no module system). Each pushes
// nothing, so only the statement thunks reach buildMain.
Directive   = ImportD | ExportD | PartD | LibraryD ;
ImportD     <~~ notImpl("import directive", up.pos) ~~>
            = KwImport UriStr [ KwAs Id ] { Combinator } [ KwIf SkipParen UriStr ] ";" ;
ExportD     <~~ notImpl("export directive", up.pos) ~~>
            = KwExport UriStr { Combinator } ";" ;
PartD       <~~ notImpl("part directive", up.pos) ~~>
            = KwPart [ KwOf ] ( UriStr | QualName ) ";" ;
LibraryD    <~~ notImpl("library directive", up.pos) ~~>
            = KwLibrary [ QualName ] ";" ;
Combinator  = ( KwShow | KwHide ) Id { "," Id } ;
UriStr      = SkipSqStr | SkipDqStr ;
QualName    = Id { "." Id } ;

// Every statement production pushes exactly one thunk: function(block) -> block.
// The keyword-led statements come first: otherwise 'return x;' would parse as a variable
// declaration of a variable x with the (identifier-shaped) type 'return'.
Statement   <~~ push(stmtPos(pop())) ~~>
            = [ Annotations ] StatementBody ;
StatementBody = Block | ClassDecl | EnumDecl | MixinDecl | ExtensionDecl | TypedefDecl
            | If | Switch | While | DoWhile | For | TryStmt | Return
            | Break | Continue | Rethrow | Assert | FuncDecl | VarDecl | LabeledStmt
            | Empty | ExprStmt ;

// Metadata annotations (@Foo, @Foo.bar, @Foo(args)) are parsed and erased, like in Java.
Annotations = Annotation { Annotation } ;
Annotation  = "@" Id { "." Id } [ SkipParen ] ;

// Top-level declarations accepted structurally and reported as not implemented; their
// bodies are matched with SkipBlock so a full file parses.
EnumDecl    <~~ push(notImplStmt("enum declaration", up.pos)) ~~>
            = KwEnum Id [ SkipAngle ] [ KwWith Type { "," Type } ] [ KwImplements Type { "," Type } ] SkipBlock ;
MixinDecl   <~~ push(notImplStmt("mixin declaration", up.pos)) ~~>
            = KwMixin [ KwClass ] Id [ SkipAngle ] [ KwOn Type { "," Type } ] [ KwImplements Type { "," Type } ] SkipBlock ;
ExtensionDecl <~~ push(notImplStmt("extension declaration", up.pos)) ~~>
            = KwExtension [ KwType ] [ Id ] [ SkipAngle ] KwOn Type SkipBlock ;
TypedefDecl <~~ push(notImplStmt("typedef declaration", up.pos)) ~~>
            = KwTypedef ( TypedefNew | TypedefOld ) ;
TypedefNew  = Id [ SkipAngle ] "=" Type [ KwFunction [ SkipAngle ] SkipParen ] [ "?" ] ";" ;
TypedefOld  = Type Id [ SkipAngle ] SkipParen ";" ;

Block       <~~ push(makeBlockStmt(takeAll())) ~~>
            = "{" { Statement } "}" ;

// class Name { fields; constructors; methods }. Class modifiers (abstract, base, final,
// interface, sealed, mixin) are parsed and erased so the class still compiles.
// Inheritance/mixins are not implemented.
ClassDecl   <~~ push(makeClassStmt(takeAll())) ~~>
            = [ ClassMods ] KwClass Id <~~ push({cname: up.in}); curClassName = up.in ~~>
              [ SkipAngle ] [ SuperClause ] "{" { Member } "}" ;
ClassMods   = { ClassMod } ;
ClassMod    = ( "abstract" | "base" | "final" | "interface" | "sealed" | "mixin" ) KwEnd ;
SuperClause <~~ notImpl("inheritance/mixins", up.pos) ~~>
            = SuperPart { SuperPart } ;
SuperPart   = ( KwExtends | KwWith | KwImplements ) Type { "," Type } ;

// A member is a field, a method (Type? name(params) body) or a constructor (name == the
// class name). NamedCtorMember is a named constructor - accepted, not implemented.
// Metadata annotations and member modifiers (static/covariant/external/abstract) are
// parsed and erased; getters, setters, operators and factory constructors are accepted
// and not implemented.
Member      = [ Annotations ] [ MemberMods ] MemberCore ;
MemberCore  = GetterMember | SetterMember | OperatorMember | FactoryMember
            | NamedCtorMember | PlainFnMember | TypedFnMember | FieldMember ;
MemberMods  = { MemberMod } ;
MemberMod   = ( "static" | "covariant" | "external" | "abstract" ) KwEnd ;
// The bare (no return type) form is tried first: an optional leading Type would greedily
// consume the get/set/operator keyword itself (it is a valid identifier) and then commit.
GetterMember   <~~ takeAll(); push({skip: notImpl("getter", up.pos)}) ~~>
            = KwGet Id MemberBody | Type KwGet Id MemberBody ;
SetterMember   <~~ takeAll(); push({skip: notImpl("setter", up.pos)}) ~~>
            = KwSet Id ParamList MemberBody | Type KwSet Id ParamList MemberBody ;
OperatorMember <~~ takeAll(); push({skip: notImpl("operator overload", up.pos)}) ~~>
            = KwOperator OverloadableOp ParamList MemberBody | Type KwOperator OverloadableOp ParamList MemberBody ;
FactoryMember  <~~ takeAll(); push({skip: notImpl("factory constructor", up.pos)}) ~~>
            = [ KwConst ] KwFactory Id [ "." Id ] ParamList ( MemberBody | "=" Type [ "." Id ] ";" ) ;
OverloadableOp = "[]=" | "[]" | "==" | "<=" | ">=" | ">>>" | "<<" | ">>" | "~/"
            | "+" | "-" | "*" | "/" | "%" | "<" | ">" | "&" | "|" | "^" | "~" ;
NamedCtorMember <~~ takeAll(); push({skip: notImpl("named constructor", up.pos)}) ~~>
            = Id "." Id ParamList [ CtorInit ] MemberBody ;
PlainFnMember <~~ push(makeMember(false, takeAll())) ~~>
            = MName ParamList [ CtorInit ] MemberBody ;
TypedFnMember <~~ push(makeMember(true, takeAll())) ~~>
            = Type MName ParamList MemberBody ;
MName       <~~ push({mn: up.in}) ~~> = Id ;

// A constructor initializer list ( : super(...), : this.x = e ) is accepted and reported
// as not implemented; the super/redirect chain and field initializers are dropped.
CtorInit    <~~ takeAll(); notImpl("constructor initializer list", up.pos) ~~>
            = ":" InitItem { "," InitItem } ;
InitItem    = SuperOrRedirect | FieldInit ;
SuperOrRedirect = ( "super" | "this" ) KwEnd [ "." Id ] "(" [ AssignExpr { "," AssignExpr } ] ")" ;
FieldInit   = [ "this" KwEnd "." ] Id "=" AssignExpr ;

MemberBody  = [ AsyncMod ] MemberBodyKind ;
MemberBodyKind = MBlock | MArrow | MSemi ;
MBlock      <~~ push({body: pop()}) ~~>  = Block ;
MArrow      <~~ push({ebody: pop()}) ~~> = "=>" Expression ";" ;
MSemi       <~~ push({none: true}) ~~>   = ";" ;
AsyncMod    <~~ notImpl("async function", up.pos) ~~> = ( "async" | "sync" ) KwEnd [ "*" ] ;

// Fields: (Type | var | final [Type]) name [= init] { , name [= init] } ; - separate
// complete alternatives so the leading-type / no-type cases never get stuck in an optional.
FieldMember = FieldVar | FieldFinalTyped | FieldFinal | FieldConstTyped | FieldConst | FieldLate | FieldTyped ;
FieldVar        = KwVar        FieldList ";" ;
FieldFinalTyped = KwFinal Type FieldList ";" ;
FieldFinal      = KwFinal      FieldList ";" ;
FieldConstTyped = KwConst Type FieldList ";" ;
FieldConst      = KwConst      FieldList ";" ;
FieldLate       = KwLate ( KwFinal Type | KwFinal | KwVar | Type ) FieldList ";" ;
FieldTyped      = Type         FieldList ";" ;
FieldList   = FieldDecl { "," FieldDecl } ;
FieldDecl   <~~ push(makeFieldDecl(takeAll())) ~~>
            = Id <~~ push({fn: up.in}) ~~> [ "=" AssignExpr ] ;

// Function declarations (top level and nested). Two alternatives so the optional return
// type does not get stuck when it is absent.
FuncDecl    = FuncTyped | FuncPlain ;
FuncTyped   <~~ push(makeFuncDecl(takeAll())) ~~>
            = Type FName ParamList FnBody ;
FuncPlain   <~~ push(makeFuncDecl(takeAll())) ~~>
            = FName ParamList FnBody ;
FName       <~~ push({fname: up.in}) ~~> = Id ;
FnBody      = [ AsyncMod ] FnBodyKind ;
FnBodyKind  = FBlock | FArrow ;
FBlock      <~~ push({body: pop()}) ~~>  = Block ;
FArrow      <~~ push({ebody: pop()}) ~~> = "=>" Expression ";" ;

// A parameter list. this.x is a field-initialising formal; a bare or typed name is a plain
// parameter. TypedParam is tried before PlainParam (both are separate alternatives).
ParamList   <~~ push({params: takeAll()}) ~~>
            = "(" [ ParamItems ] ")" ;
ParamItems  = NamedGroup | Param { "," Param } [ "," NamedGroup ] [ "," ] ;
Param       = ThisParam | TypedParam | PlainParam ;
ThisParam   <~~ push({thisf: popName()}) ~~>
            = "this" KwEnd "." Id <~~ push({mname: up.in}) ~~> ;
TypedParam  <~~ push({pname: popName()}) ~~>
            = Type Id <~~ push({mname: up.in}) ~~> ;
PlainParam  <~~ push({pname: up.in}) ~~> = Id ;

// Named (curly) parameters: foo({int a = 1, this.x = 0}). Optional, each with a default;
// unsupplied ones fall back to the default, else null. Marked named:true in the descriptor.
NamedGroup  = "{" NamedParam { "," NamedParam } [ "," ] "}" ;
NamedParam  = NamedThisParam | NamedTypedParam | NamedPlainParam ;
NamedThisParam  <~~ push(makeNamedParam(true, takeAll())) ~~>
            = "this" KwEnd "." Id <~~ push({mname: up.in}) ~~> [ "=" AssignExpr ] ;
NamedTypedParam <~~ push(makeNamedParam(false, takeAll())) ~~>
            = Type Id <~~ push({mname: up.in}) ~~> [ "=" AssignExpr ] ;
NamedPlainParam <~~ push(makeNamedParam(false, takeAll())) ~~>
            = Id <~~ push({mname: up.in}) ~~> [ "=" AssignExpr ] ;

// A type: name with optional generics <...> (skipped), dotted names and a nullable ? marker,
// all parsed and erased.
Type        = Id [ SkipAngle ] { "." Id [ SkipAngle ] } [ "?" ] ;

// Local variable declarations. Separate complete alternatives avoid the optional-type trap.
// A 'late' modifier is accepted and reported as not implemented (the initialiser still runs).
VarDecl     = VarLate | VarKwDecl | VarFinalTyped | VarFinal | VarConstTyped | VarConst | VarTyped ;
VarLate     <~~ notImpl("late variable", up.pos) ~~>
            = KwLate ( KwFinal Type | KwFinal | Type ) DeclTail ;
VarKwDecl     = KwVar         DeclTail ;
VarFinalTyped = KwFinal Type  DeclTail ;
VarFinal      = KwFinal       DeclTail ;
VarConstTyped = KwConst Type  DeclTail ;
VarConst      = KwConst       DeclTail ;
VarTyped      = Type          DeclTail ;
DeclTail    <~~ push(makeSeq(takeAll())) ~~>
            = Declarator { "," Declarator } ";" ;
Declarator  <~~ push(makeDecl(takeAll())) ~~>
            = Id <~~ push(up.in) ~~> [ "=" AssignExpr ] ;

If          <~~ push(makeIf(takeAll())) ~~>
            = KwIf "(" Expression ")" Statement [ KwElse Statement ] ;

While       <~~ push(makeWhile(pop(), pop())) ~~>
            = KwWhile "(" Expression ")" Statement ;

// for (x in coll) is tried before the C-style for; both start with 'for ('.
For         = ForInTyped | ForInBare | ForCStyle ;
ForInTyped  <~~ push(makeForIn(takeAll())) ~~>
            = KwFor "(" ForInLead Id <~~ push(up.in) ~~> KwIn Expression ")" Statement ;
ForInBare   <~~ push(makeForIn(takeAll())) ~~>
            = KwFor "(" Id <~~ push(up.in) ~~> KwIn Expression ")" Statement ;
ForInLead   = KwVar | KwFinal | Type ;
ForCStyle   <~~ push(makeFor(takeAll())) ~~>
            = KwFor "(" [ ForInit ] ";" [ ForCond ] ";" [ ForPost ] ")" Statement ;
ForInit     <~~ push({k:"init", t:pop()}) ~~> = ForVar | ForExpr ;
ForVar      <~~ push(makeSeq(takeAll())) ~~> = ForVarHead Declarator { "," Declarator } ;
ForVarHead  = KwVar | KwFinal Type | KwFinal | Type ;
ForExpr     <~~ push(exprToStmt(pop())) ~~> = Expression ;
ForCond     <~~ push({k:"cond", t:pop()}) ~~> = Expression ;
ForPost     <~~ push({k:"post", t:exprToStmt(pop())}) ~~> = Expression ;

Return      <~~ push(makeReturn(takeAll())) ~~>
            = KwReturn [ Expression ] ";" ;
// break / continue accept an optional target label (the labeled loop is not implemented,
// so the label warns and the break/continue still targets the innermost loop).
Break       <~~ push(makeBreak()) ~~>    = KwBreak [ LoopLabel ] ";" ;
Continue    <~~ push(makeContinue()) ~~> = KwContinue [ LoopLabel ] ";" ;
LoopLabel   <~~ notImpl("labeled break/continue", up.pos) ~~> = Id ;
Empty       <~~ push(function(b) { return b }) ~~>  = ";" ;

// switch and do-while: accepted, not implemented. Their bodies are matched with the
// balanced skips (SkipParen / SkipBlock) so the whole construct parses; do-while
// evaluates nothing (takeAll drops the child thunks).
Switch      <~~ push(notImplStmt("switch statement", up.pos)) ~~>
            = KwSwitch SkipParen SkipBlock ;
DoWhile     <~~ takeAll(); push(notImplStmt("do-while loop", up.pos)) ~~>
            = KwDo Statement KwWhile "(" Expression ")" ";" ;

// try/catch/finally and throw are implemented: throw calls js_throw (a Go panic the
// runtime unwinds), each try/catch/finally body compiles to its own closure handed to
// js_try (see makeTry). The leftmost catch clause wins (exception types are parsed but
// not discriminated); a return/break/continue leaving a try or catch body becomes a
// control signal that excDispatch re-issues in the enclosing frame (compile-core). Each
// part is marked so makeTry can tell them apart.
TryStmt     <~~ push(makeTry(takeAll())) ~~>
            = KwTry TryBody { CatchClause } [ FinallyClause ] ;
TryBody     <~~ push({trybody: pop()}) ~~>
            = Block ;
FinallyClause <~~ push({finbody: pop()}) ~~>
            = KwFinally Block ;
// Dart catch forms: `on Type catch (e)`, `on Type catch (e, st)`, `on Type { }` (no
// binding), `catch (e)`, `catch (e, st)`. The `on Type` type is parsed and discarded; the
// first binder is the caught value's name (pushed), the optional second binder (the stack
// trace) is parsed and dropped. makeCatch reads [name?, blockThunk].
CatchClause <~~ push(makeCatch(takeAll())) ~~>
            = ( KwOn Type [ KwCatch "(" Id <~~ push(up.in) ~~> [ "," Id ] ")" ]
              | KwCatch "(" Id <~~ push(up.in) ~~> [ "," Id ] ")" ) Block ;
// rethrow re-raises inside a catch. There is no current-exception register, so it is
// approximated as js_throw of undefined.
Rethrow     <~~ push(makeRethrow()) ~~>
            = KwRethrow ";" ;
Assert      <~~ takeAll(); push(notImplStmt("assert statement", up.pos)) ~~>
            = KwAssert "(" Expression [ "," Expression ] [ "," ] ")" ";" ;
// A labeled statement (label: stmt). The label targeting is not implemented, but the
// labeled statement still runs.
LabeledStmt <~~ notImpl("statement label", up.pos) ~~>
            = Id ":" Statement ;

ExprStmt    <~~ push(exprToStmt(pop())) ~~>
            = Expression ";" ;

// Every expression production pushes exactly one thunk: function(block) -> {b, v}.
Expression  = AssignExpr ;
AssignExpr  = ThrowExpr | Assignment | Cascade ;
// throw is an expression in Dart (=> throw e, cond ? a : throw e). Accepted, not
// implemented; the operand is still evaluated so its calls stay visible.
ThrowExpr   <~~ push(makeThrow(pop(), up.pos)) ~~>
            = KwThrow AssignExpr ;
Assignment  <~~ push(makeAssign(takeAll(), up.pos)) ~~>
            = Target ( "+=" | "-=" | "*=" | "/=" | "%=" | "??=" | "=" ) <~~ push(up.in) ~~> AssignExpr ;

// Cascade: target..m(args)..field = v . Every section acts on the one target and the
// whole expression evaluates to that target. With no sections it is just the CondExpr,
// so ordinary expressions stay unaffected.
Cascade     <~~ push(makeCascade(takeAll())) ~~>
            = CondExpr { CascadeSection } ;
CascadeSection = CascadeCall | CascadeSet ;
CascadeCall <~~ push({kind: "ccall", name: popName(), args: takeAll()}) ~~>
            = ".." Id <~~ push({mname: up.in}) ~~> "(" [ Arg { "," Arg } [ "," ] ] ")" ;
CascadeSet  <~~ var cv = pop(); var cn = pop(); push({kind: "cset", name: cn.mname, val: cv}) ~~>
            = ".." Id <~~ push({mname: up.in}) ~~> "=" CondExpr ;
Target      <~~ push(makeTargetRef(takeAll())) ~~>
            = Id <~~ push(up.in) ~~> { DotTarget | IndexTarget } ;
DotTarget   = "." Id <~~ push({key: up.in}) ~~> ;
IndexTarget <~~ push({idx: pop()}) ~~> = "[" Expression "]" ;

CondExpr    <~~ push(makeCond(takeAll())) ~~>
            = IfNullExpr [ "?" AssignExpr ":" AssignExpr ] ;
// a ?? b : if-null. Accepted, not implemented; both operands are evaluated (calls
// stay visible) and the first is returned. With no "??" it passes the operand through.
IfNullExpr  <~~ push(makeIfNull(takeAll())) ~~>
            = OrExpr { "??" <~~ push({ifnull: true, pos: up.pos}) ~~> OrExpr } ;
OrExpr      <~~ push(makeOrAnd(takeAll(), true)) ~~>
            = AndExpr { "||" AndExpr } ;
AndExpr     <~~ push(makeOrAnd(takeAll(), false)) ~~>
            = EqExpr { "&&" EqExpr } ;
EqExpr      <~~ push(foldBinary(takeAll())) ~~>
            = RelExpr { ( "==" | "!=" ) <~~ push(up.in) ~~> RelExpr } ;
RelExpr     <~~ push(foldBinary(takeAll())) ~~>
            = TypeTestExpr { ( "<=" | ">=" | "<" | ">" ) <~~ push(up.in) ~~> TypeTestExpr } ;
// is / is! / as type tests, at relational precedence. 'as' is compiled as an identity
// cast (operand evaluated, type erased); 'is' / 'is!' are accepted and not implemented.
TypeTestExpr <~~ push(makeTypeTest(takeAll())) ~~>
            = BitOrExpr [ TypeTestOp Type ] ;
TypeTestOp  = IsOp | AsOp ;
IsOp        <~~ push({tt: "is", pos: up.pos}) ~~> = KwIs [ "!" ] ;
AsOp        <~~ push({tt: "as", pos: up.pos}) ~~> = KwAs ;
// Bitwise and shift levels sit between the relational and additive levels, as in Dart.
// A lone "|" that begins "||" fails its right operand and the iteration rolls back
// (likewise "&" below "&&"), so the logical levels above keep working.
BitOrExpr   <~~ push(foldBinary(takeAll())) ~~>
            = BitXorExpr { "|" <~~ push("|") ~~> BitXorExpr } ;
BitXorExpr  <~~ push(foldBinary(takeAll())) ~~>
            = BitAndExpr { "^" <~~ push("^") ~~> BitAndExpr } ;
BitAndExpr  <~~ push(foldBinary(takeAll())) ~~>
            = ShiftExpr { "&" <~~ push("&") ~~> ShiftExpr } ;
ShiftExpr   <~~ push(foldBinary(takeAll())) ~~>
            = AddExpr { ( "<<" | ">>>" | ">>" ) <~~ push(up.in) ~~> AddExpr } ;
AddExpr     <~~ push(foldBinary(takeAll())) ~~>
            = MulExpr { ( "+" | "-" ) <~~ push(up.in) ~~> MulExpr } ;
MulExpr     <~~ push(foldBinary(takeAll())) ~~>
            = UnaryExpr { ( "*" | "~/" | "/" | "%" ) <~~ push(up.in) ~~> UnaryExpr } ;

UnaryExpr   = Await | Neg | Not | BitNot | PostfixExpr ;
Await       <~~ notImpl("await", up.pos) ~~> = "await" KwEnd UnaryExpr ;
Neg         <~~ push(makeNeg(pop())) ~~> = "-" UnaryExpr ;
Not         <~~ push(makeNot(pop())) ~~> = "!" UnaryExpr ;
BitNot      <~~ push(makeBitNot(pop())) ~~> = "~" UnaryExpr ;

PostfixExpr = IncDec | CallMember ;
IncDec      <~~ push(makeIncDec(takeAll())) ~~>
            = Target ( "++" | "--" ) <~~ push(up.in) ~~> ;

// A primary followed by any mix of method calls, field reads, index reads and the (not
// implemented) postfix null-assertion ! . The !"=" lookahead keeps a != b intact.
CallMember  <~~ push(foldCallMember(takeAll())) ~~>
            = Primary { MethodSfx | FieldSfx | IndexSfx | NullMethodSfx | NullFieldSfx | NullIndexSfx | BangSfx } ;
BangSfx     <~~ notImpl("null-assertion", up.pos); push({kind:"bang"}) ~~> = "!" !"=" ;
// Null-aware access (?., ?.(), ?[]): accepted, not implemented; behaves like the plain
// access under -warn-unsupported. Pushes the same markers foldCallMember already knows.
NullMethodSfx <~~ notImpl("null-aware method call", up.pos); push({kind:"mcall", name: popName(), args: takeAll()}) ~~>
            = "?." Id <~~ push({mname: up.in}) ~~> "(" [ Arg { "," Arg } [ "," ] ] ")" ;
NullFieldSfx <~~ notImpl("null-aware field access", up.pos) ~~>
            = "?." Id <~~ push({kind:"field", name: up.in}) ~~> ;
NullIndexSfx <~~ notImpl("null-aware index", up.pos); push({kind:"index", idx: pop()}) ~~>
            = "?" "[" Expression "]" ;
MethodSfx   <~~ push({kind:"mcall", name: popName(), args: takeAll()}) ~~>
            = "." Id <~~ push({mname: up.in}) ~~> "(" [ Arg { "," Arg } [ "," ] ] ")" ;
FieldSfx    = "." Id <~~ push({kind:"field", name: up.in}) ~~> ;
IndexSfx    <~~ push({kind:"index", idx: pop()}) ~~>
            = "[" Expression "]" ;

Primary     = ArrowFn | "(" Expression ")" | TypedColl | ListLit | MapLit | SetLit | StrLit | IntLit
            | True | False | Null | NewExpr | Call | VarRef ;

// A collection literal with an explicit type argument: <int>[...], <K,V>{...}. The type
// argument is erased and the list/map/set is built as usual.
TypedColl   = SkipAngle ( ListLit | MapLit | SetLit ) ;

// A set literal { e, e, ... } (a non-map { } with no key:value pairs). Accepted and not
// implemented; every element is still evaluated so its calls stay visible.
SetLit      <~~ push(makeSet(takeAll(), up.pos)) ~~>
            = "{" AssignExpr { "," AssignExpr } [ "," ] "}" ;

// A closure: (params) => expr or (params) { statements }.
ArrowFn     <~~ push(makeArrow(takeAll())) ~~>
            = ParamList ArrowTail ;
ArrowTail   = ArrowExpr | ArrowBlock ;
ArrowExpr   <~~ push({ebody: pop()}) ~~> = "=>" AssignExpr ;
ArrowBlock  <~~ push({body: pop()}) ~~>  = Block ;

// new Type(args) - equivalent to Type(args); both construct.
NewExpr     = KwNew Call ;

// f(args): a top level function, a builtin, or (when the name is a class) a constructor.
Call        <~~ push(makeCall(takeAll())) ~~>
            = Id <~~ push(up.in) ~~> "(" [ Arg { "," Arg } [ "," ] ] ")" ;

// A call argument is positional (a bare expression, pushed as a thunk) or named
// (name: expr, pushed as a {named, val} marker collected into a trailing options dict).
Arg         = NamedArg | AssignExpr ;
NamedArg    <~~ var av = pop(); var an = pop(); push({named: an.aname, val: av}) ~~>
            = Id <~~ push({aname: up.in}) ~~> ":" AssignExpr ;

ListLit     <~~ push(makeList(takeAll())) ~~>
            = "[" [ ListElem { "," ListElem } [ "," ] ] "]" ;
// A list element is a plain expression, a spread (...e / ...?e splicing e's elements)
// or a collection-if (conditionally include an element).
ListElem    = SpreadElem | IfElem | ExprElem ;
SpreadElem  <~~ push({ekind: "spread", t: pop()}) ~~> = "..." [ "?" ] AssignExpr ;
IfElem      <~~ push(makeIfElem(takeAll())) ~~>
            = KwIf "(" Expression ")" ListElem [ KwElse ListElem ] ;
ExprElem    <~~ push({ekind: "val", t: pop()}) ~~> = AssignExpr ;
MapLit      <~~ push(makeMap(takeAll())) ~~>
            = "{" [ MapEntry { "," MapEntry } [ "," ] ] "}" ;
MapEntry    <~~ var v = pop(); push({mk: pop(), mv: v}) ~~>
            = AssignExpr ":" AssignExpr ;

VarRef      <~~ push(makeVarRef(up.in)) ~~> = Id ;
Null        <~~ push(makeConst(null)) ~~>   = "null" KwEnd ;

// Single and double quoted strings, both interpolating $name and ${expr}.
StrLit      = SqTpl | DqTpl ;
SqTpl       <~~ push(makeTemplate(takeAll())) ~~>
            = "'" :whitespace() { TplExpr | TplVar | TplDollar | SqChunk } "'" :whitespace(Whitespace) ;
DqTpl       <~~ push(makeTemplate(takeAll())) ~~>
            = '"' :whitespace() { TplExpr | TplVar | TplDollar | DqChunk } '"' :whitespace(Whitespace) ;
TplExpr     <~~ push({e: pop()}) ~~>
            = "${" :whitespace(Whitespace) Expression "}" ;
TplVar      = "$" TplName <~~ push({e: makeVarRef(up.in)}) ~~> ;
TplName     = ( "a"..."z" | "A"..."Z" | "_" ) { "a"..."z" | "A"..."Z" | "0"..."9" | "_" } ;
TplDollar   <~~ push({s: "$"}) ~~> = "$" ;
SqChunk     <~~ push({s: unescapeJs(up.in)}) ~~> = SqTChar { SqTChar } ;
DqChunk     <~~ push({s: unescapeJs(up.in)}) ~~> = DqTChar { DqTChar } ;
SqTChar     = TplEsc | SqPlain ;
DqTChar     = TplEsc | DqPlain ;
TplEsc      = "\\" "\x00"..."\U0010ffff" ;
SqPlain     = "\x00"..."\x23" | "\x25"..."\x26" | "\x28"..."\x5b" | "\x5d"..."\U0010ffff" ;
DqPlain     = "\x00"..."\x21" | "\x23" | "\x25"..."\x5b" | "\x5d"..."\U0010ffff" ;

// A balanced < ... > run (generic parameters / arguments), parsed and ignored.
SkipAngle   = "<" { SkipAngle | SkipAngleItem } ">" ;
SkipAngleItem = "\x00"..."\x3b" | "\x3d" | "\x3f"..."\U0010ffff" ;

// A balanced { ... } run (switch / try / enum / member bodies) accepted without being
// understood. Dart string literals (single and double quoted, with $name / ${expr}
// interpolation) are matched first so braces inside them are never miscounted.
SkipBlock   = "{" { SkipItem } "}" ;
SkipItem    = SkipSqStr | SkipDqStr | SkipBlock | SkipBOther ;
SkipSqStr   = "'" :whitespace() { SkipTpl | SkipSqCh } "'" :whitespace(Whitespace) ;
SkipDqStr   = '"' :whitespace() { SkipTpl | SkipDqCh } '"' :whitespace(Whitespace) ;
SkipTpl     = "${" :whitespace(Whitespace) { SkipItem } "}" ;
SkipSqCh    = TplEsc | "$" | SqPlain ;
SkipDqCh    = TplEsc | "$" | DqPlain ;
SkipBOther  = "\x00"..."\x21" | "\x23"..."\x26" | "\x28"..."\x7a" | "\x7c" | "\x7e"..."\U0010ffff" ;

// A balanced ( ... ) run (switch / annotation / try headers), parsed and ignored.
SkipParen   = "(" { SkipSqStr | SkipDqStr | SkipParen | SkipPOther } ")" ;
SkipPOther  = "\x00"..."\x21" | "\x23"..."\x26" | "\x2a"..."\U0010ffff" ;

// Keywords end with a negative lookahead so 'ify' or 'classy' stay identifiers.
KwClass     = "class" KwEnd ;
KwNew       = "new" KwEnd ;
KwVar       = "var" KwEnd ;
KwFinal     = "final" KwEnd ;
KwConst     = "const" KwEnd ;
KwIf        = "if" KwEnd ;
KwElse      = "else" KwEnd ;
KwWhile     = "while" KwEnd ;
KwFor       = "for" KwEnd ;
KwIn        = "in" KwEnd ;
KwReturn    = "return" KwEnd ;
KwBreak     = "break" KwEnd ;
KwContinue  = "continue" KwEnd ;
KwExtends   = "extends" KwEnd ;
KwWith      = "with" KwEnd ;
KwImplements = "implements" KwEnd ;
KwLate      = "late" KwEnd ;
KwIs        = "is" KwEnd ;
KwAs        = "as" KwEnd ;
KwThrow     = "throw" KwEnd ;
KwSwitch    = "switch" KwEnd ;
KwDo        = "do" KwEnd ;
KwTry       = "try" KwEnd ;
KwCatch     = "catch" KwEnd ;
KwFinally   = "finally" KwEnd ;
KwOn        = "on" KwEnd ;
KwRethrow   = "rethrow" KwEnd ;
KwAssert    = "assert" KwEnd ;
KwImport    = "import" KwEnd ;
KwExport    = "export" KwEnd ;
KwPart      = "part" KwEnd ;
KwLibrary   = "library" KwEnd ;
KwOf        = "of" KwEnd ;
KwShow      = "show" KwEnd ;
KwHide      = "hide" KwEnd ;
KwEnum      = "enum" KwEnd ;
KwMixin     = "mixin" KwEnd ;
KwExtension = "extension" KwEnd ;
KwType      = "type" KwEnd ;
KwTypedef   = "typedef" KwEnd ;
KwFunction  = "Function" KwEnd ;
KwGet       = "get" KwEnd ;
KwSet       = "set" KwEnd ;
KwOperator  = "operator" KwEnd ;
KwFactory   = "factory" KwEnd ;

// ---


:startScript(~~

    // Shared emitter machinery (module, handle constants, externs, loopStack protocol,
    // expression/statement builders); Dart-specific behaviour is configured on `core` and
    // defined below.
    include("lib/compile-core.js")

    // takeAll empties the local stack and returns the items in push order.
    // unescapeJs resolves the JS/Dart string escapes.

    // A clean compile-time abort (used by the shared notImpl helper in compile-core.js).
    function fail(msg) { println("dart compiler error: " + msg); exit(1) }

    var curClassName = ""
    var classNames = {} // Known class names (bare-name construction).

    // ~/ is integer division: reuse js_div and wrap the result to 32 bits.
    binExt["~/"] = "js_div"
    wraps["~/"] = 1

    // Bitwise and shift operators reuse the ToInt32/ToUint32 externals (js.go); the
    // results are already 32-bit, so no extra wrap is needed.
    binExt["|"] = "js_bor"
    binExt["^"] = "js_bxor"
    binExt["&"] = "js_band"
    binExt["<<"] = "js_shl"
    binExt[">>"] = "js_shr"
    binExt[">>>"] = "js_ushr"

