        var bodyDesc = ctor != null ? ctor.body : null
        var bodyStmt = (bodyDesc != null && bodyDesc.none == undefined) ? bodyToStmt(bodyDesc) : null
        funcCount++
        var idx = funcCount
        var f = m.NewFunc("jsf_" + idx, i64, [llvm.ir.NewParam("env", i64), llvm.ir.NewParam("args", i64)])
        var savedF = curF
        var savedScope = curScopeV
        var savedLoops = loopStack
        var savedTag = curFTag
        curF = f
        curFTag = idx
        loopStack = []
        var b = f.NewBlock("entry")
        curScopeV = callExt(b, "js_scope_new", [f.Params[0]])
        var thisV = callExt(b, "js_arg", [f.Params[1], handle(0)])
        callExt(b, "js_scope_decl", [curScopeV, emitStr(b, "this"), thisV])
        for (var d = 0; d < fields.length; d++) {
            callExt(b, "js_set", [thisV, emitStr(b, fields[d].field), hNull])
        }
        var posCount = 0
        var namedC = []
        for (var k = 0; k < cparams.length; k++) {
            if (cparams[k].named === true) { namedC.push(cparams[k]); continue }
            var pv = callExt(b, "js_arg", [f.Params[1], handle(posCount + 1)])
            var pn = cparams[k].thisf != undefined ? cparams[k].thisf : cparams[k].pname
            callExt(b, "js_scope_decl", [curScopeV, emitStr(b, pn), pv])
            if (cparams[k].thisf != undefined) { callExt(b, "js_set", [thisV, emitStr(b, cparams[k].thisf), pv]) }
            posCount++
        }
        if (namedC.length > 0) { b = emitNamedBind(b, namedC, posCount + 1, thisV) }
        for (var fi = 0; fi < fields.length; fi++) {
            if (fields[fi].init != null) {
                var r = fields[fi].init(b)
                b = r.b
                callExt(b, "js_set", [thisV, emitStr(b, fields[fi].field), r.v])
            }
        }
        if (bodyStmt != null) { b = bodyStmt(b) }
        b.NewRet(hUndef)
        curF = savedF
        curScopeV = savedScope
        loopStack = savedLoops
        curFTag = savedTag
        return idx
    }
    function makeClassStmt(items) {
        var name = items[0].cname
        var fields = []
        var methods = []
        var ctor = null
        for (var i = 1; i < items.length; i++) {
            var it = items[i]
            if (it == undefined) { continue }
            if (it.field != undefined) { fields.push(it) }
            else if (it.method != undefined) { methods.push(it.method) }
            else if (it.ctor != undefined) { ctor = it.ctor }
        }
        classNames[name] = 1
        return function(b) {
            var clsV = callExt(b, "js_obj_new", [])
            callExt(b, "js_set", [clsV, emitStr(b, "__isclass"), hTrue])
            callExt(b, "js_set", [clsV, emitStr(b, "__name"), emitStr(b, name)])
            callExt(b, "js_scope_decl", [curScopeV, emitStr(b, name), clsV])
            var ctorIdx = emitCtor(fields, ctor)
            callExt(b, "js_set", [clsV, emitStr(b, "__ctor"), callExt(b, "js_closure", [handle(ctorIdx), curScopeV])])
            for (var k = 0; k < methods.length; k++) {
                var mi = emitFunc(methods[k].params, bodyToStmt(methods[k].body), true)
                callExt(b, "js_set", [clsV, emitStr(b, methods[k].name), callExt(b, "js_closure", [handle(mi), curScopeV])])
            }
            return b
        }
    }

    // ----- collections and templates -----
    // items are element descriptors: {ekind:"val"|"spread", t} or {ekind:"if", cond, then, els}.
    function makeIfElem(items) {
        return {ekind: "if", cond: items[0], then: items[1], els: items.length > 2 ? items[2] : null}
    }
    // Splice every element of srcV into arr with a runtime counter loop (arr stays one handle).
    function emitSpreadInto(b, arr, srcV) {
        var saved = curScopeV
        curScopeV = callExt(b, "js_scope_new", [curScopeV])
        callExt(b, "js_scope_decl", [curScopeV, emitStr(b, "0sp"), srcV])
        callExt(b, "js_scope_decl", [curScopeV, emitStr(b, "0spi"), callExt(b, "js_num_i", [handle(0)])])
        var headB = curF.NewBlock("")
        var bodyB = curF.NewBlock("")
        var exitB = curF.NewBlock("")
        b.NewBr(headB)
        var iC = callExt(headB, "js_scope_get", [curScopeV, emitStr(headB, "0spi")])
        var spC = callExt(headB, "js_scope_get", [curScopeV, emitStr(headB, "0sp")])
        var lenC = callExt(headB, "js_pylen", [spC])
        headB.NewCondBr(truthy(headB, callExt(headB, "js_lt", [iC, lenC])), bodyB, exitB)
        var iB = callExt(bodyB, "js_scope_get", [curScopeV, emitStr(bodyB, "0spi")])
        var spB = callExt(bodyB, "js_scope_get", [curScopeV, emitStr(bodyB, "0sp")])
        callExt(bodyB, "js_arr_push", [arr, callExt(bodyB, "js_pyget", [spB, iB])])
        callExt(bodyB, "js_scope_set", [curScopeV, emitStr(bodyB, "0spi"),
                                        callExt(bodyB, "js_add", [iB, callExt(bodyB, "js_num_i", [handle(1)])])])
        bodyB.NewBr(headB)
        curScopeV = saved
        return exitB
    }
    function emitListElem(b, arr, e) {
        if (e.ekind == "val") {
            var r = e.t(b)
            b = r.b
            callExt(b, "js_arr_push", [arr, r.v])
            return b
        }
        if (e.ekind == "spread") {
            var sr = e.t(b)
            b = sr.b
            return emitSpreadInto(b, arr, sr.v)
        }
        var cr = e.cond(b)
        var thenB = curF.NewBlock("")
        var mergeB = curF.NewBlock("")
        var elseB = (e.els != null) ? curF.NewBlock("") : mergeB
        cr.b.NewCondBr(truthy(cr.b, cr.v), thenB, elseB)
        emitListElem(thenB, arr, e.then).NewBr(mergeB)
        if (e.els != null) { emitListElem(elseB, arr, e.els).NewBr(mergeB) }
        return mergeB
    }
    function makeList(items) {
        return function(b) {
            var arr = callExt(b, "js_arr_new", [])
            for (var i = 0; i < items.length; i++) { b = emitListElem(b, arr, items[i]) }
            return {b: b, v: arr}
        }
    }
    function makeMap(entries) {
        return function(b) {
            var d = callExt(b, "js_dict_new", [])
            for (var i = 0; i < entries.length; i++) {
                var rk = entries[i].mk(b)
                b = rk.b
                var rv = entries[i].mv(b)
                b = rv.b
                callExt(b, "js_pyset", [d, rk.v, rv.v])
            }
            return {b: b, v: d}
        }
    }
    function makeTemplate(items) {
        return function(b) {
            var v = emitStr(b, "")
            for (var i = 0; i < items.length; i++) {
                var pv = anytype
                if (items[i].s != undefined) { pv = emitStr(b, items[i].s) }
                else { var r = items[i].e(b); b = r.b; pv = r.v }
                v = callExt(b, "js_jadd", [v, pv])
            }
            return {b: b, v: v}
        }
    }

    // ----- ternary, return -----
    function makeCond(items) {
        if (items.length == 1) { return items[0] }
        return function(b) {
            var r = items[0](b)
            var thenB = curF.NewBlock("")
            var elseB = curF.NewBlock("")
            var mergeB = curF.NewBlock("")
            r.b.NewCondBr(truthy(r.b, r.v), thenB, elseB)
            var rt = items[1](thenB)
            rt.b.NewBr(mergeB)
            var re = items[2](elseB)
            re.b.NewBr(mergeB)
            var phi = mergeB.NewPhi([llvm.ir.NewIncoming(rt.v, rt.b), llvm.ir.NewIncoming(re.v, re.b)])
            return {b: mergeB, v: phi}
        }
    }
    function makeReturn(items) {
        var t = items.length > 0 ? items[0] : null
        return function(b) {
            var v = hNull
            if (t != null) { var r = t(b); b = r.b; v = r.v }
            return retStmt(b, v) // plain ret, or a control signal when leaving a try body
        }
    }

    // ----- declarations, assignment, ++/-- -----
    function makeDecl(items) {
        var name = items[0]
        return function(b) {
            var v = hNull
            if (items.length > 1) { var r = items[1](b); b = r.b; v = r.v }
            callExt(b, "js_scope_decl", [curScopeV, emitStr(b, name), v])
            return b
        }
    }
    function emitRefPath(b, ref) {
        var o = callExt(b, "js_kget", [curScopeV, emitStr(b, ref.name)])
        for (var i = 0; i < ref.path.length - 1; i++) {
            var s = ref.path[i]
            if (s.key != undefined) { o = callExt(b, "js_get", [o, emitStr(b, s.key)]) }
            else { var ri = s.idx(b); b = ri.b; o = callExt(b, "js_pyget", [o, ri.v]) }
        }
        var last = ref.path[ref.path.length - 1]
        if (last.key != undefined) { return {b: b, obj: o, key: emitStr(b, last.key), field: true} }
        var kr = last.idx(b)
        return {b: kr.b, obj: o, key: kr.v, field: false}
    }
    function makeAssign(items, pos) {
        var ref = items[0]
        var op = items[1]
        var valT = items[2]
        // ??= is accepted, not implemented; it lowers to a plain assignment.
        if (op == "??=") { notImpl("??= operator", pos); op = "=" }
        return function(b) {
            var r = valT(b)
            b = r.b
            var v = r.v
            if (ref.path.length == 0) {
                var nameV = emitStr(b, ref.name)
                if (op != "=") {
                    var oldl = callExt(b, "js_kget", [curScopeV, nameV])
                    v = emitBin(b, op, oldl, v)
                }
                callExt(b, "js_kset", [curScopeV, nameV, v])
            } else {
                var p = emitRefPath(b, ref)
                b = p.b
                if (p.field) {
                    if (op != "=") { var oldf = callExt(b, "js_get", [p.obj, p.key]); v = emitBin(b, op, oldf, v) }
                    callExt(b, "js_set", [p.obj, p.key, v])
                } else {
                    if (op != "=") { var oldm = callExt(b, "js_pyget", [p.obj, p.key]); v = emitBin(b, op, oldm, v) }
                    callExt(b, "js_pyset", [p.obj, p.key, v])
                }
            }
            return {b: b, v: v}
        }
    }
    function makeIncDec(items) {
        var ref = items[0]
        var extName = (items[1] == "++") ? "js_add" : "js_sub"
        return function(b) {
            var nameV = emitStr(b, ref.name)
            var oldV = callExt(b, "js_tonum", [callExt(b, "js_kget", [curScopeV, nameV])])
            var newV = intWrap(b, callExt(b, extName, [oldV, callExt(b, "js_num_i", [handle(1)])]))
            callExt(b, "js_kset", [curScopeV, nameV, newV])
            return {b: b, v: oldV}
        }
    }

    // ----- for and for-in -----
    function makeFor(items) {
        var bodyT = items.pop()
        var init = null, cond = null, post = null
        for (var i = 0; i < items.length; i++) {
            if (items[i].k == "init") { init = items[i].t }
            if (items[i].k == "cond") { cond = items[i].t }
            if (items[i].k == "post") { post = items[i].t }
        }
        return function(b) {
            var saved = curScopeV
            curScopeV = callExt(b, "js_scope_new", [curScopeV])
            if (init != null) { b = init(b) }
            var headB = curF.NewBlock("")
            var bodyB = curF.NewBlock("")
            var postB = curF.NewBlock("")
            var exitB = curF.NewBlock("")
            b.NewBr(headB)
            if (cond != null) {
                var r = cond(headB)
                r.b.NewCondBr(truthy(r.b, r.v), bodyB, exitB)
            } else { headB.NewBr(bodyB) }
            loopStack.push({cont: postB, brk: exitB})
            bodyT(bodyB).NewBr(postB)
            loopStack.pop()
            var pb = postB
            if (post != null) { pb = post(postB) }
            pb.NewBr(headB)
            curScopeV = saved
            return exitB
        }
    }
    function makeForIn(items) {
        var name = items[0]
        var iterT = items[1]
        var bodyT = items[2]
        return function(b) {
            var saved = curScopeV
            curScopeV = callExt(b, "js_scope_new", [saved])
            var ir = iterT(b)
            b = ir.b
            // js_pyiter normalizes the iterable: a map yields its keys (js_keys order),
            // a string its chars, a list itself - so for (x in coll) walks all three.
            var itV = callExt(b, "js_pyiter", [ir.v])
            var lenV = callExt(b, "js_pylen", [itV])
            callExt(b, "js_scope_decl", [curScopeV, emitStr(b, "0it"), itV])
            callExt(b, "js_scope_decl", [curScopeV, emitStr(b, "0len"), lenV])
            callExt(b, "js_scope_decl", [curScopeV, emitStr(b, "0i"), callExt(b, "js_num_i", [handle(0)])])
            callExt(b, "js_scope_decl", [curScopeV, emitStr(b, name), hNull])
            var headB = curF.NewBlock("")
            var bodyB = curF.NewBlock("")
            var postB = curF.NewBlock("")
            var exitB = curF.NewBlock("")
            b.NewBr(headB)
            var iC = callExt(headB, "js_scope_get", [curScopeV, emitStr(headB, "0i")])
            var lC = callExt(headB, "js_scope_get", [curScopeV, emitStr(headB, "0len")])
            headB.NewCondBr(truthy(headB, callExt(headB, "js_lt", [iC, lC])), bodyB, exitB)
            var iB = callExt(bodyB, "js_scope_get", [curScopeV, emitStr(bodyB, "0i")])
            var itB = callExt(bodyB, "js_scope_get", [curScopeV, emitStr(bodyB, "0it")])
            callExt(bodyB, "js_scope_set", [curScopeV, emitStr(bodyB, name), callExt(bodyB, "js_pyget", [itB, iB])])
            loopStack.push({cont: postB, brk: exitB})
            bodyT(bodyB).NewBr(postB)
            loopStack.pop()
            var iP = callExt(postB, "js_scope_get", [curScopeV, emitStr(postB, "0i")])
            var nextV = callExt(postB, "js_add", [iP, callExt(postB, "js_num_i", [handle(1)])])
            callExt(postB, "js_scope_set", [curScopeV, emitStr(postB, "0i"), nextV])
            postB.NewBr(headB)
            curScopeV = saved
            return exitB
        }
    }

    // The top level statements become dartmain(env, args): declare the top level (functions,
    // classes, top level vars), then call int main(). Its return value is the exit code.
    function buildMain(items) {
        var f = m.NewFunc("dartmain", i64, [llvm.ir.NewParam("env", i64), llvm.ir.NewParam("args", i64)])
        curF = f
        var b = f.NewBlock("entry")
        curScopeV = callExt(b, "js_scope_new", [f.Params[0]])
        // Dart print writes its argument followed by a newline (like println).
        callExt(b, "js_scope_decl", [curScopeV, emitStr(b, "print"),
                                     callExt(b, "js_scope_get", [curScopeV, emitStr(b, "println")])])
        b = makeSeq(items)(b)
        var mainV = callExt(b, "js_kget", [curScopeV, emitStr(b, "main")])
        var argsV = callExt(b, "js_arr_new", [])
        b.NewRet(callExt(b, "js_call", [mainV, hUndef, argsV]))
    }

    // ----- Core library config (see lib/compile-core.js) -----
    core.scopeGetExt = "js_kget" // Scope read with fallback to properties of this.

    c.compile(c.asg)

    println(m)

    var res = llvm.RunJS(m, "dartmain")
    println("dart compiler: main() returned " + res.Ret)
    exit(res.Ret)

~~) ;
