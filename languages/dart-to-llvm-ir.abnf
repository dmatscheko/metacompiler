    }

    // ----- cascade: t..m()..f = v evaluates the target once and returns it -----
    function makeCascade(items) {
        if (items.length == 1) { return items[0] }
        var targetT = items[0]
        var sections = items.slice(1)
        return function(b) {
            var r = targetT(b)
