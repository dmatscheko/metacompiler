    // the caller passed in its trailing options dict (if any), then declare each param.
    function emitNamedBind(b, named, optsIdx, thisV) {
        var r = callExt(b, "js_dict_new", [])
        var i
        for (i = 0; i < named.length; i++) {
            var dv = hNull
            if (named[i].def != null) { var dr = named[i].def(b); b = dr.b; dv = dr.v }
            callExt(b, "js_pyset", [r, emitStr(b, namedKey(named[i])), dv])
        }
        var rawOpts = callExt(b, "js_arg", [curF.Params[1], handle(optsIdx)])
        var haveB = curF.NewBlock("")
        var afterB = curF.NewBlock("")
        b.NewCondBr(b.NewICmp(llvm.enum.IPredNE, rawOpts, handle(0)), haveB, afterB)
        emitCopyKeys(haveB, r, rawOpts).NewBr(afterB)
        b = afterB
        for (i = 0; i < named.length; i++) {
            var val = callExt(b, "js_pyget", [r, emitStr(b, namedKey(named[i]))])
            callExt(b, "js_scope_decl", [curScopeV, emitStr(b, namedKey(named[i])), val])
            if (named[i].thisf != undefined && thisV != null) { callExt(b, "js_set", [thisV, emitStr(b, named[i].thisf), val]) }
        }
        return b
    }
