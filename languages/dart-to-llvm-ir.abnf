    // throw is an expression in Dart, so the thunk returns {b, v}; js_throw never returns,
    // so the placeholder value (hUndef) and the still-open block are dead at runtime.
    function makeThrow(t, pos) {
        return function(b) {
            var r = t(b)
            callExt(r.b, "js_throw", [r.v])
            return {b: r.b, v: hUndef}
        }
