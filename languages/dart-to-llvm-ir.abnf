    // args, into argsV. Positional args are thunks; named args are {named, val} markers.
    function emitCallArgsInto(b, argsV, args) {
        var named = []
        for (var i = 0; i < args.length; i++) {
            var a = anytype
            a = args[i]
            if (typeof a == "function") {
                var r = a(b)
                b = r.b
                callExt(b, "js_arr_push", [argsV, r.v])
            } else { named.push(a) }
        }
        if (named.length > 0) {
            var d = callExt(b, "js_dict_new", [])
            for (var j = 0; j < named.length; j++) {
                var rv = named[j].val(b)
                b = rv.b
                callExt(b, "js_pyset", [d, emitStr(b, named[j].named), rv.v])
