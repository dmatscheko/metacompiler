        var iB = callExt(bodyB, "js_scope_get", [curScopeV, emitStr(bodyB, "0ki")])
        var ksB = callExt(bodyB, "js_scope_get", [curScopeV, emitStr(bodyB, "0ks")])
        var srcB = callExt(bodyB, "js_scope_get", [curScopeV, emitStr(bodyB, "0src")])
        var dstB = callExt(bodyB, "js_scope_get", [curScopeV, emitStr(bodyB, "0dst")])
        var kB = callExt(bodyB, "js_pyget", [ksB, iB])
        callExt(bodyB, "js_pyset", [dstB, kB, callExt(bodyB, "js_pyget", [srcB, kB])])
        callExt(bodyB, "js_scope_set", [curScopeV, emitStr(bodyB, "0ki"),
                                        callExt(bodyB, "js_add", [iB, callExt(bodyB, "js_num_i", [handle(1)])])])
        bodyB.NewBr(headB)
        curScopeV = saved
        return exitB
    }
