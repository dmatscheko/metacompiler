                    else if (s.name == "isNotEmpty") { cur = callExt(b, "js_gt", [callExt(b, "js_pylen", [cur]), emitNum(b, 0)]) }
                    else if (s.name == "keys") { cur = callExt(b, "js_mcall", [cur, emitStr(b, "keys"), callExt(b, "js_arr_new", [])]) }
                    else if (s.name == "values") { cur = callExt(b, "js_mcall", [cur, emitStr(b, "values"), callExt(b, "js_arr_new", [])]) }
