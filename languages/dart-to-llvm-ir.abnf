        notImpl("?? operator", items[1].pos)
        var ops = []
        for (var i = 0; i < items.length; i += 2) { ops.push(items[i]) }
        return function(b) {
            var first = hUndef
            for (var j = 0; j < ops.length; j++) { var r = ops[j](b); b = r.b; if (j == 0) { first = r.v } }
            return {b: b, v: first}
