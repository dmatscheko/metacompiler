        curScopeV = callExt(b, "js_scope_new", [curScopeV])
        callExt(b, "js_scope_decl", [curScopeV, emitStr(b, "0ks"), callExt(b, "js_keys", [srcDict])])
        callExt(b, "js_scope_decl", [curScopeV, emitStr(b, "0src"), srcDict])
        callExt(b, "js_scope_decl", [curScopeV, emitStr(b, "0dst"), dstDict])
        callExt(b, "js_scope_decl", [curScopeV, emitStr(b, "0ki"), callExt(b, "js_num_i", [handle(0)])])
        var headB = curF.NewBlock("")
        var bodyB = curF.NewBlock("")
        var exitB = curF.NewBlock("")
        b.NewBr(headB)
        var iC = callExt(headB, "js_scope_get", [curScopeV, emitStr(headB, "0ki")])
        var ksC = callExt(headB, "js_scope_get", [curScopeV, emitStr(headB, "0ks")])
