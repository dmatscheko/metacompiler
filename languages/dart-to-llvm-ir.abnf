        for (var i = 0; i < items.length; i++) {
            if (items[i].trybody != undefined) { tryT = items[i].trybody }
            else if (items[i].catchbody != undefined) {
                if (catchT == undefined) { catchT = items[i].catchbody; catchName = items[i].catchname }
            }
            else if (items[i].finbody != undefined) { finallyT = items[i].finbody }
        }
        return function(b) {
            var tryClo = callExt(b, "js_closure", [handle(emitFunc([], tryT, false, true)), curScopeV])
            var catchClo = hUndef
            if (catchT != undefined) {
                var cn = (catchName != undefined) ? catchName : "__caught"
                // emitFunc binds param DESCRIPTORS (Dart params carry .pname), so wrap the
                // catch-var name; js_try calls this closure with the thrown value.
                catchClo = callExt(b, "js_closure", [handle(emitFunc([{pname: cn}], catchT, false, true)), curScopeV])
            }
            var finClo = hUndef
            if (finallyT != undefined) {
                finClo = callExt(b, "js_closure", [handle(emitFunc([], finallyT, false, true)), curScopeV])
            }
            var ctl = callExt(b, "js_try", [tryClo, catchClo, finClo])
            return excDispatch(b, ctl)
        }
