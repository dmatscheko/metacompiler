    function makeCond(items) {
        if (items.length == 1) return items[0]
        return function() { return items[0]() ? items[1]() : items[2]() }
    }

    // items = [primaryThunk, {kind:"call"|"member", ...}...].
    // A member access remembers its object and its key. A directly following call is a
    // method call: if the looked-up member is a function value it is applied with the
    // object as 'this' (native string/array methods, object-literal methods); otherwise
    // it is a __class instance method, routed through mcall (which prepends the receiver
    // and follows __super). A call not preceded by a member is a plain function call.
    foldCallMember = function(items) {
        if (items.length == 1) return items[0]
        var primary = items[0]
        var suffixes = items.slice(1)
        // Any optional-chaining suffix (?. ?.[ ?.( ) routes the whole chain to
        // notImplemented: there is no short-circuit-on-nullish model in the subset.
        for (var oi = 0; oi < suffixes.length; oi++) {
            if (suffixes[oi].kind == "optchain") return notImplExpr("optional chaining (?.)", suffixes[oi].pos)
        }
        return function() {
            var cur = anytype     // A member chain hops between types,
            var curThis = anytype // so do the remembered receiver
            var lastKey = anytype // and the remembered key.
            cur = primary()
            for (var i = 0; i < suffixes.length; i++) {
                var s = suffixes[i]
                if (s.kind == "member") {
                    curThis = cur
                    lastKey = s.key()
                    cur = getMember(cur, lastKey)
                } else {
                    var argv = []
                    for (var j = 0; j < s.args.length; j++) argv.push(s.args[j]())
                    if (typeof cur == "function") {
                        cur = cur.apply(curThis, argv)
                    } else {
                        cur = mcall(curThis, lastKey, argv)
                    }
                    curThis = undefined
                }
            }
            return cur
        }
    }

    // Target items = [nameString, suffix marker...] -> reference descriptor.
    // Walks a target path (members and calls) up to the last element and returns
    // the assignable place {obj, key}. The last element must be a member.
    resolveRef = function(ref) {
        var cur = anytype     // The walked values and receivers
        var curThis = anytype // may be of mixed types.
        cur = getVar(ref.name)
        for (var i = 0; i < ref.path.length - 1; i++) {
            var s = ref.path[i]
            if (s.kind == "member") {
                curThis = cur
                cur = getMember(cur, s.key())
            } else {
                var argv = []
                for (var j = 0; j < s.args.length; j++) argv.push(s.args[j]())
                if (typeof cur != "function") fail("call of a non function value: " + cur)
                cur = cur.apply(curThis, argv)
                curThis = undefined
            }
        }
        var last = ref.path[ref.path.length - 1]
        if (last.kind != "member") fail("assignment target must end in a member")
        if (cur == undefined) fail("member assignment on " + cur)
        return {obj: cur, key: last.key()}
    }
    applyOp = function(op, a, b) {
        if (op == "+=") return a + b
        if (op == "-=") return a - b
        if (op == "*=") return a * b
        if (op == "/=") return a / b
        if (op == "%=") return a % b
    }
    // items = [ref, opString, valueThunk]. Returns the assigned value (assignment is an expression).
    function makeAssign(items) {
        var ref = items[0]
        var op = items[1]
        var valT = items[2]
        return function() {
            var v = anytype // A compound assignment (s += n) may change the value's type.
            v = valT()
            if (ref.path.length == 0) {
                if (op != "=") v = applyOp(op, getVar(ref.name), v)
                setVar(ref.name, v)
            } else {
                var p = resolveRef(ref)
                if (op != "=") v = applyOp(op, getMember(p.obj, p.key), v)
                scopePut(p.obj, p.key, v)
                trackKey(p.obj, p.key) // Keep the object's for-in key list up to date.
            }
            return v
        }
    }
    // items = [ref, "++"|"--"]. Post increment: the expression value is the old (coerced) one.
    function makeIncDec(items) {
        var ref = items[0]
        var delta = (items[1] == "++") ? 1 : -1
        return function() {
            if (ref.path.length == 0) {
                var n = getVar(ref.name) - 0
                setVar(ref.name, n + delta)
                return n
            }
            var p = resolveRef(ref)
            var m = getMember(p.obj, p.key) - 0
            scopePut(p.obj, p.key, m + delta)
            return m
        }
    }
    // Prefix ++/--: like makeIncDec, but the expression value is the new one.
    function makePreIncDec(ref, op) {
        var delta = (op == "++") ? 1 : -1
        return function() {
            if (ref.path.length == 0) {
                var n = getVar(ref.name) - 0 + delta
                setVar(ref.name, n)
                return n
            }
            var p = resolveRef(ref)
            var m = getMember(p.obj, p.key) - 0 + delta
            scopePut(p.obj, p.key, m)
            return m
        }
    }

    // ----- Statement thunks: function() -> undefined | BRK | CONT | {isRet, v} -----

    // An expression in statement position: evaluate and discard the value.
    // items = [name] or [name, initThunk].
    function makeDecl(items) {
        var name = items[0]
        var init = items.length > 1 ? items[1] : makeConst(undefined)
        return function() { declVar(name, init()) }
    }
    // items = [cond, then] or [cond, then, else].
    // Note: the childs lie on the stack in source order, so pop() delivers them reversed.
    function makeDo(condT, bodyT) {
        return function() {
            do {
                var r = bodyT()
                if (r != undefined) {
                    if (r === BRK) break
                    if (r !== CONT) return r
                }
            } while (condT())
        }
    }
    // items = [{k:"init"|"cond"|"post", t:thunk}..., bodyThunk].
    function makeFor(items) {
        var bodyT = items.pop()
        var init = null, cond = null, post = null
        for (var i = 0; i < items.length; i++) {
            if (items[i].k == "init") init = items[i].t
            if (items[i].k == "cond") cond = items[i].t
            if (items[i].k == "post") post = items[i].t
        }
        return function() {
            scopes.push({}) // The for header is its own scope (for the loop variable).
            var res = undefined
            if (init != null) init()
            while (cond == null || cond()) {
                var r = bodyT()
                if (r != undefined) {
                    if (r === BRK) break
                    if (r !== CONT) { res = r; break } // A return signal.
                }
                if (post != null) post()
            }
            scopes.pop()
            return res
        }
    }
    // items = [] or [exprThunk].
    function makeReturn(items) {
        var t = items.length > 0 ? items[0] : makeConst(undefined)
        return function() { return {isRet: true, v: t()} }
    }

    // items = [subjThunk, ({casev}|{isdflt}|stmtThunk)...]. The flat label/statement
    // list is grouped into case descriptors at build time; at run time the first ===
    // match (or default) starts execution, which falls through until a break.
    function makeSwitch(items) {
        var subj = items[0]
        var cases = []
        var cur = null
        for (var i = 1; i < items.length; i++) {
            var p = items[i]
            if (p != undefined && (p.casev != undefined || p.isdflt != undefined)) {
                cur = {isDefault: p.isdflt != undefined, v: p.casev, body: []}
                cases.push(cur)
            } else {
                if (cur == null) fail("switch: a statement before the first case label")
                cur.body.push(p)
            }
        }
        return function() {
            var v = subj()
            var start = -1
            var dflt = -1
            for (var i = 0; i < cases.length; i++) {
                if (cases[i].isDefault) { if (dflt < 0) dflt = i; continue }
                if (start < 0 && cases[i].v() === v) { start = i }
            }
            if (start < 0) { start = dflt }
            if (start < 0) { return undefined }
            for (var i = start; i < cases.length; i++) {
                var body = cases[i].body
                for (var j = 0; j < body.length; j++) {
                    var r = body[j]()
                    if (r === BRK) { return undefined }        // break leaves the switch
                    if (r != undefined) { return r }           // return/continue propagate
                }
            }
            return undefined
        }
    }

    // Local stack = [name, [paramNames...], bodyThunk] -- binds the closure when executed.
    function makeFuncDecl(bodyT, paramNames, name) {
        return function() { declVar(name, makeClosure(paramNames, bodyT, scopes)) }
    }

    // Build the program thunk out of the parsed source.
    // ----- Core library config (see lib/interp-core.js) -----
    core.lang = "js"

    c.compile(c.asg)
    var progT = popg()

    // Run the top level (it binds the functions), then call main(). The exit code of
    // this metacompiler run is what main() returned, so test programs are self checking.
    progT()
    // The entry point defaults to main() but the -main flag (c.mainName) can name any
    // other top-level function.
    var entry = c.mainName
    if (entry == undefined || entry == "") { entry = "main" }
    if (!hasOwn(globalScope, entry) || typeof globalScope[entry] != "function") {
        fail("JavaScript programs need a " + entry + "() function.")
    }
    // A user exception that escapes the entry point is reported like any runtime error.
    var ret = anytype
    try {
        ret = globalScope[entry]()
    } catch (e) {
        if (excIsUser(e)) { fail("uncaught exception: " + e.v) }
        throw e
    }
    println("js interpreter: " + entry + "() returned " + ret)
    exit(ret | 0)

~~) ;
