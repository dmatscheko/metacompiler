    // object-literal methods never reach here - foldCallMember calls this only when the
    // looked-up member was not itself a function value.
    function mcall(target, name, args) {
        if (target != undefined && target != null && target.__class != undefined) {
            var m = undefined
            for (var cl = target.__class; cl != undefined && m == undefined; cl = cl.__super) { if (hasOwn(cl, name)) m = cl[name] }
            if (typeof m != "function") fail("unknown method '" + name + "' on an instance")
            return m.apply(undefined, concat2impl([target], args))
        }
        fail("call of a non function value (method '" + name + "')")
    }

    function makeMethod(items) {
        var mods = items[0].mods
        var name = items[1].mname
        var params = items[2]   // The parameter names array (from ParamList).
        var body = items[3]
        var isStatic = false
        for (var i = 0; i < mods.length; i++) { if (mods[i] == "static") { isStatic = true } }
        return {kind: "method", name: name, statik: isStatic, params: params, body: body}
    }
    function makeCtor(items) {
        return {kind: "ctor", params: items[0], body: items[1]}
    }
    function makeField(items) {
        var mods = items[0].mods
        var name = items[1].fname
        var init = items.length > 2 ? items[2] : null
        var isStatic = false
        for (var i = 0; i < mods.length; i++) { if (mods[i] == "static") { isStatic = true } }
        return {kind: "field", name: name, statik: isStatic, init: init}
    }

    // A class declaration: build the descriptor object, attach static fields, the
    // constructor and the methods, then bind it in the current scope.
    function makeClassStmt(items) {
        var name = items[0].cname
        var superName = null
        var members = []
        for (var i = 1; i < items.length; i++) {
            if (items[i] == undefined) { continue }
            if (items[i].ext != undefined) { superName = items[i].ext }
            else if (items[i].skip != undefined) { continue }
            else { members.push(items[i]) }
        }
        var fields = []
        var methods = []
        var statics = []
        var ctorInfo = null
        for (var j = 0; j < members.length; j++) {
            var mm = members[j]
            if (mm.kind == "field") { if (mm.statik) { statics.push(mm) } else { fields.push(mm) } }
            else if (mm.kind == "method") { methods.push(mm) }
            else if (mm.kind == "ctor") { ctorInfo = mm }
        }
        return function() {
            var defScopes = scopes.slice()
            var cls = {}
            cls["__isclass"] = true
            cls["__name"] = name
            if (superName != null) {
                var sup = getVar(superName)
                if (sup == undefined || !sup.__isclass) fail("unknown superclass: " + superName)
                cls["__super"] = sup
            }
            for (var s = 0; s < statics.length; s++) {
