:title("MetaJS interpreter") ;
:description("Parses MetaJS and executes it directly, without generating code.

MetaJS is the restricted JavaScript subset that the annotation scripts of the grammars in
this repository are written in. It has: var/let/const (all block scoped), function declarations and
anonymous function expressions with real closures and an 'arguments' array, if/else, while,
do-while, for(;;), switch (=== comparison, fallthrough, stacked labels, default),
break, continue, return, throw (terminates, there is no try/catch),
numbers (doubles, hex 0x literals included), strings with the methods length/charAt/
charCodeAt/indexOf/replace/slice/substring/split/toUpperCase/toLowerCase/trim,
booleans, null, undefined,
arrays (push/pop/shift/unshift/slice/indexOf/join/concat), object literals, member
access (.name and [expr]), method calls, assignment (= += -= *= /= %=) as an expression
(the target may reach through calls: findScope(name)[name] = v), prefix and postfix
++/--, the
ternary operator, || and && (short circuit, returning the operand),
== != === !== < > <= >= + - * / % | ^ & << >> >>> and unary - ! ~ typeof.

Two discipline rules are part of the language: every variable must be declared
(var/let/const) before use, and a variable's type is pinned by the first
non-undefined, non-null value it holds - later assignments must keep that type class
(number, string, boolean, function or object; arrays and objects share the object
class like typeof does). undefined and null pin nothing and are always assignable,
and a redeclaration starts the pin fresh. A violation aborts the run.
A variable that must hold values of changing types declares it: var v = anytype
(a host global) starts the variable as undefined and exempts it from pinning;
assigning anytype to an already existing variable is an error.

Deliberately not in the subset: this, new, prototypes, try/catch, regex, for-in,
getters/setters, and hoisting (a binding must be executed before it is used;
main() is called after the whole top level ran, so mutual recursion works anyway).
Semicolons are optional at statement ends, but a statement must not begin with '(' or '['
(write an explicit ';' before it in that rare case).

Every tag composes a small JS closure (a 'thunk') out of the thunks of its children.
Expression thunks return the value, statement thunks return undefined or a signal object
(return/break/continue) that the enclosing statements route.

The program must define main(); the exit code of the metacompiler run is what main()
returns, so MetaJS test programs are self checking: they return 0 on success.
The same language is compiled to LLVM IR by metajs-to-llvm-ir.abnf.") ;


// --- main rules

// Shared token productions (languages/lib).
:include("lib/cstyle-comments.abnf") ;
:include("lib/ident-dollar.abnf") ;
:include("lib/dq-strings.abnf") ;
:include("lib/numbers.abnf") ;
:include("lib/bools.abnf") ;

:startRule(Program) ;
:whitespace(Whitespace) ;

// The merged pushes of all top level statements become one program thunk on the global stack.
Program     <~~ pushg(makeSeq(takeAll())) ~~>
            = { Statement } ;

// Every statement production pushes exactly one thunk: function() -> undefined | signal.
Statement   = Block | VarDecl | If | While | Do | For | Switch | Return | Break | Continue
            | TryStmt | Throw | FuncDecl | Empty | ExprStmt ;

// The JS switch: === comparison, fallthrough until break, stacked labels, default
// anywhere. The body is a flat list - the labels must be tried before Statement,
// because 'case 1:' would otherwise parse as two expression statements (semicolons
// are optional).
Switch      <~~ push(makeSwitch(takeAll())) ~~>
            = KwSwitch "(" Expression ")" "{" { CaseLabel | DefaultLabel | Statement } "}" ;
CaseLabel   <~~ push({casev: pop()}) ~~>
            = KwCase AssignExpr ":" ;
DefaultLabel <~~ push({isdflt: true}) ~~>
            = KwDefault ":" ;

Block       <~~ push(makeBlockStmt(takeAll())) ~~>
            = "{" { Statement } "}" ;

// var, let and const all declare a block scoped variable in the current scope.
VarDecl     = VarDeclCore [ ";" ] ;
VarDeclCore <~~ push(makeSeq(takeAll())) ~~>
            = KwVar Declarator { "," Declarator } ;
Declarator  <~~ push(makeDecl(takeAll())) ~~>
            = Id <~~ push(up.in) ~~> [ "=" AssignExpr ] ;

// [condThunk, thenThunk] or [condThunk, thenThunk, elseThunk].
If          <~~ push(makeIf(takeAll())) ~~>
            = KwIf "(" Expression ")" Statement [ KwElse Statement ] ;

While       <~~ push(makeWhile(pop(), pop())) ~~>
            = KwWhile "(" Expression ")" Statement ;

Do          <~~ push(makeDo(pop(), pop())) ~~>
            = KwDo Statement KwWhile "(" Expression ")" [ ";" ] ;

// The three optional parts are wrapped with a kind marker, otherwise e.g.
// 'for (;c;)' and 'for (i=0;;)' could not be told apart on the stack.
For         <~~ push(makeFor(takeAll())) ~~>
            = KwFor "(" [ ForInit ] ";" [ ForCond ] ";" [ ForPost ] ")" Statement ;
ForInit     <~~ push({k:"init", t:pop()}) ~~> = ForVar | ForExpr ;
ForVar      = VarDeclCore ;
ForExpr     <~~ push(exprToStmt(pop())) ~~> = Expression ;
ForCond     <~~ push({k:"cond", t:pop()}) ~~> = Expression ;
ForPost     <~~ push({k:"post", t:exprToStmt(pop())}) ~~> = Expression ;

// [] or [exprThunk].
Return      <~~ push(makeReturn(takeAll())) ~~>
            = KwReturn [ Expression ] [ ";" ] ;

Break       <~~ push(makeBreak()) ~~>
            = KwBreak [ ";" ] ;

Continue    <~~ push(makeContinue()) ~~>
            = KwContinue [ ";" ] ;

Throw       <~~ push(makeThrow(pop())) ~~>
            = KwThrow Expression [ ";" ] ;

// try/catch/finally. The catch binding is optional (ES2019 `catch {}`), and either
// catch or finally may be omitted. Each part is wrapped with a marker so makeTry can
// tell them apart on the stack; the catch clause scopes its own takeAll to pair the
// optional binding name with the block.
TryStmt     <~~ push(makeTry(takeAll())) ~~>
            = KwTry TryBody [ CatchClause ] [ FinallyClause ] ;
TryBody     <~~ push({trybody: pop()}) ~~>
            = Block ;
CatchClause <~~ push(makeCatch(takeAll())) ~~>
            = KwCatch [ "(" Id <~~ push(up.in) ~~> ")" ] Block ;
FinallyClause <~~ push({finbody: pop()}) ~~>
            = KwFinally Block ;

// A function declaration binds the closure in the current scope when it executes.
FuncDecl    <~~ push(makeFuncDecl(pop(), pop(), pop())) ~~>
            = KwFunction Id <~~ push(up.in) ~~> ParamList Block ;

ParamList   <~~ push(takeAll()) /* Collect the parameter names into one array. */ ~~>
            = "(" [ Id <~~ push(up.in) ~~> { "," Id <~~ push(up.in) ~~> } ] ")" ;

Empty       <~~ push(function() {}) ~~>
            = ";" ;

ExprStmt    <~~ push(exprToStmt(pop())) ~~>
            = Expression [ ";" ] ;

// Every expression production pushes exactly one thunk: function() -> value.
Expression  = AssignExpr ;

// Assignment is an expression and associates to the right: a = b = c.
// If the assignment shape does not fit (e.g. 'a == b'), the parser falls back to CondExpr.
AssignExpr  = Assignment | CondExpr ;
Assignment  <~~ push(makeAssign(takeAll())) ~~>
            = Target ( "+=" | "-=" | "*=" | "/=" | "%=" | "=" ) <~~ push(up.in) ~~> AssignExpr ;

// An assignable place: a variable, or a member path that may reach through calls
// but must end in a member: findScope(name)[name] = value.
// The local stack holds [name, suffix marker, suffix marker, ...].
Target      <~~ push(makeTargetRef(takeAll())) ~~>
            = Id <~~ push(up.in) ~~> { CallSuffix | DotSuffix | IndexSuffix } ;

CondExpr    <~~ push(makeCond(takeAll())) ~~>
            = OrExpr [ "?" AssignExpr ":" AssignExpr ] ;

OrExpr      <~~ push(makeOr(takeAll())) ~~>
            = AndExpr { "||" AndExpr } ;

AndExpr     <~~ push(makeAnd(takeAll())) ~~>
            = BitOrExpr { "&&" BitOrExpr } ;

// The bitwise levels sit between && and equality, like in JS. A single "|" that
// actually starts a "||" fails its right side, the iteration rolls back, and the
// enclosing || level picks it up.
BitOrExpr   <~~ push(foldBinary(takeAll())) ~~>
            = BitXorExpr { "|" <~~ push("|") ~~> BitXorExpr } ;
BitXorExpr  <~~ push(foldBinary(takeAll())) ~~>
            = BitAndExpr { "^" <~~ push("^") ~~> BitAndExpr } ;
BitAndExpr  <~~ push(foldBinary(takeAll())) ~~>
            = EqExpr { "&" <~~ push("&") ~~> EqExpr } ;

// The longer operators must be tried before their prefixes ("===" before "==").
EqExpr      <~~ push(foldBinary(takeAll())) ~~>
            = RelExpr { ( "===" | "!==" | "==" | "!=" ) <~~ push(up.in) ~~> RelExpr } ;

RelExpr     <~~ push(foldBinary(takeAll())) ~~>
            = ShiftExpr { ( "<=" | ">=" | "<" | ">" ) <~~ push(up.in) ~~> ShiftExpr } ;

ShiftExpr   <~~ push(foldBinary(takeAll())) ~~>
            = AddExpr { ( "<<" | ">>>" | ">>" ) <~~ push(up.in) ~~> AddExpr } ;

AddExpr     <~~ push(foldBinary(takeAll())) ~~>
            = MulExpr { ( "+" | "-" ) <~~ push(up.in) ~~> MulExpr } ;

MulExpr     <~~ push(foldBinary(takeAll())) ~~>
            = UnaryExpr { ( "*" | "/" | "%" ) <~~ push(up.in) ~~> UnaryExpr } ;

UnaryExpr   = PreIncDec | Neg | Not | BitNot | Typeof | PostfixExpr ;
// Prefix ++/--: the expression value is the new one.
PreIncDec   <~~ push(makePreIncDec(pop(), pop())) ~~>
            = ( "++" | "--" ) <~~ push(up.in) ~~> Target ;
Neg         <~~ push(makeNeg(pop())) ~~>
            = "-" UnaryExpr ;
Not         <~~ push(makeNot(pop())) ~~>
            = "!" UnaryExpr ;
BitNot      <~~ push(makeBitNot(pop())) ~~>
            = "~" UnaryExpr ;
Typeof      <~~ push(makeTypeof(pop())) ~~>
            = KwTypeof UnaryExpr ;

// The postfix forms: i++ evaluates to the old value.
PostfixExpr = IncDec | CallMember ;
IncDec      <~~ push(makeIncDec(takeAll())) ~~>
            = Target ( "++" | "--" ) <~~ push(up.in) ~~> ;

// A primary expression followed by any mix of calls and member accesses: a.b[i](x).c().
// A call after a member access is a method call: the object becomes 'this' of the callee
// (that is what makes items.slice(1) or str.charCodeAt(0) work on the native values).
CallMember  <~~ push(foldCallMember(takeAll())) ~~>
            = Primary { CallSuffix | DotSuffix | IndexSuffix } ;
CallSuffix  <~~ push({kind:"call", args: takeAll()}) ~~>
            = "(" [ AssignExpr { "," AssignExpr } ] ")" ;
DotSuffix   = "." Id <~~ push({kind:"member", key: makeConst(up.in)}) ~~> ;
IndexSuffix <~~ push({kind:"member", key: pop()}) ~~>
            = "[" Expression "]" ;

Primary     = "(" Expression ")" | FunctionExpr | ObjectLit | ArrayLit | StringLit | NumberLit
            | True | False | Null | Undefined | VarRef ;

// The optional name of a function expression is accepted but not bound.
FunctionExpr <~~ push(makeFunctionExpr(pop(), pop())) ~~>
            = KwFunction [ Id ] ParamList Block ;

ObjectLit   <~~ push(makeObject(takeAll())) ~~>
            = "{" [ PropDef { "," PropDef } ] "}" ;
PropDef     <~~ push(makeProp(pop(), pop())) ~~>
            = PropKey ":" AssignExpr ;
PropKey     = Id <~~ push(up.in) ~~> | StringLit ;

ArrayLit    <~~ push(makeArray(takeAll())) ~~>
            = "[" [ AssignExpr { "," AssignExpr } ] "]" ;

Null        <~~ push(makeConst(null)) ~~>      = "null" KwEnd ;
Undefined   <~~ push(makeConst(undefined)) ~~> = "undefined" KwEnd ;

VarRef      <~~ push(makeVarRef(up.in)) ~~>
            = Id ;

StringLit   = DqString | SqString ;
NumberLit   = HexLit | DecLit ;

// Hex must be tried before decimal, otherwise '0x1A' would stop after the '0'.
HexLit      <~~ push(makeConst(hexAt(up.in, 2, up.in.length - 2))) ~~>
            = ( "0x" | "0X" ) :whitespace() HexDigit { HexDigit } :whitespace(Whitespace) ;
HexDigit    = "0"..."9" | "a"..."f" | "A"..."F" ;

// The keywords end with a negative lookahead, so that e.g. 'iffy' or 'variable' stay identifiers.
KwVar       = ( "var" | "let" | "const" ) KwEnd ;
KwFunction  = "function" KwEnd ;
KwIf        = "if" KwEnd ;
KwElse      = "else" KwEnd ;
KwWhile     = "while" KwEnd ;
KwDo        = "do" KwEnd ;
KwFor       = "for" KwEnd ;
KwReturn    = "return" KwEnd ;
KwBreak     = "break" KwEnd ;
KwContinue  = "continue" KwEnd ;
KwThrow     = "throw" KwEnd ;
KwTry       = "try" KwEnd ;
KwCatch     = "catch" KwEnd ;
KwFinally   = "finally" KwEnd ;
KwTypeof    = "typeof" KwEnd ;
KwSwitch    = "switch" KwEnd ;
KwCase      = "case" KwEnd ;
KwDefault   = "default" KwEnd ;

// ---


:startScript(~~

    // Shared interpreter machinery (scopes, BRK/CONT protocol, expression and
    // statement builders); language-specific behavior is configured on `core` below.
    include("lib/interp-core.js")

    // takeAll empties the local stack of the current tag and returns its items in push
    // order as a plain JS array. It only uses pop(), so it works independently of how
    // the runtime wraps the Go slice behind up.stack.
    // Resolves the JS string escapes (\n \t \r \0 \xNN \uNNNN, and \c for the char itself).
    // The host unescape() is for the grammar token syntax and rejects \' and \", so the
    // JS string literals bring their own unescaper.
    // ----- Scopes -----
    // 'scopes' is the active scope chain (innermost last). Every closure captures a copy
    // of the chain array; the scope objects inside stay shared, so later declarations in
    // an already captured scope are visible to the closure (that is what allows mutual
    // recursion between top level functions).

    // The host names that a MetaJS program can use. Everything resolves to the goja
    // natives, so e.g. Math.imul or the string/array methods behave exactly like in JS.
    // The 'anytype' declaration marker of the interpreted programs: a unique
    // object a program can only obtain through the anytype global below.
    var anytypeMarker = {}

    var hostGlobals = {
        "println": println, "print": print, "printf": printf, "sprintf": sprintf,
        "parseInt": parseInt, "parseFloat": parseFloat, "Math": Math, "String": String,
        "exit": exit, "anytype": anytypeMarker
    }

    // The type class that pins a variable: undefined and null pin nothing.
    function typeClass(v) {
        if (v === undefined || v === null) return ""
        return typeof v
    }
    // Scope entries are {v, t} type boxes: reads unbox, declarations pin the
    // type; t '*' marks an anytype variable (starts undefined, never pins).
    getVar = function(name) {
        for (var i = scopes.length - 1; i >= 0; i--) {
            if (hasOwn(scopes[i], name)) return scopes[i][name].v
        }
        if (hasOwn(hostGlobals, name)) return hostGlobals[name]
        fail("variable not defined: " + name)
    }
    declVar = function(name, value) {
        if (value === anytypeMarker) { scopes[scopes.length - 1][name] = {v: undefined, t: "*"}; return }
        scopes[scopes.length - 1][name] = {v: value, t: typeClass(value)}
    }
    setVar = function(name, value) {
        if (value === anytypeMarker) { fail("MetaJS: anytype can only initialize a declaration") }
        for (var i = scopes.length - 1; i >= 0; i--) {
            if (hasOwn(scopes[i], name)) {
                var entry = scopes[i][name]
                var tc = typeClass(value)
                if (tc != "" && entry.t != "*") {
                    if (entry.t != "" && entry.t != tc) {
                        fail("MetaJS: variable '" + name + "' has type " + entry.t + " and cannot hold a " + tc)
                    }
                    entry.t = tc
                }
                entry.v = value
                return
            }
        }
        fail("assignment to undeclared variable: " + name)
    }

    // ----- Statement signals -----
    // Statement thunks return undefined (fall through), BRK, CONT, or {isRet:true, v:...}.

    // ----- Functions -----
    // A MetaJS function value is a real (goja) JS function, so typeof, passing it around,
    // and calling it work natively. It closes over the scope chain of its creation.
    function makeClosure(params, bodyT, defScopes) {
        var env = defScopes.slice()
        return function() {
            var args = []
            for (var i = 0; i < arguments.length; i++) args.push(arguments[i])
            var saved = scopes
            scopes = env.slice()
            var sc = {}
            for (var j = 0; j < params.length; j++) {
                sc[params[j]] = (args[j] === anytypeMarker) ? {v: undefined, t: "*"} : {v: args[j], t: typeClass(args[j])}
            }
            sc["arguments"] = {v: args, t: "object"}
            scopes.push(sc)
            var r = bodyT()
            scopes = saved
            return (r != undefined && r.isRet) ? r.v : undefined
        }
    }

    function getMember(o, k) {
        if (o == undefined) fail("member '" + k + "' of " + o) // Catches null and undefined.
        return o[k]
    }

    // ----- Expression thunks: function() -> value -----

    makeNeg = function(t) { return function() { return -t() } }
    function makeBitNot(t) { return function() { return ~t() } }
    function makeTypeof(t) { return function() { return typeof t() } }

    function makeArray(items) {
        return function() {
            var a = []
            for (var i = 0; i < items.length; i++) a.push(items[i]())
            return a
        }
    }
    // PropDef pops [valueThunk, key]; the key is an Id string or a constant string thunk
    // (calling the pure thunk once at build time yields the key text).
    function makeProp(valT, key) {
        return {k: (typeof key == "string") ? key : key(), t: valT}
    }
    function makeObject(props) {
        return function() {
            var o = {}
            for (var i = 0; i < props.length; i++) o[props[i].k] = props[i].t()
            return o
        }
    }

    function makeFunctionExpr(bodyT, params) {
        return function() { return makeClosure(params, bodyT, scopes) }
    }

    binOp = function(op, l, r) {
        if (op == "+") return l + r
        if (op == "-") return l - r
        if (op == "*") return l * r
        if (op == "/") return l / r
        if (op == "%") return l % r
        if (op == "==") return l == r
        if (op == "!=") return l != r
        if (op == "===") return l === r
        if (op == "!==") return l !== r
        if (op == "<")  return l < r
        if (op == ">")  return l > r
        if (op == "<=") return l <= r
        if (op == ">=") return l >= r
        if (op == "|")  return l | r
        if (op == "^")  return l ^ r
        if (op == "&")  return l & r
        if (op == "<<") return l << r
        if (op == ">>") return l >> r
        if (op == ">>>") return l >>> r
    }
    // items = [thunk, op, thunk, op, thunk, ...] -> one left folded thunk.
    // || and && evaluate lazily and return the deciding operand, like in JS.
    function makeOr(items) {
        if (items.length == 1) return items[0]
        return function() {
            var v = anytype // The operands may be of mixed types.
            v = items[0]()
            for (var i = 1; i < items.length; i++) {
                if (v) return v
                v = items[i]()
            }
            return v
        }
    }
    function makeAnd(items) {
        if (items.length == 1) return items[0]
        return function() {
            var v = anytype // The operands may be of mixed types.
            v = items[0]()
            for (var i = 1; i < items.length; i++) {
                if (!v) return v
                v = items[i]()
            }
            return v
        }
    }
    // items = [thunk] or [condThunk, thenThunk, elseThunk].
    function makeCond(items) {
        if (items.length == 1) return items[0]
        return function() { return items[0]() ? items[1]() : items[2]() }
    }

    // items = [primaryThunk, {kind:"call"|"member", ...}...]. A member access remembers
    // its object, so that a directly following call uses it as 'this'.
    foldCallMember = function(items) {
        if (items.length == 1) return items[0]
        var primary = items[0]
        var suffixes = items.slice(1)
        return function() {
            var cur = anytype     // A member chain hops between types,
            var curThis = anytype // and so does the remembered receiver.
            cur = primary()
            for (var i = 0; i < suffixes.length; i++) {
                var s = suffixes[i]
                if (s.kind == "member") {
                    curThis = cur
                    cur = getMember(cur, s.key())
                } else {
                    var argv = []
                    for (var j = 0; j < s.args.length; j++) argv.push(s.args[j]())
                    if (typeof cur != "function") fail("call of a non function value: " + cur)
                    cur = cur.apply(curThis, argv)
                    curThis = undefined
                }
            }
            return cur
        }
    }

    // Target items = [nameString, suffix marker...] -> reference descriptor.
    // Walks a target path (members and calls) up to the last element and returns
    // the assignable place {obj, key}. The last element must be a member.
    resolveRef = function(ref) {
        var cur = anytype     // The walked values and receivers
        var curThis = anytype // may be of mixed types.
        cur = getVar(ref.name)
        for (var i = 0; i < ref.path.length - 1; i++) {
            var s = ref.path[i]
            if (s.kind == "member") {
                curThis = cur
                cur = getMember(cur, s.key())
            } else {
                var argv = []
                for (var j = 0; j < s.args.length; j++) argv.push(s.args[j]())
                if (typeof cur != "function") fail("call of a non function value: " + cur)
                cur = cur.apply(curThis, argv)
                curThis = undefined
            }
        }
        var last = ref.path[ref.path.length - 1]
        if (last.kind != "member") fail("assignment target must end in a member")
        if (cur == undefined) fail("member assignment on " + cur)
        return {obj: cur, key: last.key()}
    }
    applyOp = function(op, a, b) {
        if (op == "+=") return a + b
        if (op == "-=") return a - b
        if (op == "*=") return a * b
        if (op == "/=") return a / b
        if (op == "%=") return a % b
    }
    // items = [ref, opString, valueThunk]. Returns the assigned value (assignment is an expression).
    function makeAssign(items) {
        var ref = items[0]
        var op = items[1]
        var valT = items[2]
        return function() {
            var v = anytype // A compound assignment (s += n) may change the value's type.
            v = valT()
            if (ref.path.length == 0) {
                if (op != "=") v = applyOp(op, getVar(ref.name), v)
                setVar(ref.name, v)
            } else {
                var p = resolveRef(ref)
                if (op != "=") v = applyOp(op, p.obj[p.key], v)
                p.obj[p.key] = v
            }
            return v
        }
    }
    // items = [ref, "++"|"--"]. Post increment: the expression value is the old (coerced) one.
    function makeIncDec(items) {
        var ref = items[0]
        var delta = (items[1] == "++") ? 1 : -1
        return function() {
            if (ref.path.length == 0) {
                var n = getVar(ref.name) - 0
                setVar(ref.name, n + delta)
                return n
            }
            var p = resolveRef(ref)
            var m = p.obj[p.key] - 0
            p.obj[p.key] = m + delta
            return m
        }
    }
    // Prefix ++/--: like makeIncDec, but the expression value is the new one.
    function makePreIncDec(ref, op) {
        var delta = (op == "++") ? 1 : -1
        return function() {
            if (ref.path.length == 0) {
                var n = getVar(ref.name) - 0 + delta
                setVar(ref.name, n)
                return n
            }
            var p = resolveRef(ref)
            var m = p.obj[p.key] - 0 + delta
            p.obj[p.key] = m
            return m
        }
    }

    // ----- Statement thunks: function() -> undefined | BRK | CONT | {isRet, v} -----

    // An expression in statement position: evaluate and discard the value.
    // items = [name] or [name, initThunk].
    function makeDecl(items) {
        var name = items[0]
        var init = items.length > 1 ? items[1] : makeConst(undefined)
        return function() { declVar(name, init()) }
    }
    // items = [cond, then] or [cond, then, else].
    // Note: the childs lie on the stack in source order, so pop() delivers them reversed.
    function makeDo(condT, bodyT) {
        return function() {
            do {
                var r = bodyT()
                if (r != undefined) {
                    if (r === BRK) break
                    if (r !== CONT) return r
                }
            } while (condT())
        }
    }
    // items = [{k:"init"|"cond"|"post", t:thunk}..., bodyThunk].
    function makeFor(items) {
        var bodyT = items.pop()
        var init = null, cond = null, post = null
        for (var i = 0; i < items.length; i++) {
            if (items[i].k == "init") init = items[i].t
            if (items[i].k == "cond") cond = items[i].t
