                for (var i = 0; i < arguments.length; i++) args.push(arguments[i])
                var saved = scopes
                scopes = callScopes(defScopes, plist, dflts, args)
                var r = bodyT()
                scopes = saved
                return (r != undefined && r.isRet) ? r.v : undefined
            })
        }
    }

    // global NAME: make sure NAME is bound in the module scope (unless a host
    // built-in already answers for it), so a later assignment lands there.
    function makeGlobal(names, pos) {
        return function() {
            for (var i = 0; i < names.length; i++) {
                var n = names[i]
                if (!hasOwn(globalScope, n) && !hasOwn(hostGlobals, n)) {
                    scopePut(globalScope, n, undefined)
                }
            }
        }
    }
    // nonlocal NAME: NAME must already be bound in an enclosing function scope
    // (neither the innermost scope nor the module scope count, like real Python).
    function makeNonlocal(names, pos) {
        return function() {
            for (var i = 0; i < names.length; i++) {
                var found = false
                for (var s = scopes.length - 2; s >= 1; s--) {
                    if (hasOwn(scopes[s], names[i])) { found = true; break }
                }
                if (!found) { fail("no binding for nonlocal " + names[i]) }
            }
        }
    }

    // lambda: a real single-expression function value, with the same lexical
    // capture, defaults and call scoping as def.
    function makeLambda(exprT, plist, pos) {
        if (plist.complex) { notImpl("**kwargs/keyword-only lambda parameters", pos) }
        return function() {
            var defScopes = scopes.slice()
            var dflts = evalDefaults(plist)
            return function() {
                var args = []
                for (var i = 0; i < arguments.length; i++) args.push(arguments[i])
                var saved = scopes
                scopes = callScopes(defScopes, plist, dflts, args)
                var r = exprT()
                scopes = saved
                return r
            }
        }
    }

    // The whole file runs top to bottom.
    function runProgram(items) {
        var progT = makeSeq(items)
        // A raise that escapes the top level is reported like any runtime error.
        try {
            progT()
        } catch (e) {
            if (excIsUser(e)) { fail("uncaught exception: " + e.v) }
            throw e
        }
    }

    // ----- Core library config (see lib/interp-core.js) -----
    core.lang = "python"
    core.test = pytruthy
    // Assignment creates the name in the innermost scope (Python declares by assigning).
    core.setMiss = function(name, value) { scopes[scopes.length - 1][name] = value; return true }
    // Python stdlib modules the runtime provides (resolveImport lives in
    // lib/interp-core.js; prefix match, so os.path resolves against "os").
    core.stdlibImports = ["sys", "os", "math", "collections", "itertools", "functools", "re", "json", "typing", "random", "string", "time", "dataclasses", "abc"]
    // Project-file imports: 'import mypkg.helper' / 'from mypkg.helper import x'
    // look for mypkg/helper.py, then mypkg.py under the program's directory and
    // the -i roots (c.findImport). The file is parsed with this grammar and
    // walked with the same tags: its top level runs right there
    // (real Python import-time execution) and its defs land in the global scope. A file is imported once; repeats and cycles
    // are no-ops. Deviation from real Python: the module's top-level names bind
    // directly (flat, no module object), so use the from-import style.
    var importedFiles = {}
    core.importFile = function(path, pos) {
        var rel = path.split(".").join("/")
        var cands = [rel + ".py"]
        var cut = -1
        for (var k = 0; k < rel.length; k++) { if (rel.charAt(k) == "/") { cut = k } }
        if (cut > 0) { cands.push(rel.substring(0, cut) + ".py") }
        for (var i = 0; i < cands.length; i++) {
            var file = c.findImport(cands[i])
            if (file == "") { continue }
            if (importedFiles["$" + file] == true) { return true }
            importedFiles["$" + file] = true
            var text = c.readFile(file)
            var asg = c.parse(c.agrammar, text, null)
            c.pushSource(file, text)
            c.compile(asg)
            c.popSource()
            return true
        }
        return false
    }

    c.compile(c.asg)

    println("python interpreter: program ran to completion")
    exit(0)

~~) ;
