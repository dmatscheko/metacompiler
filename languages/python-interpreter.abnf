:title("Python (subset) interpreter") ;
:description("Parses a Python subset - with significant indentation - and executes it
directly, without generating code.

The blocks are recognized with real INDENT/DEDENT handling: :script() rules keep an
indentation stack on the persistent parser stack, a suite is ':' NEWLINE INDENT
statements DEDENT, and every statement checks that it starts at the level of its block.
Comments (#) and blank lines are skipped by the newline rule. Indentation must use
spaces (no tabs).

The language: def functions (top level, with positional parameters), if/elif/else,
while, for x in <list, dict (its keys), string (its chars) or range(a[,b])>,
break/continue/pass/return, assignment and
+= -= *= /= (assignment creates a variable in the current function if none exists in
scope - there is no 'global' keyword; use a mutable list like fails = [0] for counters),
lists with negative indexing, element assignment, .append()/.pop(), dicts with
insertion order ({'a': 1}, d[k] get/set, in tests keys, len(), .keys()/.values()/
.get(k[, default]), the counts[w] = counts.get(w, 0) + 1 idiom), the list() builtin (a fresh list from any iterable), slicing of lists
and strings (s[1:3], s[:2], s[-3:]; no step), list comprehensions
([x * x for x in xs if x % 2 == 0]; the variable does not leak), len(), in / not in
membership tests on lists, strings and dicts, f-strings (f'x={a + 1}' renders like
str()), print() with
Python style rendering (True/None/[1, 2]/{'a': 1}), True/False/None, and/or/not with
Python
truthiness (empty lists and dicts are falsy) and operand values, comparisons (no
chaining),
+ - * % with float semantics, / as true division (7/2 == 3.5), // as floor division
(-7//2 == -4), % as floor modulo (-7%2 == 1), unary -, int and float literals, and
single or double quoted strings with escapes.

Not in the subset: classes, tuples, nested def/lambdas/closures, the global
keyword, comparison chaining, slice assignment and slice steps, dict comprehensions,
for-else, imports, exceptions, and
list/dict equality by value (== compares them by identity).

There is no main(): the file simply runs top to bottom. Self checking programs end
with exit(fails[0]).") ;


// --- main rules

// Shared token productions (languages/lib).
:include("lib/ident.abnf") ;
:include("lib/dq-strings.abnf") ;
:include("lib/numbers.abnf") ;

:startRule(Program) ;
:whitespace(Whitespace) ;

// The leading NL swallows any comment/blank lines at the top of the file.
Program     <~~ runProgram(takeAll()) ~~>
            = [ NL ] { TopStmt } ;
// Imports are module level (column 0) and yield no statement, so they are tried
// at the TopStmt level (before Statement) and push nothing net.
TopStmt     = SameLevel ( Import | FromImport | Statement ) ;

// Module level imports. resolveImport (lib/interp-core.js) checks each module
// path against core.stdlibImports; an unresolvable one aborts (or, under
// -warn-imports, warns and continues). An import produces no statement thunk:
// DottedName pushes the bare path and the resolving tag pops it (net zero).
Import      = KwImport ImportMod { "," ImportMod } NL ;
ImportMod   <~~ resolveImport(pop(), up.pos) ~~>
            = DottedName [ KwAs Id ] ;
FromImport  <~~ resolveImport(pop(), up.pos) ~~>
            = KwFrom DottedName KwImport ( "*" | ImportName { "," ImportName } ) NL ;
ImportName  = Id [ KwAs Id ] ;
DottedName  <~~ push(stripWs(up.in)) ~~>
            = Id { "." Id } ;
KwImport    = "import" KwEnd ;
KwFrom      = "from" KwEnd ;
KwAs        = "as" KwEnd ;

// Compound statements own their suites; small statements end with a newline.
Statement   = If | While | For | TryStmt | With | Decorated | AsyncDef | Def | SmallLine ;

SmallLine   = ( Return | Break | Continue | Pass | Raise | Assert | Global | Nonlocal | Del | YieldStmt
              | AugAssign | ParallelAssign | AnnAssign | Assign | ExprSmall ) NL ;

// A suite: ':' NEWLINE INDENT statements DEDENT. Every further statement of the
// suite starts at the same level; the first one defined the level via Indent.
Suite       <~~ push(makeSeq(takeAll())) ~~>
            = ":" NL Indent Statement { SameLevel Statement } Dedent ;

If          <~~ push(makeIf(takeAll())) ~~>
            = "if" KwEnd Expression Suite { Elif } [ Else ] ;
Elif        <~~ push(makeElif(pop(), pop())) ~~>
            = SameLevel "elif" KwEnd Expression Suite ;
Else        <~~ push(makeElse(pop())) ~~>
            = SameLevel "else" KwEnd Suite ;

While       <~~ push(makeWhile(pop(), pop())) ~~>
            = "while" KwEnd Expression Suite ;

For         <~~ push(makeFor(pop(), pop(), pop())) ~~>
            = "for" KwEnd Id <~~ push(up.in) ~~> "in" KwEnd Expression Suite ;

Def         <~~ push(makeDef(pop(), pop(), pop(), up.pos)) ~~>
            = "def" KwEnd Id <~~ push(up.in) ~~> ParamList [ "->" DiscardType ] Suite ;
// Parameter lists accept annotations, default values and *args/**kwargs; a def
// whose signature uses any of those beyond plain positional names is reported as
// not implemented (only the plain names bind). The bare '*' and '/' markers too.
ParamList   <~~ push(makeParamList(takeAll())) ~~>
            = "(" [ Param { "," Param } [ "," ] ] ")" ;
Param       = StarParam | SlashParam | NamedParam ;
StarParam   <~~ push({pcomplex: true}) ~~>
            = ( "**" | "*" ) [ Id [ ":" DiscardType ] ] ;
SlashParam  <~~ push({pcomplex: true}) ~~>
            = "/" ;
NamedParam  <~~ push(makeNamedParam(takeAll())) ~~>
            = Id <~~ push(up.in) ~~> [ ":" DiscardType ] [ ParamDefault ] ;
ParamDefault <~~ pop(); push({pdefault: true}) ~~>
            = "=" Expression ;

// A decorated def / async-def: the decorators parse (their call expressions are
// dropped) and the function is defined under its own name, unwrapped.
Decorated   = Decorator { SameLevel Decorator } SameLevel ( Def | AsyncDef ) ;
Decorator   = "@" DiscardExpr NL ;

// async def / await: accepted structurally, reported as not implemented.
AsyncDef    <~~ takeAll(); push(notImplStmt("async def", up.pos)) ~~>
            = "async" KwEnd "def" KwEnd Id ParamList [ "->" DiscardType ] Suite ;

// try/except/else/finally: accepted; under -warn-unsupported the try body (and a
// finally body) run, so calls inside them stay visible. There is no exception
// model, so the except/else handlers are parsed and dropped.
TryStmt     <~~ push(makeTry(takeAll(), up.pos)) ~~>
            = "try" KwEnd TryBody ( ExceptClause { ExceptClause } [ TryElse ] [ TryFinally ] | TryFinally ) ;
TryBody     <~~ push({trybody: pop()}) ~~>
            = Suite ;
ExceptClause <~~ push({handler: pop()}) ~~>
            = SameLevel "except" KwEnd [ DiscardExpr [ KwAs Id ] ] Suite ;
TryElse     <~~ push({elsebody: pop()}) ~~>
            = SameLevel "else" KwEnd Suite ;
TryFinally  <~~ push({finalbody: pop()}) ~~>
            = SameLevel "finally" KwEnd Suite ;

// raise: accepted, reported as not implemented; the raised expression still runs.
Raise       <~~ push(makeRaise(takeAll(), up.pos)) ~~>
            = "raise" KwEnd [ Expression [ KwFrom Expression ] ] ;

// with EXPR [as TARGET]: a simple form - the context expression runs, the target
// is bound to its value and the body runs (no __enter__/__exit__ protocol), so it
// is reported as not implemented but stays visible under -warn-unsupported.
With        <~~ push(makeWith(takeAll(), up.pos)) ~~>
            = "with" KwEnd WithItem { "," WithItem } WithBody ;
WithItem    <~~ push(makeWithItem(takeAll())) ~~>
            = Expression [ KwAs Target ] ;
WithBody    <~~ push({withbody: pop()}) ~~>
            = Suite ;

// assert COND [, MSG]: genuinely implemented - a false condition aborts the run.
Assert      <~~ push(makeAssert(takeAll())) ~~>
            = "assert" KwEnd Expression [ "," Expression ] ;

// global / nonlocal / del: accepted, reported as not implemented (no such scoping
// or deletion in the subset).
Global      <~~ push(notImplStmt("global declaration", up.pos)) ~~>
            = "global" KwEnd Id { "," Id } ;
Nonlocal    <~~ push(notImplStmt("nonlocal declaration", up.pos)) ~~>
            = "nonlocal" KwEnd Id { "," Id } ;
Del         <~~ takeAll(); push(notImplStmt("del statement", up.pos)) ~~>
            = "del" KwEnd Expression { "," Expression } ;

// yield: accepted as a statement, reported as not implemented (no generators).
YieldStmt   <~~ takeAll(); push(notImplStmt("yield", up.pos)) ~~>
            = "yield" KwEnd [ KwFrom ] [ Expression ] ;

// a, b = x, y (and a, b = b, a): all right-hand values are evaluated before any
// target is written; a single right-hand iterable is unpacked positionally.
ParallelAssign <~~ push(makeParallelAssign(takeAll())) ~~>
            = Target "," Target { "," Target } "=" Expression { "," Expression } ;

// name: Type [= value]: the annotation is parsed and ignored; with a value it is a
// plain assignment, without one it is a no-op declaration.
AnnAssign   <~~ push(makeAnnAssign(takeAll())) ~~>
            = Target ":" DiscardType [ "=" Expression ] ;

// A type annotation, parsed and ignored: dotted names, [..]-subscripts (commas
// allowed) and | unions.
DiscardType = TypeAtom { "|" TypeAtom } ;
TypeAtom    = Id { "." Id } [ TypeSub ] | TypeSub ;
TypeSub     = "[" [ TypeItem { "," TypeItem } ] "]" ;
TypeItem    = DiscardType ;
// An expression whose value is dropped (decorator calls, except types, defaults).
DiscardExpr <~~ pop() ~~>
            = Expression ;

Return      <~~ push(makeReturn(takeAll())) ~~>
            = "return" KwEnd [ Expression ] ;
Break       <~~ push(makeBreak()) ~~>    = "break" KwEnd ;
Continue    <~~ push(makeContinue()) ~~> = "continue" KwEnd ;
Pass        <~~ push(function() {}) ~~>  = "pass" KwEnd ;

AugAssign   <~~ push(makeAugAssign(takeAll())) ~~>
            = Target ( "+=" | "-=" | "*=" | "/=" ) <~~ push({op: up.in}) ~~> Expression ;
Assign      <~~ push(makeAssign(pop(), pop())) ~~>
            = Target "=" Expression ;
Target      <~~ push(makeTargetRef(takeAll())) ~~>
            = Id <~~ push(up.in) ~~> { TIndex } ;
TIndex      <~~ push({idx: pop()}) ~~>
            = "[" Expression "]" ;

ExprSmall   <~~ push(exprToStmt(pop())) ~~>
            = Expression ;

// Every expression production pushes exactly one thunk: function() -> value.
// A lambda (accepted, not implemented) binds loosest; then the a-if-c-else-b
// conditional expression (genuinely implemented); then the boolean/arith layers.
Expression  = Lambda | Ternary ;
Ternary     <~~ push(makeTernary(takeAll())) ~~>
            = OrExpr [ "if" KwEnd OrExpr "else" KwEnd Expression ] ;
Lambda      <~~ takeAll(); push(notImplExpr("lambda", up.pos)) ~~>
            = "lambda" KwEnd [ LamParam { "," LamParam } ] ":" Expression ;
// Lambda parameters take no annotation (the ':' ends the header), only defaults.
LamParam    = ( "**" | "*" ) [ Id ] | Id [ "=" DiscardExpr ] ;

OrExpr      <~~ push(makeOrAnd(takeAll(), true)) ~~>
            = AndExpr { "or" KwEnd AndExpr } ;
AndExpr     <~~ push(makeOrAnd(takeAll(), false)) ~~>
            = NotExpr { "and" KwEnd NotExpr } ;
NotExpr     = Not | Comparison ;
Not         <~~ push(makeNot(pop())) ~~>
            = "not" KwEnd NotExpr ;

Comparison  <~~ push(foldBinary(takeAll())) ~~>
            = Arith [ ( "==" | "!=" | "<=" | ">=" | "<" | ">" ) <~~ push(up.in) ~~> Arith
                    | ( "not" KwEnd "in" KwEnd ) <~~ push("not in") ~~> Arith
                    | ( "in" KwEnd ) <~~ push("in") ~~> Arith ] ;

Arith       <~~ push(foldBinary(takeAll())) ~~>
            = Term { ( "+" | "-" ) <~~ push(up.in) ~~> Term } ;

// The floor division // must be tried before /.
Term        <~~ push(foldBinary(takeAll())) ~~>
            = Factor { ( "*" | "//" | "/" | "%" ) <~~ push(up.in) ~~> Factor } ;

Factor      = Neg | Await | PostfixExpr ;
Neg         <~~ push(makeNeg(pop())) ~~>
            = "-" Factor ;
// await EXPR: accepted, reported as not implemented (no coroutines).
Await       <~~ takeAll(); push(notImplExpr("await", up.pos)) ~~>
            = "await" KwEnd Factor ;

// f(a), s[i], s[a:b], lst.append(x).
PostfixExpr = CallMember ;
CallMember  <~~ push(foldCallMember(takeAll())) ~~>
            = Primary { CallSfx | MethodSfx | SliceSfx | IndexSfx } ;
CallSfx     <~~ push({kind:"call", args: takeAll()}) ~~>
            = "(" [ Expression { "," Expression } ] ")" ;
MethodSfx   <~~ push({kind:"mcall", name: popName(), args: takeAll()}) ~~>
            = "." Id <~~ push({mname: up.in}) ~~> "(" [ Expression { "," Expression } ] ")" ;
// A slice s[lo:hi] with both ends optional; tried before plain indexing (the
// missing ':' makes it fail fast there).
SliceSfx    <~~ push(makeSliceSfx(takeAll())) ~~>
            = "[" [ SliceLo ] ":" [ SliceHi ] "]" ;
SliceLo     <~~ push({slo: pop()}) ~~> = Expression ;
SliceHi     <~~ push({shi: pop()}) ~~> = Expression ;
IndexSfx    <~~ push({kind:"index", idx: pop()}) ~~>
            = "[" Expression "]" ;

Primary     = "(" Expression ")" | FString | StringLit | DecLit | True | False | None
            | ListComp | ListLit | DictLit | VarRef ;

// [expr for x in iterable if cond] builds a list; the variable is comprehension local.
ListComp    <~~ push(makeListComp(takeAll())) ~~>
            = "[" Expression "for" KwEnd Id <~~ push({cvar: up.in}) ~~> "in" KwEnd Expression
              [ CompIf ] "]" ;
CompIf      <~~ push({cif: pop()}) ~~>
            = "if" KwEnd Expression ;

// {k: v, ...}: keys and values are expressions; entries keep their insertion order.
DictLit     <~~ push(makeDict(takeAll())) ~~>
            = "{" [ DictEntry { "," DictEntry } ] "}" ;
DictEntry   <~~ var dv = pop(); push({dk: pop(), dv: dv}) ~~>
            = Expression ":" Expression ;

// f-string: literal chunks and {expression} parts; every expression renders like str().
FString     <~~ push(makeFString(takeAll())) ~~>
            = ( 'f"' | 'F"' ) :whitespace() { FExpr | FChunk } '"' :whitespace(Whitespace) ;
FExpr       = "{" :whitespace(Whitespace) Expression "}" :whitespace() ;
FChunk      <~~ push({chunk: unescapeJs(up.in)}) ~~>
            = FChar { FChar } ;
FChar       = StrEsc | FPlain ;
// Everything printable except the quote, the braces and the backslash.
FPlain      = "\x20"..."\x21" | "\x23"..."\x5b" | "\x5d"..."\x7a" | "|" | "\x7e" | @"\t" | "\x7f"..."\U0010ffff" ;

ListLit     <~~ push(makeList(takeAll())) ~~>
            = "[" [ Expression { "," Expression } ] "]" ;

StringLit   = DqString | SqString ;
True        <~~ push(makeConst(true)) ~~>      = "True" KwEnd ;
False       <~~ push(makeConst(false)) ~~>     = "False" KwEnd ;
None        <~~ push(makeConst(undefined)) ~~> = "None" KwEnd ;

VarRef      <~~ push(makeVarRef(up.in)) ~~>
            = Id ;

// A logical line break: one or more newlines (blank and comment lines collapse,
// because the whitespace skip eats spaces and # comments), or the end of the file.
NL          = RealNL | AtEOF ;
RealNL      = "\n" { "\n" } ;

AtEOF = :script(~~
    (function() {
        return (c.peek(0) === -1) ? undefined : abnf.newToken("\x01not-at-eof", 0)
    })()
~~) ;

// The indentation machinery. The persistent parser stack holds the indentation
// levels; the scripts scan the spaces of the current line with c.peek().
// Indent: the line is deeper than the current level - push the new level.
Indent = :script(~~
    (function() {
        var n = 0
        while (c.peek(n) === 32) n++
        if (c.peek(n) === -1) n = -1
        var top = pop()
        if (top == null) top = 0
        push(top)
        if (n > top) { push(n); return undefined }
        return abnf.newToken("\x01expected-an-indented-block", 0)
    })()
~~) ;
// Dedent: the line (or the end of file) is shallower - pop one level.
Dedent = :script(~~
    (function() {
        var n = 0
        while (c.peek(n) === 32) n++
        if (c.peek(n) === -1) n = -1
        var top = pop()
        if (top == null) top = 0
        if (n < top) { return undefined }
        push(top)
        return abnf.newToken("\x01expected-a-dedent", 0)
    })()
~~) ;
// SameLevel: the line starts exactly at the current level.
SameLevel = :script(~~
    (function() {
        var n = 0
        while (c.peek(n) === 32) n++
        if (c.peek(n) === -1) n = -1
        var top = pop()
        if (top == null) top = 0
        push(top)
        return (n == top) ? undefined : abnf.newToken("\x01wrong-indentation-level", 0)
    })()
~~) ;

// Whitespace never includes newlines: they are structure, not noise.
Whitespace  = { @+" \t" | Comment } ;
Comment     = "#" :whitespace() { NotNewline } :whitespace(Whitespace) ;
NotNewline  = "\x00"..."\x09" | "\x0b"..."\U0010ffff" ;

// ---


:startScript(~~

    // Shared interpreter machinery (scopes, BRK/CONT protocol, expression and
    // statement builders); language-specific behavior is configured on `core` below.
    include("lib/interp-core.js")

    // The host names a program can see.
    hostGlobals["print"] = function() {
        var out = ""
        for (var i = 0; i < arguments.length; i++) {
            if (i > 0) out += " "
            out += pstr(arguments[i])
        }
        println(out)
    }
    hostGlobals["len"] = function(x) {
        if (isDict(x)) return x.keys.length
        return x.length
    }
    // list(x): a fresh list from any iterable (lists copy, dicts give their keys).
    hostGlobals["list"] = function(x) { return iterToList(x).slice(0) }
    hostGlobals["range"] = function(a, b) {
        var from = 0
        var to = a
        if (b !== undefined) { from = a; to = b }
        var out = []
        for (var i = from; i < to; i++) out.push(i)
        return out
    }
    hostGlobals["exit"] = function(code) { exit(code | 0) }
    hostGlobals["abs"] = function(v) { return v < 0 ? -v : v }

    // ----- Dicts: {__dict, keys, vals} with two parallel arrays. The arrays keep
    // the insertion order (like Python) and allow any === comparable key. -----
    function isDict(v) {
        return v !== undefined && v !== null && typeof v == "object" && v.__dict === true
    }
    function newDict() { return {__dict: true, keys: [], vals: []} }
    function dictFind(d, k) {
        for (var i = 0; i < d.keys.length; i++) {
            if (d.keys[i] === k) return i
        }
        return -1
    }
    function dictSet(d, k, v) {
        var i = dictFind(d, k)
        if (i >= 0) { d.vals[i] = v }
        else { d.keys.push(k); d.vals.push(v) }
    }

    // Python style rendering: True/False/None, lists in brackets, dicts in braces.
    function prepr(v) {
        if (typeof v == "string") return "'" + v + "'"
        return pstr(v)
    }
    function pstr(v) {
        if (v === undefined || v === null) return "None"
        if (v === true) return "True"
        if (v === false) return "False"
        if (Array.isArray(v)) {
            var out = "["
            for (var i = 0; i < v.length; i++) {
                if (i > 0) out += ", "
                out += prepr(v[i])
            }
            return out + "]"
        }
        if (isDict(v)) {
            var out2 = "{"
            for (var k = 0; k < v.keys.length; k++) {
                if (k > 0) out2 += ", "
                out2 += prepr(v.keys[k]) + ": " + prepr(v.vals[k])
            }
            return out2 + "}"
        }
        return "" + v
    }
    // Python truthiness: empty lists and dicts are falsy.
    function pytruthy(v) {
        if (Array.isArray(v)) return v.length > 0
        if (isDict(v)) return v.keys.length > 0
        if (v === undefined || v === null) return false
        return !!v
    }

    function pyget(o, i) {
        if (isDict(o)) {
            var di = dictFind(o, i)
            if (di < 0) fail("KeyError: " + pstr(i))
            return o.vals[di]
        }
        if (typeof o == "string") {
            if (i < 0) i += o.length
            if (i < 0 || i >= o.length) fail("string index out of range")
            return o.charAt(i)
        }
        if (i < 0) i += o.length
        if (i < 0 || i >= o.length) fail("list index out of range")
        return o[i]
    }
    // Slicing with Python bounds: open ends, negative wrap around, clamping.
    function pySlice(o, lo, hi) {
        var n = o.length
        if (lo === undefined) { lo = 0 } else { if (lo < 0) lo += n; if (lo < 0) lo = 0; if (lo > n) lo = n }
        if (hi === undefined) { hi = n } else { if (hi < 0) hi += n; if (hi < 0) hi = 0; if (hi > n) hi = n }
        if (hi < lo) hi = lo
        if (typeof o == "string") return o.slice(lo, hi)
        var out = []
        for (var i = lo; i < hi; i++) out.push(o[i])
        return out
    }
    // The list a for loop or comprehension runs over: dicts iterate their keys
    // (a snapshot), strings their characters.
    function iterToList(v) {
        if (Array.isArray(v)) return v
        if (isDict(v)) return v.keys.slice(0)
        if (typeof v == "string") {
            var out = []
            for (var i = 0; i < v.length; i++) out.push(v.charAt(i))
            return out
        }
        fail("iteration over " + pstr(v))
    }
    function mcall(target, name, args) {
        if (Array.isArray(target)) {
            if (name == "append") { target.push(args[0]); return undefined }
            if (name == "pop") {
                if (target.length == 0) fail("pop from empty list")
                return target.pop()
            }
            fail("unknown list method: " + name)
        }
        if (isDict(target)) {
            if (name == "keys") return target.keys.slice(0)
            if (name == "values") return target.vals.slice(0)
            if (name == "get") {
                var i = dictFind(target, args[0])
                if (i >= 0) return target.vals[i]
                return args.length > 1 ? args[1] : undefined
            }
            fail("unknown dict method: " + name)
        }
        fail("method call ." + name + "() on " + pstr(target))
    }


    // ----- Expression thunks -----

    makeNeg = function(t) { return function() { return -t() } }
    makeNot = function(t) { return function() { return !pytruthy(t()) } }

    function fdiv(a, b) { return Math.floor(a / b) }
    function fmod(a, b) {
        var r = a % b
        if (r != 0 && ((r < 0) != (b < 0))) r += b
        return r
    }
    binOp = function(op, l, r) {
        if (op == "+") return l + r
        if (op == "-") return l - r
        if (op == "*") return l * r
        if (op == "/") return l / r
        if (op == "//") return fdiv(l, r)
        if (op == "%") return fmod(l, r)
        if (op == "==") return l === r
        if (op == "!=") return l !== r
        if (op == "<")  return l < r
        if (op == ">")  return l > r
        if (op == "<=") return l <= r
        if (op == ">=") return l >= r
        if (op == "in") return pyIn(l, r)
        if (op == "not in") return !pyIn(l, r)
    }
    // Python 'x in y' for lists, strings and dict keys.
    function pyIn(l, r) {
        if (typeof r == "string") return r.indexOf(l) >= 0
        if (isDict(r)) return dictFind(r, l) >= 0
        for (var i = 0; i < r.length; i++) {
            if (r[i] === l) return true
        }
        return false
    }
    // items = [{chunk: text} | expression thunk, ...] -> the f-string value.
    function makeFString(items) {
        return function() {
            var out = ""
            for (var i = 0; i < items.length; i++) {
                var it = items[i]
                if (typeof it == "function") out += pstr(it())
                else out += it.chunk
            }
            return out
        }
    }
    // and/or return the deciding operand, with Python truthiness.
    makeOrAnd = function(items, isOr) {
        if (items.length == 1) return items[0]
        return function() {
            var v = anytype // The operands may be of mixed types.
            v = items[0]()
            for (var i = 1; i < items.length; i++) {
                if (isOr) { if (pytruthy(v)) return v }
                else      { if (!pytruthy(v)) return v }
                v = items[i]()
            }
            return v
        }
    }

    foldCallMember = function(items) {
        if (items.length == 1) return items[0]
        var primary = items[0]
        var suffixes = items.slice(1)
        return function() {
            var cur = anytype // A member chain hops between types.
            cur = primary()
            for (var i = 0; i < suffixes.length; i++) {
                var s = suffixes[i]
                if (s.kind == "call") {
                    var argv = []
                    for (var j = 0; j < s.args.length; j++) argv.push(s.args[j]())
                    if (typeof cur != "function") fail("call of a non function")
                    cur = cur.apply(undefined, argv)
                } else if (s.kind == "mcall") {
                    var argv2 = []
                    for (var j2 = 0; j2 < s.args.length; j2++) argv2.push(s.args[j2]())
                    cur = mcall(cur, s.name, argv2)
                } else if (s.kind == "slice") {
                    cur = pySlice(cur, s.lo != null ? s.lo() : undefined, s.hi != null ? s.hi() : undefined)
                } else {
                    cur = pyget(cur, s.idx())
                }
            }
            return cur
        }
    }

    function makeList(items) {
        return function() {
            var a = []
            for (var i = 0; i < items.length; i++) a.push(items[i]())
            return a
        }
    }
    // items = [{dk, dv}...] -> a dict built in source order.
    function makeDict(items) {
        return function() {
            var d = newDict()
            for (var i = 0; i < items.length; i++) dictSet(d, items[i].dk(), items[i].dv())
            return d
        }
    }
    // items = [{slo}?, {shi}?] -> a slice suffix descriptor.
    function makeSliceSfx(items) {
        var lo = null
        var hi = null
        for (var i = 0; i < items.length; i++) {
            if (items[i].slo != undefined) lo = items[i].slo
            if (items[i].shi != undefined) hi = items[i].shi
        }
        return {kind: "slice", lo: lo, hi: hi}
    }
    // items = [exprT, {cvar}, iterT, {cif}?]. The variable lives in an own scope
    // (Python 3 comprehension scoping: it does not leak).
    function makeListComp(items) {
        var exprT = items[0]
        var name = items[1].cvar
        var iterT = items[2]
        var condT = items.length > 3 ? items[3].cif : null
        return function() {
            var arr = iterToList(iterT())
            var out = []
            scopes.push({})
            for (var i = 0; i < arr.length; i++) {
                scopes[scopes.length - 1][name] = arr[i]
                if (condT == null || pytruthy(condT())) out.push(exprT())
            }
            scopes.pop()
            return out
        }
    }

    function assignRef(ref, v) {
        if (ref.path.length == 0) { setVar(ref.name, v); return }
        var o = anytype // The containers along the path may be of mixed types.
        o = getVar(ref.name)
        for (var i = 0; i < ref.path.length - 1; i++) o = pyget(o, ref.path[i].idx())
        var idx = ref.path[ref.path.length - 1].idx()
        if (isDict(o)) { dictSet(o, idx, v); return }
        if (idx < 0) idx += o.length
        if (idx < 0 || idx >= o.length) fail("list assignment index out of range")
        o[idx] = v
    }
    function readRef(ref) {
        if (ref.path.length == 0) return getVar(ref.name)
        var o = anytype // The last step lands on the element itself.
        o = getVar(ref.name)
        for (var i = 0; i < ref.path.length; i++) o = pyget(o, ref.path[i].idx())
        return o
    }
    function makeAssign(valT, ref) {
        return function() { assignRef(ref, valT()) }
    }
    function makeAugAssign(items) {
        var ref = items[0]
        var op = items[1].op
        var valT = items[2]
        return function() {
            var a = readRef(ref)
            var b = valT()
            var v
            if (op == "+=") { v = a + b }
            else if (op == "-=") { v = a - b }
            else if (op == "*=") { v = a * b }
            else { v = a / b }
            assignRef(ref, v)
        }
    }

    // ----- Statement thunks -----

    // items = [cond, suite, {elif}..., {else}?]
    function makeElif(suite, cond) { return {elifCond: cond, suite: suite} }
    function makeElse(suite) { return {elseSuite: suite} }
    makeIf = function(items) {
        var cond = items[0]
        var thenT = items[1]
        var elifs = []
        var elseT = null
        for (var i = 2; i < items.length; i++) {
            if (items[i].elifCond != undefined) elifs.push(items[i])
            if (items[i].elseSuite != undefined) elseT = items[i].elseSuite
        }
        return function() {
            if (pytruthy(cond())) return thenT()
            for (var k = 0; k < elifs.length; k++) {
                if (pytruthy(elifs[k].elifCond())) return elifs[k].suite()
            }
            if (elseT != null) return elseT()
        }
    }
    function makeFor(bodyT, listT, name) {
        return function() {
            var arr = iterToList(listT())
            for (var i = 0; i < arr.length; i++) {
                setVar(name, arr[i])
                var r = bodyT()
                if (r != undefined) {
                    if (r === BRK) break
                    if (r !== CONT) return r
                }
            }
        }
    }
    function makeReturn(items) {
        var t = items.length > 0 ? items[0] : makeConst(undefined)
        return function() { return {isRet: true, v: t()} }
    }
    // ----- Widened surface: newly accepted constructs -----

    // a if c else b: genuinely lowered, short-circuiting like Python.
    function makeTernary(items) {
        if (items.length == 1) { return items[0] }
        var thenT = items[0]
        var condT = items[1]
        var elseT = items[2]
        return function() {
            if (pytruthy(condT())) { return thenT() }
            return elseT()
        }
    }
    // a, b = x, y: evaluate every right-hand value first, then write each target;
    // a single right-hand iterable is unpacked positionally.
    function makeParallelAssign(items) {
        var targets = []
        var values = []
        for (var i = 0; i < items.length; i++) {
            if (typeof items[i] == "function") { values.push(items[i]) }
            else { targets.push(items[i]) }
        }
        return function() {
            var vals = []
            if (values.length == 1 && targets.length > 1) {
                var it = iterToList(values[0]())
                for (var j = 0; j < it.length; j++) { vals.push(it[j]) }
            } else {
                for (var k = 0; k < values.length; k++) { vals.push(values[k]()) }
            }
            for (var m = 0; m < targets.length; m++) {
                assignRef(targets[m], m < vals.length ? vals[m] : undefined)
            }
        }
    }
    // name: Type [= value]: the annotation is ignored; assign when a value is given.
    function makeAnnAssign(items) {
        var ref = items[0]
        if (items.length < 2) { return function() {} }
        var valT = items[1]
        return function() { assignRef(ref, valT()) }
    }
    // assert COND [, MSG]: a false condition aborts with AssertionError.
    function makeAssert(items) {
        var condT = items[0]
        var msgT = items.length > 1 ? items[1] : null
        return function() {
            if (!pytruthy(condT())) {
                if (msgT != null) { fail("AssertionError: " + pstr(msgT())) }
                fail("AssertionError")
            }
        }
    }
    // try/except/else/finally: not implemented (no exception model). Under
    // -warn-unsupported the try body and any finally body run in sequence; the
    // except/else handlers are dropped.
    function makeTry(items, pos) {
        notImpl("try/except", pos)
        var tryBody = null
        var finalBody = null
        for (var i = 0; i < items.length; i++) {
            if (items[i].trybody != undefined) { tryBody = items[i].trybody }
            if (items[i].finalbody != undefined) { finalBody = items[i].finalbody }
        }
        return function() {
            var r = anytype // May carry a control-flow signal from the body.
            r = undefined
            if (tryBody != null) { r = tryBody() }
            if (finalBody != null) {
                var rf = finalBody()
                if (rf != undefined) { return rf }
            }
            return r
        }
    }
    // raise: not implemented (no unwinding). The raised expression still runs.
    function makeRaise(items, pos) {
        notImpl("raise", pos)
        return function() {
            for (var i = 0; i < items.length; i++) { items[i]() }
            return undefined
        }
    }
    // with EXPR [as T]: a simple form (no context-manager protocol) - run each
    // context expression, bind the target to its value, then run the body.
    function makeWithItem(items) {
        var target = items.length > 1 ? items[1] : null
        return {ctxitem: items[0], target: target}
    }
    function makeWith(items, pos) {
        notImpl("with statement", pos)
        var body = null
        var mgrs = []
        for (var i = 0; i < items.length; i++) {
            if (items[i].withbody != undefined) { body = items[i].withbody }
            else if (items[i].ctxitem != undefined) { mgrs.push(items[i]) }
        }
        return function() {
            for (var j = 0; j < mgrs.length; j++) {
                var v = mgrs[j].ctxitem()
                if (mgrs[j].target != null) { assignRef(mgrs[j].target, v) }
            }
            if (body != null) { return body() }
            return undefined
        }
    }
    // A parameter list: collect the plain positional names; flag *args/**kwargs,
    // annotations-with-defaults and the '*'/'/' markers as unsupported.
    function makeParamList(items) {
        var names = []
        var complex = false
        for (var i = 0; i < items.length; i++) {
            if (items[i].pcomplex == true) { complex = true }
            if (items[i].pname != undefined) { names.push(items[i].pname) }
        }
        return {params: names, complex: complex}
    }
    function makeNamedParam(items) {
        if (items.length > 1) { return {pname: items[0], pcomplex: true} }
        return {pname: items[0]}
    }

    // def: bind the closure; calls get a fresh function scope. A signature using
    // *args/**kwargs/defaults is reported as not implemented (plain names bind).
    function makeDef(bodyT, plist, name, pos) {
        if (plist.complex) { notImpl("*args/keyword/default parameters", pos) }
        var params = plist.params
        return function() {
            setVar(name, function() {
                var args = []
                for (var i = 0; i < arguments.length; i++) args.push(arguments[i])
                var saved = scopes
                scopes = [globalScope, {}]
                for (var p = 0; p < params.length; p++) {
                    scopes[1][params[p]] = p < args.length ? args[p] : undefined
                }
                var r = bodyT()
                scopes = saved
                return (r != undefined && r.isRet) ? r.v : undefined
            })
        }
    }

    // The whole file runs top to bottom.
    function runProgram(items) {
        var progT = makeSeq(items)
        progT()
    }

    // ----- Core library config (see lib/interp-core.js) -----
    core.lang = "python"
    core.test = pytruthy
    // Assignment creates the name in the innermost scope (Python declares by assigning).
    core.setMiss = function(name, value) { scopes[scopes.length - 1][name] = value; return true }
    // Python stdlib modules the runtime provides (resolveImport lives in
    // lib/interp-core.js; prefix match, so os.path resolves against "os").
    core.stdlibImports = ["sys", "os", "math", "collections", "itertools", "functools", "re", "json", "typing", "random", "string", "time", "dataclasses", "abc"]

    c.compile(c.asg)

    println("python interpreter: program ran to completion")
    exit(0)

