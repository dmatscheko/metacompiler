    function makeReturn(items) {
        var t = items.length > 0 ? items[0] : makeInt(0)
        return function() { return {isRet: true, v: t()} }
    }
    // ----- Top level -----

    // Param items = [{sname}?, "*"?, name]: int, int*, or a struct pointer.
    function makeParam(items) {
        var i = 0
        var sname
        if (items[i] != undefined && items[i].sname != undefined) { sname = items[i].sname; i++ }
        var ptr = false
        if (items[i] == "*") { ptr = true; i++ }
        if (sname != undefined && !ptr) fail("struct parameters must be pointers (struct " + sname + " *)")
        var ct = ptr ? {k: "ptr", to: (sname != undefined ? sname : "int")} : ctInt
        return {name: items[i], ptr: ptr, ct: ct}
    }
    // Global declarator: ["*"?] name [{size}|{init: n}] -> registered immediately.
    function makeGDecl(items) {
        var i = 0
        var isPtr = false
        if (items[i] == "*") { isPtr = true; i++ }
        var name = items[i]
        var opt = items[i + 1]
        var ct = isPtr ? {k: "ptr", to: "int"} : ctInt
        if (opt != undefined && opt.size != undefined) {
            declVar(name, alloc(opt.size), true, ct)
        } else {
            var a = alloc(1)
            if (opt != undefined) mem[a] = opt.init | 0
            declVar(name, a, false, ct)
        }
    }
    function defineGlobals(items) {} // makeGDecl already registered them.

    function defineFunction() {
        var bodyT = pop()
        var params = pop()
        var name = pop()
        funcs[name] = {params: params, body: bodyT}
    }

    // ----- Core library config (see lib/interp-core.js) -----
    core.lang = "c"
    core.test = function(v) { return v != 0 } // C conditions: any nonzero int.
    // System headers the runtime already provides; #include of anything else is an
    // external library we cannot resolve (see resolveImport in lib/interp-core.js).
    core.stdlibImports = ["stdio.h", "stdlib.h", "string.h", "math.h", "ctype.h", "stdbool.h", "stdint.h", "stddef.h", "limits.h", "assert.h", "stdarg.h"]

    c.compile(c.asg)

    if (funcs["main"] == undefined) {
        println("Error: C programs need a main() function.")
        exit(1)
    }
    var ret = callFunction("main", [])
    println("c interpreter: main() returned " + ret)
    exit(ret)

