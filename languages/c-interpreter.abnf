:title("C (subset) interpreter") ;
:description("Parses a C subset and executes it directly, without generating code.

The language is a real C subset, richer than TinyC: the types int, int* and int[N]
(globals and locals, globals with constant initializers), structs (struct definitions
with int, pointer and nested struct value fields - including pointers to the struct
itself for linked lists -, struct locals, globals and arrays of structs, struct
pointers with initializers, . and -> member access along whole paths like
nodes[i].next->value, &s and struct pointer parameters), address-of (&x, &a[i]),
dereferencing (*p, also as assignment target), pointer arithmetic (p + i steps whole
ints), pre and post ++/--, assignment as an expression with = += -= *= /= %=, the
ternary operator, || and && with real C short circuit evaluation, the bitwise operators
| ^ & << >> and unary - ! ~, char literals ('A', '\n'), comparisons, function calls and
recursion, switch with real C fallthrough (stacked case labels, default, break), and
putchar()/getchar(). int is 32 bit, / and % truncate towards zero.
Not in the subset: struct assignment/initializers, struct values as parameters or
return types, (*p).f on struct pointers (use p->f), pointer arithmetic on struct
pointers (index them instead), typedef, sizeof, strings, casts, and multi level
pointers (int**).

The interpreter uses one flat, word addressed memory array: every variable lives at an
address, scopes map names to addresses, and pointers are plain indexes; every int,
pointer and struct field takes one word. That makes the semantics exactly match the
compiled version (c-to-llvm-ir.abnf), where the same programs run as LLVM IR.

Every tag composes a small JS closure (a 'thunk') out of the thunks of its children.
Lvalue thunks return an address, expression thunks return the value, statement thunks
return undefined or a signal (return/break/continue) that the enclosing statements route.

The exit code of the metacompiler run is the value that main() returns, so C test
programs are self checking: they return 0 on success.") ;


// --- main rules

// Shared token productions (languages/lib).
:include("lib/cstyle-comments.abnf") ;
:include("lib/ident.abnf") ;

:startRule(Program) ;
:whitespace(Whitespace) ;

Program     = { Include | PPLine | EnumDef | UnionDef | TypedefDecl | GFloatDecl
              | StructDef | StructGDecl | FuncDef | Proto | GAggDecl | GlobalDecl } ;

// Preprocessor directives other than #include are accepted and skipped (object-like
// #define, the #if/#ifdef/#ifndef/#else/#elif/#endif family, #undef, #pragma, #error,
// #line). The line (with backslash continuations) is consumed as text and ignored;
// macro bodies are NOT expanded, so a name #define'd to a value stays unresolved if
// used later. Include is tried first, so #include keeps its header resolution.
PPLine      = "#" :whitespace() { PPCont | PPChar } :whitespace(Whitespace) ;
PPCont      = "\\" [ "\r" ] "\n" ;
PPChar      = "\x00"..."\x09" | "\x0b"..."\U0010ffff" ;

// enum Color { RED, GREEN = 5, BLUE }; -- genuinely lowered to named int constants
// (sequential from 0, or from an explicit value). The optional tag is ignored; the
// constants live in a global table and resolve wherever a bare name is read.
EnumDef     <~~ defineEnum(takeAll()) ~~>
            = KwEnum [ Id <~~ push({tag: up.in}) ~~> ]
              "{" [ Enumerator { "," Enumerator } [ "," ] ] "}" ";" ;
Enumerator  <~~ push(makeEnumerator(takeAll())) ~~>
            = Id <~~ push(up.in) ~~> [ "=" EnumInit ] ;
EnumInit    <~~ push({val: makeEnumVal(takeAll())}) ~~>
            = [ "-" <~~ push("-") ~~> ] Number ;

// union U { ... }; -- accepted structurally, then reported as not implemented (the
// flat one-word memory has no overlapping layout). The balanced body is skipped.
UnionDef    <~~ notImpl("union", up.pos) ~~>
            = KwUnion [ Id ] SkipBlock ";" ;

// typedef <anything> Name; -- accepted and reported as not implemented (there is no
// symbol table, so the introduced name cannot later be used as a type). The whole
// declaration, including a braced struct/union/enum body, is skipped up to its ';'.
TypedefDecl <~~ notImpl("typedef", up.pos) ~~>
            = KwTypedef { SkipBlock | TdChar } ";" ;
TdChar      = "\x00"..."\x3a" | "\x3c"..."\x7a" | "\x7c" | "\x7e"..."\U0010ffff" ;

// Global float/double declarations: accepted and reported as not implemented (the
// machine is integer only). The initializer / array size text is skipped to the ';'.
GFloatDecl  <~~ notImpl("floating-point declaration", up.pos) ~~>
            = KwFloating { SkipBlock | TdChar } ";" ;

// A balanced { ... } body consumed without interpreting it (string and char literals
// are matched first so braces inside them are never miscounted). Copied from the
// shared widening pattern (see the Kotlin/Java grammars).
SkipBlock   = "{" { SkipItem } "}" ;
SkipItem    = SkipStr | SkipChar | SkipBlock | SkipOther ;
SkipStr     = '"' :whitespace() { SkipStrEsc | SkipStrChar } '"' :whitespace(Whitespace) ;
SkipStrEsc  = "\\" "\x00"..."\U0010ffff" ;
SkipStrChar = "\x00"..."\x21" | "\x23"..."\x5b" | "\x5d"..."\U0010ffff" ;
SkipChar    = "'" :whitespace() { SkipChEsc | SkipChChar } "'" :whitespace(Whitespace) ;
SkipChEsc   = "\\" "\x00"..."\U0010ffff" ;
SkipChChar  = "\x00"..."\x26" | "\x28"..."\x5b" | "\x5d"..."\U0010ffff" ;
SkipOther   = "\x00"..."\x21" | "\x23"..."\x26" | "\x28"..."\x7a" | "\x7c" | "\x7e"..."\U0010ffff" ;

// A balanced ( ... ) run, parsed and ignored (used to skip __attribute__ argument
// lists). Same shape as SkipBlock but for parentheses; strings and char literals are
// matched first so parens inside them are never miscounted.
SkipParen   = "(" { SkipStr | SkipChar | SkipParen | SkipPOther } ")" ;
SkipPOther  = "\x00"..."\x21" | "\x23"..."\x26" | "\x2a"..."\U0010ffff" ;

// __attribute__((...)) GCC attribute specifiers are accepted and ignored wherever a
// type specifier or a prototype tail may appear; the balanced (( )) body is skipped.
Attr        = ( "__attribute__" | "__attribute" ) SkipParen ;

// #include <stdio.h> or #include "local.h": the header is routed through the
// shared resolveImport (lib/interp-core.js). System <...> headers listed in
// core.stdlibImports resolve; a quoted "local.h" or an unknown header aborts,
// or warns under -warn-imports. The production-level tag's up.in is the whole
// <...>/"..." token including its delimiters, so slice them off to get the bare
// header name. Nothing is pushed, so an include yields no top-level statement.
Include     = "#" "include" ( SysHeader | LocHeader ) ;
SysHeader   <~~ resolveImport(up.in.slice(1, up.in.length - 1), up.pos) ~~>
            = "<" :whitespace() { HdrChar } ">" :whitespace(Whitespace) ;
LocHeader   <~~ resolveImport(up.in.slice(1, up.in.length - 1), up.pos) ~~>
            = '"' :whitespace() { HdrChar } '"' :whitespace(Whitespace) ;
HdrChar     = "\x20"..."\x21" | "\x23"..."\x3b" | "\x3d" | "\x3f"..."\x7e" ;

// struct Point { int x; int y; }; -- the fields: int, int* and, of already defined
// structs, nested struct values and struct pointers (also of the struct itself:
// that is how linked lists work).
StructDef   <~~ defineStruct(takeAll()) ~~>
            = KwStruct Id <~~ push(up.in) ~~> "{" { FieldLine } "}" ";" ;
FieldLine   <~~ push(makeFieldLine(takeAll())) ~~>
            = FieldType FDecl { "," FDecl } ";" ;
FieldType   = TypeInt <~~ push({bty: "int"}) ~~>
            | EnumRef <~~ push({bty: "int"}) ~~>
            | KwStruct Id <~~ push({bty: up.in}) ~~> ;
FDecl       = [ "*" <~~ push("*") ~~> ] Id <~~ push(up.in) ~~> ;

// A function prototype (int putchar(int c);) is accepted and ignored: the callees
// are resolved by name anyway. It keeps the test programs valid for a real C compiler.
Proto       <~~ pop(); pop() /* Drop the collected name and parameters. */ ~~>
            = TypeInt [ "*" ] Id <~~ push(up.in) ~~> ParamList { Attr } ";" ;

// The merged pushes: [name, [params...], bodyThunk]. A parameter is {name, ptr, sname?}.
FuncDef     <~~ defineFunction() ~~>
            = TypeInt Id <~~ push(up.in) ~~> ParamList { Attr } Block ;

// Param is tried before the empty (void): 'void' as a base type only makes a
// parameter with '*' (void *p); a bare '(void)' has no declarator, so Param fails
// on the missing name and the '(void)' fallback matches. A trailing '...' (a
// variadic function) is accepted and ignored: only its named parameters are tracked.
ParamList   <~~ push(takeAll()) ~~>
            = "(" [ ( Param { "," Param } [ "," "..." ] | "void" KwEnd | "..." ) ] ")" ;
Param       <~~ push(makeParam(takeAll())) ~~>
            = ParamType [ Stars ] Id <~~ push(up.in) ~~> ;
ParamType   = TypeInt | EnumRef | KwStruct Id <~~ push({sname: up.in}) ~~> ;

// Globals are declared like locals but registered at build time.
GlobalDecl  <~~ defineGlobals(takeAll()) ~~>
            = BaseInt GDeclarator { "," GDeclarator } ";" ;
GDeclarator <~~ push(makeGDecl(takeAll())) ~~>
            = [ "*" <~~ push("*") ~~> ] Id <~~ push(up.in) ~~>
              [ ArraySize | "=" Number <~~ push({init: pop()}) ~~> ] ;
ArraySize   <~~ push({size: pop()}) ~~>
            = "[" Number "]" ;

// Global struct variables, pointers and arrays (zero initialized like all globals).
StructGDecl <~~ defineStructGlobals(takeAll()) ~~>
            = KwStruct Id <~~ push(up.in) ~~> SGDecl { "," SGDecl } ";" ;
SGDecl      <~~ push(makeSDecl(takeAll())) ~~>
            = [ "*" <~~ push("*") ~~> ] Id <~~ push(up.in) ~~> [ ArraySize ] ;

// Aggregate '= { ... }' initializers and multi-dimensional arrays are accepted and
// reported as not implemented (the flat one-word memory has no aggregate init and no
// nested array layout). AggForm matches only the unsupported shapes - a brace body, an
// empty '[]', or two or more dimensions - so a plain 'int a[3];' still falls through to
// the genuine declarators. The declarator, dimensions and '{ ... }' body are all
// skipped; takeAll() drops whatever the dimension sizes pushed. GAggDecl is top-level.
GAggDecl    <~~ takeAll(); notImpl("aggregate initializer", up.pos) ~~>
            = AggBase { "*" } Id AggForm ";" ;
AggBase     = BaseInt | KwStruct Id ;
AggForm     = EmptyArr [ "=" SkipBlock ]
            | ArraySize ArraySize { ArraySize } [ "=" SkipBlock ]
            | ArraySize "=" SkipBlock
            | "=" SkipBlock ;
EmptyArr    = "[" "]" ;

// A run of one or more '*' collapses to a single pointer level (the machine has no
// multi level pointers); two or more is reported as not implemented but still parses.
Stars       <~~ push(makeStars(up.in, up.pos)) ~~> = "*" { "*" } ;

// Every statement production pushes exactly one thunk: function() -> undefined | signal.
Statement   = Block | If | While | Do | For | Switch | Return | Break | Continue
            | AggDecl | StructDecl | Decl | LFloatDecl | Goto | PPStmt | Label | Empty | ExprStmt ;

// Local aggregate / multi-dimensional / brace-initialized declarations: the statement
// form of GAggDecl (see there). Placed before StructDecl and Decl so it claims only
// the unsupported shapes and leaves genuine 'int a[3];' / 'struct P p;' to them.
AggDecl     <~~ takeAll(); push(notImplStmt("aggregate initializer", up.pos)) ~~>
            = AggBase { "*" } Id AggForm ";" ;

// goto is accepted and reported as not implemented (the structured lowering has no
// arbitrary jumps); a plain label passes its statement straight through, so labelled
// code that is not jumped to still runs.
Goto        <~~ push(notImplStmt("goto", up.pos)) ~~>
            = KwGoto Id ";" ;
// A label must not be 'case' or 'default': those are switch labels and must be left
// for the enclosing switch (a case body is a { Statement } run, so without this guard
// a label would swallow the following 'default:' clause).
Label       = NotSwitchKw Id ":" Statement ;
NotSwitchKw = :script(~~
    (function() {
        var s = 0 // Whitespace is not skipped before a :script, so scan past it first.
        while (c.peek(s) === 32 || c.peek(s) === 9 || c.peek(s) === 10 || c.peek(s) === 13) { s++ }
        var kws = ["case", "default"]
        var hit = false
        for (var k = 0; k < kws.length; k++) {
            var w = kws[k]
            var ok = true
            for (var i = 0; i < w.length; i++) { if (c.peek(s + i) !== w.charCodeAt(i)) { ok = false } }
            if (ok) {
                var cc = c.peek(s + w.length)
                if (!((cc >= 48 && cc <= 57) || (cc >= 65 && cc <= 90) || cc === 95 || (cc >= 97 && cc <= 122))) { hit = true }
            }
        }
        return hit ? abnf.newToken("\x01switch-label", 0) : undefined
    })()
~~) ;

// A preprocessor line inside a function body is skipped (no-op statement).
PPStmt      <~~ push(function() {}) ~~>
            = PPLine ;

// A local float/double declaration: accepted, reported as not implemented.
LFloatDecl  <~~ push(notImplStmt("floating-point declaration", up.pos)) ~~>
            = KwFloating { SkipBlock | TdChar } ";" ;

// Local struct variables, struct pointers (with optional initializer) and struct arrays.
StructDecl  <~~ push(makeStructDecl(takeAll())) ~~>
            = KwStruct Id <~~ push(up.in) ~~> SDeclarator { "," SDeclarator } ";" ;
SDeclarator <~~ push(makeSDecl(takeAll())) ~~>
            = [ "*" <~~ push("*") ~~> ] Id <~~ push(up.in) ~~>
              [ ArraySize | "=" AssignExpr ] ;

Block       <~~ push(makeBlockStmt(takeAll())) ~~>
            = "{" { Statement } "}" ;

If          <~~ push(makeIf(takeAll())) ~~>
            = KwIf "(" Expression ")" Statement [ KwElse Statement ] ;

While       <~~ push(makeWhile(pop(), pop())) ~~>
            = KwWhile "(" Expression ")" Statement ;

Do          <~~ push(makeDo(pop(), pop())) ~~>
            = KwDo Statement KwWhile "(" Expression ")" ";" ;

For         <~~ push(makeFor(takeAll())) ~~>
            = KwFor "(" [ ForInit ] ";" [ ForCond ] ";" [ ForPost ] ")" Statement ;
ForInit     <~~ push({k:"init", t:pop()}) ~~> = ForVar | ForExpr ;
ForVar      = DeclCore ;
ForExpr     <~~ push(exprToStmt(pop())) ~~> = Expression ;
ForCond     <~~ push({k:"cond", t:pop()}) ~~> = Expression ;
ForPost     <~~ push({k:"post", t:exprToStmt(pop())}) ~~> = Expression ;

Return      <~~ push(makeReturn(takeAll())) ~~>
            = KwReturn [ Expression ] ";" ;

Break       <~~ push(makeBreak()) ~~>   = KwBreak ";" ;
Continue    <~~ push(makeContinue()) ~~> = KwContinue ";" ;

// C switch with fallthrough: execution starts at the first matching case (or default)
// and runs until a break or the end of the switch. Labels may stack (case 1: case 2:).
Switch      <~~ push(makeSwitch(takeAll())) ~~>
            = KwSwitch "(" Expression ")" "{" { SwitchCase } "}" ;
SwitchCase  = Case | Default ;
Case        <~~ push(makeCase(takeAll())) ~~>
            = KwCase CondExpr ":" { Statement } ;
Default     <~~ push(makeDefault(takeAll())) ~~>
            = KwDefault ":" { Statement } ;

Decl        = DeclCore ";" ;
DeclCore    <~~ push(makeSeq(takeAll())) ~~>
            = BaseInt InitDecl { "," InitDecl } ;
InitDecl    <~~ push(makeDecl(takeAll())) ~~>
            = [ Stars ] Id <~~ push(up.in) ~~>
              [ ArraySize | "=" AssignExpr ] ;

Empty       <~~ push(function() {}) ~~>
            = ";" ;

ExprStmt    <~~ push(exprToStmt(pop())) ~~>
            = Expression ";" ;

// Every expression production pushes exactly one thunk: function() -> 32 bit value.
// The comma operator evaluates each side in order and yields the last (real C).
Expression  <~~ push(makeComma(takeAll())) ~~>
            = AssignExpr { "," AssignExpr } ;

// Assignment is an expression: the target is an lvalue (a variable, *expr or a[i]).
AssignExpr  = Assignment | CondExpr ;
Assignment  <~~ push(makeAssign(takeAll())) ~~>
            = Lvalue ( "<<=" | ">>=" | "+=" | "-=" | "*=" | "/=" | "%=" | "&=" | "^=" | "|=" | "=" ) <~~ push(up.in) ~~> AssignExpr ;

// An lvalue thunk evaluates to an address. A place is a variable followed by any
// mix of indexing and struct member steps: a[i], p.x, r.min.y, head->next->value.
Lvalue      = Deref | VarPlace ;
Deref       <~~ push(makeDerefPlace(pop())) ~~>
            = "*" UnaryExpr ;
VarPlace    <~~ push(makeVarPlace(takeAll())) ~~>
            = Id <~~ push(up.in) ~~> { PlaceSfx } ;
PlaceSfx    = Index | Arrow | Member ;
Index       <~~ push({idx: pop()}) ~~>
            = "[" Expression "]" ;
Arrow       = "->" Id <~~ push({arw: up.in}) ~~> ;
Member      = "." Id <~~ push({fld: up.in}) ~~> ;

CondExpr    <~~ push(makeCond(takeAll())) ~~>
            = OrExpr [ "?" AssignExpr ":" AssignExpr ] ;

OrExpr      <~~ push(makeOrAnd(takeAll(), "||")) ~~>
            = AndExpr { "||" AndExpr } ;

AndExpr     <~~ push(makeOrAnd(takeAll(), "&&")) ~~>
            = BitOrExpr { "&&" BitOrExpr } ;

BitOrExpr   <~~ push(foldBinary(takeAll())) ~~>
            = BitXorExpr { "|" <~~ push("|") ~~> BitXorExpr } ;
BitXorExpr  <~~ push(foldBinary(takeAll())) ~~>
            = BitAndExpr { "^" <~~ push("^") ~~> BitAndExpr } ;
// The & operator must not match the start of &&: && with an addressable right side
// (0 && bump()) would otherwise parse as 0 & (&bump) and poison the parse.
BitAndExpr  <~~ push(foldBinary(takeAll())) ~~>
            = EqExpr { "&" <~~ push("&") ~~> NotAmp EqExpr } ;
NotAmp = :script(~~
    (function() {
        return (c.peek(0) === 38) ? abnf.newToken("\x01single-amp-only", 0) : undefined
    })()
~~) ;

EqExpr      <~~ push(foldBinary(takeAll())) ~~>
            = RelExpr { ( "==" | "!=" ) <~~ push(up.in) ~~> RelExpr } ;

RelExpr     <~~ push(foldBinary(takeAll())) ~~>
            = ShiftExpr { ( "<=" | ">=" | "<" | ">" ) <~~ push(up.in) ~~> ShiftExpr } ;

ShiftExpr   <~~ push(foldBinary(takeAll())) ~~>
            = AddExpr { ( "<<" | ">>" ) <~~ push(up.in) ~~> AddExpr } ;

AddExpr     <~~ push(foldBinary(takeAll())) ~~>
            = MulExpr { ( "+" | "-" ) <~~ push(up.in) ~~> MulExpr } ;

MulExpr     <~~ push(foldBinary(takeAll())) ~~>
            = UnaryExpr { ( "*" | "/" | "%" ) <~~ push(up.in) ~~> UnaryExpr } ;

// Prefix operators. ++/-- work on lvalues; & takes the address of an lvalue;
// * dereferences (as an expression it loads the pointed to value).
UnaryExpr   = PreIncDec | AddrOf | DerefLoad | Neg | Not | BitNot | Sizeof | Cast | PostfixExpr ;

// A cast '(Type)expr' is accepted and reported as not implemented (the machine models
// one numeric type and uniform pointers, so a cast cannot change a value). CastType
// requires a real type keyword, so '(expr)' still parses as a parenthesized expression
// and only '(int)x' / '(struct P *)p' are taken as casts.
Cast        <~~ pop(); push(cNIExpr("cast expression", up.pos)) ~~>
            = "(" CastType ")" UnaryExpr ;
CastType    = ( TypeInt | KwStruct Id | EnumRef ) { "*" } ;

// sizeof(type): a compile-time constant. Scalars are 4 bytes, any pointer 8; a
// struct value or a sizeof over an expression is reported as not implemented.
Sizeof      = KwSizeof ( SizeofType | SizeofExpr ) ;
SizeofType  <~~ push(makeSizeof(takeAll(), up.pos)) ~~>
            = "(" SizeName ")" ;
SizeofExpr  <~~ pop(); push(cNIExpr("sizeof expression", up.pos)) ~~>
            = UnaryExpr ;
SizeName    <~~ push(makeSizeName(takeAll())) ~~>
            = SizeBase { "*" <~~ push("*") ~~> } ;
SizeBase    = TypeInt <~~ push({kind: "int"}) ~~>
            | EnumRef <~~ push({kind: "int"}) ~~>
            | KwStruct Id <~~ push({kind: "struct"}) ~~> ;
PreIncDec   <~~ push(makePreIncDec(pop(), pop())) ~~>
            = ( "++" | "--" ) <~~ push(up.in) ~~> Lvalue ;
AddrOf      <~~ push(pop() /* The lvalue thunk already yields the address. */) ~~>
            = "&" Lvalue ;
DerefLoad   <~~ push(makeLoad(makeDerefPlace(pop()))) ~~>
            = "*" UnaryExpr ;
Neg         <~~ push(makeNeg(pop())) ~~>
            = "-" UnaryExpr ;
Not         <~~ push(makeNot(pop())) ~~>
            = "!" UnaryExpr ;
BitNot      <~~ push(makeBitNot(pop())) ~~>
            = "~" UnaryExpr ;

PostfixExpr = PostIncDec | Call | Primary ;
PostIncDec  <~~ push(makePostIncDec(pop(), pop())) ~~>
            = Lvalue ( "++" | "--" ) <~~ push(up.in) ~~> ;

Call        <~~ push(makeCall(takeAll())) ~~>
            = Id <~~ push(up.in) ~~> "(" [ AssignExpr { "," AssignExpr } ] ")" ;

// A plain variable reference loads the value; an array name yields its address.
// A place path as an expression (a[i], p.x, head->next) loads the resolved cell.
// A string literal (with adjacent-literal concatenation) has no char* backing on the
// flat integer memory, so it is accepted and reported as not implemented.
Primary     = "(" Expression ")" | StrLit | NumberLit | CharLit | PlaceRef | VarRef ;
StrLit      <~~ push(cNIExpr("string literal", up.pos)) ~~>
            = SkipStr { SkipStr } ;
PlaceRef    <~~ push(makeLoad(makeVarPlace(takeAll()))) ~~>
            = Id <~~ push(up.in) ~~> PlaceSfx { PlaceSfx } ;
NumberLit   <~~ push(makeInt(pop())) ~~>
            = Number ;
CharLit     = "'" :whitespace() CChar <~~ push(makeInt(charCode(unescapeC(up.in)))) ~~> "'" :whitespace(Whitespace) ;
CChar       = "\\" "\x20"..b"\x7e" | "\x20"..."\x26" | "\x28"..."\x5b" | "\x5d"..."\x7e" ;
VarRef      <~~ push(makeVarRef(up.in)) ~~>
            = Id ;

// A hexadecimal (0x...) or decimal integer literal with optional C integer suffixes
// (u/U/l/L in any combination). parseInt reads the 0x prefix and stops at the suffix
// letters, so hex and suffixed literals both yield the right 32-bit value.
Number      <~~ push(parseInt(up.in)) ~~>
            = ( "0x" | "0X" ) :whitespace() HexDig { HexDig } { IntSfx } :whitespace(Whitespace)
            | ( "0" | "1"..."9" ) :whitespace() { "0"..."9" } { IntSfx } :whitespace(Whitespace) ;
HexDig      = "0"..."9" | "a"..."f" | "A"..."F" ;
IntSfx      = "u" | "U" | "l" | "L" ;

// The scalar integer type: any run of int-family keywords and qualifiers, all of
// which collapse to the one 32-bit int model (unsigned/signed/short/long widths and
// const/volatile qualifiers are parsed and ignored; char is a full int-sized word;
// void is accepted here so that void and void* parse). Storage-class and function
// specifiers (static/extern/register/auto/inline/_Noreturn/_Thread_local) and the
// _Atomic/restrict qualifiers are likewise parsed and ignored; _Bool and _Complex
// collapse to int; __attribute__((...)) specifiers are skipped. Pushes nothing.
TypeInt     = TypeElem { TypeElem } ;
TypeElem    = TypeTok | Attr ;
TypeTok     = "int" KwEnd | "char" KwEnd | "short" KwEnd | "long" KwEnd
            | "unsigned" KwEnd | "signed" KwEnd | "void" KwEnd
            | "const" KwEnd | "volatile" KwEnd
            | "static" KwEnd | "extern" KwEnd | "register" KwEnd | "auto" KwEnd
            | "inline" KwEnd | "restrict" KwEnd | "_Bool" KwEnd | "_Complex" KwEnd
            | "_Noreturn" KwEnd | "_Atomic" KwEnd | "_Thread_local" KwEnd ;
// A declaration base type: a scalar, or an enum tag used as an int. Pushes nothing.
BaseInt     = TypeInt | EnumRef ;
EnumRef     = KwEnum Id ;

KwStruct    = "struct" KwEnd ;
KwEnum      = "enum" KwEnd ;
KwUnion     = "union" KwEnd ;
KwTypedef   = "typedef" KwEnd ;
KwGoto      = "goto" KwEnd ;
KwSizeof    = "sizeof" KwEnd ;
KwFloating  = "float" KwEnd | "double" KwEnd ;
KwIf        = "if" KwEnd ;
KwElse      = "else" KwEnd ;
KwWhile     = "while" KwEnd ;
KwDo        = "do" KwEnd ;
KwFor       = "for" KwEnd ;
KwReturn    = "return" KwEnd ;
KwBreak     = "break" KwEnd ;
KwContinue  = "continue" KwEnd ;
KwSwitch    = "switch" KwEnd ;
KwCase      = "case" KwEnd ;
KwDefault   = "default" KwEnd ;

// ---


:startScript(~~

    // Shared interpreter machinery (scopes, BRK/CONT protocol, expression and
    // statement builders); language-specific behavior is configured on `core` below.
    include("lib/interp-core.js")

    function charCode(s) { return s.charCodeAt(0) }
    function unescapeC(s) {
        if (s.charCodeAt(0) != 92) return s
        var e = s.charCodeAt(1)
        if (e == 110) return "\n"
        if (e == 116) return "\t"
        if (e == 114) return "\r"
        if (e == 48) return String.fromCharCode(0)
        return String.fromCharCode(e) // \\ \' and everything else: the char itself.
    }

    // ----- The machine: one flat, word addressed memory -----
    // Address 0 stays unused so that 0 can act as a null pointer.
    var mem = [0]
    function alloc(words) {
        var base = mem.length
        for (var i = 0; i < words; i++) mem.push(0)
        return base
    }
    function load(addr) {
        if (addr <= 0 || addr >= mem.length) fail("invalid load at address " + addr)
        return mem[addr]
    }
    function store(addr, v) {
        if (addr <= 0 || addr >= mem.length) fail("invalid store at address " + addr)
        mem[addr] = v | 0
        return mem[addr]
    }

    // ----- Scopes map names to {addr, arr, ct} (arr marks array names: they yield
    // their address; for arrays ct is the ELEMENT type) -----
    declVar = function(name, addr, arr, ct) {
        scopes[scopes.length - 1][name] = {addr: addr, arr: arr, ct: ct}
    }
    function lookupVar(name) {
        for (var i = scopes.length - 1; i >= 0; i--) {
            if (scopes[i][name] != undefined) return scopes[i][name]
        }
        return undefined
    }
    function findVar(name) {
        var v = lookupVar(name)
        if (v == undefined) fail("variable not defined: " + name)
        return v
    }

    // enum constants: name -> integer value, filled by defineEnum, read in makeVarRef.
    var enumConsts = {}
    // A C-appropriate placeholder for an unlowered expression: yields a constant 0
    // (the shared notImplExpr returns undefined, which is not a valid C int value).
    function cNIExpr(construct, pos) { notImpl(construct, pos); return function() { return 0 } }
    // A run of '*' collapses to one pointer level; two or more is a multi-level
    // pointer, which the single-word pointer model cannot represent - reported as not
    // implemented but still parsed (the declarator keeps a single pointer level).
    function makeStars(s, pos) {
        var n = 0
        for (var i = 0; i < s.length; i++) { if (s.charCodeAt(i) == 42) n++ }
        if (n > 1) notImpl("multi-level pointer", pos)
        return "*"
    }
    // enum: sequential values from 0, or continuing after an explicit '= n'.
    function makeEnumVal(items) { return items.length > 1 ? -items[1] : items[0] }
    function makeEnumerator(items) {
        if (items.length > 1) return {name: items[0], explicit: items[1].val}
        return {name: items[0]}
    }
    function defineEnum(items) {
        var next = 0
        for (var i = 0; i < items.length; i++) {
            if (items[i].tag != undefined) continue // The enum tag is not tracked.
            if (items[i].explicit != undefined) next = items[i].explicit | 0
            enumConsts[items[i].name] = next
            next = next + 1
        }
    }
    // The comma operator: evaluate each side left to right, yield the last value.
    function makeComma(items) {
        if (items.length == 1) return items[0]
        return function() {
            var v = 0
            for (var i = 0; i < items.length; i++) v = items[i]()
            return v
        }
    }
    // sizeof: SizeName items = [{kind}, "*"...] -> {kind, ptr}. makeSizeof turns it
    // into a constant thunk (pointer 8, scalar/enum 4) or a notImpl for a struct value.
    function makeSizeName(items) { return {kind: items[0].kind, ptr: items.length > 1} }
    function makeSizeof(items, pos) {
        var d = items[0]
        if (d.ptr) return function() { return 8 }
        if (d.kind == "struct") return cNIExpr("sizeof of a struct value", pos)
        return function() { return 4 }
    }

    // ----- C types and struct layouts -----
    // A ct descriptor is {k:"int"} | {k:"ptr", to:"int"|structName} | {k:"struct", s:name}.
    // structs[name] = {size: words, fields: {fname: {off, ct}}}; fields lie back to
    // back, ints and pointers take one word each (matching the compiled layout).
    var ctInt = {k: "int"}
    var structs = {}
    function ctSize(ct) { return ct.k == "struct" ? structs[ct.s].size : 1 }
    function pointeeCt(ct) { return ct.to == "int" ? ctInt : {k: "struct", s: ct.to} }
    function structOf(sname) {
        var st = structs[sname]
        if (st == undefined) fail("struct not defined: " + sname)
        return st
    }
    function fieldOf(sname, fname) {
        var f = structOf(sname).fields[fname]
        if (f == undefined) fail("struct " + sname + " has no field " + fname)
        return f
    }
    // FieldLine items = [{bty}, "*"?, name, "*"?, name...] -> {fields: [{name, bty, star}...]}.
    function makeFieldLine(items) {
        var bty = items[0].bty
        var fields = []
        var star = false
        for (var i = 1; i < items.length; i++) {
            if (items[i] == "*") { star = true; continue }
            fields.push({name: items[i], bty: bty, star: star})
            star = false
        }
        return {fields: fields}
    }
    // StructDef items = [name, {fields}...]. Nested struct values need a complete
    // (already defined) struct; pointer fields may point at the struct itself.
    function defineStruct(items) {
        var name = items[0]
        if (structs[name] != undefined) fail("struct defined twice: " + name)
        var st = {size: 0, fields: {}}
        for (var i = 1; i < items.length; i++) {
            var fl = items[i].fields
            for (var j = 0; j < fl.length; j++) {
                var f = fl[j]
                var ct
                if (f.star) { ct = {k: "ptr", to: f.bty} }           // May point at any (even later) struct.
                else if (f.bty == "int") { ct = ctInt }
                else { structOf(f.bty); ct = {k: "struct", s: f.bty} }
                if (st.fields[f.name] != undefined) fail("duplicate field " + f.name + " in struct " + name)
                st.fields[f.name] = {off: st.size, ct: ct}
                st.size += ctSize(ct)
            }
        }
        structs[name] = st
    }

    // All user defined functions by name: {params: [{name, ptr}...], body: thunk}.
    var funcs = {}

    function callFunction(name, argValues) {
        if (name == "putchar") {
            printf("%c", argValues[0] & 255)
            return argValues[0]
        }
        if (name == "getchar") {
            return -1 // No stdin in the interpreter run (matches llvm.Run without input).
        }
        var f = funcs[name]
        if (f == undefined) fail("function not defined: " + name)
        var callerScopes = scopes
        scopes = [globalScope, {}]
        for (var i = 0; i < f.params.length; i++) {
            var a = alloc(1)
            mem[a] = (i < argValues.length ? argValues[i] : 0) | 0
            declVar(f.params[i].name, a, false, f.params[i].ct)
        }
        var r = f.body()
        scopes = callerScopes
        return (r != undefined && r.isRet) ? r.v : 0
    }

    // ----- Expression thunks: function() -> 32 bit int. Lvalue thunks -> address. -----

    function makeInt(n) { return function() { return n | 0 } }
    makeVarRef = function(name) {
        return function() {
            var v = lookupVar(name)
            if (v != undefined) return v.arr ? v.addr : load(v.addr) // An array name decays to its address.
            if (enumConsts[name] != undefined) return enumConsts[name] | 0
            fail("variable not defined: " + name)
        }
    }
    // A place path: the variable, then indexing and member steps. The walk keeps the
    // address of the current place and its C type: a[i] steps by whole elements (the
    // array in place, a pointer through its loaded base), .f adds the field offset,
    // ->f loads the pointer and adds the field offset. The result is the final address.
    function makeVarPlace(items) {
        var name = items[0]
        var path = items.slice(1)
        return function() {
            var v = findVar(name)
            if (path.length == 0) {
                if (v.arr) fail("an array is not assignable: " + name)
                return v.addr
            }
            var addr = v.addr
            var ct = v.ct != undefined ? v.ct : ctInt
            var arr = v.arr
            for (var i = 0; i < path.length; i++) {
                var s = path[i]
                if (s.idx != undefined) {
                    var idx = s.idx()
                    if (arr) { addr = addr + idx * ctSize(ct) }
                    else if (ct.k == "ptr") { ct = pointeeCt(ct); addr = load(addr) + idx * ctSize(ct) }
                    else fail("indexing needs an array or a pointer: " + name)
                } else if (s.fld != undefined) {
                    if (ct.k != "struct") fail("'.' needs a struct value: ." + s.fld)
                    var f = fieldOf(ct.s, s.fld)
                    addr += f.off
                    ct = f.ct
                } else {
                    if (ct.k != "ptr" || ct.to == "int") fail("'->' needs a struct pointer: ->" + s.arw)
                    var f2 = fieldOf(ct.to, s.arw)
                    addr = load(addr) + f2.off
                    ct = f2.ct
                }
                arr = false
            }
            return addr
        }
    }
    function makeDerefPlace(t) { return function() { return t() } }
    function makeLoad(placeT) { return function() { return load(placeT()) } }
    makeNot = function(t) { return function() { return t() == 0 ? 1 : 0 } }
    function makeBitNot(t) { return function() { return ~t() } }

    binOp = function(op, l, r) {
        if (op == "+") return (l + r) | 0
        if (op == "-") return (l - r) | 0
        if (op == "*") return Math.imul(l, r)
        if (op == "/") return (l / r) | 0
        if (op == "%") return (l % r) | 0
        if (op == "==") return (l == r) ? 1 : 0
        if (op == "!=") return (l != r) ? 1 : 0
        if (op == "<")  return (l < r) ? 1 : 0
        if (op == ">")  return (l > r) ? 1 : 0
        if (op == "<=") return (l <= r) ? 1 : 0
        if (op == ">=") return (l >= r) ? 1 : 0
        if (op == "|")  return l | r
        if (op == "^")  return l ^ r
        if (op == "&")  return l & r
        if (op == "<<") return l << r
        if (op == ">>") return l >> r
    }
    // Real C short circuit: the right side only runs if it can still change the result.
    makeOrAnd = function(items, op) {
        if (items.length == 1) return items[0]
        return function() {
            var v = items[0]() != 0
            for (var i = 1; i < items.length; i++) {
                if (op == "||") { if (v) return 1; v = items[i]() != 0 }
                else            { if (!v) return 0; v = items[i]() != 0 }
            }
            return v ? 1 : 0
        }
    }
    function makeCond(items) {
        if (items.length == 1) return items[0]
        return function() { return items[0]() != 0 ? items[1]() : items[2]() }
    }
    applyOp = function(op, a, b) {
        if (op == "+=") return (a + b) | 0
        if (op == "-=") return (a - b) | 0
        if (op == "*=") return Math.imul(a, b)
        if (op == "/=") return (a / b) | 0
        if (op == "%=") return (a % b) | 0
        if (op == "&=") return a & b
        if (op == "^=") return a ^ b
        if (op == "|=") return a | b
        if (op == "<<=") return a << b
        if (op == ">>=") return a >> b
    }
    // items = [placeThunk, opString, valueThunk]. Value of the assignment: the stored value.
    function makeAssign(items) {
        var placeT = items[0]
        var op = items[1]
        var valT = items[2]
        return function() {
            var addr = placeT()
            var v = valT()
            if (op != "=") v = applyOp(op, load(addr), v)
            return store(addr, v)
        }
    }
    function makePreIncDec(placeT, op) {
        var d = (op == "++") ? 1 : -1
        return function() {
            var addr = placeT()
            return store(addr, load(addr) + d)
        }
    }
    function makePostIncDec(op, placeT) {
        var d = (op == "++") ? 1 : -1
        return function() {
            var addr = placeT()
            var old = load(addr)
            store(addr, old + d)
            return old
        }
    }
    // items = [name, argThunk...].
    function makeCall(items) {
        var name = items[0]
        var args = items.slice(1)
        return function() {
            var argValues = []
            for (var i = 0; i < args.length; i++) argValues.push(args[i]())
            return callFunction(name, argValues)
        }
    }

    // ----- Statement thunks -----

    // items = ["*"?] name [{size}|initThunk] -> declaration thunk.
    function makeDecl(items) {
        var i = 0
        var isPtr = false
        if (items[i] == "*") { isPtr = true; i++ } // A pointer is an int sized cell holding an address.
        var name = items[i]
        var opt = items[i + 1]
        var ct = isPtr ? {k: "ptr", to: "int"} : ctInt
        return function() {
            if (opt != undefined && opt.size != undefined) {
                declVar(name, alloc(opt.size), true, ct)
            } else {
                var a = alloc(1)
                if (opt != undefined) mem[a] = opt() | 0
                declVar(name, a, false, ct)
            }
        }
    }
    // SDeclarator/SGDecl items = ["*"?] name [{size}|initThunk] -> a plain descriptor.
    function makeSDecl(items) {
        var i = 0
        var star = false
        if (items[i] == "*") { star = true; i++ }
        var name = items[i]
        var opt = items[i + 1]
        if (opt != undefined && opt.size != undefined) return {name: name, star: star, size: opt.size}
        return {name: name, star: star, init: opt}
    }
    // One declared struct entity: struct S v / struct S *p (= expr) / struct S a[N].
    function declStructVar(sname, d) {
        if (d.star) {
            var a = alloc(1)
            if (d.init != undefined) mem[a] = d.init() | 0
            declVar(d.name, a, false, {k: "ptr", to: sname})
        } else if (d.size != undefined) {
            declVar(d.name, alloc(d.size * structOf(sname).size), true, {k: "struct", s: sname})
        } else {
            if (d.init != undefined) fail("struct initializers are not supported: " + d.name)
            declVar(d.name, alloc(structOf(sname).size), false, {k: "struct", s: sname})
        }
    }
    // StructDecl items = [structName, descriptor...] -> declaration thunk.
    function makeStructDecl(items) {
        var sname = items[0]
        var decls = items.slice(1)
        return function() {
            for (var i = 0; i < decls.length; i++) declStructVar(sname, decls[i])
        }
    }
    // StructGDecl: like makeStructDecl, but registered at build time (initializers
    // would run before main, so they are not allowed on globals).
    function defineStructGlobals(items) {
        var sname = items[0]
        for (var i = 1; i < items.length; i++) {
            if (items[i].init != undefined) fail("global struct pointers take no initializer: " + items[i].name)
            declStructVar(sname, items[i])
        }
    }
    function makeDo(condT, bodyT) {
        return function() {
            do {
                var r = bodyT()
                if (r != undefined) {
                    if (r === BRK) break
                    if (r !== CONT) return r
                }
            } while (condT() != 0)
        }
    }
    function makeFor(items) {
        var bodyT = items.pop()
        var init = null, cond = null, post = null
        for (var i = 0; i < items.length; i++) {
            if (items[i].k == "init") init = items[i].t
            if (items[i].k == "cond") cond = items[i].t
            if (items[i].k == "post") post = items[i].t
        }
        return function() {
            scopes.push({})
            var res = undefined
            if (init != null) init()
            while (cond == null || cond() != 0) {
                var r = bodyT()
                if (r != undefined) {
                    if (r === BRK) break
                    if (r !== CONT) { res = r; break }
                }
                if (post != null) post()
            }
            scopes.pop()
            return res
        }
    }
    // items = [valueThunk, stmtThunk...] resp. [stmtThunk...] -> one case descriptor.
    function makeCase(items) { return {isDefault: false, v: items[0], body: items.slice(1)} }
    function makeDefault(items) { return {isDefault: true, body: items} }
    // items = [scrutineeThunk, caseDescriptor...]: C switch with fallthrough.
    function makeSwitch(items) {
        var scrut = items[0]
        var cases = items.slice(1)
        return function() {
            var v = scrut()
            var start = -1
            var dflt = -1
            for (var i = 0; i < cases.length; i++) {
                if (cases[i].isDefault) { dflt = i; continue }
                if (start < 0 && cases[i].v() == v) { start = i }
            }
            if (start < 0) { start = dflt }
            if (start < 0) { return undefined }
            for (var i = start; i < cases.length; i++) {
