            scopes.pop()
            return res
        }
    }
    function makeReturn(items) {
        var t = items.length > 0 ? items[0] : makeConst(undefined)
        return function() { return {isRet: true, v: t()} }
    }

    // guard COND else BLOCK: run the else block only when COND is falsey, and
    // propagate its signal (typically a return); otherwise fall through.
    function makeGuard(items) {
        var condT = items[0]
        var elseT = items[1]
        return function() {
            if (core.test(condT())) { return undefined }
            return elseT()
        }
    }

    // A case label carries its value thunks (empty for default).
    function makeCaseLabel(items) {
        var vals = []
        for (var i = 0; i < items.length; i++) { vals.push(items[i].v) }
        return {isDefault: items.length == 0, vals: vals}
    }
    // items = [{subj}, label or statement thunk...]: the flat item list is regrouped
    // so every statement belongs to the last label; no fallthrough. The subject is
    // evaluated once and compared (==) to each case value in source order; a bare
    // break ends the switch, other signals (return/continue) propagate.
    function makeSwitch(items) {
        var subj = null
        var cases = []
        var cur = null
        for (var i = 0; i < items.length; i++) {
            var it = items[i]
            if (typeof it == "function") {
                if (cur != null) { cur.body.push(it) }
            } else if (it.subj != undefined) {
                subj = it.subj
            } else {
