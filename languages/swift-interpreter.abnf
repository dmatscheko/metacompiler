:title("Swift (subset) interpreter") ;
:description("Parses a Swift subset and executes it directly, without generating code.

The subset: top level code that runs in source order (declare before use, no
hoisting), let/var declarations with an optional type annotation (types are
parsed and ignored, let is not enforced), functions with LABELLED parameters
(func greet(name: String, from town: String) -> String, called greet(name: x,
from: y); the external label is parsed and the last identifier is the bound
name), struct and class with stored properties (var value = 0, var step: Int),
methods and an explicit init (self and implicit unqualified property access
inside methods, construction without new: Counter(start: 10, step: 1)), if/else
(braces required), while, repeat/while, for-in over the ranges 1...5 (closed)
and 1..<5 (half-open) and over arrays, break/continue, closures { x in x * 2 }
and { (a: Int, b: Int) -> Int in a + b } as values with trailing-closure call
syntax (nums.map { x in x * 2 }), the array higher order methods map/filter/
forEach plus append/contains/count, arrays [1, 2, 3] and dictionaries
[\"a\": 1] (empty dict [:]) with subscript read/write and .count, string
interpolation \\(expr), the nil-coalescing operator a ?? b, nil, print(...) and
return. Int arithmetic is 32 bit and / truncates; + concatenates when a side is
a String; == compares strings by value and objects by identity. A plain enum of
bare cases becomes named string constants (Direction.north). Error handling with
do { STMTS } catch [pattern] { STMTS } and throw EXPR (no finally; the first catch
wins, patterns are parsed but not discriminated, an unbound catch binds the implicit
`error`); try/try?/try! are parsed and ignored (the throw happens inside the call).

Not in the subset (accepted structurally and reported as not implemented under
-warn-unsupported, or simply not parsed): optionals beyond nil and ?? (Type?,
if let, guard let, force unwrap !, optional chaining ?.), protocols, extensions,
generics (parsed and ignored), enums with raw or associated values, switch,
computed properties, tuples and tuple patterns, async/await, typed catch
discrimination, struct value semantics (structs behave like classes) and bare
(unqualified) method calls (methods are called via self.m() or obj.m()).

Top level self checking programs count failures and end with exit(failures).") ;


// --- main rules

// Shared token productions (languages/lib).
:include("lib/cstyle-comments.abnf") ;
:include("lib/ident.abnf") ;
:include("lib/numbers.abnf") ;
:include("lib/bools.abnf") ;

:startRule(Program) ;
:whitespace(Whitespace) ;

// Top level items run in source order during the tree walk: functions and
// types register themselves; a bare statement's thunk runs immediately.
Program     = { TopItem } ;
TopItem     = FunTop | TypeTop | UnsupTop | TopStmt ;
FunTop      <~~ registerFun(pop()) ~~> = [ Modifiers ] FunDecl ;
TypeTop     = [ Modifiers ] ( StructDecl | ClassDecl | EnumDecl ) ;
UnsupTop    = [ Modifiers ] UnsupDecl ;
TopStmt     <~~ var t = pop(); t() ~~> = Statement ;

// Declaration modifiers and attributes (@objc, @available(...), @escaping) are
// parsed and ignored.
Modifiers   = { Modifier | Attribute } ;
Attribute   = "@" Id { "." Id } [ SkipParen ] ;
Modifier    = ( "public" | "private" | "fileprivate" | "internal" | "open"
              | "final" | "static" | "mutating" | "nonmutating"
              | "override" | "lazy" | "weak" | "unowned" | "convenience"
              | "required" | "dynamic" | "indirect" ) KwEnd ;

// func name(label param: Type, ...) -> Ret { ... }
FunDecl     <~~ push(makeFun(takeAll())) ~~>
            = KwFunc Id <~~ push(up.in) ~~> [ SkipAngle ] ParamList [ FnEffects ] [ "->" Type ] [ GenWhere ] Block ;
FnEffects   = { ( "throws" | "rethrows" | "async" ) KwEnd } ;
// A generic constraint clause on a function/type: where T: P, U == V (ignored).
GenWhere    = KwWhere GenConstraint { "," GenConstraint } ;
GenConstraint = Type ( ":" TypeList | "==" Type | "=" Type ) ;

ParamList   <~~ push({params: takeAll()}) ~~>
            = "(" [ Param { "," Param } ] ")" ;
// A parameter is [externalLabel] internalName : Type; the last identifier is
// the bound name (Swift's _ label is just an identifier here).
Param       <~~ push(paramName(takeAll())) ~~>
            = Id <~~ push(up.in) ~~> [ Id <~~ push(up.in) ~~> ] ":" [ "inout" KwEnd ] { ParamAttr } Type [ "..." ] [ "=" DiscardExpr ] ;
// Parameter/type attributes (@escaping, @autoclosure) take no argument list here,
// so no SkipParen: the ( ... ) that follows belongs to a function type.
ParamAttr   = "@" Id { "." Id } ;

// class / struct with stored properties, methods and an explicit init.
StructDecl  <~~ buildClass(takeAll()) ~~>
            = KwStruct Id <~~ push(up.in) ~~> [ SkipAngle ] [ ":" TypeList ] "{" { Member } "}" ;
ClassDecl   <~~ buildClass(takeAll()) ~~>
            = KwClass Id <~~ push(up.in) ~~> [ SkipAngle ] [ ":" TypeList ] "{" { Member } "}" ;
TypeList    = Type { "," Type } ;

Member      = [ Modifiers ] ( InitDecl | DeinitDecl | SubscriptDecl | MethodDecl | ComputedProp | PropDecl ) ;
InitDecl    <~~ push({method: makeInit(takeAll())}) ~~>
            = KwInit [ "?" | "!" ] [ SkipAngle ] ParamList [ FnEffects ] [ GenWhere ] Block ;
// deinit and subscript are accepted structurally, not implemented.
DeinitDecl  <~~ notImpl("deinitializer", up.pos) ~~>
            = KwDeinit SkipBlock ;
SubscriptDecl <~~ notImpl("subscript", up.pos) ~~>
            = KwSubscript [ SkipAngle ] SkipParen [ "->" Type ] SkipBlock ;
MethodDecl  <~~ push({method: makeFun(takeAll())}) ~~>
            = KwFunc Id <~~ push(up.in) ~~> [ SkipAngle ] ParamList [ FnEffects ] [ "->" Type ] [ GenWhere ] Block ;
PropDecl    <~~ push(makeProp(takeAll())) ~~>
            = ( "let" | "var" ) KwEnd Id <~~ push(up.in) ~~> [ ":" Type ] [ "=" Expression ] [ ";" ] ;
// Computed properties and stored properties with willSet/didSet observers.
ComputedProp <~~ notImpl("computed property or property observer", up.pos) ~~>
            = ( "let" | "var" ) KwEnd Id [ ":" Type ] [ "=" DiscardExpr ] SkipBlock ;

// A plain enum of bare cases becomes named constants (Direction.north = "north").
EnumDecl    = PlainEnum | ComplexEnum ;
PlainEnum   <~~ buildEnum(takeAll()) ~~>
            = KwEnum Id <~~ push(up.in) ~~> "{" { SimpleCase } "}" ;
SimpleCase  = KwCase Id <~~ push({ecase: up.in}) ~~> { "," Id <~~ push({ecase: up.in}) ~~> } [ ";" ] ;
ComplexEnum <~~ notImpl("enum with raw or associated values", up.pos) ~~>
            = KwEnum Id [ SkipAngle ] [ ":" TypeList ] SkipBlock ;

// protocol / extension / typealias: accepted structurally, not implemented.
UnsupDecl   = ImportDecl | ProtocolDecl | ExtensionDecl | TypeAliasDecl ;
// import Geom (or a submodule import 'import struct A.B'): the module name is resolved by
// resolveImport - a builtin module (core.stdlibImports) is a no-op, otherwise it maps to a
// project file (Geom -> Geom.swift, A.B -> A/B.swift) parsed and walked by core.importFile,
// whose declarations register in the shared scope like the main file's. The submodule kind
// (struct/class/...) is parsed and dropped; the dotted module path is what is resolved.
ImportDecl  <~~ resolveImport(pop(), up.pos) ~~>
            = KwImport [ ImportKind ] ImportPath [ ";" ] ;
ImportPath  <~~ push(stripWs(up.in)) ~~>
            = Id { "." ( Id | "*" ) } ;
ImportKind  = ( "typealias" | "struct" | "class" | "enum" | "protocol"
              | "func" | "let" | "var" | "inout" ) KwEnd ;
ProtocolDecl <~~ notImpl("protocol", up.pos) ~~>
            = KwProtocol Id [ SkipAngle ] [ ":" TypeList ] SkipBlock ;
ExtensionDecl <~~ notImpl("extension", up.pos) ~~>
            = KwExtension Type [ ":" TypeList ] SkipBlock ;
TypeAliasDecl <~~ notImpl("typealias", up.pos) ~~>
            = KwTypealias Id [ SkipAngle ] "=" Type [ ";" ] ;

// Types are parsed and ignored: arrays [T], dictionaries [K: V], optionals T?,
// implicitly unwrapped T!, tuples/function types (A, B) -> C, dotted and generic.
Type        = TypeCore { "?" | "!" } ;
TypeCore    = "[" Type [ ":" Type ] "]"
            | "(" [ Type { "," Type } ] ")" [ "->" Type ]
            | Id [ SkipAngle ] { "." Id [ SkipAngle ] } ;

// Every statement production pushes exactly one thunk: function() -> undefined | signal.
// do/throw are genuinely executed (try/catch via excTry, throw via excThrow); the
// Cplx* / Local* / defer / fallthrough forms are recognized but not executed - they
// route to notImplStmt (a warning under -warn-unsupported).
Statement   = Decl | LocalFunc | LocalType | CplxIf | If | CplxGuard | Guard
            | CplxWhile | While | Repeat | For | Switch | Return | Throw | Break
            | Continue | Fallthrough | Do | Defer | Empty | ExprStmt ;

// A nested function or nested type declaration inside a body.
LocalFunc   <~~ push(notImplStmt("nested function", up.pos)) ~~>
            = KwFunc Id [ SkipAngle ] SkipParen [ FnEffects ] [ "->" Type ] [ GenWhere ] SkipBlock ;
LocalType   <~~ push(notImplStmt("nested type declaration", up.pos)) ~~>
            = ( KwStruct | KwClass | KwEnum ) Id [ SkipAngle ] [ ":" TypeList ] SkipBlock ;

// do { STMTS } catch [pattern] { STMTS } [catch ...]: genuine try/catch (Swift has
// NO finally). throw raises a value that unwinds to the nearest catch; the first
// catch clause wins (patterns are parsed but not discriminated); a catch with no
// `let NAME` binds the implicit name `error`. return/break/continue inside a do still
// propagate to the enclosing loop or function. Each part is marked so excTry can tell
// them apart on the stack. defer and fallthrough stay not implemented.
Do          <~~ push(excTry(takeAll())) ~~>
            = KwDo TryBody { CatchClause } ;
TryBody     <~~ push({trybody: pop()}) ~~>
            = Block ;
CatchClause <~~ push(excCatch(takeAll())) ~~>
            = KwCatch ( CatchLet | CatchPat ) Block ;
// catch let e / catch let e as T / catch let e where c: bind e (the caught value).
CatchLet    = ( "let" | "var" ) KwEnd Id <~~ push(up.in) ~~> [ "as" KwEnd Type ] [ KwWhere DiscardExpr ] ;
// catch SomeError / catch .case / catch { }: no `let` binding, so the caught value
// binds to the implicit name `error` (always pushed, so excCatch binds it).
CatchPat    <~~ push("error") ~~>
            = [ Pattern ] [ KwWhere DiscardExpr ] ;
Defer       <~~ push(notImplStmt("defer", up.pos)) ~~>
            = KwDefer SkipBlock ;
Throw       <~~ push(excThrow(pop())) ~~>
            = KwThrow Expression [ ";" ] ;
Fallthrough <~~ push(notImplStmt("fallthrough", up.pos)) ~~>
            = KwFallthrough [ ";" ] ;

// if / guard / while whose condition uses optional binding (if let x = ...),
// pattern matching (if case ...) or a compound comma condition: recognized and
// routed to notImplStmt. Plain boolean conditions fall through to If/Guard/While.
// The body SkipBlock is optional: when the last binding initializer ends in a
// method call (let x = it.next()), the trailing { body } is grabbed as a trailing
// closure by the expression, so no separate body block remains to consume.
CplxIf      <~~ push(notImplStmt("if with binding or compound condition", up.pos)) ~~>
            = KwIf CplxCondClause [ SkipBlock ] [ KwElse ElseTail ] ;
ElseTail    = KwIf AnyCondClause [ SkipBlock ] [ KwElse ElseTail ] | SkipBlock ;
CplxGuard   <~~ push(notImplStmt("guard with binding or compound condition", up.pos)) ~~>
            = KwGuard CplxCondClause KwElse SkipBlock ;
CplxWhile   <~~ push(notImplStmt("while with binding or compound condition", up.pos)) ~~>
            = KwWhile CplxCondClause [ SkipBlock ] ;
// A complex clause requires either a comma (2+ conditions) or a leading binding.
CplxCondClause = CondItem "," CondItem { "," CondItem } | BindCond { "," CondItem } ;
AnyCondClause  = CondItem { "," CondItem } ;
CondItem    = BindCond | DiscardExpr ;
BindCond    = OptBind | CaseCond ;
OptBind     = ( "let" | "var" ) KwEnd BindPat [ ":" Type ] [ "=" DiscardExpr ] [ PatWhere ] ;
CaseCond    = KwCase Pattern "=" DiscardExpr [ PatWhere ] ;
PatWhere    = KwWhere DiscardExpr ;
BindPat     = "(" BindPat { "," BindPat } ")" | Wildcard | Id ;
Pattern     = "(" Pattern { "," Pattern } ")" | ( "let" | "var" ) KwEnd Pattern
            | Wildcard | [ "." ] Id { "." Id } [ SkipParen ] ;
Wildcard    = "_" KwEnd ;

Block       <~~ push(makeBlockStmt(takeAll())) ~~>
            = "{" { Statement } "}" ;

Decl        <~~ push(makeDecl(takeAll())) ~~>
            = ( "let" | "var" ) KwEnd Id <~~ push(up.in) ~~> [ ":" Type ] "=" Expression [ ";" ] ;

If          <~~ push(makeIf(takeAll())) ~~>
            = KwIf Expression Block [ KwElse ElseBody ] ;
ElseBody    = Block | If ;

While       <~~ push(makeWhile(pop(), pop())) ~~>
            = KwWhile Expression Block ;

Repeat      <~~ push(makeDo(pop(), pop())) ~~>
            = KwRepeat Block KwWhile Expression [ ";" ] ;

// for x in 1...5 / 1..<5, and for x in array. The range form is tried first.
For         = ForRange | ForList ;
ForRange    <~~ push(makeForRange(takeAll())) ~~>
            = KwFor Id <~~ push(up.in) ~~> KwIn Expression RangeOp Expression Block ;
RangeOp     = "..." <~~ push({rop: "..."}) ~~>
            | "..<" <~~ push({rop: "..<"}) ~~> ;
ForList     <~~ push(makeForList(pop(), pop(), pop())) ~~>
            = KwFor Id <~~ push(up.in) ~~> KwIn Expression Block ;

// guard COND else { ... }: if COND is false the else block runs (and normally
// exits via return/break/continue, which propagates); otherwise control falls
// through past the guard.
Guard       <~~ push(makeGuard(takeAll())) ~~>
            = KwGuard Expression KwElse Block ;

// switch SUBJ { case V1, V2: stmts  case V3: stmts  default: stmts } - lowered to
// a chain of == tests (no fallthrough). The body is parsed FLAT: the labels must
// be tried before Statement (a bare 'case' would parse as an identifier), and the
// builder groups the statements under the label they follow. A bare break ends the
// case; return/continue propagate to the function/enclosing loop.
Switch      <~~ push(makeSwitch(takeAll())) ~~>
            = KwSwitch SwitchSubj "{" { CaseLabel | Statement } "}" ;
SwitchSubj  <~~ push({subj: pop()}) ~~>
            = Expression ;
CaseLabel   <~~ push(makeCaseLabel(takeAll())) ~~>
            = ( KwCase Expression <~~ push({v: pop()}) ~~> { "," Expression <~~ push({v: pop()}) ~~> }
              | KwDefault ) ":" ;

Return      <~~ push(makeReturn(takeAll())) ~~>
            = KwReturn [ Expression ] [ ";" ] ;
Break       <~~ push(makeBreak()) ~~>    = KwBreak [ ";" ] ;
Continue    <~~ push(makeContinue()) ~~> = KwContinue [ ";" ] ;
Empty       <~~ push(function() {}) ~~>  = ";" ;

ExprStmt    <~~ push(exprToStmt(pop())) ~~>
            = Expression [ ";" ] ;

// Every expression production pushes exactly one thunk: function() -> value.
Expression  = Assignment | Ternary ;
Assignment  <~~ push(makeAssign(takeAll())) ~~>
            = Target ( "+=" | "-=" | "*=" | "/=" | "%=" | "=" ) <~~ push(up.in) ~~> Expression ;

Target      <~~ push(makeTargetRef(takeAll())) ~~>
            = Id <~~ push(up.in) ~~> { "." Id <~~ push({key: up.in}) ~~> | TIndex } ;
TIndex      <~~ push({idx: pop()}) ~~>
            = "[" Expression "]" ;

// cond ? a : b (right associative). The ? cannot be confused with ?? (consumed
// deeper, at Coalesce) or with an argument label's colon.
Ternary     <~~ push(makeTernary(takeAll())) ~~>
            = OrExpr [ "?" Expression ":" Ternary ] ;
OrExpr      <~~ push(makeOrAnd(takeAll(), true)) ~~>
            = AndExpr { "||" AndExpr } ;
AndExpr     <~~ push(makeOrAnd(takeAll(), false)) ~~>
            = EqExpr { "&&" EqExpr } ;
EqExpr      <~~ push(foldBinary(takeAll())) ~~>
            = RelExpr { ( "==" | "!=" ) <~~ push(up.in) ~~> RelExpr } ;
RelExpr     <~~ push(foldBinary(takeAll())) ~~>
            = Cast { ( "<=" | ">=" | "<" | ">" ) <~~ push(up.in) ~~> Cast } ;
// e as T / e as? T / e as! T / e is T: recognized, routed to notImplExpr. With no
// cast operator it is a pure pass-through (a single item), so behavior is
// unchanged for programs that do not cast.
Cast        <~~ push(makeCast(takeAll(), up.pos)) ~~>
            = Coalesce { CastOp Type } ;
CastOp      <~~ push({cast: 1}) ~~>
            = ( "as" KwEnd [ "?" | "!" ] | "is" KwEnd ) ;
// a ?? b yields a unless it is nil (short circuit; the nil-coalescing operator).
Coalesce    <~~ push(makeCoalesce(takeAll())) ~~>
            = AddExpr { "??" AddExpr } ;
AddExpr     <~~ push(foldBinary(takeAll())) ~~>
            = MulExpr { ( "+" | "-" ) <~~ push(up.in) ~~> MulExpr } ;
MulExpr     <~~ push(foldBinary(takeAll())) ~~>
            = UnaryExpr { ( "*" | "/" | "%" ) <~~ push(up.in) ~~> UnaryExpr } ;

UnaryExpr   = Neg | Not | TryExpr | Await | CallMember ;
Neg         <~~ push(makeNeg(pop())) ~~>   = "-" UnaryExpr ;
Not         <~~ push(makeNot(pop())) ~~>   = "!" UnaryExpr ;
// try / try? / try! : the prefix is parsed and ignored and the inner expression is
// evaluated normally (a throw inside the call unwinds via excThrow regardless).
TryExpr     = ( KwTry [ "?" | "!" ] ) UnaryExpr ;
// await: recognized as a prefix, routed to notImplExpr.
Await       <~~ pop(); push(notImplExpr("await expression", up.pos)) ~~>
            = KwAwait UnaryExpr ;

// obj.m(args), obj.field, arr[i] - and a trailing closure becomes the last arg.
CallMember  <~~ push(foldCallMember(takeAll())) ~~>
            = Primary { MethodSfx | FieldSfx | IndexSfx } ;
MethodSfx   <~~ push({kind:"mcall", name: popName(), args: takeAll()}) ~~>
            = "." Id <~~ push({mname: up.in}) ~~> MArgs ;
FieldSfx    = "." Id <~~ push({kind:"field", name: up.in}) ~~> ;
IndexSfx    <~~ push({kind:"index", idx: pop()}) ~~>
            = "[" Expression "]" ;
MArgs       = "(" [ CallArg { "," CallArg } ] ")" [ Closure ] | Closure ;

// Argument labels are parsed and dropped; arguments bind positionally.
CallArg     = [ ArgLabel ] Expression ;
ArgLabel    = Id ":" ;

Primary     = Paren | Template | FloatLit | IntLit | True | False | Nil
            | Closure | DictLit | ArrayLit | Shorthand | Call | VarRef ;

// ( e ) is a pass-through; ( e, e, ... ) is a tuple, recognized and routed to
// notImplExpr. Element labels (x: e) are accepted and dropped.
Paren       <~~ push(makeParen(takeAll(), up.pos)) ~~>
            = "(" TupleElem { "," TupleElem } ")" ;
TupleElem   = [ Id ":" ] Expression ;
// Floating-point literals (3.14): recognized, routed to notImplExpr (the runtime
// is 32-bit integer only). Tried before IntLit; a plain integer or a range (1...5)
// still parses as IntLit because a fractional digit is required.
FloatLit    <~~ push(notImplExpr("floating-point literal", up.pos)) ~~>
            = ( "0" | "1"..."9" ) :whitespace() { "0"..."9" } "." "0"..."9" { "0"..."9" } :whitespace(Whitespace) ;
// Closure shorthand arguments ($0, $1, ...): recognized, routed to notImplExpr.
Shorthand   <~~ push(notImplExpr("closure shorthand argument", up.pos)) ~~>
            = "$" :whitespace() "0"..."9" { "0"..."9" } :whitespace(Whitespace) ;

// A closure: { x in x * 2 } or { (a: Int, b: Int) -> Int in a + b } or, with no
// signature, { doThing() }. Its value is the last expression; a real closure
// over the defining scope.
Closure     <~~ push(makeClosure(takeAll())) ~~>
            = "{" [ ClosureSig ] { LamStmt } "}" ;
ClosureSig  <~~ push({cparams: takeAll()}) ~~>
            = "(" [ ClParam { "," ClParam } ] ")" [ "->" Type ] KwIn
            | ClParam { "," ClParam } KwIn ;
ClParam     = Id <~~ push(up.in) ~~> [ ":" Type ] ;
LamStmt     = LamCtrl | LamExpr ;
LamCtrl     <~~ push({stmt: pop()}) ~~>
            = Decl | While | Repeat | For | Return | Break | Continue | If ;
LamExpr     <~~ push({expr: pop()}) ~~>
            = Expression [ ";" ] ;

// [k: v] dictionaries (empty [:]) tried before [e] arrays.
DictLit     <~~ push(makeDict(takeAll())) ~~>
            = "[" ( ":" | DictEntry { "," DictEntry } ) "]" ;
DictEntry   <~~ var v = pop(); push({dk: pop(), dv: v}) ~~>
            = Expression ":" Expression ;
ArrayLit    <~~ push(makeArray(takeAll())) ~~>
            = "[" [ Expression { "," Expression } ] "]" ;

// f(args): a global function or a struct/class constructor (calls init).
Call        <~~ push(makeCall(takeAll())) ~~>
            = Id <~~ push(up.in) ~~> "(" [ CallArg { "," CallArg } ] ")" ;

// String interpolation: "sum = \(a + b)".
Template    <~~ push(makeTemplate(takeAll())) ~~>
            = '"' :whitespace() { TplExpr | TplChunk } '"' :whitespace(Whitespace) ;
TplExpr     <~~ push({e: pop()}) ~~>
            = "\\(" :whitespace(Whitespace) Expression ")" ;
TplChunk    <~~ push({s: unescapeJs(up.in)}) ~~>
            = TplChar { TplChar } ;
TplChar     = TplEsc | TplPlain ;
TplEsc      = "\\" ( "n" | "t" | "r" | "0" | "\\" | @'"' | "'" ) ;
TplPlain    = "\x20"..."\x21" | "\x23"..."\x5b" | "\x5d"..."\x7e" | @"\t" | "\x7f"..."\U0010ffff" ;

Nil         <~~ push(makeConst(null)) ~~>  = "nil" KwEnd ;
VarRef      <~~ push(makeVarRef(up.in)) ~~> = Id ;

// ----- Widened surface: a balanced { ... } / < ... > run consumed but ignored -----
SkipBlock   = "{" { SkipItem } "}" ;
SkipItem    = SkipStr | SkipChar | SkipBlock | SkipOther ;
SkipStr     = '"' :whitespace() { SkipStrEsc | SkipStrChar } '"' :whitespace(Whitespace) ;
SkipStrEsc  = "\\" "\x00"..."\U0010ffff" ;
SkipStrChar = "\x00"..."\x21" | "\x23"..."\x5b" | "\x5d"..."\U0010ffff" ;
SkipChar    = "'" :whitespace() { SkipChEsc | SkipChChar } "'" :whitespace(Whitespace) ;
SkipChEsc   = "\\" "\x00"..."\U0010ffff" ;
SkipChChar  = "\x00"..."\x26" | "\x28"..."\x5b" | "\x5d"..."\U0010ffff" ;
SkipOther   = "\x00"..."\x21" | "\x23"..."\x26" | "\x28"..."\x7a" | "\x7c" | "\x7e"..."\U0010ffff" ;

SkipAngle   = "<" { SkipAngle | SkipAngleItem } ">" ;
SkipAngleItem = "\x00"..."\x3b" | "\x3d" | "\x3f"..."\U0010ffff" ;

// A balanced ( ... ) run consumed but ignored (attribute args, subscript params).
SkipParen   = "(" { SkipStr | SkipChar | SkipParen | SkipPOther } ")" ;
SkipPOther  = "\x00"..."\x21" | "\x23"..."\x26" | "\x2a"..."\U0010ffff" ;

DiscardExpr <~~ pop() ~~> = Expression ;

KwFunc      = "func" KwEnd ;
KwImport    = "import" KwEnd ;
KwWhere     = "where" KwEnd ;
KwDeinit    = "deinit" KwEnd ;
KwSubscript = "subscript" KwEnd ;
KwDo        = "do" KwEnd ;
KwCatch     = "catch" KwEnd ;
KwDefer     = "defer" KwEnd ;
KwThrow     = "throw" KwEnd ;
KwFallthrough = "fallthrough" KwEnd ;
KwTry       = "try" KwEnd ;
KwAwait     = "await" KwEnd ;
KwStruct    = "struct" KwEnd ;
KwClass     = "class" KwEnd ;
KwEnum      = "enum" KwEnd ;
KwCase      = "case" KwEnd ;
KwInit      = "init" KwEnd ;
KwProtocol  = "protocol" KwEnd ;
KwExtension = "extension" KwEnd ;
KwTypealias = "typealias" KwEnd ;
KwIf        = "if" KwEnd ;
KwGuard     = "guard" KwEnd ;
KwSwitch    = "switch" KwEnd ;
KwDefault   = "default" KwEnd ;
KwElse      = "else" KwEnd ;
KwWhile     = "while" KwEnd ;
KwRepeat    = "repeat" KwEnd ;
KwFor       = "for" KwEnd ;
KwIn        = "in" KwEnd ;
KwReturn    = "return" KwEnd ;
KwBreak     = "break" KwEnd ;
KwContinue  = "continue" KwEnd ;

// ---


:startScript(~~

    // Shared interpreter machinery (scopes, BRK/CONT protocol, expression and
    // statement builders); Swift-specific behavior is configured on `core` below.
    include("lib/interp-core.js")

    // ----- Values: dictionaries, strings, indexing (js_pyget/js_pyset semantics) -----
    function isDict(v) { return v !== null && v !== undefined && typeof v == "object" && v.__dict === true }
    function dictFind(d, k) {
        for (var i = 0; i < d.keys.length; i++) { if (d.keys[i] === k) { return i } }
        return -1
    }
    function dictSet(d, k, v) {
        var i = dictFind(d, k)
        if (i >= 0) { d.vals[i] = v } else { d.keys.push(k); d.vals.push(v) }
    }
    function swstr(v) {
        if (v === undefined) { return "" }
        if (v === null) { return "nil" }
        if (v === true) { return "true" }
        if (v === false) { return "false" }
        if (typeof v == "string") { return v }
        return "" + v
    }
    function swadd(l, r) {
