        var start = 0
        if (items.length > 0 && items[0] != undefined && items[0].cparams != undefined) {
            params = items[0].cparams
            start = 1
        }
        var body = items.slice(start)
        return function() {
            var captured = scopes.slice(0)
            return function() {
                var args = arguments
                var saved = scopes
                scopes = captured.slice(0)
                scopes.push({})
                for (var i = 0; i < params.length; i++) {
                    declVar(params[i], i < args.length ? args[i] : undefined)
