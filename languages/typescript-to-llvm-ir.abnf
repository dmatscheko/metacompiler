                        var isFn = truthy(b, callExt(b, "js_seq", [callExt(b, "js_typeof", [fV]), emitStr(b, "function")]))
                        var thenB = curF.NewBlock("")
                        var elseB = curF.NewBlock("")
                        var mergeB = curF.NewBlock("")
                        b.NewCondBr(isFn, thenB, elseB)
                        var tv = callExt(thenB, "js_call", [fV, objV, argsV])
                        thenB.NewBr(mergeB)
                        var ev = callExt(elseB, "js_mcall", [objV, keyV, argsV])
                        elseB.NewBr(mergeB)
                        cur = mergeB.NewPhi([llvm.ir.NewIncoming(tv, thenB), llvm.ir.NewIncoming(ev, elseB)])
                        b = mergeB
                        curThis = hUndef
                        i = i + 2
                    } else {
