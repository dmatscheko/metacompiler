// and a method's '(' are recognized before the field form). A stray ';' is skipped.
// get/set accessors and generator/async methods are accepted but not implemented (they
// warn and contribute nothing to the class); an index signature is a type-layer member.
ClassMember = ClassSemi | IndexSig | Accessor | GenMethod | CtorDef | MethodDef | FieldDef ;
ClassSemi   <~~ push({skip: true}) ~~> = ";" ;
Accessor    <~~ notImpl("get/set accessor", up.pos); takeAll(); push({skip: true}) ~~>
            = MemberMods ( "get" KwEnd | "set" KwEnd ) Id ParamList [ TypeAnnot ] Block ;
GenMethod   <~~ notImpl("generator/async* method", up.pos); takeAll(); push({skip: true}) ~~>
            = MemberMods [ KwAsync ] "*" Id [ TypeParams ] ParamList [ TypeAnnot ] Block ;
// An index signature ([k: string]: T;) is pure type syntax; it emits nothing.
IndexSig    <~~ takeAll(); push({skip: true}) ~~>
            = MemberMods [ "readonly" KwEnd ] "[" Id ":" Type "]" TypeAnnot [ ";" ] ;

// A constructor. Its parameters may carry access modifiers (erased) and types (erased).
CtorDef     <~~ push(makeCtor(takeAll())) ~~>
            = { CtorMod } KwConstructor CtorParams Block ;
CtorMod     = ( "public" | "private" | "protected" ) KwEnd ;
CtorParams  <~~ push(takeAll()) ~~>
            = "(" [ CtorParam { "," CtorParam } ] ")" ;
CtorParam   = { PropMod } Id <~~ push(up.in) ~~> [ "?" ] [ TypeAnnot ] ;
PropMod     = ( "public" | "private" | "protected" | "readonly" ) KwEnd ;

// A method (instance unless 'static'). Generics on the method, the parameter types and
// the return type are all erased; only the name, the parameter names and the body count.
MethodDef   <~~ push(makeMethod(takeAll())) ~~>
            = MemberMods Id <~~ push({mname: up.in}) ~~> [ TypeParams ] ParamList [ TypeAnnot ] Block ;

// A field (instance unless 'static'), with an optional '?'/'!' marker, an erased type
// annotation and an optional initializer.
FieldDef    <~~ push(makeField(takeAll())) ~~>
            = MemberMods Id <~~ push({fname: up.in}) ~~> [ "?" | "!" ] [ TypeAnnot ] [ "=" AssignExpr ] [ ";" ] ;

MemberMods  <~~ push({mods: takeAll()}) ~~>
            = { MemberMod <~~ push(up.in) ~~> } ;
MemberMod   = ( "public" | "private" | "protected" | "static" | "readonly" | "abstract" | "override" | "async" | "declare" ) KwEnd ;

// A balanced { ... } body consumed without interpreting it. String and template
// literals are matched first, so braces inside them are never miscounted.
SkipBlock   = "{" { SkipItem } "}" ;
SkipItem    = SkipDq | SkipSq | SkipTpl | SkipBlock | SkipOther ;
SkipDq      = '"' :whitespace() { SkipStrEsc | SkipDqChar } '"' :whitespace(Whitespace) ;
SkipSq      = "'" :whitespace() { SkipStrEsc | SkipSqChar } "'" :whitespace(Whitespace) ;
SkipTpl     = "`" :whitespace() { SkipTplSub | SkipStrEsc | SkipTplChar } "`" :whitespace(Whitespace) ;
SkipTplSub  = "${" :whitespace(Whitespace) { SkipItem } "}" ;
SkipStrEsc  = "\\" "\x00"..."\U0010ffff" ;
SkipDqChar  = "\x00"..."\x21" | "\x23"..."\x5b" | "\x5d"..."\U0010ffff" ;
SkipSqChar  = "\x00"..."\x26" | "\x28"..."\x5b" | "\x5d"..."\U0010ffff" ;
SkipTplChar = "\x00"..."\x5b" | "\x5d"..."\x5f" | "\x61"..."\U0010ffff" ;
SkipOther   = "\x00"..."\x21" | "\x23"..."\x26" | "\x28"..."\x5f" | "\x61"..."\x7a" | "\x7c" | "\x7e"..."\U0010ffff" ;

// --- TypeScript type expressions: parsed structurally and fully erased. ---
// NONE of these productions push onto the stack, so the value productions that embed a
// type annotation see exactly the stack they would without it. The grammar is scannerless
// but the global whitespace rule skips spaces after every terminal, so '< >', ':' and '|'
// behave as expected. A type is bounded by the surrounding syntax ('=', ';', ')', '=>',
// a function body '{'), so no explicit terminator token is needed.
TypeAnnot   = ":" Type ;
TypeList    = Type { "," Type } ;
Type        = FuncType | UnionType ;
FuncType    = [ TypeParams ] "(" [ FnTypeParam { "," FnTypeParam } ] ")" "=>" Type ;
FnTypeParam = [ "..." ] Id [ "?" ] [ TypeAnnot ] | Type ;
UnionType   = [ "|" ] IsectType { "|" IsectType } ;
IsectType   = [ "&" ] PostfixType { "&" PostfixType } ;
PostfixType = AtomType { ArraySfx } ;
ArraySfx    = "[" [ Type ] "]" ;
AtomType    = "(" Type ")" | ObjType | TupleType | LitType | NamedType ;
ObjType     = SkipBlock ;
TupleType   = "[" [ Type { "," Type } ] "]" ;
NamedType   = Id [ TypeArgs ] { "." Id [ TypeArgs ] } ;
TypeArgs    = "<" Type { "," Type } ">" ;
LitType     = StrTypeLit | NumTypeLit | "true" KwEnd | "false" KwEnd | "null" KwEnd | "undefined" KwEnd ;
StrTypeLit  = '"' :whitespace() { StrEsc | DqPlain } '"' :whitespace(Whitespace)
            | "'" :whitespace() { StrEsc | SqPlain } "'" :whitespace(Whitespace) ;
NumTypeLit  = ( "0" | "1"..."9" ) :whitespace() { "0"..."9" } [ "." "0"..."9" { "0"..."9" } ] :whitespace(Whitespace) ;
// A generic parameter declaration list: <T>, <K, V>, <T extends U>, <T = string>.
TypeParams  = "<" TypeParamDecl { "," TypeParamDecl } ">" ;
TypeParamDecl = Id [ KwExtends Type ] [ "=" Type ] ;

Null        <~~ push(makeHandleConst(1)) ~~>   = "null" KwEnd ;
Undefined   <~~ push(makeHandleConst(0)) ~~>   = "undefined" KwEnd ;

VarRef      <~~ push(makeVarRef(up.in)) ~~>
            = Id ;

StringLit   = DqString | SqString ;
// The radix-prefixed literals (hex 0x, binary 0b, octal 0o) are tried before decimal,
// otherwise '0x1A' would stop after the '0'. A trailing bigint 'n' suffix is accepted
// and dropped (the value is a plain number).
NumberLit   = HexLit | BinLit | OctLit | DecLit ;

HexLit      <~~ push(makeConst(hexAt(up.in, 2, up.in.length - 2))) ~~>
            = ( "0x" | "0X" ) :whitespace() HexDigit { HexDigit } [ "n" ] :whitespace(Whitespace) ;
HexDigit    = "0"..."9" | "a"..."f" | "A"..."F" ;
BinLit      <~~ push(makeConst(radixVal(up.in, 2))) ~~>
            = ( "0b" | "0B" ) :whitespace() BinDigit { BinDigit } [ "n" ] :whitespace(Whitespace) ;
BinDigit    = "0"..."1" ;
OctLit      <~~ push(makeConst(radixVal(up.in, 8))) ~~>
            = ( "0o" | "0O" ) :whitespace() OctDigit { OctDigit } [ "n" ] :whitespace(Whitespace) ;
OctDigit    = "0"..."7" ;

// A regular-expression literal (/pattern/flags) is accepted at value position (division
// is a binary operator and never starts a primary). It is not implemented; the result
// value is undefined. The body matches a character class ([...] may contain '/'), an
// escape, or a plain character; a leading '/' or '*' is consumed by the comment layer,
// so a regex cannot begin with those (a rare limitation).
RegexLit    <~~ push(notImplExpr("regular expression literal", up.pos)) ~~>
            = "/" :whitespace() RegexPart { RegexPart } "/" { RegexFlag } :whitespace(Whitespace) ;
RegexPart   = RegexClass | RegexEsc | RegexChar ;
RegexClass  = "[" { RegexEsc | RegexClassChar } "]" ;
RegexEsc    = "\\" "\x00"..."\U0010ffff" ;
RegexChar   = "\x00"..."\x09" | "\x0b"..."\x0c" | "\x0e"..."\x2e" | "\x30"..."\x5a" | "\x5d"..."\U0010ffff" ;
RegexClassChar = "\x00"..."\x09" | "\x0b"..."\x0c" | "\x0e"..."\x5b" | "\x5e"..."\U0010ffff" ;
RegexFlag   = "a"..."z" ;

// The keywords end with a negative lookahead, so that e.g. 'iffy' or 'variable' stay identifiers.
KwVar       = ( "var" | "let" | "const" ) KwEnd ;
KwFunction  = "function" KwEnd ;
KwIf        = "if" KwEnd ;
KwElse      = "else" KwEnd ;
KwWhile     = "while" KwEnd ;
KwDo        = "do" KwEnd ;
KwFor       = "for" KwEnd ;
KwReturn    = "return" KwEnd ;
KwBreak     = "break" KwEnd ;
KwContinue  = "continue" KwEnd ;
KwThrow     = "throw" KwEnd ;
KwTypeof    = "typeof" KwEnd ;
KwSwitch    = "switch" KwEnd ;
KwCase      = "case" KwEnd ;
KwDefault   = "default" KwEnd ;
KwOf        = "of" KwEnd ;
KwIn        = "in" KwEnd ;
KwTry       = "try" KwEnd ;
KwCatch     = "catch" KwEnd ;
KwFinally   = "finally" KwEnd ;
KwClass     = "class" KwEnd ;
KwExtends   = "extends" KwEnd ;
KwImplements = "implements" KwEnd ;
KwNew       = "new" KwEnd ;
KwSuper     = "super" KwEnd ;
KwConstructor = "constructor" KwEnd ;
KwInterface = "interface" KwEnd ;
KwType      = "type" KwEnd ;
KwEnum      = "enum" KwEnd ;
KwAs        = "as" KwEnd ;
KwImport    = "import" KwEnd ;
KwExport    = "export" KwEnd ;
KwFrom      = "from" KwEnd ;
KwNamespace = "namespace" KwEnd ;
KwModule    = "module" KwEnd ;
KwGlobal    = "global" KwEnd ;
KwDeclare   = "declare" KwEnd ;
KwAsync     = "async" KwEnd ;
KwAwait     = "await" KwEnd ;
KwDelete    = "delete" KwEnd ;
KwVoid      = "void" KwEnd ;
KwYield     = "yield" KwEnd ;
KwInstanceof = "instanceof" KwEnd ;
KwDebugger  = "debugger" KwEnd ;

// A balanced ( ... ) span consumed without interpreting it (used by decorator arguments).
// String and template literals are matched first, so parens inside them are never counted.
SkipParen   = "(" { SkipDq | SkipSq | SkipTpl | SkipBlock | SkipParen | SkipPOther } ")" ;
SkipPOther  = "\x00"..."\x21" | "\x23"..."\x26" | "\x2a"..."\x5f" | "\x61"..."\x7a" | "\x7c" | "\x7e"..."\U0010ffff" ;

// ---


:startScript(~~

    // Shared emitter machinery (module, handle constants, externs, loopStack
