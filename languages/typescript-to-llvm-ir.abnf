        if (rel.length >= 2 && rel.slice(0, 2) == "./") { rel = rel.slice(2) }
        var hasExt = false
        if (rel.length >= 3) {
            var ext = rel.slice(rel.length - 3)
            if (ext == ".ts" || ext == ".js") { hasExt = true }
        }
        var cand = hasExt ? rel : rel + ".ts"
        return c.findImport(cand)
    }
    var importedFiles = {}
    var importDepth = 0
    // imported files top-level items: stashImported / emitImported (compile-core)
    core.importFile = function(path, pos) {
        var file = tsFindImport(path)
        if (file == "") {
