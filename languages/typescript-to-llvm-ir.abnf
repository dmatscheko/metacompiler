            var p = emitRefPath(b, ref)
            b = p.b
            var oldM = callExt(b, "js_tonum", [callExt(b, "js_get", [p.obj, p.key])])
            callExt(b, "js_set", [p.obj, p.key, callExt(b, extName, [oldM, oneV])])
            return {b: b, v: oldM}
        }
    }
    // Prefix ++/--: like makeIncDec, but the expression value is the new one.
    function makePreIncDec(ref, op) {
        var extName = (op == "++") ? "js_add" : "js_sub"
        return function(b) {
            var oneV = callExt(b, "js_num_i", [handle(1)])
            if (ref.path.length == 0) {
                var nameV = emitStr(b, ref.name)
                var oldV = callExt(b, "js_tonum", [callExt(b, "js_scope_get", [curScopeV, nameV])])
                var newV = callExt(b, extName, [oldV, oneV])
                callExt(b, "js_scope_set", [curScopeV, nameV, newV])
                return {b: b, v: newV}
            }
            var p = emitRefPath(b, ref)
            b = p.b
            var oldM = callExt(b, "js_tonum", [callExt(b, "js_get", [p.obj, p.key])])
            var newM = callExt(b, extName, [oldM, oneV])
            callExt(b, "js_set", [p.obj, p.key, newM])
            return {b: b, v: newM}
        }
    }

    // A function body: an own IR function jsf_N(env, args) whose entry opens a scope on
    // the passed environment, binds the parameters and 'arguments', and runs the body.
    // isCtl marks a try/catch body closure: a return/break/continue leaving it emits a
    // control signal instead of a ret/br (see compile-core inCtlBody / excDispatch).
    function emitFunction(paramNames, bodyT, isCtl) {
        funcCount++
        var idx = funcCount
        var f = m.NewFunc("jsf_" + idx, i64, [llvm.ir.NewParam("env", i64), llvm.ir.NewParam("args", i64)])

        var savedF = curF
        var savedScope = curScopeV
        var savedLoops = loopStack
        var savedTag = curFTag
        curF = f
        curFTag = idx
        loopStack = []
        if (isCtl) { ctlEnter(idx) }

        var b = f.NewBlock("entry")
        curScopeV = callExt(b, "js_scope_new", [f.Params[0]])
        for (var i = 0; i < paramNames.length; i++) {
            callExt(b, "js_scope_decl", [curScopeV, emitStr(b, paramNames[i]),
                                    callExt(b, "js_arg", [f.Params[1], handle(i)])])
        }
        callExt(b, "js_scope_decl", [curScopeV, emitStr(b, "arguments"), f.Params[1]])
        var endB = bodyT(b)
        endB.NewRet(hUndef) // A function without return returns undefined.

        if (isCtl) { ctlLeave() }
        curF = savedF
        curScopeV = savedScope
        loopStack = savedLoops
        curFTag = savedTag
        return idx
    }
    function makeFunctionExpr(bodyT, paramNames) {
        return function(b) {
            var idx = emitFunction(paramNames, bodyT)
            return {b: b, v: callExt(b, "js_closure", [handle(idx), curScopeV])}
        }
    }

    // Arrow function: items = [{aparams:[names]}, {body: stmtThunk} | {ebody: exprThunk}].
    // A block body is a statement thunk; an expression body becomes 'return <expr>'.
    function makeArrow(items) {
        var params = items[0].aparams
        var bm = items[1]
        var bodyT = anytype // Either a block statement thunk or a synthesized return.
        if (bm.body != undefined) {
            bodyT = bm.body
        } else {
            var et = bm.ebody
            bodyT = function(b) { var r = et(b); r.b.NewRet(r.v); return deadBlock() }
        }
        return function(b) {
            var idx = emitFunction(params, bodyT)
            return {b: b, v: callExt(b, "js_closure", [handle(idx), curScopeV])}
        }
    }

    // Template literal: items = [{str:"chunk"} | {expr: thunk}...]. Seeding with ""
    // forces JS string coercion on every interpolated part (js_add).
    function makeTemplate(items) {
        return function(b) {
            var v = emitStr(b, "")
            for (var i = 0; i < items.length; i++) {
                var pv = anytype // The chunk handle: a literal string or an expression value.
                if (items[i].str != undefined) { pv = emitStr(b, items[i].str) }
                else {
                    var r = items[i].expr(b)
                    b = r.b
                    pv = r.v
                }
                v = callExt(b, "js_add", [v, pv])
            }
            return {b: b, v: v}
        }
    }

    // for-of / for-in. items = [name, "of"|"in", iterThunk, bodyThunk].
    // for-of genuinely iterates by index over an array/string: it opens its own scope
    // holding the iterable, the length, and the index (hidden 0-prefixed names that no
    // JS identifier can collide with), then loops name = iter[i] while i < length.
    // for-in iterates the object's own keys: js_keys yields them (insertion order,
    // deterministic, __-prefixed slots skipped), and the same index loop walks that key
    // array, binding name to each key string.
    function makeForOf(items, pos) {
        var name = items[0]
        var iterT = items[2]
        var bodyT = items[3]
        var isIn = items[1] == "in"
        return function(b) {
            var saved = curScopeV
            curScopeV = callExt(b, "js_scope_new", [saved])
            var ir = iterT(b)
            b = ir.b
            var seqV = ir.v
            if (isIn) { seqV = callExt(b, "js_keys", [seqV]) }
            var lenV = callExt(b, "js_tonum", [callExt(b, "js_get", [seqV, emitStr(b, "length")])])
            callExt(b, "js_scope_decl", [curScopeV, emitStr(b, "0it"), seqV])
            callExt(b, "js_scope_decl", [curScopeV, emitStr(b, "0len"), lenV])
            callExt(b, "js_scope_decl", [curScopeV, emitStr(b, "0i"), callExt(b, "js_num_i", [handle(0)])])
            callExt(b, "js_scope_decl", [curScopeV, emitStr(b, name), hUndef])
            var headB = curF.NewBlock("")
            var bodyB = curF.NewBlock("")
            var postB = curF.NewBlock("")
            var exitB = curF.NewBlock("")
            b.NewBr(headB)
            var iC = callExt(headB, "js_scope_get", [curScopeV, emitStr(headB, "0i")])
            var lC = callExt(headB, "js_scope_get", [curScopeV, emitStr(headB, "0len")])
            headB.NewCondBr(truthy(headB, callExt(headB, "js_lt", [iC, lC])), bodyB, exitB)
            var iB = callExt(bodyB, "js_scope_get", [curScopeV, emitStr(bodyB, "0i")])
            var itB = callExt(bodyB, "js_scope_get", [curScopeV, emitStr(bodyB, "0it")])
            callExt(bodyB, "js_scope_set", [curScopeV, emitStr(bodyB, name), callExt(bodyB, "js_get", [itB, iB])])
            loopStack.push({cont: postB, brk: exitB})
            bodyT(bodyB).NewBr(postB)
            loopStack.pop()
            var iP = callExt(postB, "js_scope_get", [curScopeV, emitStr(postB, "0i")])
            var nextV = callExt(postB, "js_add", [iP, callExt(postB, "js_num_i", [handle(1)])])
            callExt(postB, "js_scope_set", [curScopeV, emitStr(postB, "0i"), nextV])
            postB.NewBr(headB)
            curScopeV = saved
            return exitB
        }
    }

    // A destructuring binding is not lowered; run the initializer (calls stay visible).
    function makeDestructure(init, pos) {
        notImpl("destructuring declaration", pos)
        return function(b) { return init(b).b }
    }

    // try/catch/finally is not implemented; under -warn the try block runs.
    // makeCatch is shared - see lib/compile-core.js.
    // try/catch/finally: each body compiles to its own IR closure handed to js_try; the
    // try and catch bodies are ctl closures, so a return/break/continue leaving them
    // becomes a control signal that excDispatch re-issues here.
    function makeTry(items) {
        var tryT = anytype, catchT = anytype, catchName = anytype, finallyT = anytype
        for (var i = 0; i < items.length; i++) {
            if (items[i].trybody != undefined) { tryT = items[i].trybody }
            else if (items[i].catchbody != undefined) { catchT = items[i].catchbody; catchName = items[i].catchname }
            else if (items[i].finbody != undefined) { finallyT = items[i].finbody }
        }
        return function(b) {
            var tryClo = callExt(b, "js_closure", [handle(emitFunction([], tryT, true)), curScopeV])
            var catchClo = hUndef
            if (catchT != undefined) {
                var cn = (catchName != undefined) ? catchName : "__caught"
                catchClo = callExt(b, "js_closure", [handle(emitFunction([cn], catchT, true)), curScopeV])
            }
            var finClo = hUndef
            if (finallyT != undefined) {
                finClo = callExt(b, "js_closure", [handle(emitFunction([], finallyT, true)), curScopeV])
            }
            var ctl = callExt(b, "js_try", [tryClo, catchClo, finClo])
            return excDispatch(b, ctl)
        }
    }

    // ----- Classes (the __class machinery, shared with Java/Ruby) -----
    // An instance is a js_obj_new object carrying a __class descriptor; the descriptor
    // holds the methods (js_closure over the class-defining scope) and the __ctor. A
    // method call dispatches through js_mcall (which prepends the instance as the
    // receiver and follows __super for inheritance); super.m() goes through js_supercall.

    // The class whose body is being built, captured by super() / super.m() at build time.
    var curClassName = ""

    function makeMethod(items) {
        var mods = items[0].mods
        var name = items[1].mname
        var params = items[2]   // The parameter names array (from ParamList).
        var body = items[3]
        var isStatic = false
        for (var i = 0; i < mods.length; i++) { if (mods[i] == "static") { isStatic = true } }
        return {kind: "method", name: name, statik: isStatic, params: params, body: body}
    }
    function makeCtor(items) {
        return {kind: "ctor", params: items[0], body: items[1]}
    }
    function makeField(items) {
        var mods = items[0].mods
        var name = items[1].fname
        var init = items.length > 2 ? items[2] : null
        var isStatic = false
        for (var i = 0; i < mods.length; i++) { if (mods[i] == "static") { isStatic = true } }
        return {kind: "field", name: name, statik: isStatic, init: init}
    }

    // Emits one method/constructor as jsf_N(env, args). For an instance function args[0]
    // is 'this'. A constructor (initFields != null) sets the field defaults/initializers
    // at entry; a default constructor of a subclass (implicitSuper set) first runs the
    // parent constructor with no arguments.
    function emitClassFunc(params, body, isInstance, initFields, implicitSuper) {
        funcCount++
        var idx = funcCount
        var f = m.NewFunc("jsf_" + idx, i64, [llvm.ir.NewParam("env", i64), llvm.ir.NewParam("args", i64)])
        var savedF = curF
        var savedScope = curScopeV
        var savedLoops = loopStack
        curF = f
        loopStack = []
        var b = f.NewBlock("entry")
        curScopeV = callExt(b, "js_scope_new", [f.Params[0]])
        var off = 0
        if (isInstance) {
            callExt(b, "js_scope_decl", [curScopeV, emitStr(b, "this"), callExt(b, "js_arg", [f.Params[1], handle(0)])])
            off = 1
        }
        for (var i = 0; i < params.length; i++) {
            callExt(b, "js_scope_decl", [curScopeV, emitStr(b, params[i]),
                                    callExt(b, "js_arg", [f.Params[1], handle(i + off)])])
        }
        if (implicitSuper != undefined && implicitSuper != null) {
            var supCls = callExt(b, "js_scope_get", [curScopeV, emitStr(b, implicitSuper)])
            var supCtor = callExt(b, "js_get", [supCls, emitStr(b, "__ctor")])
            var sargsV = callExt(b, "js_arr_new", [])
            callExt(b, "js_arr_push", [sargsV, callExt(b, "js_scope_get", [curScopeV, emitStr(b, "this")])])
            callExt(b, "js_call", [supCtor, hUndef, sargsV])
        }
        if (initFields != null) {
            var thisV = callExt(b, "js_scope_get", [curScopeV, emitStr(b, "this")])
            for (var k = 0; k < initFields.length; k++) {
                var fv = hUndef
                if (initFields[k].init != null && initFields[k].init != undefined) {
                    var r = initFields[k].init(b)
                    b = r.b
                    fv = r.v
                }
                callExt(b, "js_set", [thisV, emitStr(b, initFields[k].name), fv])
            }
        }
        var endB = body != null ? body(b) : b
        endB.NewRet(hUndef)
        curF = savedF
        curScopeV = savedScope
        loopStack = savedLoops
        return idx
    }

    // A class declaration: build the descriptor object, bind it in the current scope,
    // then attach static fields, the constructor and the methods.
    function makeClassStmt(items) {
        var name = items[0].cname
        var superName = null
        var members = []
        for (var i = 1; i < items.length; i++) {
            if (items[i] == undefined) { continue }
            if (items[i].ext != undefined) { superName = items[i].ext }
            else if (items[i].skip != undefined) { continue }
            else { members.push(items[i]) }
        }
        var fields = []
        var methods = []
        var statics = []
        var ctorInfo = null
        for (var j = 0; j < members.length; j++) {
            var mm = members[j]
            if (mm.kind == "field") { if (mm.statik) { statics.push(mm) } else { fields.push(mm) } }
            else if (mm.kind == "method") { methods.push(mm) }
            else if (mm.kind == "ctor") { ctorInfo = mm }
        }
        return function(b) {
            var clsV = callExt(b, "js_obj_new", [])
            callExt(b, "js_set", [clsV, emitStr(b, "__isclass"), hTrue])
            callExt(b, "js_set", [clsV, emitStr(b, "__name"), emitStr(b, name)])
            if (superName != null) {
                callExt(b, "js_set", [clsV, emitStr(b, "__super"),
                                      callExt(b, "js_scope_get", [curScopeV, emitStr(b, superName)])])
            }
            callExt(b, "js_scope_decl", [curScopeV, emitStr(b, name), clsV])
            for (var s = 0; s < statics.length; s++) {
                var sv = hUndef
                if (statics[s].init != null && statics[s].init != undefined) {
                    var rs = statics[s].init(b)
                    b = rs.b
                    sv = rs.v
                }
                callExt(b, "js_set", [clsV, emitStr(b, statics[s].name), sv])
            }
            var ctorIdx
            if (ctorInfo != null) {
                ctorIdx = emitClassFunc(ctorInfo.params, ctorInfo.body, true, fields, null)
            } else {
                ctorIdx = emitClassFunc([], null, true, fields, superName)
            }
            callExt(b, "js_set", [clsV, emitStr(b, "__ctor"), callExt(b, "js_closure", [handle(ctorIdx), curScopeV])])
            for (var mi = 0; mi < methods.length; mi++) {
                var idx = emitClassFunc(methods[mi].params, methods[mi].body, !methods[mi].statik, null, null)
                callExt(b, "js_set", [clsV, emitStr(b, methods[mi].name), callExt(b, "js_closure", [handle(idx), curScopeV])])
            }
            return b
        }
    }

    // new C(args): build the instance, attach __class, run the constructor as
    // __ctor(instance, args...).
    function makeNew(items) {
        var clsName = items[0].cls
        var argThunks = items.slice(1)
        return function(b) {
            var clsV = callExt(b, "js_scope_get", [curScopeV, emitStr(b, clsName)])
            var objV = callExt(b, "js_obj_new", [])
            callExt(b, "js_set", [objV, emitStr(b, "__class"), clsV])
            var argsV = callExt(b, "js_arr_new", [])
            callExt(b, "js_arr_push", [argsV, objV])
            for (var i = 0; i < argThunks.length; i++) {
                var r = argThunks[i](b)
                b = r.b
                callExt(b, "js_arr_push", [argsV, r.v])
            }
            var ctorV = callExt(b, "js_get", [clsV, emitStr(b, "__ctor")])
            callExt(b, "js_call", [ctorV, hUndef, argsV])
            return {b: b, v: objV}
        }
    }

    // super(args): delegate to the parent constructor. super.m(args): dispatch m on the
    // parent class (js_supercall walks __super from there). The defining class is
    // captured at build time (curClassName), like Java's super.
    function makeSuperCall(name, argThunks) {
        var defName = curClassName
        if (name == "") {
            return function(b) {
                var clsV = callExt(b, "js_scope_get", [curScopeV, emitStr(b, defName)])
                var supV = callExt(b, "js_get", [clsV, emitStr(b, "__super")])
                var supCtor = callExt(b, "js_get", [supV, emitStr(b, "__ctor")])
                var thisV = callExt(b, "js_scope_get", [curScopeV, emitStr(b, "this")])
                var argsV = callExt(b, "js_arr_new", [])
                callExt(b, "js_arr_push", [argsV, thisV])
                for (var i = 0; i < argThunks.length; i++) {
                    var r = argThunks[i](b)
                    b = r.b
                    callExt(b, "js_arr_push", [argsV, r.v])
                }
                callExt(b, "js_call", [supCtor, hUndef, argsV])
                return {b: b, v: hUndef}
            }
        }
        return function(b) {
            var clsV = callExt(b, "js_scope_get", [curScopeV, emitStr(b, defName)])
            var supV = callExt(b, "js_get", [clsV, emitStr(b, "__super")])
            var thisV = callExt(b, "js_scope_get", [curScopeV, emitStr(b, "this")])
            var argsV = callExt(b, "js_arr_new", [])
            for (var i = 0; i < argThunks.length; i++) {
                var r = argThunks[i](b)
                b = r.b
                callExt(b, "js_arr_push", [argsV, r.v])
            }
            return {b: b, v: callExt(b, "js_supercall", [supV, thisV, emitStr(b, name), argsV])}
        }
    }

    // ----- TypeScript enum -----
    // EnumMember pops [{mname}] or [{mname}, {val}]; the value is the explicit integer
    // or null (auto-increment).
    function makeEnumMember(items) {
        var name = items[0].mname
        var val = null
        if (items.length > 1) { val = items[1].val }
        return {member: name, val: val}
    }
    // makeEnum computes the {name: value} pairs at parse time (identically to the
    // interpreter), then emits an object of those integer constants declared under the
    // enum name, so that Color.Red reads the value at run time.
    function makeEnum(items) {
        var ename = items[0].enumName
        var members = items.slice(1)
        var pairs = []
        var next = 0
        for (var i = 0; i < members.length; i++) {
            var v = anytype // Either the explicit integer or the running counter.
            v = members[i].val
            if (v == null) { v = next }
            pairs.push({k: members[i].member, v: v})
            next = v + 1
        }
        return function(b) {
            var obj = callExt(b, "js_obj_new", [])
            for (var j = 0; j < pairs.length; j++) {
                callExt(b, "js_set", [obj, emitStr(b, pairs[j].k), callExt(b, "js_num_i", [handle(pairs[j].v)])])
            }
            callExt(b, "js_scope_decl", [curScopeV, emitStr(b, ename), obj])
            return b
        }
    }

    // ----- Statement thunks: function(block) -> block to continue in -----

    // An expression in statement position: evaluate the value and record it as the
    // program completion value (what a goja Run() would return; js_getret reads it).
    exprToStmt = function(t) {
        return function(b) {
            var r = t(b)
            callExt(r.b, "js_setret", [r.v])
            return r.b
        }
    }
    // For loop init/post clauses: evaluate and drop (they are no statements, so
    // they must not touch the completion value).
    function exprToClause(t) {
        return function(b) { return t(b).b }
    }
    // items = [name] or [name, initThunk].
    function makeDecl(items) {
        var name = items[0]
        return function(b) {
            var v = hUndef
            if (items.length > 1) {
                var r = items[1](b)
                b = r.b
                v = r.v
            }
            callExt(b, "js_scope_decl", [curScopeV, emitStr(b, name), v])
            return b
        }
    }
    // items = [cond, then] or [cond, then, else].
    // Note: the childs lie on the stack in source order, so pop() delivers them reversed.
    function makeDo(condT, bodyT) {
        return function(b) {
            var bodyB = curF.NewBlock("")
            var condB = curF.NewBlock("")
            var exitB = curF.NewBlock("")
            b.NewBr(bodyB)
            loopStack.push({cont: condB, brk: exitB})
            bodyT(bodyB).NewBr(condB)
            loopStack.pop()
            var r = condT(condB)
            r.b.NewCondBr(truthy(r.b, r.v), bodyB, exitB)
            return exitB
        }
    }
    // items = [{k:"init"|"cond"|"post", t:thunk}..., bodyThunk].
    function makeFor(items) {
        var bodyT = items.pop()
        var init = null, cond = null, post = null
        for (var i = 0; i < items.length; i++) {
            if (items[i].k == "init") init = items[i].t
            if (items[i].k == "cond") cond = items[i].t
            if (items[i].k == "post") post = items[i].t
        }
        return function(b) {
            var saved = curScopeV
            curScopeV = callExt(b, "js_scope_new", [curScopeV]) // The for header is its own scope.
            if (init != null) b = init(b)
            var headB = curF.NewBlock("")
            var bodyB = curF.NewBlock("")
            var postB = curF.NewBlock("")
            var exitB = curF.NewBlock("")
            b.NewBr(headB)
            if (cond != null) {
                var r = cond(headB)
                r.b.NewCondBr(truthy(r.b, r.v), bodyB, exitB)
            } else {
                headB.NewBr(bodyB)
            }
            loopStack.push({cont: postB, brk: exitB})
            bodyT(bodyB).NewBr(postB)
            loopStack.pop()
            var pb = postB
            if (post != null) pb = post(postB)
            pb.NewBr(headB)
            curScopeV = saved
            return exitB
        }
    }
    // items = [] or [exprThunk].
    function makeReturn(items) {
        var t = items.length > 0 ? items[0] : null
        return function(b) {
            var v = hUndef
            if (t != null) {
                var r = t(b)
                b = r.b
                v = r.v
            }
            return retStmt(b, v) // plain ret, or a control signal when leaving a try body
        }
    }
    function makeThrow(t) {
        return function(b) {
            var r = t(b)
            callExt(r.b, "js_throw", [r.v])
            r.b.NewRet(hUndef) // Never reached: js_throw aborts on the host side.
            return deadBlock()
        }
    }
    // items = [subjThunk, ({casev}|{isdflt}|stmtThunk)...]. The flat label/statement
    // list is grouped at build time. The dispatch chain compares with js_seq (===);
    // the case bodies fall through into each other, break jumps to the exit, and
    // continue still targets the enclosing loop.
    function makeSwitch(items) {
        var subj = items[0]
        var cases = []
        var cur = null
        for (var i = 1; i < items.length; i++) {
            var p = items[i]
            if (p != undefined && (p.casev != undefined || p.isdflt != undefined)) {
                cur = {isDefault: p.isdflt != undefined, v: p.casev, body: []}
                cases.push(cur)
            } else {
                if (cur == null) {
                    println("typescript compiler error: switch: a statement before the first case label")
                    exit(1)
                }
                cur.body.push(p)
            }
        }
        return function(b) {
            var r = subj(b)
            b = r.b
            var exitB = curF.NewBlock("")
            var bodyBs = []
            var dfltB = exitB
            for (var i = 0; i < cases.length; i++) {
                bodyBs.push(curF.NewBlock(""))
                if (cases[i].isDefault && dfltB === exitB) { dfltB = bodyBs[i] }
            }
            for (var i = 0; i < cases.length; i++) {
                if (cases[i].isDefault) { continue }
                var rc = cases[i].v(b)
                b = rc.b
                var nextB = curF.NewBlock("")
                b.NewCondBr(truthy(b, callExt(b, "js_seq", [r.v, rc.v])), bodyBs[i], nextB)
                b = nextB
            }
            b.NewBr(dfltB)
            var outerCont = loopStack.length > 0 ? loopStack[loopStack.length - 1].cont : null
            loopStack.push({cont: outerCont, brk: exitB})
            for (var i = 0; i < cases.length; i++) {
                var bb = bodyBs[i]
                var body = cases[i].body
                for (var j = 0; j < body.length; j++) { bb = body[j](bb) }
                bb.NewBr(i + 1 < cases.length ? bodyBs[i + 1] : exitB)
            }
            loopStack.pop()
            return exitB
        }
    }
    // Local stack = [name, [paramNames...], bodyThunk] -- declares the closure when executed.
    function makeFuncDecl(bodyT, paramNames, name) {
        return function(b) {
            var idx = emitFunction(paramNames, bodyT)
            var cl = callExt(b, "js_closure", [handle(idx), curScopeV])
            callExt(b, "js_scope_decl", [curScopeV, emitStr(b, name), cl])
            return b
        }
    }

    // The top level statements become jsrun(scope, args): the caller provides the scope
    // that the top level declarations land in (the frozen tag executor passes the shared
    // scope of the compile run, so scripts see each others globals). The return value is
    // the completion value: what the last executed expression statement produced.
    // jsmain(env, args) is the standalone entry on top of it: it makes a fresh scope,
    // runs the program, and then calls main() - the self checking test convention.
    function buildMain(items) {
        // The walk of an imported file ends here too: stash its top-level statements for
        // the real jsrun (below) instead of emitting a second jsrun/jsmain.
        if (importDepth > 0) {
            stashImported(items) // stashed with its file; emitted later (compile-core)
            return
        }
        var f = m.NewFunc("jsrun", i64, [llvm.ir.NewParam("scope", i64), llvm.ir.NewParam("args", i64)])
        curF = f
        var b = f.NewBlock("entry")
        curScopeV = f.Params[0]
        callExt(b, "js_setret", [hUndef]) // A program without expression statements completes with undefined.
        b = emitImported(b)
        b = makeSeq(items)(b) // imported files' declarations run first
        b.NewRet(callExt(b, "js_getret", []))

        var fm = m.NewFunc("jsmain", i64, [llvm.ir.NewParam("env", i64), llvm.ir.NewParam("args", i64)])
        curF = fm
        var bm = fm.NewBlock("entry")
        var sc = callExt(bm, "js_scope_new", [fm.Params[0]])
        bm.NewCall(f, [sc, fm.Params[1]])
        // The entry point defaults to main() but -main (c.mainName) can name another.
        var entry = c.mainName
        if (entry == undefined || entry == "") { entry = "main" }
        if (mainIsSnippet(entry)) {
            curScopeV = sc // The snippet resolves names in the populated program scope.
            bm = emitMainSnippet(bm, entry, "Statement")
            bm.NewRet(emitNum(bm, 0))
        } else {
            var mainV = callExt(bm, "js_scope_get", [sc, emitStr(bm, entry)])
            var argsV = callExt(bm, "js_arr_new", [])
            bm.NewRet(callExt(bm, "js_call", [mainV, hUndef, argsV]))
        }
    }

    // ----- Widened (recognized-but-not-lowered) constructs -----
    // A binary/relational operator with no runtime primitive (??, **, instanceof, in):
    // with no operator present it is the identity; otherwise it warns and keeps the left
    // operand as the value, so the surrounding expression still produces something.
    function makeNiFold(items, pos, what) {
        if (items.length == 1) { return items[0] }
        notImpl(what, pos)
        return items[0]
    }
    // A prefix operator with no runtime primitive (await/delete/void): evaluate the
    // operand (its side effects stay visible) and hand back its value.
    function makeNiUnary(t, pos, what) {
        notImpl(what, pos)
        return function(b) { return t(b) }
    }
    // yield / yield*: not implemented; evaluate the optional operand, yield undefined.
    function makeYield(items, pos) {
        notImpl("yield", pos)
        if (items.length == 0) { return function(b) { return {b: b, v: hUndef} } }
        var t = items[0]
        return function(b) { var r = t(b); return {b: r.b, v: hUndef} }
    }
    // An async arrow: warn, then build the ordinary (synchronous) closure so it still runs.
    function makeNiArrow(items, pos) {
        notImpl("async arrow function", pos)
        return makeArrow(items)
    }
    // A radix-prefixed integer literal (0b.../0o...): parse the digits after the 2-char
    // prefix in the given base, mirroring the hexAt digit loop (no String.slice needed).
    function radixVal(s, radix) {
        var v = 0
        for (var i = 2; i < s.length; i++) {
            var ch = s.charCodeAt(i)
            var d = (ch >= 48 && ch <= 57) ? ch - 48 : (ch >= 97 ? ch - 87 : ch - 55)
            v = v * radix + d
        }
        return v
    }

    // ===== goja driver =====
    // Everything below this marker is the driver for the normal (goja) run of this
    // grammar. The freezer (-freeze) cuts the start script here: only the library above
    // goes into the bootstrap snapshot; in frozen mode the Go core replaces the driver.

    // Build the module out of the parsed program.
    c.compile(c.asg)

    // Show the compiler output (the LLVM IR module).
    println(m)

    // Run jsmain() with the built-in IR interpreter and the MetaJS handle runtime.
    // The exit code of this metacompiler run is what main() returned, so test
    // programs are self checking.
    var res = llvm.RunJS(m, "jsmain")
    var entryName = c.mainName
    if (entryName == undefined || entryName == "") { entryName = "main" }
    if (mainIsSnippet(entryName)) {
        println("typescript compiler: -main snippet returned " + res.Ret)
    } else {
        println("typescript compiler: " + entryName + "() returned " + res.Ret)
    }
    exit(res.Ret)

~~) ;
