    // preceded by a member is a plain function call.
    foldCallMember = function(items) {
        if (items.length == 1) return items[0]
        var primary = items[0]
        var suffixes = items.slice(1)
        return function(b) {
            var r = primary(b)
            b = r.b
            var cur = r.v
            var curThis = hUndef
            var i = 0
            while (i < suffixes.length) {
                var s = suffixes[i]
                if (s.kind == "member") {
                    var kr = s.key(b)
                    b = kr.b
                    if (i + 1 < suffixes.length && suffixes[i + 1].kind == "call") {
                        var callS = suffixes[i + 1]
                        var objV = cur
                        var keyV = kr.v
                        var fV = callExt(b, "js_get", [objV, keyV])
                        var argsV = callExt(b, "js_arr_new", [])
                        for (var j = 0; j < callS.args.length; j++) {
