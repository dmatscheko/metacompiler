    // ----- values: arrays (indexed) and associative arrays (ordered maps) -----
    function makeArray(items) {
        var hasKeys = false
        for (var i = 0; i < items.length; i++) { if (items[i].hk != undefined) { hasKeys = true } }
        return function() {
            if (!hasKeys) {
                var out = []
                for (var j = 0; j < items.length; j++) { out.push(items[j].elem()) }
