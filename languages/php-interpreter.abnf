    function storeAt(p, v) {
        if (p.last.append === true) { p.obj.push(v); return }
        if (p.last.key != undefined) { p.obj[p.last.key] = v; return }
        var key = p.last.idx()
        if (isDict(p.obj)) { dictSet(p.obj, key, v) } else { p.obj[key] = v }
