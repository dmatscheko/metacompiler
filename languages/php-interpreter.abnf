    function readAt(p) {
        if (p.last.append === true) { return null }
        if (p.last.key != undefined) { return hasOwn(p.obj, p.last.key) ? p.obj[p.last.key] : null }
        return phpIndex(p.obj, p.last.idx())
    }
    function makeAssign(items) {
        var ref = items[0]
        var op = items[1]
        var valT = items[2]
