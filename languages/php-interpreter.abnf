    function applyPhp(op, a, b) {
        if (op == "+=") { return (a + b) | 0 }
        if (op == "-=") { return (a - b) | 0 }
        if (op == "*=") { return (a * b) | 0 }
        if (op == "/=") { return (a / b) | 0 }
        if (op == "%=") { return (a % b) | 0 }
        if (op == ".=") { return phpConcat(a, b) }
