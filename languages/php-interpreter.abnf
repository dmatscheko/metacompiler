    hostGlobals["exit"] = function(code) { exit(code === undefined ? 0 : code | 0) }

    // ----- core config -----
    core.lang = "php"
    core.test = phptest
    binOp = function(op, l, r) {
        if (op == ".") { return phpConcat(l, r) }
        if (op == "+") { return (l + r) | 0 }
        if (op == "-") { return (l - r) | 0 }
        if (op == "*") { return (l * r) | 0 }
        if (op == "/") { return (l / r) | 0 }
        if (op == "%") { return (l % r) | 0 }
        if (op == "==" || op == "===") { return l === r }
        if (op == "!=" || op == "!==") { return l !== r }
        if (op == "<")  { return l < r }
        if (op == ">")  { return l > r }
        if (op == "<=") { return l <= r }
        if (op == ">=") { return l >= r }
