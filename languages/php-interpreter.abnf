                return null
            }
        }
    }

    // ----- new C(...) -----
    function makeNew(items) {
        var name = items[0].cls
        var args = items.slice(1)
        return function() {
            var argv = []
            for (var i = 0; i < args.length; i++) { argv.push(args[i]()) }
