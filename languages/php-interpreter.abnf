            if (cls == undefined || cls == null || cls.__isclass !== true) { fail("new on a non-class: " + name) }
            var obj = {__class: cls}
            if (typeof cls["__construct"] == "function") {
                cls["__construct"].apply(undefined, concat2impl([obj], argv))
            }
            return obj
        }
    }

    // ----- echo / print -----
    function makeEcho(items) {
        var args = items.slice(1)
        return function() {
            var out = ""
            for (var i = 0; i < args.length; i++) { out += phpStr(args[i]()) }
            print(out)
            return null
        }
    }

    // ----- assignment (locals, ->field, [index], [] append) -----
    makeTargetRef = function(items) {
        var head = items[0]
        return {name: head.var, path: items.slice(1)}
    }
    function phpSet(name, value) {
        for (var i = scopes.length - 1; i >= 0; i--) {
            if (hasOwn(scopes[i], name)) { scopes[i][name] = value; return }
        }
        scopes[scopes.length - 1][name] = value
    }
    function resolveRefPhp(ref) {
        var o = anytype
        o = getVar(ref.name)
        for (var i = 0; i < ref.path.length - 1; i++) {
            var s = ref.path[i]
            if (s.key != undefined) { o = o[s.key] } else { o = phpIndex(o, s.idx()) }
        }
