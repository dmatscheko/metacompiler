    // ----- builtins -----
    var phpBuiltins = {
        "count": function(a) { return phpLen(a) },
        "strlen": function(s) { return s.length },
        "in_array": function(n, a) { return a.indexOf(n) >= 0 },
        "array_push": function(a, v) { a.push(v); return a.length },
        "array_keys": function(d) { return isDict(d) ? d.keys.slice(0) : intRange(d.length) },
