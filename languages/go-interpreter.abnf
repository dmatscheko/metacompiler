    // items = [ref..., {op}, exprThunks...]: parallel assignment, or unpacking of a
    // multi value call when there are more targets than expressions.
    function makeAssign(items) {
        var refs = []
        var op = "="
        var i = 0
        for (; i < items.length; i++) {
            if (items[i].op != undefined) { op = items[i].op; i++; break }
            refs.push(items[i])
        }
        var exprs = items.slice(i)
        return function() {
            var vals = []
            for (var k = 0; k < exprs.length; k++) vals.push(exprs[k]())
