    // Each reports "not implemented" (aborts by default, warns under -warn-unsupported)
    // and still evaluates its operands so their calls stay visible in call graphs.

    // go f(...): the callee is evaluated, the concurrency is not modeled.
    function makeGoStmt(callT, pos) {
        notImpl("goroutine", pos)
        return function() { callT(); return undefined }
    }
    // ch <- v: both operands are evaluated, the send is not modeled.
    function makeChanSend(items, pos) {
        var chT = items[0]
        var valT = items[1]
        notImpl("channel send", pos)
        return function() { chT(); valT(); return undefined }
    }
