    // items = [name, name?, listThunk, bodyThunk]: for i, v := range s. Ranging over
    // a map yields its keys (and values) in insertion order (real Go randomizes).
    function makeForRange(items) {
        var bodyT = items.pop()
        var listT = items.pop()
        var iName = items[0]
        var vName = items.length > 1 ? items[1] : null
        return function() {
            var arr = listT()
            var keys = null
            var vals = null
            if (isMap(arr)) { keys = arr.keys.slice(0); vals = arr.vals.slice(0) }
            // range over an int (Go 1.22): the bound is the value itself.
            var n = (typeof arr == "number") ? arr : (keys != null ? keys.length : arr.length)
            var res = undefined
            scopes.push({})
            declVar(iName, 0)
            if (vName != null) declVar(vName, undefined)
            for (var i = 0; i < n; i++) {
                setVar(iName, keys != null ? keys[i] : i)
                if (vName != null) setVar(vName, keys != null ? vals[i] : arr[i])
                var r = bodyT()
                if (r != undefined) {
                    if (r === BRK) break
                    if (r !== CONT) { res = r; break }
                }
            }
            scopes.pop()
            return res
        }
    }
    // Multiple return values travel as an array.
    function makeReturn(items) {
        if (items.length == 0) return function() { return {isRet: true, v: undefined} }
        if (items.length == 1) {
            var t = items[0]
            return function() { return {isRet: true, v: t()} }
        }
        return function() {
            var vals = []
            for (var i = 0; i < items.length; i++) vals.push(items[i]())
            return {isRet: true, v: vals}
        }
    }
    // items = [{v: thunk}...]: one label; no values means 'default'.
    function makeCaseLabel(items) {
        var vals = []
        for (var i = 0; i < items.length; i++) vals.push(items[i].v)
        return {isDefault: items.length == 0, vals: vals}
    }
    // items = [{subj}?, label or statement thunk...]: Go switch, no fallthrough.
    // The flat item list is regrouped: every statement belongs to the last label.
    function makeSwitch(items) {
        var subj = null
        var cases = []
        var cur = null
        for (var i = 0; i < items.length; i++) {
            var it = items[i]
            if (typeof it == "function") {
                if (cur != null) cur.body.push(it)
            } else if (it.subj != undefined) {
                subj = it.subj
            } else {
                cur = {isDefault: it.isDefault, vals: it.vals, body: []}
                cases.push(cur)
            }
        }
        return function() {
            var s = subj != null ? subj() : undefined
            var dflt = -1
            var hit = -1
            for (var i = 0; i < cases.length && hit < 0; i++) {
                if (cases[i].isDefault) { dflt = i; continue }
                for (var v = 0; v < cases[i].vals.length && hit < 0; v++) {
                    var val = cases[i].vals[v]()
                    if (subj != null ? val === s : val) hit = i
                }
