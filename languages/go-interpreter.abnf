    if (typeof globalScope["main"] != "function") {
        fail("Go programs need a func main().")
    }
    var ret = globalScope["main"]()
    println("go interpreter: main() returned " + (ret === undefined ? 0 : ret))
    exit(ret === undefined ? 0 : ret | 0)

