    // type Name struct {...} builds a descriptor; type Name interface {...} is
    // accepted (marked with {iface}) and reported not implemented.
    function buildTypeDecl(items, pos) {
        var last = items[items.length - 1]
        if (typeof last == "object" && last != null && last.iface == true) { notImpl("interface", pos); return }
        buildStruct(items)
    }

