    core.framePop = function() { runDefers(deferFrames.pop()) }

    c.compile(c.asg)

    // Attach the collected methods to their struct descriptors. The receiver type is
    // found by name: func (p Point) dist() -- recvName pushed [name, type].
    for (var mi = 0; mi < methodTodo.length; mi++) {
        var mm = methodTodo[mi]
        var recvVar = mm.recvName[0]
        var recvType = mm.recvName[1]
        var cls = structs[recvType]
        if (cls == undefined) fail("method receiver type not found: " + recvType)
        cls[mm.name] = makeMethodClosure({recvName: recvVar, name: mm.name, params: mm.params, body: mm.body})
