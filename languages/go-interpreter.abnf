    function makeMethodClosure(mm) {
        return function() {
            var self = arguments[0]
            var args = []
            for (var i = 1; i < arguments.length; i++) args.push(arguments[i])
            return invokeBody(mm.params, mm.body, self, mm.recvName, args)
