            if (init != null) { v = init() }
            else if (ty == "int") { v = 0 }
            else if (ty == "string") { v = "" }
            else if (ty == "bool") { v = false }
            else if (ty.charCodeAt(0) == 91) { v = [] } // A slice type: [ ...
