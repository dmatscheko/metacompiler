    function makeForEach(bodyT, arrT, name) {
        return function() {
            var arr = arrT()
            scopes.push({})
            declVar(name, undefined)
            var res = undefined
            for (var i = 0; i < arr.length; i++) {
                setVar(name, arr[i])
                var r = bodyT()
                if (r != undefined) {
