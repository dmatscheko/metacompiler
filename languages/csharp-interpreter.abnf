:title("C# (subset) interpreter") ;
:description("Parses a C# subset and executes it directly, without generating code.

The subset: 'using' directives (resolved against the runtime builtins, like imports),
'namespace X.Y { ... }' blocks (unwrapped; declarations inside behave like top level
ones), classes with instance and static fields (with initializers), instance and static
methods (block bodied and expression bodied '=> e;'), constructors (with an optional
': base(...)' / ': this(...)' header that is parsed and skipped), single inheritance
('class B : A' inherits fields and methods, overrides with dynamic dispatch, runs the
implicit base constructor, and 'base.M()' calls; a base class must appear before its
subclasses), object creation with 'new', arrays (new int[n], new int[]{...}, a.Length,
indexing), List<T> (new List<T>(), .Add, [i], .Count, .Contains, foreach), Dictionary<K,V>
(new Dictionary<K,V>(), d[k] get/set, .Count, .ContainsKey, .Keys, .Values), the 'foreach
(var x in coll)' loop, 'var' and typed locals/params/returns (types are parsed; the
semantics are dynamic), string concatenation with +, '$\"...{expr}...\"' interpolation,
the String members .Length, .Substring, .IndexOf and .Equals, Console.WriteLine /
Console.Write mapped to the print builtin, if/else, while, do-while, both for forms, the
colon switch on int or string (fallthrough with break, stacked labels, default),
break/continue, return, assignment (also += -= *= /= %=), postfix ++/--, the ternary
operator, || && with short circuit, == != < > <= >= (== compares objects by identity and
strings by value) and + - * / % (int arithmetic is 32 bit, / truncates) and unary - !.

Widened surface (parsed so a whole C# file is accepted): generics (<...>), nullable ('?')
and array type suffixes are parsed and dropped; casts ((Type) expr) are identity;
modifier keywords are parsed and ignored. Interfaces, structs, enums, delegates,
nested types, properties ({ get; set; } bodies), lambdas ('=>' as an expression) and LINQ
query expressions are accepted and reported as not implemented; -warn-unsupported
downgrades that to a warning so call graphs / CFGs / traces still work on partly
understood files.

Not genuinely modelled: char/decimal/float literals, overloading, implicit field access
(fields are reached via this.x or ClassName.x), real exception unwinding, properties,
delegates/events, async/await and LINQ.

Fields live directly on the instance object, methods on the class descriptor; a
constructor always exists (a default one is generated) and first applies the field
initializers. The static Main of class Program is the entry point; the process exit code
is Main's return value, so self checking programs 'return failures;'.") ;


// --- main rules

// Shared token productions (languages/lib).
:include("lib/cstyle-comments.abnf") ;
:include("lib/ident.abnf") ;
:include("lib/dq-strings.abnf") ;
:include("lib/numbers.abnf") ;
:include("lib/bools.abnf") ;

:startRule(Program) ;
:whitespace(Whitespace) ;

Program     = { Using } { TopDecl } ;

// A 'using' directive (also 'using static' and the 'using Alias = Path;' form) is
// resolved against the runtime builtins (core.stdlibImports); one that does not resolve
// aborts, unless -warn-imports downgrades it to a warning (see resolveImport). It leaves
// no value on the stack.
Using       <~~ resolveImport(pop(), up.pos) ~~>
            = [ "global" KwEnd ] KwUsing [ "static" KwEnd ] [ Id "=" ] QualName ";" ;
QualName    <~~ push(stripWs(up.in)) ~~> = Id { "." Id } [ "." "*" ] ;

TopDecl     = TopAttr | Namespace | FileNs | UnsupType | ClassDecl ;

// A standalone attribute section at file scope ('[assembly: ...]' / '[module: ...]'):
// accepted and ignored (it pushes no declaration).
TopAttr     = AttrSection ;
// A file scoped namespace ('namespace X.Y;'): a no-op marker; the declarations that
// follow it register themselves at top level (like a block namespace, which is unwrapped).
// The name QualName pushes is discarded so it never lands in a later declaration.
FileNs      <~~ pop() ~~> = KwNamespace QualName ";" ;

// namespace X.Y { ... }: unwrapped. The inner declarations register themselves
// (their tags run during the match); the namespace tag just clears its own name.
Namespace   <~~ takeAll() ~~>
            = KwNamespace QualName "{" { Using | TopDecl } "}" ;

ClassDecl   <~~ buildClass(takeAll()) ~~>
            = [ LeadMods ] KwClass Id <~~ push(up.in); curClassName = up.in ~~> [ SkipAngle ]
              [ ":" Id <~~ push({ext: up.in}) ~~> [ SkipAngle ] { "," Type } ] { WhereClause } "{" { Member } "}" ;

Member      = NestedType | Ctor | Method | Property | Field ;

// A constructor: name matches the class; an optional ': base(...)' / ': this(...)'
// header is parsed and skipped (the implicit base constructor already ran). The body is
// a block or an expression bodied '=> e;' form.
Ctor        <~~ push(makeCtor(takeAll())) ~~>
            = [ LeadMods ] Id <~~ push(up.in) ~~> ParamList [ CtorInit ] CtorBody ;
CtorInit    = ":" ( KwBase | KwThis ) SkipParen ;
CtorBody    = Block | CtorArrow ;
CtorArrow   <~~ push(exprToStmt(pop())) ~~> = "=>" Expression ";" ;

Method      <~~ push(makeMethod(takeAll())) ~~>
            = Mods Type Id <~~ push(up.in) ~~> [ SkipAngle ] ParamList { WhereClause } MethodBody ;
MethodBody  = Block | ArrowBody ;
ArrowBody   <~~ push(makeArrowBody(pop())) ~~>
            = "=>" Expression ";" ;

// A property ({ get; set; } / expression bodied): accepted, reported as not implemented.
Property    <~~ notImpl("property", up.pos) ~~>
            = LeadMods Type Id ( SkipBlock [ "=" DiscardExpr ";" ] | "=>" DiscardExpr ";" ) ;

Field       <~~ push(makeField(takeAll())) ~~>
            = Mods FType Id <~~ push(up.in) ~~> [ "=" Expression ] ";" ;

// Modifiers before a member; ModWord keeps the text so 'static' stays detectable. An
// attribute section here (e.g. '[Obsolete] static int F') is accepted and dropped.
Mods        <~~ push({mods: takeAll()}) ~~>
            = { ModWord | AttrSection } ;
ModWord     <~~ push(up.in) ~~>
            = ModKw ;
FType       <~~ push({ty: up.in}) ~~>
            = Type ;

ParamList   <~~ push({params: takeAll()}) ~~>
            = "(" [ Param { "," Param } ] ")" ;
Param       = { AttrSection } { ParamMod } Type [ "..." ] Id <~~ push(up.in) ~~> [ "=" DiscardExpr ] ;
ParamMod    = ( "ref" | "out" | "in" | "params" | "this" | "readonly" ) KwEnd ;

// Types are parsed and (apart from field defaults) ignored: generic arguments (<...>),
// dotted names, array suffixes and the nullable '?' are accepted and dropped.
Type        = TypeName { "[" { "," } "]" } [ "?" ] ;
TypeName    = PrimType | "string" KwEnd | "String" KwEnd | "object" KwEnd | "void" KwEnd
            | "var" KwEnd | "dynamic" KwEnd | UserType ;
PrimType    = ( "int" | "uint" | "long" | "ulong" | "short" | "ushort" | "byte" | "sbyte"
              | "double" | "float" | "decimal" | "bool" | "char" ) KwEnd ;
UserType    = Id [ SkipAngle ] { "." Id [ SkipAngle ] } ;

// Every statement production pushes exactly one thunk: function() -> undefined | signal.
Statement   = Block | If | While | Do | ForEach | For | Switch | Return | Break | Continue
            | Try | Throw | UsingStmt | Lock | Checked | Decl | Empty | ExprStmt ;

// 'checked { ... }' / 'unchecked { ... }': the block runs (overflow checking is not
// modelled); the keyword is dropped and the inner block thunk stands in for it.
Checked     = ( "checked" KwEnd | "unchecked" KwEnd ) Block ;

// 'lock (e) stmt': the monitor is not modelled; the guard expression still runs (so its
// calls stay visible) and the guarded statement executes.
Lock        <~~ push(makeLock(pop(), pop())) ~~>
            = "lock" KwEnd "(" Expression ")" Statement ;

// 'using (init) stmt' and the 'using var r = e;' declaration form: disposal is not
// modelled; the initializer runs, then the body (or the enclosing statements) execute.
UsingStmt   = KwUsing ( UsingParen | UsingBare ) ;
UsingParen  <~~ push(makeUsing(pop(), pop())) ~~>
            = "(" UsingInit ")" Statement ;
UsingBare   <~~ push(makeUsingDecl(pop())) ~~>
            = DeclCore ";" ;
UsingInit   = UsingDecl | UsingExpr ;
UsingDecl   = DeclCore ;
UsingExpr   <~~ push(exprToStmt(pop())) ~~> = Expression ;

Block       <~~ push(makeBlockStmt(takeAll())) ~~>
            = "{" { Statement } "}" ;

If          <~~ push(makeIf(takeAll())) ~~>
            = KwIf "(" Expression ")" Statement [ KwElse Statement ] ;

While       <~~ push(makeWhile(pop(), pop())) ~~>
            = KwWhile "(" Expression ")" Statement ;

Do          <~~ push(makeDo(pop(), pop())) ~~>
            = KwDo Statement KwWhile "(" Expression ")" ";" ;

// The colon switch (on int or string): starts at the first matching label and runs
// until a break or the end of the switch. Labels may stack.
Switch      <~~ push(makeSwitch(takeAll())) ~~>
            = KwSwitch "(" Expression ")" "{" { SwitchCase } "}" ;
SwitchCase  = Case | Default ;
Case        <~~ push(makeCase(takeAll())) ~~>
            = KwCase CondExpr ":" { Statement } ;
Default     <~~ push(makeDefault(takeAll())) ~~>
            = KwDefault ":" { Statement } ;

// foreach (var x in coll) body.
ForEach     <~~ push(makeForEach(pop(), pop(), pop())) ~~>
            = KwForeach "(" Type Id <~~ push(up.in) ~~> KwIn Expression ")" Statement ;

For         <~~ push(makeFor(takeAll())) ~~>
            = KwFor "(" [ ForInit ] ";" [ ForCond ] ";" [ ForPost ] ")" Statement ;
ForInit     <~~ push({k:"init", t:pop()}) ~~> = ForVar | ForExpr ;
ForVar      = DeclCore ;
ForExpr     <~~ push(exprToStmt(pop())) ~~> = Expression ;
ForCond     <~~ push({k:"cond", t:pop()}) ~~> = Expression ;
ForPost     <~~ push({k:"post", t:exprToStmt(pop())}) ~~> = Expression ;

Return      <~~ push(makeReturn(takeAll())) ~~>
            = KwReturn [ Expression ] ";" ;

Break       <~~ push(makeBreak()) ~~>    = KwBreak ";" ;
Continue    <~~ push(makeContinue()) ~~> = KwContinue ";" ;

// try/catch/finally and throw are implemented (excThrow/excTry, languages/lib): throw
// raises the value, catch binds it (the first catch clause wins - the exception type and
// an optional 'when (cond)' filter are parsed but not discriminated / evaluated), finally
// always runs. return/break/continue inside a try still propagate. A catch may omit the
// parens ('catch { }'), the binding ('catch (T) { }') or bind a name ('catch (T e) { }').
Try         <~~ push(excTry(takeAll())) ~~>
            = KwTry TryBody { CatchClause } [ FinallyClause ] ;
TryBody     <~~ push({trybody: pop()}) ~~>
            = Block ;
CatchClause <~~ push(excCatch(takeAll())) ~~>
            = KwCatch [ "(" Type [ Id <~~ push(up.in) ~~> ] ")" ] [ KwWhen "(" DiscardExpr ")" ] Block ;
FinallyClause <~~ push({finbody: pop()}) ~~>
            = KwFinally Block ;
// throw e; raises e; a bare throw; (rethrow) has no value here, so it raises undefined.
Throw       <~~ push(excThrow(csThrowVal(takeAll()))) ~~>
            = KwThrow [ Expression ] ";" ;

Decl        = DeclCore ";" ;
DeclCore    <~~ push(makeSeq(takeAll())) ~~>
            = Type Declarator { "," Declarator } ;
Declarator  <~~ push(makeDecl(takeAll())) ~~>
            = Id <~~ push(up.in) ~~> [ "=" Expression ] ;

Empty       <~~ push(function() {}) ~~>
            = ";" ;

ExprStmt    <~~ push(exprToStmt(pop())) ~~>
            = Expression ";" ;

// Every expression production pushes exactly one thunk: function() -> value.
Expression  = Assignment | CondExpr ;
// The compound bitwise/shift forms apply like their arithmetic siblings; '??=' is
// accepted but reported as not implemented (it needs a null test). Longer operators are
// listed before their prefixes.
Assignment  <~~ push(makeAssign(takeAll(), up.pos)) ~~>
            = Target ( "<<=" | ">>=" | "??=" | "+=" | "-=" | "*=" | "/=" | "%="
                     | "&=" | "|=" | "^=" | ( "=" !"=" ) ) <~~ push(stripWs(up.in)) ~~> Expression ;

// An assignable place: a variable (this and class names are variables too), or a
// member/index path: this.x, p.X, Program.Fails, arr[i], dict[k].
Target      <~~ push(makeTargetRef(takeAll())) ~~>
            = Id <~~ push(up.in) ~~> { "." Id <~~ push({key: up.in}) ~~> | TIndex } ;
TIndex      <~~ push({idx: pop()}) ~~>
            = "[" Expression "]" ;

CondExpr    <~~ push(makeCond(takeAll())) ~~>
            = NullCoal [ "?" Expression ":" Expression ] ;

// Null-coalescing 'a ?? b': accepted, reported as not implemented (it needs a null test).
NullCoal    <~~ push(makeNullCoal(takeAll(), up.pos)) ~~>
            = OrExpr { "??" OrExpr } ;

OrExpr      <~~ push(makeOrAnd(takeAll(), true)) ~~>
            = AndExpr { "||" AndExpr } ;

AndExpr     <~~ push(makeOrAnd(takeAll(), false)) ~~>
            = BitOr { "&&" BitOr } ;

// The bitwise levels sit between && and equality (as in C#). A lone '|' that actually
// begins '||' fails its right side, the iteration rolls back, and the '||' level above
// picks it up (likewise '&' vs '&&').
BitOr       <~~ push(foldBinary(takeAll())) ~~>
            = BitXor { "|" <~~ push("|") ~~> BitXor } ;
BitXor      <~~ push(foldBinary(takeAll())) ~~>
            = BitAnd { "^" <~~ push("^") ~~> BitAnd } ;
BitAnd      <~~ push(foldBinary(takeAll())) ~~>
            = EqExpr { "&" <~~ push("&") ~~> EqExpr } ;

EqExpr      <~~ push(foldBinary(takeAll())) ~~>
            = RelExpr { ( "==" | "!=" ) <~~ push(up.in) ~~> RelExpr } ;

RelExpr     <~~ push(foldBinary(takeAll())) ~~>
            = TypeTest { ( "<=" | ">=" | "<" | ">" ) <~~ push(up.in) ~~> TypeTest } ;

// 'e is Pattern' / 'e as Type': accepted (common declaration/type/null patterns),
// reported as not implemented (there is no runtime type model).
TypeTest    <~~ push(makeTypeTest(takeAll(), up.pos)) ~~>
            = Shift [ IsAs ] ;
IsAs        <~~ push({typetest: true}) ~~>
            = KwAs Type | KwIs IsPat ;
IsPat       = [ "not" KwEnd ] ( "null" KwEnd | "true" KwEnd | "false" KwEnd | Type [ Id ] ) ;

Shift       <~~ push(foldBinary(takeAll())) ~~>
            = AddExpr { ( "<<" | ">>" ) <~~ push(up.in) ~~> AddExpr } ;

AddExpr     <~~ push(foldBinary(takeAll())) ~~>
            = MulExpr { ( "+" | "-" ) <~~ push(up.in) ~~> MulExpr } ;

MulExpr     <~~ push(foldBinary(takeAll())) ~~>
            = UnaryExpr { ( "*" | "/" | "%" ) <~~ push(up.in) ~~> UnaryExpr } ;

UnaryExpr   = Cast | Neg | Not | BitNot | PostfixExpr ;
Neg         <~~ push(makeNeg(pop())) ~~>
            = "-" UnaryExpr ;
Not         <~~ push(makeNot(pop())) ~~>
            = "!" UnaryExpr ;
BitNot      <~~ push(makeBitNot(pop())) ~~>
            = "~" UnaryExpr ;

// A cast is identity ((Type) expr yields expr). A primitive cast accepts any unary
// operand; a reference cast excludes a leading '-'/'+' so '(a) - b' stays subtraction.
Cast        = PrimCast | RefCast ;
PrimCast    <~~ push(makeCast(pop())) ~~>
            = "(" PrimType { "[" "]" } ")" UnaryExpr ;
RefCast     <~~ push(makeCast(pop())) ~~>
            = "(" RefType ")" UnaryNoPM ;
UnaryNoPM   = Not | PostfixExpr ;
RefType     = ( "string" KwEnd | "String" KwEnd | UserType ) { "[" "]" } ;

PostfixExpr = IncDec | NewExpr | BaseCall | CallMember ;
IncDec      <~~ push(makeIncDec(takeAll())) ~~>
            = Target ( "++" | "--" ) <~~ push(up.in) ~~> ;

// new Point(1, 2) | new List<int>() | new Dictionary<K,V>() | new int[]{...} | new int[n]
// | new Foo{ X = 1 } (object initializer) | new Foo(a){ X = 1 } (ctor + initializer)
NewExpr     = NewObjInit | NewArrLit | NewArrSize | NewObject ;
// An object initializer without constructor parens: 'new Foo{ X = 1, Y = 2 }' runs the
// parameterless constructor, then assigns each named member. Tried before NewArrLit so a
// collection literal ('new List<int>{1, 2}', whose entries are plain expressions) still
// falls through to it.
NewObjInit  <~~ push(makeNew(takeAll())) ~~>
            = KwNew Id <~~ push(up.in) ~~> [ SkipAngle ] ObjInit ;
// The array type suffix ('[]') is part of Type, so 'new int[]{...}' consumes it here.
NewArrLit   <~~ push(makeArray(takeAll())) ~~>
            = KwNew Type "{" [ Expression { "," Expression } ] "}" ;
NewArrSize  <~~ push(makeNewArray(pop())) ~~>
            = KwNew Type "[" Expression "]" ;
NewObject   <~~ push(makeNew(takeAll())) ~~>
            = KwNew Id <~~ push(up.in) ~~> [ SkipAngle ] "(" [ Expression { "," Expression } ] ")" [ ObjInit | SkipBlock ] ;
// { X = expr, ... }: the trailing member initializer of an object creation.
ObjInit     <~~ push({objinit: takeAll()}) ~~>
            = "{" [ MemberInit { "," MemberInit } ] "}" ;
MemberInit  <~~ push(makeMemberInit(pop(), pop())) ~~>
            = Id <~~ push(up.in) ~~> "=" Expression ;

// base.M(args): the method search starts at the base class of the class the call
// appears in (curClassName is set while the class body is being built).
BaseCall    <~~ push(makeBaseCall(popName(), takeAll())) ~~>
            = KwBase "." Id <~~ push({mname: up.in}) ~~> "(" [ Expression { "," Expression } ] ")" ;

// A primary followed by method calls, delegate calls, field reads and indexing. A bare
// '(args)' suffix invokes a delegate / lambda value (a closure call).
CallMember  <~~ push(foldCallMember(takeAll())) ~~>
            = Primary { MethodSfx | CallSfx | FieldSfx | IndexSfx
                      | NCMethodSfx | NCFieldSfx | NCIndexSfx } ;
MethodSfx   <~~ push({kind:"mcall", name: popName(), args: takeAll()}) ~~>
            = "." Id <~~ push({mname: up.in}) ~~> "(" [ Expression { "," Expression } ] ")" ;
CallSfx     <~~ push({kind:"call", args: takeAll()}) ~~>
            = "(" [ Expression { "," Expression } ] ")" ;
FieldSfx    = "." Id <~~ push({kind:"field", name: up.in}) ~~> ;
IndexSfx    <~~ push({kind:"index", idx: pop()}) ~~>
            = "[" Expression "]" ;

// Null-conditional access ('a?.b', 'a?.m(...)', 'a?[i]'): accepted, but a chain that
// contains one is reported as not implemented (there is no null short-circuit model).
// The '?' must be followed by '.' or '[' so the ternary '?' is never captured here.
NCMethodSfx <~~ push({nullcond: true, pos: up.pos}) ~~>
            = "?" "." Id "(" [ Expression { "," Expression } ] ")" ;
NCFieldSfx  <~~ push({nullcond: true, pos: up.pos}) ~~>
            = "?" "." Id ;
NCIndexSfx  <~~ push({nullcond: true, pos: up.pos}) ~~>
            = "?" "[" Expression "]" ;

Primary     = Lambda | LinqQuery | "(" Expression ")"
            | TypeofExpr | NameofExpr | SizeofExpr | DefaultExpr
            | VerbatimStr | InterpStr | DqString | CharLit
            | CsNum | IntLit | True | False | Null | VarRef ;

// typeof(T) / nameof(x) / sizeof(T) / default(T) / default: accepted, reported as not
// implemented (there is no type/reflection model).
TypeofExpr  <~~ push(notImplExpr("typeof", up.pos)) ~~>
            = "typeof" KwEnd "(" Type ")" ;
NameofExpr  <~~ push(notImplExpr("nameof", up.pos)) ~~>
            = "nameof" KwEnd "(" Type ")" ;
SizeofExpr  <~~ push(notImplExpr("sizeof", up.pos)) ~~>
            = "sizeof" KwEnd "(" Type ")" ;
DefaultExpr <~~ push(notImplExpr("default expression", up.pos)) ~~>
            = "default" KwEnd [ "(" Type ")" ] ;

// A char literal 'x' is a one character string constant (SqString, from the shared lib).
CharLit     = SqString ;

// Verbatim '@"..."' and verbatim/interpolated '$@"..." / @$"..."' strings: accepted,
// reported as not implemented (verbatim escaping and the $@ interpolation differ from the
// plain forms). '""' is the escaped quote; every other byte (including newlines) is literal.
VerbatimStr <~~ push(notImplExpr("verbatim string", up.pos)) ~~>
            = ( "$@" | "@$" | "@" ) '"' :whitespace() { VbDQuote | VbChar } '"' :whitespace(Whitespace) ;
VbDQuote    = '"' '"' ;
VbChar      = "\x00"..."\x21" | "\x23"..."\U0010ffff" ;

// C# numeric literals beyond the plain decimal integer that IntLit already handles: hex
// (0x), binary (0b), reals (a '.' fraction, an exponent or an f/d/m suffix), and decimals
// with '_' digit groups or an integer u/l suffix. The value is computed by csNum.
CsNum       <~~ push(makeConst(csNum(up.in))) ~~>
            = CsHex | CsBin | CsReal | CsDecU | CsDecS ;
CsHex       = ( "0x" | "0X" ) :whitespace() CsHexD { CsHexD | "_" } [ CsISfx ] :whitespace(Whitespace) ;
CsBin       = ( "0b" | "0B" ) :whitespace() CsBit { CsBit | "_" } [ CsISfx ] :whitespace(Whitespace) ;
CsReal      = "0"..."9" :whitespace() { "0"..."9" | "_" } CsRealT :whitespace(Whitespace) ;
CsDecU      = "0"..."9" :whitespace() { "0"..."9" } "_" { "0"..."9" | "_" } [ CsISfx ] :whitespace(Whitespace) ;
CsDecS      = "0"..."9" :whitespace() { "0"..."9" } CsISfx :whitespace(Whitespace) ;
CsRealT     = "." "0"..."9" { "0"..."9" | "_" } [ CsExp ] [ CsRSfx ] | CsExp [ CsRSfx ] | CsRSfx ;
CsExp       = ( "e" | "E" ) [ "+" | "-" ] "0"..."9" { "0"..."9" | "_" } ;
CsHexD      = "0"..."9" | "a"..."f" | "A"..."F" ;
CsBit       = "0" | "1" ;
CsISfx      = ( "u" | "U" | "l" | "L" ) [ "u" | "U" | "l" | "L" ] ;
CsRSfx      = "f" | "F" | "d" | "D" | "m" | "M" ;

// A lambda ('x => e', '(a, b) => { ... }') is a real closure value (a Func / Action
// delegate): it captures the current scope chain and is invoked at a call site (CallSfx).
Lambda      <~~ push(makeLambda(takeAll())) ~~>
            = LambdaHead "=>" LambdaBody ;
LambdaHead  = LamParenHead | LamBareHead ;
LamParenHead <~~ push({params: takeAll()}) ~~>
            = "(" [ LamParam { "," LamParam } ] ")" ;
LamBareHead <~~ push({params: takeAll()}) ~~>
            = Id <~~ push(up.in) ~~> ;
// A parameter name, with or without a (parsed, ignored) type. The typed form is an
// ordered alternative so an untyped name is not swallowed by a greedy optional type.
LamParam    = LamTypedParam | LamBareParam ;
LamTypedParam = Type Id <~~ push(up.in) ~~> ;
LamBareParam = Id <~~ push(up.in) ~~> ;
LambdaBody  = LamBlock | LamExpr ;
LamBlock    <~~ push({body: pop()}) ~~> = Block ;
LamExpr     <~~ push({ebody: pop()}) ~~> = Expression ;
// A LINQ query expression: accepted, reported as not implemented.
LinqQuery   <~~ push(makeLinq(up.pos)) ~~>
            = KwFrom Id KwIn DiscardExpr LinqTail ;
LinqTail    = { LinqClause } KwSelect DiscardExpr ;
LinqClause  = KwWhere DiscardExpr | KwOrderby DiscardExpr | KwLet Id "=" DiscardExpr ;
DiscardExpr <~~ pop() ~~>
            = Expression ;

Null        <~~ push(makeConst(null)) ~~>  = "null" KwEnd ;

// 'this' and class names resolve like variables.
VarRef      <~~ push(makeVarRef(up.in)) ~~>
            = Id ;

// $"...{expr}..." interpolated string; a plain "..." (DqString) does not interpolate.
InterpStr   <~~ push(makeTemplate(takeAll())) ~~>
            = "$" '"' :whitespace() { IsExpr | IsChunk } '"' :whitespace(Whitespace) ;
IsExpr      <~~ push({e: pop()}) ~~>
            = "{" :whitespace(Whitespace) Expression :whitespace() "}" ;
IsChunk     <~~ push({s: unescapeJs(up.in)}) ~~>
            = IsChar { IsChar } ;
IsChar      = IsEsc | IsPlain ;
IsEsc       = "\\" "\x20"..b"\x7e" ;
IsPlain     = "\x20"..."\x21" | "\x23"..."\x5b" | "\x5d"..."\x7a" | "\x7c" | "\x7e"..."\U0010ffff" | @"\t" ;

// ----- Widened surface: generics, casts, unsupported declarations (see :description) -----

// Balanced skips let a construct be ACCEPTED without being understood. String and char
// literals are matched first so braces/brackets inside them are never miscounted.
SkipBlock   = "{" { SkipItem } "}" ;
SkipItem    = SkipStr | SkipChar | SkipBlock | SkipOther ;
SkipStr     = '"' :whitespace() { SkipStrEsc | SkipStrChar } '"' :whitespace(Whitespace) ;
SkipStrEsc  = "\\" "\x00"..."\U0010ffff" ;
SkipStrChar = "\x00"..."\x21" | "\x23"..."\x5b" | "\x5d"..."\U0010ffff" ;
SkipChar    = "'" :whitespace() { SkipChEsc | SkipChChar } "'" :whitespace(Whitespace) ;
SkipChEsc   = "\\" "\x00"..."\U0010ffff" ;
SkipChChar  = "\x00"..."\x26" | "\x28"..."\x5b" | "\x5d"..."\U0010ffff" ;
SkipOther   = "\x00"..."\x21" | "\x23"..."\x26" | "\x28"..."\x7a" | "\x7c" | "\x7e"..."\U0010ffff" ;

// A balanced < ... > run (generic parameters / arguments), parsed and ignored.
SkipAngle   = "<" { SkipAngle | SkipAngleItem } ">" ;
SkipAngleItem = "\x00"..."\x3b" | "\x3d" | "\x3f"..."\U0010ffff" ;

// A balanced ( ... ) run (constructor init arguments), parsed and ignored.
SkipParen   = "(" { SkipStr | SkipChar | SkipParen | SkipPOther } ")" ;
SkipPOther  = "\x00"..."\x21" | "\x23"..."\x26" | "\x2a"..."\U0010ffff" ;

// A balanced [ ... ] run: an attribute section (also '[assembly: ...]'), parsed and
// ignored. Strings and chars are matched first so brackets inside them are not miscounted.
AttrSection = "[" { SkipStr | SkipChar | AttrSection | AttrOther } "]" ;
AttrOther   = "\x00"..."\x21" | "\x23"..."\x26" | "\x28"..."\x5a" | "\x5c" | "\x5e"..."\U0010ffff" ;

// A generic constraint clause ('where T : class, IFoo, new()'): accepted and ignored.
WhereClause = "where" KwEnd Id ":" WhereCon { "," WhereCon } ;
WhereCon    = "new" KwEnd "(" ")" | Type ;

KwIs        = "is" KwEnd ;
KwAs        = "as" KwEnd ;

ModKw       = ( "public" | "private" | "protected" | "internal" | "static" | "abstract"
              | "sealed" | "virtual" | "override" | "readonly" | "const" | "partial"
              | "unsafe" | "async" | "extern" | "volatile" ) KwEnd ;
LeadMods    = { ModKw | AttrSection } ;

// Type declarations accepted structurally, then reported as not implemented (so a whole
// C# file parses; -warn-unsupported lets the rest run). Bodies are skipped.
UnsupType   = Interface | StructDecl | EnumDecl | DelegateDecl ;
Interface   <~~ notImpl("interface", up.pos) ~~>
            = LeadMods KwInterface Id [ SkipAngle ] [ ":" Type { "," Type } ] SkipBlock ;
StructDecl  <~~ notImpl("struct", up.pos) ~~>
            = LeadMods KwStruct Id [ SkipAngle ] [ ":" Type { "," Type } ] SkipBlock ;
EnumDecl    <~~ notImpl("enum", up.pos) ~~>
            = LeadMods KwEnum Id [ ":" Type ] SkipBlock ;
DelegateDecl <~~ notImpl("delegate", up.pos) ~~>
            = LeadMods KwDelegate Type Id [ SkipAngle ] SkipParen ";" ;

// A type declared inside a class body (nested): accepted, reported as not implemented.
NestedType  <~~ notImpl("nested type", up.pos) ~~>
            = LeadMods NestedKw Id [ SkipAngle ] [ ":" Type { "," Type } ] SkipBlock ;
NestedKw    = ( "class" | "interface" | "enum" | "struct" | "record" ) KwEnd ;

KwUsing     = "using" KwEnd ;
KwNamespace = "namespace" KwEnd ;
KwClass     = "class" KwEnd ;
KwInterface = "interface" KwEnd ;
KwStruct    = "struct" KwEnd ;
KwEnum      = "enum" KwEnd ;
KwDelegate  = "delegate" KwEnd ;
KwTry       = "try" KwEnd ;
KwCatch     = "catch" KwEnd ;
KwFinally   = "finally" KwEnd ;
KwWhen      = "when" KwEnd ;
KwThrow     = "throw" KwEnd ;
KwIf        = "if" KwEnd ;
KwElse      = "else" KwEnd ;
KwWhile     = "while" KwEnd ;
KwDo        = "do" KwEnd ;
KwFor       = "for" KwEnd ;
KwForeach   = "foreach" KwEnd ;
KwIn        = "in" KwEnd ;
KwReturn    = "return" KwEnd ;
KwBreak     = "break" KwEnd ;
KwContinue  = "continue" KwEnd ;
KwNew       = "new" KwEnd ;
KwBase      = "base" KwEnd ;
KwThis      = "this" KwEnd ;
KwSwitch    = "switch" KwEnd ;
KwCase      = "case" KwEnd ;
KwDefault   = "default" KwEnd ;
KwFrom      = "from" KwEnd ;
KwSelect    = "select" KwEnd ;
KwWhere     = "where" KwEnd ;
KwOrderby   = "orderby" KwEnd ;
KwLet       = "let" KwEnd ;

// ---


:startScript(~~

    // Shared interpreter machinery (scopes, BRK/CONT protocol, expression and
    // statement builders); C#-specific behavior is configured on `core` below.
    include("lib/interp-core.js")

    // The host names a program can see. Console is built here.
    hostGlobals["Console"] = {
        WriteLine: function(x) { println(x === undefined ? "" : csStr(x)) },
        Write: function(x) { print(x === undefined ? "" : csStr(x)) }
    }

    // The class whose body is currently being built (for base calls).
    var curClassName = ""

    // C# to-string for the interpolated / concatenated subset (integers as "5").
    function csStr(v) {
        if (v === undefined || v === null) return ""
        if (v === true) return "true"
        if (v === false) return "false"
        if (typeof v == "string") return v
        return "" + v
    }
    function csStr2(v) {
        if (typeof v == "string") return v
        return csStr(v)
    }
    // The + operator and +=: string concat when either side is a string, else 32-bit add.
    function csAdd(l, r) {
        if (typeof l == "string" || typeof r == "string") return csStr2(l) + csStr2(r)
        return (l + r) | 0
    }

    // ----- Dictionaries mirror the compiled runtime's js_dict handle -----
    function isDict(v) { return v !== null && v !== undefined && typeof v == "object" && v.__dict === true }
    function dictFind(d, k) {
        for (var i = 0; i < d.keys.length; i++) { if (d.keys[i] === k) return i }
        return -1
    }
    function dictSet(d, k, v) {
        var i = dictFind(d, k)
        if (i >= 0) { d.vals[i] = v } else { d.keys.push(k); d.vals.push(v) }
    }
    // .Count / .Length and indexing understand strings, arrays and dictionaries. Defined
    // before their core.* hookup below (the frozen engine does not hoist declarations).
    function csLen(o) {
        if (isDict(o)) return o.keys.length
        if (o === undefined || o === null) fail("Length/Count of null")
        return o.length
    }
    function csGetIndex(o, i) {
        if (isDict(o)) {
            var di = dictFind(o, i)
            if (di < 0) fail("KeyError: " + i)
            return o.vals[di]
        }
        if (typeof o == "string") {
            if (i < 0 || i >= o.length) fail("string index out of range: " + i)
            return o.charAt(i)
        }
        if (o === undefined || o === null) fail("index of null")
        if (i < 0 || i >= o.length) fail("index out of range: " + i)
        return o[i]
    }

    // ----- Method dispatch (mirrors the js_mcall external of the compiled world) -----
    function mcall(target, name, args) {
        if (typeof target == "string") {
            if (name == "Substring") return args.length > 1 ? target.slice(args[0], args[1]) : target.slice(args[0])
            if (name == "IndexOf") return target.indexOf(args[0])
            if (name == "Equals") return target === args[0]
            fail("unknown string method: " + name)
        }
        if (isDict(target)) {
            if (name == "ContainsKey") return dictFind(target, args[0]) >= 0
            if (name == "keys") return target.keys.slice(0)
            if (name == "values") return target.vals.slice(0)
            if (name == "Count") return target.keys.length
            fail("unknown Dictionary method: " + name)
        }
        if (Array.isArray(target)) {
            if (name == "Add") { target.push(args[0]); return true }
            if (name == "Contains") return target.indexOf(args[0]) >= 0
            if (name == "Count") return target.length
            fail("unknown List method: " + name)
        }
        if (target === undefined || target === null) fail("method call ." + name + "() on null")
        if (target.__class != undefined) {
            // The lookup follows the __super chain (inheritance).
            var m = undefined
            for (var c = target.__class; c != undefined && m == undefined; c = c.__super) m = c[name]
            if (typeof m != "function") fail("unknown method '" + name + "' on " + target.__class.__name)
            return m.apply(undefined, concat2impl([target], args))
        }
        if (target.__isclass === true) {
            var sm = target[name]
            if (typeof sm == "function") return sm.apply(undefined, args)
            fail("unknown static method '" + name + "' on " + target.__name)
        }
        var f = target[name]
        if (typeof f != "function") fail("unknown method '" + name + "'")
        return f.apply(undefined, args)
    }

    // A member / call chain: '.m(args)' dispatches through mcall, a bare '(args)' invokes a
    // delegate / lambda closure value, '.field' reads a field and '[i]' indexes. Overrides
    // the shared foldCallMember (assignment form, after the include) to add the call case.
    foldCallMember = function(items) {
        // A chain that carries a null-conditional step ('a?.b', 'a?[i]') is not implemented.
        for (var q = 0; q < items.length; q++) {
            if (items[q] != undefined && items[q].nullcond == true) { return notImplExpr("null-conditional access", items[q].pos) }
        }
        if (items.length == 1) return items[0]
        var primary = items[0]
        var suffixes = items.slice(1)
        return function() {
            var cur = anytype // A chain hops between types: obj.name.length is object, string, number.
            cur = primary()
            for (var i = 0; i < suffixes.length; i++) {
                var s = suffixes[i]
                if (s.kind == "mcall") {
                    var argv = []
                    for (var j = 0; j < s.args.length; j++) argv.push(s.args[j]())
                    cur = mcall(cur, s.name, argv)
                } else if (s.kind == "call") {
                    var av = []
                    for (var k = 0; k < s.args.length; k++) av.push(s.args[k]())
                    if (typeof cur != "function") fail("call of a non-delegate value")
                    cur = cur.apply(undefined, av)
                } else if (s.kind == "field") {
                    if (cur === undefined || cur === null) fail("field ." + s.name + " of " + core.nullWord)
                    cur = core.getField(cur, s.name)
                } else {
                    cur = core.getIndex(cur, s.idx())
                }
            }
            return cur
        }
    }

    // ----- Expression thunks: function() -> value -----

    function makeCond(items) {
        if (items.length == 1) return items[0]
        return function() { return core.test(items[0]()) ? items[1]() : items[2]() }
    }

    // A member/index target: obj[key] / obj.field. Dict-aware for Dictionary targets.
    function csResolveRef(ref) {
        var o = anytype // The containers along the path may be of mixed types.
        o = getVar(ref.name)
        for (var i = 0; i < ref.path.length - 1; i++) {
            var s = ref.path[i]
            if (s.key != undefined) { o = o[s.key] } else { o = csGetIndex(o, s.idx()) }
            if (o === undefined || o === null) fail("null in assignment path of " + ref.name)
        }
        var last = ref.path[ref.path.length - 1]
        return {obj: o, key: (last.key != undefined) ? last.key : last.idx()}
    }
    function makeAssign(items, pos) {
        var ref = items[0]
        var op = items[1]
        var valT = items[2]
        // '??=' needs a null test we do not model: warn, then behave like a plain '='.
        if (op == "??=") { notImpl("??= assignment", pos); op = "=" }
        return function() {
            var v = anytype
            v = valT()
            if (ref.path.length == 0) {
                if (op != "=") v = applyOp(op, getVar(ref.name), v)
                setVar(ref.name, v)
            } else {
                var p = csResolveRef(ref)
                if (isDict(p.obj)) {
                    if (op != "=") { var di = dictFind(p.obj, p.key); v = applyOp(op, di < 0 ? 0 : p.obj.vals[di], v) }
                    dictSet(p.obj, p.key, v)
                } else {
                    if (op != "=") v = applyOp(op, p.obj[p.key], v)
                    p.obj[p.key] = v
                }
            }
            return v
        }
    }
    function makeIncDec(items) {
        var ref = items[0]
        var d = (items[1] == "++") ? 1 : -1
        return function() {
            if (ref.path.length == 0) {
                var n = getVar(ref.name)
                setVar(ref.name, (n + d) | 0)
                return n
            }
            var p = csResolveRef(ref)
            if (isDict(p.obj)) {
                var di = dictFind(p.obj, p.key)
                var m = di < 0 ? 0 : p.obj.vals[di]
                dictSet(p.obj, p.key, (m + d) | 0)
                return m
            }
            var m2 = p.obj[p.key]
            p.obj[p.key] = (m2 + d) | 0
            return m2
        }
    }

    // base.M(args): the search starts at the base class of the DEFINING class.
    function makeBaseCall(name, argThunks) {
        var defName = curClassName
        return function() {
            var self = getVar("this")
            var m = undefined
            for (var c = getVar(defName).__super; c != undefined && m == undefined; c = c.__super) m = c[name]
            if (typeof m != "function") fail("unknown base method '" + name + "'")
            var argv = [self]
            for (var i = 0; i < argThunks.length; i++) argv.push(argThunks[i]())
            return m.apply(undefined, argv)
        }
    }

    // new C(args) | new C(args){ F = e } | new C{ F = e } | new List<T>(...) |
    // new Dictionary<K,V>(...). An object initializer ({objinit} marker) assigns the named
    // members after construction; the remaining thunks are the constructor arguments.
    function makeNew(items) {
        var clsName = items[0]
        var args = []
        var minits = null
        for (var i = 1; i < items.length; i++) {
            if (typeof items[i] == "function") { args.push(items[i]) }
            else if (items[i].objinit != undefined) { minits = items[i].objinit }
        }
        return function() {
            if (clsName == "List") {
                for (var i = 0; i < args.length; i++) { args[i]() }
                return []
            }
            if (clsName == "Dictionary") {
                for (var j = 0; j < args.length; j++) { args[j]() }
                return {__dict: true, keys: [], vals: []}
            }
            var cls = getVar(clsName)
            if (cls == undefined || !cls.__isclass) fail("unknown class: " + clsName)
            var obj = {__class: cls}
            var argv = [obj]
            for (var k = 0; k < args.length; k++) argv.push(args[k]())
            cls.__ctor.apply(undefined, argv)
            if (minits != null) {
                for (var q = 0; q < minits.length; q++) obj[minits[q].mfield] = minits[q].mval()
            }
            return obj
        }
    }
    // { F = e, ... } member initializer entry: the field name and its value thunk.
    function makeMemberInit(valT, name) { return {mfield: name, mval: valT} }
    function makeArray(items) {
        return function() {
            var a = []
            for (var i = 0; i < items.length; i++) a.push(items[i]())
            return a
        }
    }
    function makeNewArray(sizeT) {
        return function() {
            var n = sizeT()
            var a = []
            for (var i = 0; i < n; i++) a.push(0)
            return a
        }
    }
    // A cast is identity: (Type) expr evaluates to expr.
    function makeCast(inner) { return inner }
    // ~v flips the 32-bit representation (JS ~).
    function makeBitNot(t) { return function() { return ~t() } }
    // A '??' chain / 'is'-'as' test / null-conditional chain: parsed, not implemented.
    function makeNullCoal(items, pos) {
        if (items.length == 1) { return items[0] }
        return notImplExpr("null-coalescing operator", pos)
    }
    function makeTypeTest(items, pos) {
        if (items.length == 1) { return items[0] }
        return notImplExpr("is/as operator", pos)
    }

    // Extended numeric literal text (whitespace and '_' removed) to a number: hex (0x),
    // binary (0b), then real (parseFloat) or integer (parseInt); type suffixes are ignored
    // by parseInt/parseFloat, which stop at the first non-digit.
    function csNum(s) {
        s = stripWs(s)
        var t = ""
        for (var i = 0; i < s.length; i++) { if (s.charAt(i) != "_") { t = t + s.charAt(i) } }
        if (t.length >= 2 && t.charAt(0) == "0" && (t.charAt(1) == "x" || t.charAt(1) == "X")) { return parseInt(t.substring(2), 16) }
        if (t.length >= 2 && t.charAt(0) == "0" && (t.charAt(1) == "b" || t.charAt(1) == "B")) { return parseInt(t.substring(2), 2) }
        if (t.indexOf(".") >= 0 || t.indexOf("e") >= 0 || t.indexOf("E") >= 0) { return parseFloat(t) }
        return parseInt(t, 10)
    }

    // 'lock (e) s': run the guard (keeping its calls), then the guarded statement.
    function makeLock(stmtT, exprT) {
        return function() {
            exprT()
            return stmtT()
        }
    }
    // 'using (init) s': the initializer and body run in a fresh frame; disposal is skipped.
    function makeUsing(bodyT, initT) {
        return function() {
            scopes.push({})
            initT()
            var r = bodyT()
            scopes.pop()
            return r
        }
    }
    // 'using var r = e;': the declaration runs; disposal is skipped.
    function makeUsingDecl(t) { return t }
    // A lambda is a real closure value. It captures the scope chain live at the point it is
    // evaluated (a copy of the array, so the scope objects stay shared and later mutations
    // of a captured local stay visible). LINQ stays unimplemented.
    function makeLambda(items) {
        var params = items[0].params
        var bm = items[1]
        var bodyT = anytype // A block statement thunk, or a synthesized 'return <expr>'.
        if (bm.body != undefined) { bodyT = bm.body }
        else { bodyT = makeArrowBody(bm.ebody) }
        return function() { return makeCsClosure(params, bodyT, scopes.slice(0)) }
    }
    function makeCsClosure(params, bodyT, defScopes) {
        return function() {
            var args = []
            for (var i = 0; i < arguments.length; i++) args.push(arguments[i])
            var saved = scopes
            scopes = defScopes.slice(0)
            var sc = {}
            for (var j = 0; j < params.length; j++) sc[params[j]] = j < args.length ? args[j] : undefined
            scopes.push(sc)
            var r = bodyT()
            scopes = saved
            return (r != undefined && r.isRet) ? r.v : undefined
        }
    }
    function makeLinq(pos) { return notImplExpr("LINQ query", pos) }

    // ----- Statement thunks -----

    // try/catch/finally and throw are handled by excTry/excThrow (lib/interp-core.js).
    // csThrowVal supplies the thrown-value thunk: the expression for 'throw e;', or an
    // undefined constant for a bare 'throw;' rethrow (which carries no value in this model).
    function csThrowVal(items) { return items.length > 0 ? items[0] : makeConst(undefined) }

    function makeDecl(items) {
        var name = items[0]
        var init = items.length > 1 ? items[1] : makeConst(0)
        return function() { declVar(name, init()) }
    }
    // An expression bodied method '=> e;' behaves like { return e; }.
    function makeArrowBody(t) {
        return function() { return {isRet: true, v: t()} }
    }
    function makeDo(condT, bodyT) {
        return function() {
            do {
                var r = bodyT()
                if (r != undefined) {
                    if (r === BRK) break
                    if (r !== CONT) return r
                }
            } while (core.test(condT()))
        }
    }
    function makeCase(items) { return {isDefault: false, v: items[0], body: items.slice(1)} }
    function makeDefault(items) { return {isDefault: true, body: items} }
    // The switch compares with === (identity for ints and value for strings, matching
    // js_seq of the compiled world). Execution falls through until a break.
    function makeSwitch(items) {
        var scrut = items[0]
        var cases = items.slice(1)
        return function() {
            var v = scrut()
            var start = -1
            var dflt = -1
            for (var i = 0; i < cases.length; i++) {
                if (cases[i].isDefault) { dflt = i; continue }
                if (start < 0 && cases[i].v() === v) { start = i }
            }
            if (start < 0) { start = dflt }
            if (start < 0) { return undefined }
            for (var j = start; j < cases.length; j++) {
                var body = cases[j].body
                for (var k = 0; k < body.length; k++) {
                    var r = body[k]()
                    if (r === BRK) { return undefined }
                    if (r != undefined) { return r }
                }
            }
            return undefined
        }
    }
