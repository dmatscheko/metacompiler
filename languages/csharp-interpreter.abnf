        // without arguments), then this class' field defaults and initializers.
        function initFields(self) {
            if (sup != null) sup.__ctor(self)
            for (var k = 0; k < fields.length; k++) {
                self[fields[k].name] = (fields[k].init != null && fields[k].init != undefined) ? fields[k].init() : fields[k].dflt
            }
        }
        if (ctorInfo != null) {
            cls.__ctor = makeCtorClosure(ctorInfo, initFields)
        } else {
            cls.__ctor = function() { initFields(arguments[0]) }
        }
        for (i = 0; i < members.length; i++) {
            var m2 = members[i]
            if (m2.kind == "method") {
                cls[m2.name] = m2.statik ? makeStaticClosure(m2) : makeInstanceClosure(m2)
            }
        }
        globalScope[name] = cls
    }
    function makeCtorClosure(info, initFields) {
        return function() {
            var self = arguments[0]
            initFields(self)
            var args = []
            for (var i = 1; i < arguments.length; i++) args.push(arguments[i])
            invokeBody(info.params, info.body, self, "this", args)
        }
    }
    function makeInstanceClosure(m) {
        return function() {
            var self = arguments[0]
            var args = []
            for (var i = 1; i < arguments.length; i++) args.push(arguments[i])
            return invokeBody(m.params, m.body, self, "this", args)
        }
    }
    function makeStaticClosure(m) {
        return function() {
            var args = []
            for (var i = 0; i < arguments.length; i++) args.push(arguments[i])
            return invokeBody(m.params, m.body, undefined, "this", args)
        }
    }

    function buildClass(items) {
        buildClassFrom(items[0], items.slice(1))
    }

    // ----- Core library config (see lib/interp-core.js) -----
    core.lang = "csharp"
    core.add = csAdd
    core.getField = function(o, name) {
        if (name == "Count" || name == "Length") return csLen(o)
        if (name == "Keys") return mcall(o, "keys", [])
        if (name == "Values") return mcall(o, "values", [])
        return o[name]
    }
    core.getIndex = csGetIndex

    // The binary/compound operators, extended with the bitwise and shift forms (32-bit,
    // matching the compiled js_band/js_bor/... externals). The existing arithmetic and
    // comparison cases are preserved exactly; only the bitwise cases are new.
    binOp = function(op, l, r) {
        if (op == "+") return core.add(l, r)
        if (op == "-") return (l - r) | 0
        if (op == "*") return (l * r) | 0
        if (op == "/") return (l / r) | 0
        if (op == "%") return (l % r) | 0
        if (op == "==") return l === r
        if (op == "!=") return l !== r
        if (op == "<")  return l < r
        if (op == ">")  return l > r
        if (op == "<=") return l <= r
        if (op == ">=") return l >= r
        if (op == "|")  return l | r
        if (op == "^")  return l ^ r
        if (op == "&")  return l & r
        if (op == "<<") return l << r
        if (op == ">>") return l >> r
    }
    applyOp = function(op, a, b) {
        if (op == "+=") return core.add(a, b)
        if (op == "-=") return (a - b) | 0
        if (op == "*=") return (a * b) | 0
        if (op == "/=") return (a / b) | 0
        if (op == "%=") return (a % b) | 0
        if (op == "&=") return a & b
        if (op == "|=") return a | b
        if (op == "^=") return a ^ b
        if (op == "<<=") return a << b
        if (op == ">>=") return a >> b
    }

    // Import roots the runtime already provides (Console, collections, ...); importing
    // them is a no-op. Anything else is a library we cannot resolve.
    core.stdlibImports = ["System", "Microsoft"]

    c.compile(c.asg)

    var progCls = globalScope["Program"]
    if (progCls == undefined || typeof progCls["Main"] != "function") {
        fail("C# programs need a class Program with a static Main method.")
    }
    // A user exception that escapes Main() is reported like any runtime error.
    var ret = anytype
    try {
        ret = progCls["Main"]()
    } catch (e) {
        if (excIsUser(e)) { fail("uncaught exception: " + e.v) }
        throw e
    }
    exit(ret === undefined ? 0 : ret | 0)

