    function buildClassFrom(name, members) {
        var cls = {__isclass: true, __name: name}
        var fields = []
        var ctorInfo = null
        var sup = null
        var i
        for (i = 0; i < members.length; i++) {
            if (members[i].ext != undefined) {
                // Lenient: a base that is not a known class (an interface) is ignored.
                sup = globalScope[members[i].ext]
                if (sup != undefined) cls.__super = sup
