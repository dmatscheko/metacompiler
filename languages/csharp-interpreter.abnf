    function makeLinq(pos) { return notImplExpr("LINQ query", pos) }

    // ----- Statement thunks -----

    // try/catch/finally has no exception model; the try block still runs. throw
    // evaluates its expression (keeping calls visible) but does not unwind.
    function makeTry(items, pos) { notImpl("try/catch/finally", pos); return items[0] }
