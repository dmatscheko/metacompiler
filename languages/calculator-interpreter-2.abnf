:title("Calculator interpreter (local stacks)") ;
:description("Like calculator-interpreter-1.abnf, but built on the local stacks
(push/pop) instead of the global one (pushg/popg): The tag of a group sees the merged
pushes of everything inside the group, so the whole chain 'Term op Term op Term ...'
can be collected and folded left to right in one place.") ;


:startRule(Expression) ;

Expression  =
    (
        Term
        {
            ( "+" | "-" )       <~~push(up.in)~~>
            Term
        }
    )                           <~~
                                // The local stack now holds [value, op, value, op, value, ...].
                                push(foldChain(takeAll()))
                                ~~>
    ;

Term        =
    (
        Factor
        {
            ( "*" | "/" )       <~~push(up.in)~~>
            Factor
        }
    )                           <~~
                                push(foldChain(takeAll()))
                                ~~>
    ;

Factor      =
    (
        "("
        Expression
        ")"
    )
    |
    Neg
    |
    // The grammar allows a comma as decimal separator, parseFloat() does not.
    Number                      <~~push(mkNum(parseFloat(up.in.replace(",", ".")), up.in))~~>
    ;

// Unary minus negates the factor behind it (and '- -x' works through the recursion).
Neg         = ( "-" Factor )    <~~push(mkNeg(pop()))~~> ;

Number      = ( "0" | "1"..."9" { "0"..."9" } )
              [ ( "." | "," ) "0"..."9" { "0"..."9" } ] ;


:startScript(~~
    // takeAll empties the local stack of the current tag and returns its items in push order.
    function takeAll() {
        var items = []
        var v = anytype // The tags push values of every type.
        while ((v = pop()) != null) items.unshift(v)
        return items
    }

    // A node carries the value v and the parenthesized text s of its sub-expression;
    // atom marks a leaf (a number) that needs no parentheses when nested. paren() wraps a
    // composite child, so the printed formula shows exactly how the input was parsed.
    function mkNum(v, txt) { return {v: v, s: txt, atom: true} }
    function paren(n) { return n.atom ? n.s : "(" + n.s + ")" }
    function mkNeg(n) { return {v: -n.v, s: "-" + paren(n), atom: false} }

    // items = [node, op, node, op, node, ...] -> the left folded node.
    function foldChain(items) {
        var node = items[0]
        for (var i = 1; i < items.length; i += 2) {
            var op = items[i]
            var w = items[i + 1]
            println("calculating " + node.v + " " + op + " " + w.v)
            var v = anytype
            if (op == "+") { v = node.v + w.v }
            if (op == "-") { v = node.v - w.v }
            if (op == "*") { v = node.v * w.v }
            if (op == "/") { v = node.v / w.v }
            node = {v: v, s: paren(node) + " " + op + " " + paren(w), atom: false}
        }
        return node
    }

    var res = c.compile(c.asg)
    // The final node lies on the local stack of the topmost expression, which arrives
    // here as the combined up.stack of the whole compilation.
    var top = res.stack[0]
    println("\nFormula was: " + top.s + "\nRESULT: " + top.v)
~~) ;
