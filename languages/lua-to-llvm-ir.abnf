:title("Lua (subset) to LLVM IR compiler") ;
:description("Compiles a Lua subset to an LLVM IR module and runs it with the built-in IR
interpreter and the MetaJS handle runtime (llvm.RunJS).

The language is the one of lua-interpreter.abnf; see there for the description. This
grammar shares its rules and only swaps the tree walking start script for an emitter.

The emitted IR is handle threaded: every dynamic value is an i64 handle into the value
table of the Go side MetaJS runtime (abnf/jsrt.go), and every operation with real
semantics is a call to one of its js_* externals. Only the control flow is real IR:
if/elseif/while/numeric-for/and/or compile to basic blocks, branches and phis, driven by
a Lua truthiness test (only false and nil are falsy) built from js_seq. repeat/until and
the ipairs generic for lower to basic blocks the same way; a method call obj:m(a) loads m
via js_get and js_call's it with the receiver prepended as self. The handles 0..3
are nil, null, false and true. Locals live in scope chain objects (js_scope_new /
js_scope_decl / js_scope_get / js_scope_set); a bare assignment goes through
js_pyset_var (assign up the chain, else create). Tables are host objects (js_obj_new,
js_get, js_set) with 1 based numeric keys stringified like the interpreter; #t probes
t[1], t[2], ... for the sequence border. Concatenation stringifies both sides with
js_pystr and joins them with js_add; the arithmetic and comparison operators map to
js_add/js_sub/js_mul/js_div/js_fdiv/js_fmod and js_seq/js_sne/js_lt/js_gt/js_le/js_ge.
Functions become IR functions jsf_N(env, args) plus a js_closure at the creation site;
print is a small IR function over js_pyprint. The whole file becomes jsmain(env, args)
and runs top to bottom. Self checking programs count their failures and end with
exit(fails). The same language with the same semantics is interpreted directly by
lua-interpreter.abnf.") ;

// --- main rules

// Shared token productions (languages/lib).
:include("lib/ident.abnf") ;
:include("lib/dq-strings.abnf") ;
:include("lib/numbers.abnf") ;
:include("lib/bools.abnf") ;

:startRule(Chunk) ;
:whitespace(Whitespace) ;

// The whole file is one block; buildChunk runs it (interpreter) or wraps it into
// jsmain (compiler). Block collects the statement thunks of exactly its own subtree.
Chunk       <~~ buildChunk(takeAll()) ~~>
            = Block ;
Block       <~~ push(makeSeq(takeAll())) ~~>
            = { NotEnders Statement } ;

// NotEnders stops a block at the keywords that terminate it (end / else / elseif /
// until), which the plain identifier statements would otherwise swallow. It consumes
// nothing and only fails (via the impossible-token trick) when one of those words - as
// a whole word, not merely a prefix like 'ending' - is next.
NotEnders = :script(~~
    (function() {
        // Skip leading whitespace and -- line comments (a :script sees the raw input).
        var off = 0
        var scanning = true
        while (scanning) {
            var cc = c.peek(off)
            if (cc === 32 || cc === 9 || cc === 13 || cc === 10) { off++ }
            else if (cc === 45 && c.peek(off + 1) === 45) {
                off += 2
                while (c.peek(off) !== 10 && c.peek(off) !== -1) { off++ }
            } else { scanning = false }
        }
        var p0 = c.peek(off)
        var after = -1
        var hit = false
        if (p0 === 101) {
            var p1 = c.peek(off + 1)
            var p2 = c.peek(off + 2)
            var p3 = c.peek(off + 3)
            if (p1 === 110 && p2 === 100) {
                after = c.peek(off + 3)
                hit = true
            } else if (p1 === 108 && p2 === 115 && p3 === 101) {
                after = c.peek(off + 4)
                if (after === 105 && c.peek(off + 5) === 102) { after = c.peek(off + 6) }
                hit = true
            }
        } else if (p0 === 117) {
            if (c.peek(off + 1) === 110 && c.peek(off + 2) === 116 && c.peek(off + 3) === 105 && c.peek(off + 4) === 108) {
                after = c.peek(off + 5)
                hit = true
            }
        } else {
            return undefined
        }
        if (!hit) { return undefined }
        if ((after >= 48 && after <= 57) || (after >= 65 && after <= 90) || after === 95 || (after >= 97 && after <= 122)) {
            return undefined
        }
        return abnf.newToken("\x01block-terminator", 0)
    })()
~~) ;

// Every statement production pushes exactly one thunk. The keyword led statements come
// first (they commit on their unique keyword); an assignment is tried before a bare
// call statement, because its targets look like the start of a call until the '='.
Statement   <~~ push(stmtPos(pop())) ~~>
            = If | While | Repeat | NumFor | GenFor | DoBlock | LocalFunc | Local | Func
            | Return | Break | Goto | Label | EmptyStat | AssignStat | CallStat ;

If          <~~ push(makeIf(takeAll())) ~~>
            = KwIf Expression KwThen Block { ElseIf } [ Else ] KwEndKw ;
ElseIf      <~~ push(makeElseIf(pop(), pop())) ~~>
            = KwElseif Expression KwThen Block ;
Else        <~~ push(makeElse(pop())) ~~>
            = KwElse Block ;

While       <~~ push(makeWhile(pop(), pop())) ~~>
            = KwWhile Expression KwDo Block KwEndKw ;

// repeat ... until cond: the body runs at least once and repeats while cond is false;
// unlike while, the condition sees the locals declared in the body (same scope).
Repeat      <~~ var cond = pop(); var block = pop(); push(makeRepeat(block, cond)) ~~>
            = KwRepeat Block KwUntil Expression ;

// for i = start, limit [, step] do ... end. The loop variable is local to the loop.
NumFor      <~~ push(makeNumFor(takeAll())) ~~>
            = KwFor ForName "=" Expression "," Expression [ "," Expression ] KwDo Block KwEndKw ;
ForName     <~~ push({fname: up.in}) ~~>
            = Id ;

// for k, v in <iter> do ... end. Only the pairs()/ipairs() iterators are recognized;
// ipairs is lowered to a 1-based array walk (index, value) that stops at the first nil.
// pairs (key enumeration) and any other iterator are accepted but not implemented.
GenFor      <~~ push(makeGenFor(takeAll(), up.pos)) ~~>
            = KwFor GenName { "," GenName } KwIn IterExpr KwDo Block KwEndKw ;
GenName     <~~ push({gname: up.in}) ~~>
            = Id ;
IterExpr    = IpairsIter | PairsIter | GenericIter ;
IpairsIter  <~~ push({iterkind: "ipairs", tbl: pop()}) ~~>
            = "ipairs" KwEnd "(" Expression ")" ;
PairsIter   <~~ push({iterkind: "pairs", tbl: pop()}) ~~>
            = "pairs" KwEnd "(" Expression ")" ;
GenericIter <~~ takeAll(); push({iterkind: "generic"}) ~~>
            = Expression { "," Expression } ;

DoBlock     <~~ push(makeDoBlock(pop())) ~~>
            = KwDo Block KwEndKw ;

LocalFunc   <~~ push(makeLocalFunc(pop(), pop(), pop())) ~~>
            = KwLocal KwFunction Id <~~ push(up.in) ~~> ParamList Block KwEndKw ;

Local       <~~ push(makeLocal(takeAll())) ~~>
            = KwLocal LocalName [ Attrib ] { "," LocalName [ Attrib ] } [ "=" ExprList ] ;
LocalName   <~~ push({lname: up.in}) ~~>
            = Id ;
// Lua 5.4 local attribute: local x <const> = 1 / local h <close> = r. Accepted and
// ignored (the subset enforces neither const-ness nor to-be-closed semantics).
Attrib      = "<" Id ">" ;

// function name(...) end, function tbl.field(...) end, and the method-definition sugar
// function tbl:method(...) end (which binds an implicit first parameter 'self').
Func        <~~ push(makeFunc(pop(), pop(), pop())) ~~>
            = KwFunction FuncName ParamList Block KwEndKw ;
FuncName    <~~ push(makeFuncName(takeAll())) ~~>
            = Id <~~ push({fnbase: up.in}) ~~> { "." Id <~~ push({fnstep: up.in}) ~~> } [ ":" Id <~~ push({fnstep: up.in, fnself: true}) ~~> ] ;

ParamList   <~~ push({params: takeAll()}) ~~>
            = "(" [ ( Id <~~ push(up.in) ~~> { "," Id <~~ push(up.in) ~~> } [ "," VarargPar ] | VarargPar ) ] ")" ;
// A trailing '...' makes the function variadic. Accepted and ignored (extra arguments
// are dropped); a use of '...' inside the body is separately not implemented.
VarargPar   = "..." ;

Return      <~~ push(makeReturn(takeAll())) ~~>
            = KwReturn [ ExprList ] ;
Break       <~~ push(makeBreak()) ~~>
            = KwBreak ;

// goto Name jumps to a matching ::Name:: label (Lua 5.2+); both are accepted
// structurally and reported as not implemented (the tree walker / CFG builder has no
// cross-statement jump). -warn-unsupported keeps the surrounding code.
Goto        <~~ push(notImplStmt("goto", up.pos)) ~~>
            = KwGoto Id ;
Label       <~~ push(notImplStmt("label", up.pos)) ~~>
            = "::" Id "::" ;
// A lone ';' or one terminating the previous statement (Lua allows ';' between and
// after statements): a no-op.
EmptyStat   <~~ push(makeEmpty()) ~~>
            = ";" ;

// varlist '=' exprlist. The targets and the values sit interleaved on the stack;
// makeAssign tells them apart (a target is an object, a value thunk a function).
AssignStat  <~~ push(makeAssign(takeAll())) ~~>
            = Target { "," Target } "=" ExprList ;
Target      <~~ push(makeTargetRef(takeAll())) ~~>
            = Id <~~ push(up.in) ~~> { DotSfx | IndexSfx } ;

CallStat    <~~ push(exprToStmt(pop())) ~~>
            = SuffixedExpr ;

ExprList    = Expression { "," Expression } ;

// Every expression production pushes exactly one thunk: function() -> value.
Expression  = OrExpr ;

OrExpr      <~~ push(makeOrAnd(takeAll(), true)) ~~>
            = AndExpr { KwOr AndExpr } ;
AndExpr     <~~ push(makeOrAnd(takeAll(), false)) ~~>
            = CmpExpr { KwAnd CmpExpr } ;

CmpExpr     <~~ push(foldBinary(takeAll())) ~~>
            = BitExpr { ( "==" | "~=" | "<=" | ">=" | "<" | ">" ) <~~ push(up.in) ~~> BitExpr } ;

// Bitwise & | ~ << >> (Lua 5.3+): accepted, reported as not implemented (the handle
// runtime has no integer bit operations). Binary '~' is guarded with !"=" so a '~='
// comparison is left for CmpExpr above.
BitExpr     <~~ push(makeBit(takeAll(), up.pos)) ~~>
            = ConcatExpr { ( "&" | "|" | "<<" | ">>" | ( "~" !"=" ) ) ConcatExpr } ;

// Concatenation is right associative, so it recurses on its own right hand side.
ConcatExpr  <~~ push(makeConcat(takeAll())) ~~>
            = AddExpr [ ".." ConcatExpr ] ;

AddExpr     <~~ push(foldBinary(takeAll())) ~~>
            = MulExpr { ( "+" | "-" ) <~~ push(up.in) ~~> MulExpr } ;
// The floor division // must be tried before the true division /.
MulExpr     <~~ push(foldBinary(takeAll())) ~~>
            = UnaryExpr { ( "*" | "//" | "/" | "%" ) <~~ push(up.in) ~~> UnaryExpr } ;

UnaryExpr   = NotExpr | LenExpr | NegExpr | BNotExpr | PowExpr ;
NotExpr     <~~ push(makeNot(pop())) ~~>
            = KwNot UnaryExpr ;
LenExpr     <~~ push(makeLen(pop())) ~~>
            = "#" UnaryExpr ;
NegExpr     <~~ push(makeNeg(pop())) ~~>
            = "-" UnaryExpr ;
// Unary bitwise not ~x (Lua 5.3+): accepted, not implemented (guarded against '~=').
BNotExpr    <~~ pop(); push(notImplExpr("unary ~ (bitwise not)", up.pos)) ~~>
            = ( "~" !"=" ) UnaryExpr ;
// Exponentiation a ^ b, right associative and binding tighter than the unary operators
// (Lua float pow): accepted, not implemented (no js_pow extern in the handle runtime).
PowExpr     <~~ push(makePow(takeAll(), up.pos)) ~~>
            = SuffixedExpr [ "^" PowExpr ] ;

// f(a), t.x, t[k], t:m(a) in any mix.
SuffixedExpr <~~ push(foldCallMember(takeAll())) ~~>
            = Primary { CallSfx | MethodSfx | DotSfx | IndexSfx } ;
CallSfx     <~~ push({kind:"call", args: takeAll()}) ~~>
            = "(" [ Expression { "," Expression } ] ")" ;
// obj:m(args): sugar for obj.m(obj, args) - the receiver is passed as the first arg.
MethodSfx   <~~ var it = takeAll(); push({kind:"method", name: it[0].mname, args: it.slice(1)}) ~~>
            = ":" MethodName "(" [ Expression { "," Expression } ] ")" ;
MethodName  <~~ push({mname: up.in}) ~~>
            = Id ;
DotSfx      = "." Id <~~ push({kind:"field", name: up.in}) ~~> ;
IndexSfx    <~~ push({kind:"index", idx: pop()}) ~~>
            = "[" Expression "]" ;

Primary     = "(" Expression ")" | FuncExpr | TableLit | LongString | VarargExpr
            | DqString | SqString | Number | True | False | Nil | VarRef ;

// [[ ... ]] long-bracket string literals (also [=[ ]=] and [==[ ]==] for content that
// contains a closing bracket). The body is verbatim (no escapes) and a single leading
// newline is dropped, matching Lua. Longer '=' levels are still unrecognized.
LongString  = LongStr2 | LongStr1 | LongStr0 ;
LongStr0    = "[[" :whitespace() { !"]]" AnyByte } <~~ push(makeConst(luaLong(up.in))) ~~> "]]" :whitespace(Whitespace) ;
LongStr1    = "[=[" :whitespace() { !"]=]" AnyByte } <~~ push(makeConst(luaLong(up.in))) ~~> "]=]" :whitespace(Whitespace) ;
LongStr2    = "[==[" :whitespace() { !"]==]" AnyByte } <~~ push(makeConst(luaLong(up.in))) ~~> "]==]" :whitespace(Whitespace) ;
// '...' in expression position (varargs): accepted, not implemented (the subset passes
// only the named parameters).
VarargExpr  <~~ push(notImplExpr("varargs ...", up.pos)) ~~>
            = "..." ;
AnyByte     = "\x00"..."\U0010ffff" ;

FuncExpr    <~~ push(makeFuncExpr(pop(), pop())) ~~>
            = KwFunction ParamList Block KwEndKw ;

// { }, { 1, 2, 3 }, { x = 1 }, { [k] = v }, mixed; ',' or ';' separate the fields.
TableLit    <~~ push(makeTable(takeAll())) ~~>
            = "{" [ Field { FieldSep Field } [ FieldSep ] ] "}" ;
FieldSep    = "," | ";" ;
Field       = KeyField | NameField | PosField ;
KeyField    <~~ var kv = pop(); push({fkind:"key", k: pop(), v: kv}) ~~>
            = "[" Expression "]" "=" Expression ;
NameField   <~~ var nv = pop(); push({fkind:"name", name: pop(), v: nv}) ~~>
            = Id <~~ push(up.in) ~~> "=" Expression ;
PosField    <~~ push({fkind:"pos", v: pop()}) ~~>
            = Expression ;

// Numbers: hexadecimal (0x1F), a decimal with an exponent (1e3, 2.5e-4), or a plain
// decimal (DecLit from lib/numbers.abnf). Hex/exponent are tried before DecLit, which
// has neither.
Number      = HexLit | FloatLit | DecLit ;
HexLit      <~~ push(makeConst(luaHexVal(up.in))) ~~>
            = ( "0x" | "0X" ) :whitespace() HexDigit { HexDigit } :whitespace(Whitespace) ;
HexDigit    = "0"..."9" | "a"..."f" | "A"..."F" ;
FloatLit    <~~ push(makeConst(parseFloat(up.in))) ~~>
            = ( "0" | "1"..."9" ) :whitespace() { "0"..."9" } [ "." { "0"..."9" } ] ( "e" | "E" ) [ "+" | "-" ] "0"..."9" { "0"..."9" } :whitespace(Whitespace) ;
Nil         <~~ push(makeConst(undefined)) ~~>
            = "nil" KwEnd ;
VarRef      <~~ push(makeVarRef(up.in)) ~~>
            = Id ;

// Keywords, each closed by KwEnd so that 'ending' or 'ifx' stay identifiers.
KwLocal     = "local" KwEnd ;
KwFunction  = "function" KwEnd ;
KwIf        = "if" KwEnd ;
KwThen      = "then" KwEnd ;
KwElseif    = "elseif" KwEnd ;
KwElse      = "else" KwEnd ;
KwEndKw     = "end" KwEnd ;
KwWhile     = "while" KwEnd ;
KwRepeat    = "repeat" KwEnd ;
KwUntil     = "until" KwEnd ;
KwDo        = "do" KwEnd ;
KwFor       = "for" KwEnd ;
KwIn        = "in" KwEnd ;
KwReturn    = "return" KwEnd ;
KwBreak     = "break" KwEnd ;
KwGoto      = "goto" KwEnd ;
KwAnd       = "and" KwEnd ;
KwOr        = "or" KwEnd ;
KwNot       = "not" KwEnd ;

// Lua whitespace: blanks and newlines plus comments. Block comments --[[ ... ]] (and
// --[=[ ]=] / --[==[ ]==]) are tried before the line comment, since '--[[' extends
// '--'. A line comment runs to the end of the line.
Whitespace  = { @+" \t\r\n" | Comment } ;
Comment     = LongCmt2 | LongCmt1 | LongCmt0 | LineComment ;
LongCmt0    = "--[[" :whitespace() { !"]]" AnyByte } "]]" :whitespace(Whitespace) ;
LongCmt1    = "--[=[" :whitespace() { !"]=]" AnyByte } "]=]" :whitespace(Whitespace) ;
LongCmt2    = "--[==[" :whitespace() { !"]==]" AnyByte } "]==]" :whitespace(Whitespace) ;
LineComment = "--" :whitespace() { NotNewline } :whitespace(Whitespace) ;
NotNewline  = "\x00"..."\x09" | "\x0b"..."\U0010ffff" ;

// ---



:startScript(~~

    // Shared emitter machinery (module, handle constants, externs, loopStack
    // protocol, expression/statement builders); Lua specifics are set below.
    include("lib/compile-core.js")

    // resolveImport / notImpl (lib/compile-core.js) call fail; define it.
    function fail(msg) { println("lua compiler error: " + msg); exit(1) }

    var hidCount = 0

    // ----- Widening helpers -----
    // A no-op statement thunk for an empty ';' statement.
    function makeEmpty() { return function(b) { return b } }
    // A bitwise/exponentiation node: pass through when the operator is absent (a single
    // operand collected), otherwise accept-and-notImplemented. makeBit is applied to
    // every BitExpr and makePow to every PowExpr, so the pass-through keeps the emitted
    // IR of operator-free programs exactly as before.
    function makeBit(items, pos) { if (items.length == 1) { return items[0] } return notImplExpr("bitwise operator", pos) }
    function makePow(items, pos) { if (items.length == 1) { return items[0] } return notImplExpr("^ (exponentiation) operator", pos) }
    // A long-bracket string body: a single leading newline is dropped (the Lua rule).
    function luaLong(s) {
        if (s.length > 0 && s.charCodeAt(0) === 10) { return s.slice(1) }
        if (s.length > 1 && s.charCodeAt(0) === 13 && s.charCodeAt(1) === 10) { return s.slice(2) }
        return s
    }
    // Parse a hex integer literal (0x....) to a number, stopping at the first non-hex
    // char (so trailing whitespace captured in up.in is ignored).
    function luaHexVal(s) {
        var v = 0
        var i = 2
        var going = true
        while (going && i < s.length) {
            var cc = s.charCodeAt(i)
            var d = -1
            if (cc >= 48 && cc <= 57) { d = cc - 48 }
            else if (cc >= 97 && cc <= 102) { d = cc - 87 }
            else if (cc >= 65 && cc <= 70) { d = cc - 55 }
            if (d < 0) { going = false }
            else { v = v * 16 + d; i = i + 1 }
        }
        return v
    }

    // The standard-library tables (math/string/table) and the global next() are emitted
    // into jsmain's scope only when the program actually references them, so a program
    // that uses none of them compiles to exactly the IR it did before. makeVarRef is the
    // single read path for a bare name, so it is where a reference is noticed.
    var libNeed = {math: false, string: false, table: false, next: false}
    makeVarRef = function(name) {
        if (name == "math" || name == "string" || name == "table" || name == "next") {
            libNeed[name] = true
        }
        return function(b) {
            return {b: b, v: callExt(b, core.scopeGetExt, [curScopeV, emitStr(b, name)])}
        }
    }

    // Lua truthiness for branches: an i1 that is 1 unless v is nil (hUndef) or false.
    truthy = function(b, v) {
        var isNil = b.NewICmp(llvm.enum.IPredNE, callExt(b, "js_truthy", [callExt(b, "js_seq", [v, hUndef])]), handle(0))
        var isFalse = b.NewICmp(llvm.enum.IPredNE, callExt(b, "js_truthy", [callExt(b, "js_seq", [v, hFalse])]), handle(0))
        var truthH = b.NewSelect(isNil, hFalse, b.NewSelect(isFalse, hFalse, hTrue))
        return b.NewICmp(llvm.enum.IPredNE, callExt(b, "js_truthy", [truthH]), handle(0))
    }

    // ----- Expression thunks: function(block) -> {b, v} -----

    // Lua numbers are floats: unary minus does not truncate to 32 bit.
    makeNeg = function(t) {
        return function(b) {
            var r = t(b)
            return {b: r.b, v: callExt(r.b, "js_neg", [r.v])}
        }
    }
    // not v: true exactly when v is falsy.
    makeNot = function(t) {
        return function(b) {
            var r = t(b)
            b = r.b
            return {b: b, v: b.NewSelect(truthy(b, r.v), hFalse, hTrue)}
        }
    }
    // #t: probe t[1], t[2], ... for the first nil; the border is that index minus one.
    function makeLen(t) {
        return function(b) {
            var r = t(b)
            b = r.b
            var tv = r.v
            var saved = curScopeV
            curScopeV = callExt(b, "js_scope_new", [curScopeV])
            hidCount++
            var iName = "$li" + hidCount
            var tName = "$lt" + hidCount
            callExt(b, "js_scope_decl", [curScopeV, emitStr(b, tName), tv])
            callExt(b, "js_scope_decl", [curScopeV, emitStr(b, iName), emitNum(b, 1)])
            var headB = curF.NewBlock("")
            var bodyB = curF.NewBlock("")
            var exitB = curF.NewBlock("")
            b.NewBr(headB)
            var iV = callExt(headB, "js_scope_get", [curScopeV, emitStr(headB, iName)])
            var tV = callExt(headB, "js_scope_get", [curScopeV, emitStr(headB, tName)])
            var elem = callExt(headB, "js_get", [tV, iV])
            headB.NewCondBr(truthy(headB, callExt(headB, "js_sne", [elem, hUndef])), bodyB, exitB)
            var iV2 = callExt(bodyB, "js_scope_get", [curScopeV, emitStr(bodyB, iName)])
            callExt(bodyB, "js_scope_set", [curScopeV, emitStr(bodyB, iName), callExt(bodyB, "js_add", [iV2, emitNum(bodyB, 1)])])
            bodyB.NewBr(headB)
            var iFin = callExt(exitB, "js_scope_get", [curScopeV, emitStr(exitB, iName)])
            var lenV = callExt(exitB, "js_sub", [iFin, emitNum(exitB, 1)])
            curScopeV = saved
            return {b: exitB, v: lenV}
        }
    }
    // Concatenation: right associative, so at most two operands per node. Both sides are
    // rendered to strings (js_pystr) and joined (js_add on two strings concatenates).
    function makeConcat(items) {
        if (items.length == 1) { return items[0] }
        var l = items[0]
        var r = items[1]
        return function(b) {
            var rl = l(b)
            b = rl.b
            var rr = r(b)
            b = rr.b
            var ls = callExt(b, "js_pystr", [rl.v])
            var rs = callExt(b, "js_pystr", [rr.v])
            return {b: b, v: callExt(b, "js_add", [ls, rs])}
        }
    }

    // Lua operators: no 32 bit wrapping, floor division //, floor modulo %, ~= not equal.
    binExt = {"+": "js_add", "-": "js_sub", "*": "js_mul", "/": "js_div",
              "//": "js_fdiv", "%": "js_fmod",
              "==": "js_seq", "~=": "js_sne",
              "<": "js_lt", ">": "js_gt", "<=": "js_le", ">=": "js_ge"}
    wraps = {}

    // items = [primaryThunk, {kind:"call"|"field"|"index", ...}...].
    foldCallMember = function(items) {
        if (items.length == 1) { return items[0] }
        var primary = items[0]
        var suffixes = items.slice(1)
        return function(b) {
            var r = primary(b)
            b = r.b
            var cur = r.v
            for (var i = 0; i < suffixes.length; i++) {
                var s = suffixes[i]
                if (s.kind == "call") {
                    var ea = emitArgs(b, s.args)
                    b = ea.b
                    cur = callExt(b, "js_call", [cur, hUndef, ea.v])
                } else if (s.kind == "method") {
                    // obj:m(args): look up m on the receiver, then call it with the
                    // receiver prepended as the first argument (self).
                    var fn = callExt(b, "js_get", [cur, emitStr(b, s.name)])
                    var margs = callExt(b, "js_arr_new", [])
                    callExt(b, "js_arr_push", [margs, cur])
                    for (var mj = 0; mj < s.args.length; mj++) {
                        var mar = s.args[mj](b)
                        b = mar.b
                        callExt(b, "js_arr_push", [margs, mar.v])
                    }
                    cur = callExt(b, "js_call", [fn, hUndef, margs])
                } else if (s.kind == "field") {
                    cur = callExt(b, "js_get", [cur, emitStr(b, s.name)])
                } else {
                    var ir = s.idx(b)
                    b = ir.b
                    cur = callExt(b, "js_get", [cur, ir.v])
                }
            }
            return {b: b, v: cur}
        }
    }

    // { ... } fields, in source order: positional fields fill numeric keys 1, 2, 3, ...
    function makeTable(items) {
        return function(b) {
            var t = callExt(b, "js_obj_new", [])
            var pos = 1
            for (var i = 0; i < items.length; i++) {
                var f = items[i]
                if (f.fkind == "pos") {
                    var rv = f.v(b)
                    b = rv.b
                    callExt(b, "js_set", [t, emitNum(b, pos), rv.v])
                    pos++
                } else if (f.fkind == "name") {
                    var rv2 = f.v(b)
                    b = rv2.b
                    callExt(b, "js_set", [t, emitStr(b, f.name), rv2.v])
                } else {
                    var rk = f.k(b)
                    b = rk.b
                    var rv3 = f.v(b)
                    b = rv3.b
                    callExt(b, "js_set", [t, rk.v, rv3.v])
                }
            }
            return {b: b, v: t}
        }
    }

    // ----- Assignment -----
    function pathKeyV(b, p) {
        if (p.kind == "field") { return {b: b, v: emitStr(b, p.name)} }
        return p.idx(b)
    }
    function emitTargetWrite(b, ref, v) {
        if (ref.path.length == 0) {
            callExt(b, "js_pyset_var", [curScopeV, emitStr(b, ref.name), v])
            return b
        }
        var o = callExt(b, "js_scope_get", [curScopeV, emitStr(b, ref.name)])
        for (var i = 0; i < ref.path.length - 1; i++) {
            var pk = pathKeyV(b, ref.path[i])
            b = pk.b
            o = callExt(b, "js_get", [o, pk.v])
        }
        var lk = pathKeyV(b, ref.path[ref.path.length - 1])
        b = lk.b
        callExt(b, "js_set", [o, lk.v, v])
        return b
    }
    // items interleave targets (objects) and value thunks (functions); all right hand
    // sides are evaluated first, then assigned positionally (missing values are nil).
    function makeAssign(items) {
        var targets = []
        var vals = []
        for (var i = 0; i < items.length; i++) {
            if (typeof items[i] == "function") { vals.push(items[i]) }
            else { targets.push(items[i]) }
        }
        return function(b) {
            var vvals = []
            for (var i = 0; i < vals.length; i++) {
                var r = vals[i](b)
                b = r.b
                vvals.push(r.v)
            }
            for (var t = 0; t < targets.length; t++) {
                b = emitTargetWrite(b, targets[t], t < vvals.length ? vvals[t] : hUndef)
            }
            return b
        }
    }
    function makeLocal(items) {
        var names = []
        var vals = []
        for (var i = 0; i < items.length; i++) {
            if (typeof items[i] == "function") { vals.push(items[i]) }
            else { names.push(items[i].lname) }
        }
        return function(b) {
            var vvals = []
            for (var i = 0; i < vals.length; i++) {
                var r = vals[i](b)
                b = r.b
                vvals.push(r.v)
            }
            for (var n = 0; n < names.length; n++) {
                callExt(b, "js_scope_decl", [curScopeV, emitStr(b, names[n]), n < vvals.length ? vvals[n] : hUndef])
            }
            return b
        }
    }

    // ----- Functions -----
    function emitFunction(params, bodyT) {
        funcCount++
        var idx = funcCount
        var f = m.NewFunc("jsf_" + idx, i64, [llvm.ir.NewParam("env", i64), llvm.ir.NewParam("args", i64)])
        var savedF = curF
        var savedScope = curScopeV
        var savedLoops = loopStack
        curF = f
        loopStack = []
        var b = f.NewBlock("entry")
        curScopeV = callExt(b, "js_scope_new", [f.Params[0]])
        for (var i = 0; i < params.length; i++) {
            callExt(b, "js_scope_decl", [curScopeV, emitStr(b, params[i]), callExt(b, "js_arg", [f.Params[1], handle(i)])])
        }
        var endB = bodyT(b)
        endB.NewRet(hUndef)
        curF = savedF
        curScopeV = savedScope
        loopStack = savedLoops
        return idx
    }
    function makeFuncExpr(bodyT, plist) {
        return function(b) {
            var idx = emitFunction(plist.params, bodyT)
            return {b: b, v: callExt(b, "js_closure", [handle(idx), curScopeV])}
        }
    }
    // A function-definition name: a base variable, a chain of .field steps, and a flag
    // marking a trailing :method step (which binds an implicit leading 'self' parameter).
    function makeFuncName(items) {
        var base = items[0].fnbase
        var steps = []
        var isMethod = false
        for (var i = 1; i < items.length; i++) {
            steps.push(items[i].fnstep)
            if (items[i].fnself === true) { isMethod = true }
        }
        return {fbase: base, fsteps: steps, fmethod: isMethod}
    }
    // function name(...) / function tbl.field(...) / function tbl:method(...). A method
    // definition prepends 'self'; a plain name assigns the variable, a dotted/method name
    // writes the closure into the last field of the resolved table path.
    function makeFunc(bodyT, plist, nameDesc) {
        var params = plist.params
        if (nameDesc.fmethod) {
            var mp = []
            mp.push("self")
            for (var i = 0; i < plist.params.length; i++) { mp.push(plist.params[i]) }
            params = mp
        }
        return function(b) {
            var idx = emitFunction(params, bodyT)
            var cl = callExt(b, "js_closure", [handle(idx), curScopeV])
            if (nameDesc.fsteps.length == 0) {
                callExt(b, "js_pyset_var", [curScopeV, emitStr(b, nameDesc.fbase), cl])
                return b
            }
            var o = callExt(b, "js_scope_get", [curScopeV, emitStr(b, nameDesc.fbase)])
            for (var i = 0; i < nameDesc.fsteps.length - 1; i++) {
                o = callExt(b, "js_get", [o, emitStr(b, nameDesc.fsteps[i])])
            }
            callExt(b, "js_set", [o, emitStr(b, nameDesc.fsteps[nameDesc.fsteps.length - 1]), cl])
            return b
        }
    }
    function makeLocalFunc(bodyT, plist, name) {
        return function(b) {
            callExt(b, "js_scope_decl", [curScopeV, emitStr(b, name), hUndef])
            var idx = emitFunction(plist.params, bodyT)
            var cl = callExt(b, "js_closure", [handle(idx), curScopeV])
            callExt(b, "js_scope_set", [curScopeV, emitStr(b, name), cl])
            return b
        }
    }

    // ----- Statement thunks: function(block) -> block -----
    function makeElseIf(suite, cond) { return {elifCond: cond, suite: suite} }
    function makeElse(suite) { return {elseSuite: suite} }
    makeIf = function(items) {
        var cond = items[0]
        var thenT = items[1]
        var elifs = []
        var elseT = null
        for (var i = 2; i < items.length; i++) {
            if (items[i].elifCond != undefined) { elifs.push(items[i]) }
            if (items[i].elseSuite != undefined) { elseT = items[i].elseSuite }
        }
        return function(b) {
            var mergeB = curF.NewBlock("")
            var r = cond(b)
            b = r.b
            var thenB = curF.NewBlock("")
            var nextB = curF.NewBlock("")
            b.NewCondBr(truthy(b, r.v), thenB, nextB)
            thenT(thenB).NewBr(mergeB)
            b = nextB
            for (var k = 0; k < elifs.length; k++) {
                var r2 = elifs[k].elifCond(b)
                b = r2.b
                var armB = curF.NewBlock("")
                var next2 = curF.NewBlock("")
                b.NewCondBr(truthy(b, r2.v), armB, next2)
                elifs[k].suite(armB).NewBr(mergeB)
                b = next2
            }
            if (elseT != null) { elseT(b).NewBr(mergeB) }
            else { b.NewBr(mergeB) }
            return mergeB
        }
    }
    function makeNumFor(items) {
        var name = items[0].fname
        var startT = items[1]
        var limitT = items[2]
        var block = items[items.length - 1]
        var stepT = (items.length == 5) ? items[3] : null
        return function(b) {
            var saved = curScopeV
            curScopeV = callExt(b, "js_scope_new", [curScopeV])
            hidCount++
            var iName = "$fi" + hidCount
            var limName = "$fl" + hidCount
            var stepName = "$fs" + hidCount
            var rs = startT(b)
            b = rs.b
            callExt(b, "js_scope_decl", [curScopeV, emitStr(b, iName), rs.v])
            var rl = limitT(b)
            b = rl.b
            callExt(b, "js_scope_decl", [curScopeV, emitStr(b, limName), rl.v])
            var stepV = emitNum(b, 1)
            if (stepT != null) {
                var rst = stepT(b)
                b = rst.b
                stepV = rst.v
            }
            callExt(b, "js_scope_decl", [curScopeV, emitStr(b, stepName), stepV])
            callExt(b, "js_scope_decl", [curScopeV, emitStr(b, name), hUndef])
            var headB = curF.NewBlock("")
            var bodyB = curF.NewBlock("")
            var postB = curF.NewBlock("")
            var exitB = curF.NewBlock("")
            b.NewBr(headB)
            var iV = callExt(headB, "js_scope_get", [curScopeV, emitStr(headB, iName)])
            var limV = callExt(headB, "js_scope_get", [curScopeV, emitStr(headB, limName)])
            var stpV = callExt(headB, "js_scope_get", [curScopeV, emitStr(headB, stepName)])
            var stepPos = truthy(headB, callExt(headB, "js_gt", [stpV, emitNum(headB, 0)]))
            var leCond = callExt(headB, "js_le", [iV, limV])
            var geCond = callExt(headB, "js_ge", [iV, limV])
            var condH = headB.NewSelect(stepPos, leCond, geCond)
            headB.NewCondBr(truthy(headB, condH), bodyB, exitB)
            callExt(bodyB, "js_scope_set", [curScopeV, emitStr(bodyB, name), callExt(bodyB, "js_scope_get", [curScopeV, emitStr(bodyB, iName)])])
            loopStack.push({cont: postB, brk: exitB})
            block(bodyB).NewBr(postB)
            loopStack.pop()
            var iV2 = callExt(postB, "js_scope_get", [curScopeV, emitStr(postB, iName)])
            var stpV2 = callExt(postB, "js_scope_get", [curScopeV, emitStr(postB, stepName)])
            callExt(postB, "js_scope_set", [curScopeV, emitStr(postB, iName), callExt(postB, "js_add", [iV2, stpV2])])
            postB.NewBr(headB)
            curScopeV = saved
            return exitB
        }
    }
    // repeat body until cond. The body block gets a fresh scope each iteration (so the
    // until condition, evaluated in that scope, sees the body's locals); it loops back
    // while cond is falsy. break -> exit, continue -> the until test.
    function makeRepeat(block, condT) {
        return function(b) {
            var saved = curScopeV
            var bodyB = curF.NewBlock("")
            var contB = curF.NewBlock("")
            var exitB = curF.NewBlock("")
            b.NewBr(bodyB)
            curScopeV = callExt(bodyB, "js_scope_new", [saved])
            loopStack.push({cont: contB, brk: exitB})
            block(bodyB).NewBr(contB)
            loopStack.pop()
            var r = condT(contB)
            r.b.NewCondBr(truthy(r.b, r.v), exitB, bodyB)
            curScopeV = saved
            return exitB
        }
    }
    // Generic for. items = [{gname}..., {iterkind, tbl?}, blockThunk]. Only ipairs is
    // lowered (a 1-based array walk that stops at the first nil); pairs and any other
    // iterator are accepted, then reported as not implemented.
    function makeGenFor(items, pos) {
        var names = []
        var iter = null
        var block = null
        for (var i = 0; i < items.length; i++) {
            var it = items[i]
            if (typeof it == "function") { block = it }
            else if (it.gname != undefined) { names.push(it.gname) }
            else { iter = it }
        }
        // pairs(t): full key/value enumeration. js_keys returns the table's own keys as
        // an array in insertion order (deterministic across engines and skipping the
        // internal __ slots); the loop walks that array by index, reads each value, and
        // skips keys whose value is nil (a removed entry). The key is bound in its stored
        // (string) form. break -> exit, continue -> the index bump, like ipairs.
        if (iter.iterkind == "pairs") {
            var tblTp = iter.tbl
            return function(b) {
                var saved = curScopeV
                curScopeV = callExt(b, "js_scope_new", [curScopeV])
                hidCount++
                var iName = "$pi" + hidCount
                var tName = "$pt" + hidCount
                var kName = "$pk" + hidCount
                var nName = "$pn" + hidCount
                var rt = tblTp(b)
                b = rt.b
                callExt(b, "js_scope_decl", [curScopeV, emitStr(b, tName), rt.v])
                var keysV = callExt(b, "js_keys", [rt.v])
                callExt(b, "js_scope_decl", [curScopeV, emitStr(b, kName), keysV])
                callExt(b, "js_scope_decl", [curScopeV, emitStr(b, nName), callExt(b, "js_get", [keysV, emitStr(b, "length")])])
                callExt(b, "js_scope_decl", [curScopeV, emitStr(b, iName), emitNum(b, 0)])
                callExt(b, "js_scope_decl", [curScopeV, emitStr(b, names[0]), hUndef])
                if (names.length > 1) { callExt(b, "js_scope_decl", [curScopeV, emitStr(b, names[1]), hUndef]) }
                var headB = curF.NewBlock("")
                var bodyB = curF.NewBlock("")
                var runB = curF.NewBlock("")
                var postB = curF.NewBlock("")
                var exitB = curF.NewBlock("")
                b.NewBr(headB)
                var iV = callExt(headB, "js_scope_get", [curScopeV, emitStr(headB, iName)])
                var nV = callExt(headB, "js_scope_get", [curScopeV, emitStr(headB, nName)])
                headB.NewCondBr(truthy(headB, callExt(headB, "js_lt", [iV, nV])), bodyB, exitB)
                var iVb = callExt(bodyB, "js_scope_get", [curScopeV, emitStr(bodyB, iName)])
                var kArr = callExt(bodyB, "js_scope_get", [curScopeV, emitStr(bodyB, kName)])
                var tVb = callExt(bodyB, "js_scope_get", [curScopeV, emitStr(bodyB, tName)])
                var keyV = callExt(bodyB, "js_get", [kArr, iVb])
                var valV = callExt(bodyB, "js_get", [tVb, keyV])
                bodyB.NewCondBr(truthy(bodyB, callExt(bodyB, "js_sne", [valV, hUndef])), runB, postB)
                callExt(runB, "js_scope_set", [curScopeV, emitStr(runB, names[0]), keyV])
                if (names.length > 1) { callExt(runB, "js_scope_set", [curScopeV, emitStr(runB, names[1]), valV]) }
                loopStack.push({cont: postB, brk: exitB})
                block(runB).NewBr(postB)
                loopStack.pop()
                var iV3 = callExt(postB, "js_scope_get", [curScopeV, emitStr(postB, iName)])
                callExt(postB, "js_scope_set", [curScopeV, emitStr(postB, iName), callExt(postB, "js_add", [iV3, emitNum(postB, 1)])])
                postB.NewBr(headB)
                curScopeV = saved
                return exitB
            }
        }
        if (iter.iterkind != "ipairs") {
            return notImplStmt("generic for over " + iter.iterkind + "()", pos)
        }
        var tblT = iter.tbl
        return function(b) {
            var saved = curScopeV
            curScopeV = callExt(b, "js_scope_new", [curScopeV])
            hidCount++
            var iName = "$gi" + hidCount
            var tName = "$gt" + hidCount
            var rt = tblT(b)
            b = rt.b
            callExt(b, "js_scope_decl", [curScopeV, emitStr(b, tName), rt.v])
            callExt(b, "js_scope_decl", [curScopeV, emitStr(b, iName), emitNum(b, 1)])
            callExt(b, "js_scope_decl", [curScopeV, emitStr(b, names[0]), hUndef])
            if (names.length > 1) { callExt(b, "js_scope_decl", [curScopeV, emitStr(b, names[1]), hUndef]) }
            var headB = curF.NewBlock("")
            var bodyB = curF.NewBlock("")
            var postB = curF.NewBlock("")
            var exitB = curF.NewBlock("")
            b.NewBr(headB)
            var iV = callExt(headB, "js_scope_get", [curScopeV, emitStr(headB, iName)])
            var tV = callExt(headB, "js_scope_get", [curScopeV, emitStr(headB, tName)])
            var elem = callExt(headB, "js_get", [tV, iV])
            headB.NewCondBr(truthy(headB, callExt(headB, "js_sne", [elem, hUndef])), bodyB, exitB)
            var iV2 = callExt(bodyB, "js_scope_get", [curScopeV, emitStr(bodyB, iName)])
            var tV2 = callExt(bodyB, "js_scope_get", [curScopeV, emitStr(bodyB, tName)])
            var elem2 = callExt(bodyB, "js_get", [tV2, iV2])
            callExt(bodyB, "js_scope_set", [curScopeV, emitStr(bodyB, names[0]), iV2])
            if (names.length > 1) { callExt(bodyB, "js_scope_set", [curScopeV, emitStr(bodyB, names[1]), elem2]) }
            loopStack.push({cont: postB, brk: exitB})
            block(bodyB).NewBr(postB)
            loopStack.pop()
            var iV3 = callExt(postB, "js_scope_get", [curScopeV, emitStr(postB, iName)])
            callExt(postB, "js_scope_set", [curScopeV, emitStr(postB, iName), callExt(postB, "js_add", [iV3, emitNum(postB, 1)])])
            postB.NewBr(headB)
            curScopeV = saved
            return exitB
        }
    }
    function makeDoBlock(block) {
        return function(b) {
            var saved = curScopeV
            curScopeV = callExt(b, "js_scope_new", [curScopeV])
            b = block(b)
            curScopeV = saved
            return b
        }
    }
    function makeReturn(items) {
        var t = items.length > 0 ? items[0] : null
        return function(b) {
            var v = hUndef
            if (t != null) {
                var r = t(b)
                b = r.b
                v = r.v
            }
            b.NewRet(v)
            return deadBlock()
        }
    }

    // ----- Standard library emission -----
    // Each library function is emitted as its own IR function jsf_N (like a Lua-level
    // function): a fresh scope/function/loop-stack, a body built by bodyEmit(entryBlock,
    // argsHandle) -> {b, v}, and a return. Its handle is wrapped by js_closure at the
    // declaration site so the running program can call it.
    function emitLibFunc(bodyEmit) {
        funcCount++
        var idx = funcCount
        var f = m.NewFunc("jsf_" + idx, i64, [llvm.ir.NewParam("env", i64), llvm.ir.NewParam("args", i64)])
        var savedF = curF
        var savedScope = curScopeV
        var savedLoops = loopStack
        curF = f
        loopStack = []
        var b = f.NewBlock("entry")
        curScopeV = callExt(b, "js_scope_new", [f.Params[0]])
        var r = bodyEmit(b, f.Params[1])
        r.b.NewRet(r.v)
        curF = savedF
        curScopeV = savedScope
        loopStack = savedLoops
        return idx
    }
    function libArg(b, argsH, n) { return callExt(b, "js_arg", [argsH, handle(n)]) }
    // The sequence border (#t) of a live table handle, reusing the length probe loop.
    function emitBorder(b, tv) {
        return makeLen(function(bb) { return {b: bb, v: tv} })(b)
    }

    // math.*: floor via floor-division by 1; ceil derived from floor; abs/max/min via a
    // comparison and a select. All straight-line (Lua numbers are floats, no wrapping).
    function libFloor(bb, argsH) {
        var x = libArg(bb, argsH, 0)
        return {b: bb, v: callExt(bb, "js_fdiv", [x, emitNum(bb, 1)])}
    }
    function libCeil(bb, argsH) {
        var x = libArg(bb, argsH, 0)
        var fl = callExt(bb, "js_fdiv", [callExt(bb, "js_neg", [x]), emitNum(bb, 1)])
        return {b: bb, v: callExt(bb, "js_neg", [fl])}
    }
    function libAbs(bb, argsH) {
        var x = libArg(bb, argsH, 0)
        var isNeg = truthy(bb, callExt(bb, "js_lt", [x, emitNum(bb, 0)]))
        return {b: bb, v: bb.NewSelect(isNeg, callExt(bb, "js_neg", [x]), x)}
    }
    function libMax(bb, argsH) {
        var a = libArg(bb, argsH, 0)
        var c = libArg(bb, argsH, 1)
        return {b: bb, v: bb.NewSelect(truthy(bb, callExt(bb, "js_gt", [a, c])), a, c)}
    }
    function libMin(bb, argsH) {
        var a = libArg(bb, argsH, 0)
        var c = libArg(bb, argsH, 1)
        return {b: bb, v: bb.NewSelect(truthy(bb, callExt(bb, "js_lt", [a, c])), a, c)}
    }

    // string.*: len via the host string's .length; upper/lower via the string methods;
    // sub is 1-based inclusive lowered to JS slice(i-1, j) (a nil j reaches the end);
    // rep concatenates n copies in a scoped while loop.
    function libStrLen(bb, argsH) {
        var s = libArg(bb, argsH, 0)
        return {b: bb, v: callExt(bb, "js_get", [s, emitStr(bb, "length")])}
    }
    // The compiled runtime exposes toUpperCase/toLowerCase/slice on strings through the
    // bound-method path (js_get yields the method, js_call runs it), not js_mcall.
    function libStrMethod(bb, s, method, argsArr) {
        return callExt(bb, "js_call", [callExt(bb, "js_get", [s, emitStr(bb, method)]), hUndef, argsArr])
    }
    function libUpper(bb, argsH) {
        var s = libArg(bb, argsH, 0)
        return {b: bb, v: libStrMethod(bb, s, "toUpperCase", callExt(bb, "js_arr_new", []))}
    }
    function libLower(bb, argsH) {
        var s = libArg(bb, argsH, 0)
        return {b: bb, v: libStrMethod(bb, s, "toLowerCase", callExt(bb, "js_arr_new", []))}
    }
    function libSub(bb, argsH) {
        var s = libArg(bb, argsH, 0)
        var i = libArg(bb, argsH, 1)
        var j = libArg(bb, argsH, 2)
        var arr = callExt(bb, "js_arr_new", [])
        callExt(bb, "js_arr_push", [arr, callExt(bb, "js_sub", [i, emitNum(bb, 1)])])
        callExt(bb, "js_arr_push", [arr, j])
        return {b: bb, v: libStrMethod(bb, s, "slice", arr)}
    }
    function libRep(bb, argsH) {
        var s = libArg(bb, argsH, 0)
        var n = libArg(bb, argsH, 1)
        var saved = curScopeV
        curScopeV = callExt(bb, "js_scope_new", [curScopeV])
        hidCount++
        var iName = "$ri" + hidCount
        var aName = "$ra" + hidCount
        callExt(bb, "js_scope_decl", [curScopeV, emitStr(bb, iName), emitNum(bb, 0)])
        callExt(bb, "js_scope_decl", [curScopeV, emitStr(bb, aName), emitStr(bb, "")])
        var headB = curF.NewBlock("")
        var bodyB = curF.NewBlock("")
        var exitB = curF.NewBlock("")
        bb.NewBr(headB)
        var iV = callExt(headB, "js_scope_get", [curScopeV, emitStr(headB, iName)])
        headB.NewCondBr(truthy(headB, callExt(headB, "js_lt", [iV, n])), bodyB, exitB)
        var aV = callExt(bodyB, "js_scope_get", [curScopeV, emitStr(bodyB, aName)])
        callExt(bodyB, "js_scope_set", [curScopeV, emitStr(bodyB, aName), callExt(bodyB, "js_add", [aV, s])])
        var iV2 = callExt(bodyB, "js_scope_get", [curScopeV, emitStr(bodyB, iName)])
        callExt(bodyB, "js_scope_set", [curScopeV, emitStr(bodyB, iName), callExt(bodyB, "js_add", [iV2, emitNum(bodyB, 1)])])
        bodyB.NewBr(headB)
        var aFin = callExt(exitB, "js_scope_get", [curScopeV, emitStr(exitB, aName)])
        curScopeV = saved
        return {b: exitB, v: aFin}
    }

    // table.insert(t, v): append at the border+1. table.remove(t): read the last element,
    // clear its slot (so #t shrinks), and return it.
    function libInsert(bb, argsH) {
        var t = libArg(bb, argsH, 0)
        var v = libArg(bb, argsH, 1)
        var rb = emitBorder(bb, t)
        var b2 = rb.b
        callExt(b2, "js_set", [t, callExt(b2, "js_add", [rb.v, emitNum(b2, 1)]), v])
        return {b: b2, v: hUndef}
    }
    function libRemove(bb, argsH) {
        var t = libArg(bb, argsH, 0)
        var rb = emitBorder(bb, t)
        var b2 = rb.b
        var val = callExt(b2, "js_get", [t, rb.v])
        callExt(b2, "js_set", [t, rb.v, hUndef])
        return {b: b2, v: val}
    }

    // next(t [, k]): the array-part iterator, straight-line. k nil -> probe index 1, else
    // k+1; the result is that index while t[index] is non-nil, else nil (the key only,
    // since the subset yields one value per call).
    function libNext(bb, argsH) {
        var t = libArg(bb, argsH, 0)
        var k = libArg(bb, argsH, 1)
        var i = bb.NewSelect(truthy(bb, callExt(bb, "js_seq", [k, hUndef])), emitNum(bb, 0), k)
        var nk = callExt(bb, "js_add", [i, emitNum(bb, 1)])
        var elem = callExt(bb, "js_get", [t, nk])
        return {b: bb, v: bb.NewSelect(truthy(bb, callExt(bb, "js_seq", [elem, hUndef])), hUndef, nk)}
    }

    // libSet wires one closure into a library table field; libDecl binds a table (or a
    // bare function) into jsmain's scope under its global name.
    function libSet(b, obj, name, idx) {
        callExt(b, "js_set", [obj, emitStr(b, name), callExt(b, "js_closure", [handle(idx), curScopeV])])
        return b
    }
    // Emit only the referenced libraries; a program that uses none emits nothing here and
    // its IR is unchanged from before this feature existed.
    function emitLibs(b) {
        if (libNeed.next) {
            callExt(b, "js_scope_decl", [curScopeV, emitStr(b, "next"), callExt(b, "js_closure", [handle(emitLibFunc(libNext)), curScopeV])])
        }
        if (libNeed.math) {
            var mt = callExt(b, "js_obj_new", [])
            b = libSet(b, mt, "floor", emitLibFunc(libFloor))
            b = libSet(b, mt, "ceil", emitLibFunc(libCeil))
            b = libSet(b, mt, "abs", emitLibFunc(libAbs))
            b = libSet(b, mt, "max", emitLibFunc(libMax))
            b = libSet(b, mt, "min", emitLibFunc(libMin))
            callExt(b, "js_scope_decl", [curScopeV, emitStr(b, "math"), mt])
        }
        if (libNeed.string) {
            var st = callExt(b, "js_obj_new", [])
            b = libSet(b, st, "len", emitLibFunc(libStrLen))
            b = libSet(b, st, "upper", emitLibFunc(libUpper))
            b = libSet(b, st, "lower", emitLibFunc(libLower))
            b = libSet(b, st, "sub", emitLibFunc(libSub))
            b = libSet(b, st, "rep", emitLibFunc(libRep))
            callExt(b, "js_scope_decl", [curScopeV, emitStr(b, "string"), st])
        }
        if (libNeed.table) {
            var tt = callExt(b, "js_obj_new", [])
            b = libSet(b, tt, "insert", emitLibFunc(libInsert))
            b = libSet(b, tt, "remove", emitLibFunc(libRemove))
            callExt(b, "js_scope_decl", [curScopeV, emitStr(b, "table"), tt])
        }
        return b
    }

    // jsmain: declare print, then run the file top to bottom.
    function buildMain(items) {
        var f = m.NewFunc("jsmain", i64, [llvm.ir.NewParam("env", i64), llvm.ir.NewParam("args", i64)])
        curF = f
        var b = f.NewBlock("entry")
        curScopeV = callExt(b, "js_scope_new", [f.Params[0]])
        funcCount++
        var prIdx = funcCount
        var pf = m.NewFunc("jsf_" + prIdx, i64, [llvm.ir.NewParam("env", i64), llvm.ir.NewParam("args", i64)])
        var pb = pf.NewBlock("entry")
        pb.NewCall(getExtern("js_pyprint", 1), [pf.Params[1]])
        pb.NewRet(hUndef)
        callExt(b, "js_scope_decl", [curScopeV, emitStr(b, "print"), callExt(b, "js_closure", [handle(prIdx), curScopeV])])
        b = emitLibs(b)
        b = makeSeq(items)(b)
        b.NewRet(hUndef)
    }
    function buildChunk(items) { buildMain(items) }

    // ----- Core library config (see lib/compile-core.js) -----
    // Lua stdlib prefixes the runtime already provides (none are needed for the subset).
    core.stdlibImports = []

    c.compile(c.asg)

    println(m)

    var res = llvm.RunJS(m, "jsmain")
    println("lua compiler: program ran to completion")
    exit(res.Ret)

~~) ;
