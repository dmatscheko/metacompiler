    // closure (a lambda / method reference): route it to js_call(receiver, args)
    // instead of js_mcall, which only dispatches named methods on objects/strings.
    // The receiver kind is decided at runtime with js_typeof, so ordinary method
    // calls are unaffected. This overrides the compile-core foldCallMember.
    foldCallMember = function(items) {
        if (items.length == 1) return items[0]
        var primary = items[0]
        var suffixes = items.slice(1)
        return function(b) {
            var r = primary(b)
            b = r.b
            var cur = r.v
            for (var i = 0; i < suffixes.length; i++) {
                var s = suffixes[i]
                if (s.kind == "mcall") {
                    var ea = emitArgs(b, s.args)
                    b = ea.b
                    var isFn = truthy(b, callExt(b, "js_seq", [callExt(b, "js_typeof", [cur]), emitStr(b, "function")]))
                    var callB = curF.NewBlock("")
                    var mcallB = curF.NewBlock("")
                    var mergeB = curF.NewBlock("")
                    b.NewCondBr(isFn, callB, mcallB)
                    var cv = callExt(callB, "js_call", [cur, hUndef, ea.v])
                    callB.NewBr(mergeB)
                    var mv = callExt(mcallB, "js_mcall", [cur, emitStr(mcallB, s.name), ea.v])
                    mcallB.NewBr(mergeB)
                    cur = mergeB.NewPhi([llvm.ir.NewIncoming(cv, callB), llvm.ir.NewIncoming(mv, mcallB)])
                    b = mergeB
                } else if (s.kind == "field") {
                    cur = callExt(b, "js_get", [cur, emitStr(b, s.name)])
                } else {
                    var ir2 = s.idx(b)
                    b = ir2.b
                    cur = callExt(b, core.indexExt, [cur, ir2.v])
                }
            }
            return {b: b, v: cur}
        }
    }

    // ----- Statement thunks: function(block) -> block -----

    // try/catch/finally has no exception model; the try block is still compiled. throw
    // lowers its expression (keeping calls visible) but does not unwind.
    // items = [name, blockThunk]. Java's catch always binds a name (type before it).
    function makeCatch(items) {
        if (items.length > 1) { return {catchbody: items[1], catchname: items[0]} }
        return {catchbody: items[0], catchname: undefined}
    }
    // try/catch/finally: each body compiles to its own IR closure handed to js_try; the
    // try and catch bodies are ctl closures, so a return/break/continue leaving them
    // becomes a control signal that excDispatch re-issues here. The first catch wins.
    function makeTry(items) {
        var tryT = anytype, catchT = anytype, catchName = anytype, finallyT = anytype
        for (var i = 0; i < items.length; i++) {
            if (items[i].trybody != undefined) { tryT = items[i].trybody }
            else if (items[i].catchbody != undefined) {
                if (catchT == undefined) { catchT = items[i].catchbody; catchName = items[i].catchname }
            }
            else if (items[i].finbody != undefined) { finallyT = items[i].finbody }
        }
        return function(b) {
            var tryClo = callExt(b, "js_closure", [handle(emitFunc([], tryT, false, null, null, null, true)), curScopeV])
            var catchClo = hUndef
            if (catchT != undefined) {
                var cn = (catchName != undefined) ? catchName : "__caught"
                catchClo = callExt(b, "js_closure", [handle(emitFunc([cn], catchT, false, null, null, null, true)), curScopeV])
            }
            var finClo = hUndef
            if (finallyT != undefined) {
                finClo = callExt(b, "js_closure", [handle(emitFunc([], finallyT, false, null, null, null, true)), curScopeV])
            }
            var ctl = callExt(b, "js_try", [tryClo, catchClo, finClo])
            return excDispatch(b, ctl)
        }
    }
    // throw e: evaluate e and raise it with js_throw (a Go panic the runtime unwinds).
    function makeThrow(e) {
        return function(b) {
            var r = e(b)
            callExt(r.b, "js_throw", [r.v])
            r.b.NewRet(hUndef) // Never reached: js_throw unwinds on the host side.
            return deadBlock()
        }
    }
    // super(args) / this(args): not implemented; lower the arguments and continue.
    function makeCtorCall(args, pos) {
        notImpl("explicit constructor invocation", pos)
        return function(b) {
            for (var i = 0; i < args.length; i++) { var r = args[i](b); b = r.b }
            return b
        }
    }
    // assert cond [: msg]; -- not implemented; the condition and message are still lowered.
    function makeAssert(items, pos) {
        notImpl("assert", pos)
        return function(b) {
            for (var i = 0; i < items.length; i++) { var r = items[i](b); b = r.b }
            return b
        }
    }
    // synchronized (lock) block -- not implemented; the lock is lowered and the block runs.
    function makeSync(items, pos) {
        notImpl("synchronized statement", pos)
        var lockT = items[0]
        var bodyT = items[1]
        return function(b) {
            var r = lockT(b)
            return bodyT(r.b)
        }
    }
    // label: stmt -- not implemented; the label is dropped and the statement still runs.
    function makeLabeled(items, pos) {
        notImpl("labeled statement", pos)
        return items[1]
    }
    // break / continue with a target label: recognized, not implemented; fall back to the
    // plain innermost jump. Without a label they stay the genuine break / continue.
    function makeBreakL(items, pos) {
        if (items.length > 0) { notImpl("labeled break", pos) }
        return makeBreak()
    }
    function makeContinueL(items, pos) {
        if (items.length > 0) { notImpl("labeled continue", pos) }
        return makeContinue()
    }

    function makeDecl(items) {
        var name = items[0]
        var init = items.length > 1 ? items[1] : makeConst(0)
        return function(b) {
            var r = init(b)
            b = r.b
            callExt(b, "js_scope_decl", [curScopeV, emitStr(b, name), r.v])
            return b
        }
    }
    function makeDo(condT, bodyT) {
        return function(b) {
            var bodyB = curF.NewBlock("")
            var condB = curF.NewBlock("")
            var exitB = curF.NewBlock("")
            b.NewBr(bodyB)
            loopStack.push({cont: condB, brk: exitB})
            bodyT(bodyB).NewBr(condB)
            loopStack.pop()
            var r = condT(condB)
            r.b.NewCondBr(truthy(r.b, r.v), bodyB, exitB)
            return exitB
        }
