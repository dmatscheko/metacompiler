    // for (var x : arr): a hidden index variable in an own scope drives the loop.
    function makeForEach(bodyT, arrT, name) {
        return function(b) {
            feCount++
            var iName = "$fe" + feCount
            var aName = "$fa" + feCount
            var saved = curScopeV
            curScopeV = callExt(b, "js_scope_new", [curScopeV])
            var r = arrT(b)
            b = r.b
            callExt(b, "js_scope_decl", [curScopeV, emitStr(b, aName), r.v])
