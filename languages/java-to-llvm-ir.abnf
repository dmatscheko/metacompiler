            callExt(b, "js_scope_decl", [curScopeV, emitStr(b, name), hUndef])
            var headB = curF.NewBlock("")
            var bodyB = curF.NewBlock("")
            var postB = curF.NewBlock("")
            var exitB = curF.NewBlock("")
            b.NewBr(headB)
            var iV = callExt(headB, "js_scope_get", [curScopeV, emitStr(headB, iName)])
            var aV = callExt(headB, "js_scope_get", [curScopeV, emitStr(headB, aName)])
            var lenV = callExt(headB, "js_get", [aV, emitStr(headB, "length")])
            var condV = callExt(headB, "js_lt", [iV, lenV])
            headB.NewCondBr(truthy(headB, condV), bodyB, exitB)
            var iV2 = callExt(bodyB, "js_scope_get", [curScopeV, emitStr(bodyB, iName)])
            var aV2 = callExt(bodyB, "js_scope_get", [curScopeV, emitStr(bodyB, aName)])
            callExt(bodyB, "js_scope_set", [curScopeV, emitStr(bodyB, name), callExt(bodyB, "js_get", [aV2, iV2])])
            loopStack.push({cont: postB, brk: exitB})
            bodyT(bodyB).NewBr(postB)
            loopStack.pop()
            var iV3 = callExt(postB, "js_scope_get", [curScopeV, emitStr(postB, iName)])
            callExt(postB, "js_scope_set", [curScopeV, emitStr(postB, iName), callExt(postB, "js_jadd", [iV3, emitNum(postB, 1)])])
            postB.NewBr(headB)
            curScopeV = saved
            return exitB
        }
    }
    function makeFor(items) {
        var bodyT = items.pop()
        var init = null, cond = null, post = null
        for (var i = 0; i < items.length; i++) {
            if (items[i].k == "init") init = items[i].t
            if (items[i].k == "cond") cond = items[i].t
            if (items[i].k == "post") post = items[i].t
        }
        return function(b) {
            var saved = curScopeV
            curScopeV = callExt(b, "js_scope_new", [curScopeV])
            if (init != null) b = init(b)
            var headB = curF.NewBlock("")
            var bodyB = curF.NewBlock("")
            var postB = curF.NewBlock("")
            var exitB = curF.NewBlock("")
            b.NewBr(headB)
            if (cond != null) {
                var r = cond(headB)
                r.b.NewCondBr(truthy(r.b, r.v), bodyB, exitB)
            } else {
                headB.NewBr(bodyB)
            }
            loopStack.push({cont: postB, brk: exitB})
            bodyT(bodyB).NewBr(postB)
            loopStack.pop()
            var pb = postB
            if (post != null) pb = post(postB)
            pb.NewBr(headB)
            curScopeV = saved
            return exitB
        }
    }
    function makeReturn(items) {
        var t = items.length > 0 ? items[0] : null
        return function(b) {
            var v = hUndef
            if (t != null) {
                var r = t(b)
                b = r.b
                v = r.v
            }
            return retStmt(b, v) // plain ret, or a control signal when leaving a try body
        }
    }
    // ----- Class building -----

    function makeMethod(items) {
        var mods = items[0].mods
        var name = items[1]
        var params = items[2].params
        var body = items[3]
        var isStatic = false
        for (var i = 0; i < mods.length; i++) if (mods[i] == "static") isStatic = true
        return {kind: "method", name: name, statik: isStatic, params: params, body: body}
    }
    function makeCtor(items) {
        return {kind: "ctor", name: items[0], params: items[1].params, body: items[2]}
    }
    function makeField(items) {
        var mods = items[0].mods
        var ty = items[1].ty
        var name = items[2]
        var init = items.length > 3 ? items[3] : null
        var isStatic = false
        for (var i = 0; i < mods.length; i++) if (mods[i] == "static") isStatic = true
        var dflt = 0
        if (ty == "boolean") dflt = 2 // The handle constants: 2 false, 1 null.
        if (ty != "int" && ty != "boolean") dflt = 1
        if (ty.indexOf("[") >= 0) dflt = 1
        return {kind: "field", name: name, statik: isStatic, init: init, dfltH: dflt, isInt: ty == "int"}
    }
    function fieldDefault(b, f) {
        if (f.isInt) return emitNum(b, 0)
        return handle(f.dfltH)
    }

    // Emits one method/ctor as jsf_N(env, args). For instance functions args[0] is this.
    // fields != null marks a constructor: the field initializers run before the body.
    // The class whose body is currently being built (for super calls).
    var curClassName = ""

    // isCtl marks a try/catch body closure: a return/break/continue leaving it emits a
    // control signal instead of a ret/br (see compile-core inCtlBody / excDispatch).
    function emitFunc(params, body, isInstance, fields, recordParams, superName, isCtl) {
        funcCount++
        var idx = funcCount
        var f = m.NewFunc("jsf_" + idx, i64, [llvm.ir.NewParam("env", i64), llvm.ir.NewParam("args", i64)])
        var savedF = curF
        var savedScope = curScopeV
        var savedLoops = loopStack
        var savedTag = curFTag
        curF = f
        curFTag = idx
        loopStack = []
        if (isCtl) { ctlEnter(idx) }
        var b = f.NewBlock("entry")
        curScopeV = callExt(b, "js_scope_new", [f.Params[0]])
        var off = 0
        if (isInstance) {
            callExt(b, "js_scope_decl", [curScopeV, emitStr(b, "this"), callExt(b, "js_arg", [f.Params[1], handle(0)])])
            off = 1
        }
        for (var i = 0; i < params.length; i++) {
            callExt(b, "js_scope_decl", [curScopeV, emitStr(b, params[i]),
                                         callExt(b, "js_arg", [f.Params[1], handle(i + off)])])
        }
        if (superName != undefined && superName != null) {
            // The implicit super(): run the whole parent constructor without arguments.
            var supClsV = callExt(b, "js_scope_get", [curScopeV, emitStr(b, superName)])
            var supCtorV = callExt(b, "js_get", [supClsV, emitStr(b, "__ctor")])
            var sargsV = callExt(b, "js_arr_new", [])
            callExt(b, "js_arr_push", [sargsV, callExt(b, "js_scope_get", [curScopeV, emitStr(b, "this")])])
            callExt(b, "js_call", [supCtorV, hUndef, sargsV])
        }
        if (fields != null) {
            var thisV = callExt(b, "js_scope_get", [curScopeV, emitStr(b, "this")])
            for (var k = 0; k < fields.length; k++) {
                var fv
                if (fields[k].init != null && fields[k].init != undefined) {
                    var r = fields[k].init(b)
                    b = r.b
                    fv = r.v
                } else {
                    fv = fieldDefault(b, fields[k])
                }
                callExt(b, "js_set", [thisV, emitStr(b, fields[k].name), fv])
            }
            if (recordParams != undefined) {
                for (var k2 = 0; k2 < recordParams.length; k2++) {
                    callExt(b, "js_set", [thisV, emitStr(b, recordParams[k2]),
                                          callExt(b, "js_arg", [f.Params[1], handle(k2 + 1)])])
                }
            }
        }
        var endB = body != null ? body(b) : b
        endB.NewRet(hUndef)
        if (isCtl) { ctlLeave() }
        curF = savedF
        curScopeV = savedScope
        loopStack = savedLoops
        curFTag = savedTag
        return idx
    }
    // A record accessor: return this.f
    function emitAccessor(fname) {
        funcCount++
        var idx = funcCount
        var f = m.NewFunc("jsf_" + idx, i64, [llvm.ir.NewParam("env", i64), llvm.ir.NewParam("args", i64)])
        var b = f.NewBlock("entry")
        var thisV = b.NewCall(getExtern("js_arg", 2), [f.Params[1], handle(0)])
        b.NewRet(b.NewCall(getExtern("js_get", 2), [thisV, emitStr(b, fname)]))
        return idx
    }

    function buildClassStmt(name, members, recordParams) {
        return function(b) {
            var clsV = callExt(b, "js_obj_new", [])
            callExt(b, "js_set", [clsV, emitStr(b, "__isclass"), hTrue])
            callExt(b, "js_set", [clsV, emitStr(b, "__name"), emitStr(b, name)])
            callExt(b, "js_scope_decl", [curScopeV, emitStr(b, name), clsV])
            var fields = []
            var ctorInfo = null
            var superName = null
            var i
            for (i = 0; i < members.length; i++) {
                if (members[i].ext != undefined) {
                    superName = members[i].ext
                    callExt(b, "js_set", [clsV, emitStr(b, "__super"),
                                          callExt(b, "js_scope_get", [curScopeV, emitStr(b, superName)])])
                }
            }
            if (recordParams != undefined) {
                for (i = 0; i < recordParams.length; i++) {
                    fields.push({name: recordParams[i], init: null, isInt: true, dfltH: 0})
                }
            }
            for (i = 0; i < members.length; i++) {
                var mm = members[i]
                if (mm.kind == "field") {
                    if (mm.statik) {
                        var sv
                        if (mm.init != null && mm.init != undefined) {
                            var r = mm.init(b)
                            b = r.b
                            sv = r.v
                        } else {
                            sv = fieldDefault(b, mm)
                        }
                        callExt(b, "js_set", [clsV, emitStr(b, mm.name), sv])
                    } else {
                        fields.push(mm)
                    }
                }
                if (mm.kind == "ctor") ctorInfo = mm
            }
            var ctorIdx
            if (recordParams != undefined) {
                ctorIdx = emitFunc([], null, true, fields, recordParams)
            } else if (ctorInfo != null) {
                ctorIdx = emitFunc(ctorInfo.params, ctorInfo.body, true, fields, undefined, superName)
            } else {
                ctorIdx = emitFunc([], null, true, fields, undefined, superName)
            }
            callExt(b, "js_set", [clsV, emitStr(b, "__ctor"), callExt(b, "js_closure", [handle(ctorIdx), curScopeV])])
            for (i = 0; i < members.length; i++) {
                var m2 = members[i]
                if (m2.kind == "method") {
                    var idx = emitFunc(m2.params, m2.body, !m2.statik, null, undefined)
                    callExt(b, "js_set", [clsV, emitStr(b, m2.name), callExt(b, "js_closure", [handle(idx), curScopeV])])
                }
            }
            if (recordParams != undefined) {
                for (i = 0; i < recordParams.length; i++) {
                    var aidx = emitAccessor(recordParams[i])
                    callExt(b, "js_set", [clsV, emitStr(b, recordParams[i]), callExt(b, "js_closure", [handle(aidx), curScopeV])])
                }
            }
            return b
        }
    }
    function makeClassStmt(items) {
        return buildClassStmt(items[0], items.slice(1), undefined)
    }
    function makeRecordStmt(items) {
        return buildClassStmt(items[0], items.slice(2), items[1].rparams)
    }

    // The program: jsmain(env, args) builds System, the classes, then calls Main.main.
    function buildMain(items) {
        var f = m.NewFunc("jsmain", i64, [llvm.ir.NewParam("env", i64), llvm.ir.NewParam("args", i64)])
        curF = f
        var b = f.NewBlock("entry")
        curScopeV = callExt(b, "js_scope_new", [f.Params[0]])
        // System.out.println / System.out.print / System.exit from the host globals.
        var sysV = callExt(b, "js_obj_new", [])
        var outV = callExt(b, "js_obj_new", [])
        callExt(b, "js_set", [outV, emitStr(b, "println"), callExt(b, "js_scope_get", [curScopeV, emitStr(b, "println")])])
        callExt(b, "js_set", [outV, emitStr(b, "print"), callExt(b, "js_scope_get", [curScopeV, emitStr(b, "print")])])
        callExt(b, "js_set", [sysV, emitStr(b, "out"), outV])
        callExt(b, "js_set", [sysV, emitStr(b, "exit"), callExt(b, "js_scope_get", [curScopeV, emitStr(b, "exit")])])
        callExt(b, "js_scope_decl", [curScopeV, emitStr(b, "System"), sysV])
        b = makeSeq(items)(b)
        var mainCls = callExt(b, "js_scope_get", [curScopeV, emitStr(b, "Main")])
        var mainV = callExt(b, "js_get", [mainCls, emitStr(b, "main")])
        var argsV = callExt(b, "js_arr_new", [])
        callExt(b, "js_arr_push", [argsV, callExt(b, "js_arr_new", [])])
        b.NewRet(callExt(b, "js_call", [mainV, hUndef, argsV]))
    }

    c.compile(c.asg)

    println(m)

    var res = llvm.RunJS(m, "jsmain")
    println("java compiler: main() returned " + res.Ret)
    exit(res.Ret)

~~) ;
