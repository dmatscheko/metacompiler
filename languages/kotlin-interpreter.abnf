:title("Kotlin (subset) interpreter") ;
:description("Parses a Kotlin subset and executes it directly, without generating code.

The subset: top level functions with block or expression bodies (fun add(a: Int, b: Int)
: Int = a + b), val/var declarations with type inference (annotations are parsed and
ignored, val is not enforced), if/else as statement and as expression, when expressions
with and without subject (arms are expressions, multiple comma separated match values,
else required for a value, range branches with in 1..9 and !in 1..9), the elvis
operator a ?: b (b when a is null; short circuit), the safe calls x?.length and
obj?.m() (null when the receiver is null; skipped calls do not evaluate their
arguments), while, do-while, for over ranges (for (i in 1..n), 0 until n, n downTo 1,
each with an optional positive step)
and over lists, break/continue, lambdas as values ({ it * 2 }, { x: Int -> x * 2 },
multi parameter, real closures over the defining scope; the body is one expression)
with trailing lambda call syntax (list.map { it * 2 }), the list higher order methods
map/filter/sumOf/forEach/count/any, classes with primary constructor properties
(class Counter(val start: Int) { var value = start; fun next(): Int { ... } }) and
implicit property access inside methods (value += step resolves against this), object
creation without new (Counter(5)), string templates ('x=$x sum=${a+b}'), listOf() with
.size, indexing, .add()/.get()/.contains(), the stdlib infix operators (a to b builds
a Pair read via .first/.second; and/or/xor are boolean logical on two booleans and
int32 bitwise otherwise; shl/shr/ushr are the int32 shifts), the builtins
println/print/abs/max/min and
exitProcess. Int arithmetic is 32 bit and / truncates; + concatenates when one side is
a String; == compares structurally for strings and by identity for objects. Top level
extension functions with a body (fun Recv.name(...) { ... }) are genuine: recv.name()
binds the receiver to this - dispatch is by NAME (the receiver type is dropped), so an
extension must not reuse a builtin or class method name (those win in both engines).

Delegated properties: `val x by lazy { init }` is genuine (the initializer runs once
and its value becomes a plain field; eager, so it is computed at the declaration, not
on first access); every other delegate (by inject(), custom getValue/setValue) is not
in the subset.

Not in the subset: inheritance, interfaces, generics, nullable types (? is parsed and
ignored), member-level and bodiless extension functions, named/default arguments,
multi statement lambda bodies,
data class methods
(the data modifier is parsed), init blocks, secondary constructors, non-lazy
property delegates, and bare method
calls (methods are called via this.m() or obj.m()).

The entry point is fun main(); self checking programs end with exitProcess(failures).") ;


// --- main rules

// Shared token productions (languages/lib).
:include("lib/cstyle-comments.abnf") ;
:include("lib/ident.abnf") ;
:include("lib/numbers.abnf") ;
:include("lib/bools.abnf") ;

:startRule(Program) ;
:whitespace(Whitespace) ;

Program     = { Annotation } [ Package ] { Import } { [ Modifiers ] ( UnsupType | FunDecl <~~ registerFun(pop()) ~~> | ExtFun | UnsupFun | ClassDecl | TopProp ) } ;

// Modifiers/annotations before a declaration are parsed and ignored. Annotations
// accept ALL forms: an argument list @Suppress("Unused"), qualified names @a.b.C,
// use-site targets @field:A / @get:A / @file:A, and annotation arrays @[A B C(x)].
// Body-shaping modifiers (enum/annotation/companion) are not consumed - those
// declaration forms route to notImplemented instead.
Modifiers   = { Modifier | Annotation } ;
Modifier    = ( "public" | "private" | "protected" | "internal" | "open" | "final"
              | "abstract" | "sealed" | "data" | "override" | "lateinit" | "const"
              | "inner" | "vararg" | "noinline" | "crossinline" | "tailrec"
              | "operator" | "infix" | "inline" | "external" | "suspend"
              | "expect" | "actual" | "reified" ) KwEnd ;
Annotation  = "@" [ AnnTarget ":" ] ( AnnSet | AnnEntry ) ;
AnnTarget   = ( "field" | "property" | "get" | "set" | "receiver" | "param"
              | "setparam" | "delegate" | "file" ) KwEnd ;
AnnSet      = "[" { AnnEntry } "]" ;
AnnEntry    = Id { "." Id } [ SkipParen ] ;

// package / import headers (same policy as kotlin-to-llvm-ir.abnf): the package
// name is ignored; each import is resolved against the runtime builtins, and an
// unresolvable one aborts unless -warn-imports downgrades it to a warning.
Package     <~~ pop() ~~> = KwPackage QualName [ ";" ] ;
Import      <~~ resolveImport(pop(), up.pos) ~~> = KwImport QualName [ KwAs Id ] [ ";" ] ;
QualName    <~~ push(stripWs(up.in)) ~~> = Id { "." Id } [ "." "*" ] ;

// A top level val/var: its declaration thunk runs right away (into the global scope).
TopProp     <~~ var t = pop(); t() ~~>
            = DelegateDecl | Decl ;

FunDecl     <~~ push(makeFun(takeAll())); retLblPop() ~~>
            = KwFun [ SkipAngle ] Id <~~ push(up.in); retLblPush(up.in, "fun") ~~> ParamList [ ":" Type ] FunBody ;
FunBody     = Block | "=" ExprBody ;
ExprBody    <~~ push(makeExprBody(pop())) ~~>
            = Expression ;

// A top-level extension function WITH a body - fun Receiver.name(params): T { ... } -
// is genuine: it registers under its bare name, and a method call recv.name(args)
// dispatches to it with the receiver bound to `this` (a nullable-receiver extension
// may see null). The receiver type (dotted, generic, nullable) is parsed and DROPPED:
// dispatch is by NAME, so an extension must not reuse a builtin or class method name
// (those always win; see extResolves). The tag-less RecvSeg pushes nothing.
ExtFun      <~~ registerExtFun(takeAll()); retLblPop() ~~>
            = KwFun [ SkipAngle ] RecvSeg { RecvSeg } Id <~~ push(up.in); retLblPush(up.in, "fun") ~~> ParamList [ ":" Type ] FunBody ;
RecvSeg     = Id [ SkipAngle ] [ "?" ] "." ;

// A function declaration outside the executable subset: a BODILESS extension or
// abstract declaration (abstract fun name(): R / fun Recv.name(): R). A NON-dotted
// fun WITH a body is deliberately NOT matched here: its body must parse in FunDecl,
// so a syntax gap inside the body surfaces at its true position instead of degrading
// the whole function into this notImpl. (Member-level extension functions also land
// here: they carry two receivers, which the single-`this` subset cannot model.)
UnsupFun    <~~ notImpl("extension or abstract function", up.pos) ~~>
            = KwFun [ SkipAngle ] ( ExtFunName SkipParen [ ":" Type ] [ SkipBlock | "=" DiscardExpr ]
                                  | Id [ SkipAngle ] SkipParen [ ":" Type ] ) ;
ExtFunName  = Id [ SkipAngle ] "." Id [ SkipAngle ] { "." Id [ SkipAngle ] } ;

ParamList   <~~ push({params: takeAll()}) ~~>
            = "(" [ Param { "," Param } [ "," ] ] ")" ;
// Parameter modifiers (vararg/noinline/crossinline) and a default value are parsed
// and dropped - the default is not supplied at call sites, but the header parses.
Param       = [ Modifiers ] Id <~~ push(up.in) ~~> ":" Type [ "=" DiscardExpr ] ;

// class Counter(val start: Int, var step: Int) { var value = start; fun next() ... }
ClassDecl   <~~ buildClass(takeAll()) ~~>
            = [ "data" KwEnd ] KwClass Id <~~ push(up.in) ~~> [ SkipAngle ] [ CtorParams ] [ ":" SuperList ] [ "{" { Member } "}" ] ;
CtorParams  <~~ push({cparams: takeAll()}) ~~>
            = "(" [ CtorParam { "," CtorParam } [ "," ] ] ")" ;
CtorParam   <~~ push(makeCtorParam(takeAll())) ~~>
            = [ Modifiers ] [ ( "val" | "var" ) <~~ push({vv: up.in}) ~~> KwEnd ] Id <~~ push(up.in) ~~> ":" Type ;

Member      = [ Modifiers ] ( InitBlock | CompanionObject | SecondaryCtor | PropAccessor | PropDelegate | PropDecl | FunDecl <~~ push({method: pop()}) ~~> | UnsupFun ) ;
PropDecl    <~~ push(makeProp(takeAll())) ~~>
            = ( "val" | "var" ) KwEnd Id <~~ push(up.in) ~~> [ ":" Type ] "=" Expression [ ";" ] ;
// A delegated property (val/var x [: T] by <delegate>). The `by lazy { init }` form
// is GENUINE (see LazyProp): the initializer is run once and its value becomes a
// plain field, so reads use the ordinary member machinery. Every OTHER delegate -
// the Koin/DI `by inject()`, a custom getValue/setValue, `by Delegates.observable`,
// `var by` (Kotlin allows lazy only on val) - needs the delegate protocol, which is
// outside the subset: parsed and reported as not implemented (no field, like an
// accessor). LazyProp is tried first; a non-lazy delegate backtracks to UnsupDelegate.
PropDelegate = LazyProp | UnsupDelegate ;
LazyProp    <~~ push(makeProp(takeAll())) ~~>
            = "val" KwEnd Id <~~ push(up.in) ~~> [ ":" Type ] KwBy KwLazy [ SkipParen ] LazyInit [ ";" ] ;
UnsupDelegate <~~ notImpl("delegated property", up.pos) ~~>
            = ( "val" | "var" ) KwEnd Id [ ":" Type ] KwBy DiscardExpr [ SkipBlock ] [ ";" ] ;
// The lazy initializer lambda, wrapped so it runs once and yields its value: the
// property's init thunk. EAGER - the value is computed at the declaration, not on
// first access (single-threaded, deterministic). Deviation: a lazy initializer that
// forward-references a not-yet-initialized property sees it unset (real Kotlin would
// defer past that); write lazy inits over already-bound names.
LazyInit    <~~ push(makeLazyInit(pop())) ~~>
            = Lambda ;

// Type is parsed and (apart from steering as/is) ignored. Generics (<...>) and the
// nullable ? are accepted and dropped; dotted names and simple function types too.
Type        = ( "(" [ Type { "," Type } [ "," ] ] ")" "->" Type | Id [ SkipAngle ] { "." Id [ SkipAngle ] } ) [ "?" ] ;

// Every statement production pushes exactly one thunk: function() -> undefined | signal.
// A statement may carry a label (loop@ ...); the label is parsed and ignored, so the
// labelled statement still runs. Labelled jumps (break@l / continue@l / return@l)
// route to notImpl (the target label cannot be resolved in the subset).
Statement   = { Annotation } ( ReturnAt | Return | BreakAt | Break | ContinueAt | Continue
            | Labeled | PlainStmt ) ;
PlainStmt   = Block | Destructure | DelegateDecl | Decl | If | While | Do | For | TryStmt | Throw | Empty | ExprStmt ;
Labeled     <~~ push(makeLabeled(takeAll(), up.pos)) ~~>
            = LabelDef PlainStmt ;

// try/catch/finally and throw are implemented (excThrow/excTry, languages/lib):
// throw raises the value, catch binds it (the first catch clause wins - exception
// types are parsed but not discriminated), finally always runs. return/break/continue
// inside a try still propagate to the enclosing loop or function. Each part is marked
// so excTry can tell them apart on the stack.
TryStmt     <~~ push(excTry(takeAll())) ~~>
            = KwTry TryBody { CatchClause } [ FinallyClause ] ;
TryBody     <~~ push({trybody: pop()}) ~~>
            = Block ;
CatchClause <~~ push(excCatch(takeAll())) ~~>
            = KwCatch "(" Id <~~ push(up.in) ~~> [ ":" Type ] ")" Block ;
FinallyClause <~~ push({finbody: pop()}) ~~>
            = KwFinally Block ;
Throw       <~~ push(excThrow(pop())) ~~>
            = KwThrow Expression [ ";" ] ;

Block       <~~ push(makeBlockStmt(takeAll())) ~~>
            = "{" { Statement } "}" ;

Decl        <~~ push(makeDecl(takeAll())) ~~>
            = ( "val" | "var" ) KwEnd Id <~~ push(up.in) ~~> [ ":" Type ] "=" Expression [ ";" ] ;
// A local or top-level delegated property (val x by <delegate>). Same split as
// PropDelegate: `val x by lazy { init }` is GENUINE (LazyDecl - the initializer runs
// once and x becomes an ordinary binding); every other delegate is not implemented.
DelegateDecl = LazyDecl | UnsupDelegateDecl ;
LazyDecl    <~~ push(makeDecl(takeAll())) ~~>
            = "val" KwEnd Id <~~ push(up.in) ~~> [ ":" Type ] KwBy KwLazy [ SkipParen ] LazyInit [ ";" ] ;
UnsupDelegateDecl <~~ push(notImplStmt("delegated property", up.pos)) ~~>
            = ( "val" | "var" ) KwEnd Id [ ":" Type ] KwBy DiscardExpr [ SkipBlock ] [ ";" ] ;

If          <~~ push(makeIf(takeAll())) ~~>
            = KwIf "(" Expression ")" Statement [ KwElse Statement ] ;

While       <~~ push(makeWhile(pop(), pop())) ~~>
            = KwWhile "(" Expression ")" Statement ;

Do          <~~ push(makeDo(pop(), pop())) ~~>
            = KwDo Statement KwWhile "(" Expression ")" [ ";" ] ;

// for (i in 1..n) and for (x in list); the range is tried first. Ranges come as
// 1..n (inclusive), 0 until n (exclusive) and n downTo 1, all with an optional
// positive step (soft keywords: until/downTo/step stay usable as names).
For         = ForRange | ForList ;
ForRange    <~~ push(makeForRange(takeAll())) ~~>
            = KwFor "(" Id <~~ push(up.in) ~~> KwIn Expression RangeOp Expression [ StepSfx ] ")" Statement ;
RangeOp     = ".." <~~ push({rop: ".."}) ~~>
            | KwUntil <~~ push({rop: "until"}) ~~>
            | KwDownTo <~~ push({rop: "downTo"}) ~~> ;
StepSfx     <~~ push({step: pop()}) ~~>
            = KwStep Expression ;
ForList     <~~ push(makeForList(pop(), pop(), pop())) ~~>
            = KwFor "(" Id <~~ push(up.in) ~~> KwIn Expression ")" Statement ;

Return      <~~ push(makeReturn(takeAll())) ~~>
            = KwReturn [ Expression ] [ ";" ] ;

Break       <~~ push(makeBreak()) ~~>    = KwBreak [ ";" ] ;
Continue    <~~ push(makeContinue()) ~~> = KwContinue [ ";" ] ;

Empty       <~~ push(function() {}) ~~>
            = ";" ;

ExprStmt    <~~ push(exprToStmt(pop())) ~~>
            = Expression [ ";" ] ;

// Every expression production pushes exactly one thunk: function() -> value.
Expression  = Assignment | CondLevel ;
Assignment  <~~ push(makeAssign(takeAll())) ~~>
            = Target ( "+=" | "-=" | "*=" | "/=" | "%=" | "=" ) <~~ push(up.in) ~~> Expression ;

Target      <~~ push(makeTargetRef(takeAll())) ~~>
            = Id <~~ push(up.in) ~~> { "." Id <~~ push({key: up.in}) ~~> | TIndex } ;
TIndex      <~~ push({idx: pop()}) ~~>
            = "[" Expression "]" ;

CondLevel   = IfExpr | WhenExpr | OrExpr ;

// if as an expression needs both arms.
IfExpr      <~~ push(makeIfExpr(pop(), pop(), pop())) ~~>
            = KwIf "(" Expression ")" Expression KwElse Expression ;

// when { c1 -> e1; else -> e } and when (x) { 1, 2 -> e1; else -> e }.
WhenExpr    <~~ push(makeWhen(takeAll())) ~~>
            = KwWhen [ "(" WhenSubj ")" ] "{"
              { WhenElse | WhenArm } "}" ;
// The subject is a plain expression, or a val/var binding - when (val x = e) { ... } -
// whose name is in scope in every arm body. The type annotation is parsed and ignored.
WhenSubj    = WhenBind | WhenExprSubj ;
WhenBind    <~~ var e = pop(); push({subj: e, subjName: pop()}) ~~>
            = ( "val" | "var" ) KwEnd Id <~~ push(up.in) ~~> [ ":" Type ] "=" Expression ;
WhenExprSubj <~~ push({subj: pop()}) ~~>
            = Expression ;
// The else arm must be tried first: otherwise 'else' would parse as a variable arm
// (and only fail at run time, when no other arm matches).
WhenElse    = KwElse "->" Expression <~~ push({els: pop()}) ~~> [ ";" ] ;
WhenArm     <~~ push(makeWhenArm(takeAll())) ~~>
            = WhenCond { "," WhenCond } [ "," ] "->" Expression [ ";" ] ;
// A branch condition: an inclusive range test (in / !in), a type test (is T / !is T,
// undecidable so it never matches and warns), or a value to compare with.
WhenCond    = WhenIn | WhenNotIn | WhenIs | WhenVal ;
WhenIs      <~~ var t = pop(); push({isType: true, neg: pop(), tname: t, pos: up.pos}) ~~> = IsKw TypeName ;
WhenIn      <~~ var h = pop(); push({lo: pop(), hi: h, neg: false}) ~~>
            = KwIn Expression ".." Expression ;
WhenNotIn   <~~ var h = pop(); push({lo: pop(), hi: h, neg: true}) ~~>
            = "!" KwIn Expression ".." Expression ;
WhenVal     <~~ push({v: pop()}) ~~>
            = Expression ;

OrExpr      <~~ push(makeOrAnd(takeAll(), true)) ~~>
            = AndExpr { "||" AndExpr } ;

AndExpr     <~~ push(makeOrAnd(takeAll(), false)) ~~>
            = EqExpr { "&&" EqExpr } ;

// Referential equality === / !== is evaluated like structural == / != (untyped values
// compare by identity for objects), so the operands still run and fold.
EqExpr      <~~ push(foldBinary(takeAll())) ~~>
            = RelExpr { EqOp RelExpr } ;
EqOp        = "===" <~~ push("==") ~~> | "!==" <~~ push("!=") ~~>
            | "==" <~~ push("==") ~~> | "!=" <~~ push("!=") ~~> ;

RelExpr     <~~ push(foldBinary(takeAll())) ~~>
            = TypeOp { ( "<=" | ">=" | "<" | ">" ) <~~ push(up.in) ~~> TypeOp } ;

// x as T / x as? T = identity (untyped values); x is T / x !is T undecidable, so
// not implemented. The suffix is optional, so plain expressions are unaffected.
TypeOp      <~~ push(applyTypeOp(takeAll())) ~~> = Elvis [ IsSfx | AsSfx ] ;
// A postfix `is T` must not fire when `->` immediately follows: there the `is T` leads
// the next `when` arm (is CellInfoGsm -> ...), and slurping it as a postfix would strand
// the arrow. `is T ->` occurs only at a when-arm boundary, so the guard is safe globally.
IsSfx       <~~ var t = pop(); push({isType: true, neg: pop(), tname: t, pos: up.pos}) ~~> = IsKw TypeName NotArrow ;
AsSfx       <~~ var t = pop(); push({asType: true, safe: pop(), tname: t}) ~~> = AsKw TypeName ;
IsKw        = KwIs <~~ push(false) ~~> | KwNotIs <~~ push(true) ~~> ;
AsKw        = KwAsSafe <~~ push(true) ~~> | KwAs <~~ push(false) ~~> ;
TypeName    <~~ push(stripWs(up.in)) ~~> = Type ;
// A zero-width guard that fails when the next non-whitespace token is `->`.
NotArrow    = :script(~~
    (function() {
        var i = 0
        var cc = c.peek(i)
        while (cc === 32 || cc === 9 || cc === 10 || cc === 13) { i++; cc = c.peek(i) }
        return (cc === 45 && c.peek(i + 1) === 62)
            ? abnf.newToken("\x01arrow-follows", 0)
            : undefined
    })()
~~) ;

// A zero-width guard that fails at end of line (a newline or a // comment before
// the next token): the value of a labelled return must start on the SAME line,
// otherwise `return@lbl` followed by another statement would swallow that
// statement as its return value (newlines are insignificant everywhere else).
SameLine    = :script(~~
    (function() {
        var i = 0
        var cc = c.peek(i)
        while (cc === 32 || cc === 9) { i++; cc = c.peek(i) }
        return (cc === 10 || cc === 13 || (cc === 47 && c.peek(i + 1) === 47))
            ? abnf.newToken("\x01newline-follows", 0)
            : undefined
    })()
~~) ;

// a ?: b yields a unless it is null (the elvis operator; the right side only runs then).
Elvis       <~~ push(makeElvis(takeAll())) ~~>
            = InfixExpr { "?:" InfixExpr } ;

// A stdlib infix call - a to b (Pair), a and b / a shl b - binds tighter than elvis
// and looser than +/-, matching Kotlin. All seven are genuine: `to` builds a Pair
// (read via .first/.second), and/or/xor are the non-short-circuit boolean operators
// on two booleans and the int32 bit operations otherwise, shl/shr/ushr are the int32
// shifts. Only these built-in infix names are recognised (not arbitrary user infix
// funs); the names stay usable as identifiers (KwEnd word boundary).
InfixExpr   <~~ push(makeInfix(takeAll())) ~~>
            = AddExpr { InfixOp AddExpr } ;
InfixOp     = ( "to" | "and" | "or" | "xor" | "shl" | "shr" | "ushr" ) <~~ push({iop: up.in}) ~~> KwEnd ;

AddExpr     <~~ push(foldBinary(takeAll())) ~~>
            = MulExpr { ( "+" | "-" ) <~~ push(up.in) ~~> MulExpr } ;

MulExpr     <~~ push(foldBinary(takeAll())) ~~>
            = UnaryExpr { ( "*" | "/" | "%" ) <~~ push(up.in) ~~> UnaryExpr } ;

UnaryExpr   = Neg | Not | PostfixExpr ;
Neg         <~~ push(makeNeg(pop())) ~~>
            = "-" UnaryExpr ;
Not         <~~ push(makeNot(pop())) ~~>
            = "!" UnaryExpr ;

PostfixExpr = IncDec | CallMember ;
IncDec      <~~ push(makeIncDec(takeAll())) ~~>
            = Target ( "++" | "--" ) <~~ push(up.in) ~~> ;

// Counter(5) is a constructor call, this.m() and list.add() are method calls,
// p.x is a property read, list[i] an indexed read. The ?. variants yield null
// (instead of failing) when their receiver is null. A method call may take a
// trailing lambda - list.map { it * 2 } - which becomes the last argument.
// A trailing "!!" (non-null assertion) is consumed and dropped: for untyped values it
// is the identity, so x!! evaluates exactly like x (and x!!.m() still chains).
CallMember  <~~ push(foldCallMember(takeAll())) ~~>
            = Primary { MethodSfx | SafeMethodSfx | FieldSfx | SafeFieldSfx | IndexSfx | "!!" } ;
MethodSfx   <~~ push({kind:"mcall", name: popName(), args: takeAll()}); retLblPop() ~~>
            = "." Id <~~ push({mname: up.in}); retLblPush(up.in, "lam") ~~> [ SkipAngle ] MArgs ;
SafeMethodSfx <~~ push({kind:"mcall", name: popName(), args: takeAll(), safe: true}); retLblPop() ~~>
            = "?." Id <~~ push({mname: up.in}); retLblPush(up.in, "lam") ~~> [ SkipAngle ] MArgs ;
FieldSfx    = "." Id <~~ push({kind:"field", name: up.in}) ~~> ;
SafeFieldSfx = "?." Id <~~ push({kind:"field", name: up.in, safe: true}) ~~> ;
IndexSfx    <~~ push({kind:"index", idx: pop()}) ~~>
            = "[" Expression "]" ;
MArgs       = "(" [ Expression { "," Expression } [ "," ] ] ")" [ Lambda ] | Lambda ;

// RawStr before Template (both open with "), KHexLit/KBinLit before FloatLit/KIntLit
// (0x/0b prefixes), FloatLit before KIntLit (a plain integer falls through),
// AnonFun/CallableRef before Call/VarRef (they would otherwise eat the leading
// identifier). AnonFun and qualified callable references are recognised, not run.
Primary     = "(" Expression ")" | RawStr | Template | KHexLit | KBinLit | FloatLit | KIntLit | CharLit | True | False | Null | Lambda | AnonFun | CallableRef | ObjectExpr | ThisExpr | Call | VarRef ;

// An anonymous object expression - object [: Supertypes] { members } - in value
// position, e.g. passed as an argument (object : IHasComponent<Navigator> { ... }).
// GENUINE: each evaluation builds a fresh instance whose descriptor holds the
// methods and whose fields are the initialized properties. Methods and property
// initializers see the expression site's scope chain (a real closure, like a
// lambda) plus the new object as `this`. Supertypes are parsed and ignored (no
// inheritance; passing the object where an interface is expected still works
// because method calls dispatch by name). A body outside the member subset falls
// back to ObjectExprSkip (notImplemented). Must precede Call/VarRef, which would
// otherwise read `object` as an identifier.
ObjectExpr  = ObjectExprReal | ObjectExprSkip ;
ObjectExprReal <~~ push(makeObjectExpr(takeAll())) ~~>
            = KwObject [ ":" SuperList ] "{" { Member } "}" ;
ObjectExprSkip <~~ push(notImplExpr("object expression", up.pos)) ~~>
            = KwObject [ ":" SuperList ] SkipBlock ;

// A labelled receiver - this@Label (this@TriangleApplication). The subset has a single
// receiver, so it resolves to the nearest enclosing `this` exactly like a bare `this`;
// the label names an outer scope we do not model, so it is parsed and ignored. Bare
// `this` is a plain VarRef; this must precede Call/VarRef so `this` is not read as an
// identifier before the `@Label` is seen.
ThisExpr    <~~ push(makeVarRef("this")) ~~>
            = "this" KwEnd "@" Id ;

// A lambda: { it * 2 }, { x -> x * 2 }, { a: Int, b: Int -> a + b }. The body is
// one expression; without parameters the single argument is bound to 'it'.
Lambda      <~~ push(makeLambda(takeAll())) ~~>
            = "{" [ LambdaParams ] { LamStmt } "}" ;
// A lambda body is a sequence of statements whose value is its last expression
// (a single expression is the common case). Genuinely lowered, not notImpl.
// Keyword-led statements first; then an if/else whose arms are expressions (an
// IfExpr keeps its value); then any REMAINING if statement - a bare `if (c) s`
// must be consumed here, BEFORE LamExpr, which would otherwise read the keyword
// `if` as an identifier (`if (c)` parses as the call if(c)) and only fail at run
// time; then any expression; then an empty statement.
LamStmt     = LamCtrl | LamIfValue | LamIf | LamExpr | ";" ;
LamCtrl     <~~ push({stmt: pop()}) ~~>
            = ReturnAt | Return | BreakAt | Break | ContinueAt | Continue
            | Labeled | Decl | While | Do | For | TryStmt | Throw ;
LamIfValue  <~~ push({expr: pop()}) ~~>
            = IfExpr ;
LamIf       <~~ push({stmt: pop()}) ~~>
            = If ;
LamExpr     <~~ push({expr: pop()}) ~~>
            = Expression [ ";" ] ;
LambdaParams <~~ push({lparams: takeAll()}) ~~>
            = LParam { "," LParam } [ "," ] "->" ;
LParam      = Id <~~ push(up.in) ~~> [ ":" Type ] ;

// f(a, b): a top level function, a builtin, or a class constructor. A trailing lambda
// becomes the last argument (Kotlin): after a parenthesized list - f(a) { ... } - or on
// its own - f { ... } (the sole argument, e.g. module { single { ... } }). Either form
// works as a Primary anywhere, including as an argument to an outer call
// (modules(module(createdAtStart = true) { ... }, module { ... }, ...)).
Call        <~~ push(makeCall(takeAll())); retLblPop() ~~>
            = Id <~~ push(up.in); retLblPush(up.in, "lam") ~~> [ SkipAngle ] ( "(" [ Expression { "," Expression } [ "," ] ] ")" [ Lambda ] | Lambda ) ;

// String templates: "x=$x sum=${a + b}".
Template    <~~ push(makeTemplate(takeAll())) ~~>
            = '"' :whitespace() { TplExpr | TplVar | TplChunk } '"' :whitespace(Whitespace) ;
TplExpr     <~~ push({e: pop()}) ~~>
            = "${" :whitespace(Whitespace) Expression "}" ;
TplVar      = "$" TplName <~~ push({e: makeVarRef(up.in)}) ~~> ;
TplName     = ( "a"..."z" | "A"..."Z" | "_" ) { "a"..."z" | "A"..."Z" | "0"..."9" | "_" } ;
TplChunk    <~~ push({s: unescapeJs(up.in)}) ~~>
            = TplChar { TplChar } ;
TplChar     = TplEsc | TplPlain ;
TplEsc      = "\\" "\x20"..b"\x7e" ;
TplPlain    = "\x20"..."\x21" | "\x23"..."\x23" | "\x25"..."\x5b" | "\x5d"..."\x7e" | @"\t" | "\x7f"..."\U0010ffff" ;

Null        <~~ push(makeConst(null)) ~~>  = "null" KwEnd ;

VarRef      <~~ push(makeVarRef(up.in)) ~~>
            = Id ;

// ----- Widened surface: constructs accepted structurally but not lowered -----

// A balanced { ... } body consumed without interpreting it, so a construct can be
// ACCEPTED without being understood. Full string/char literals and ${...} templates
// are matched first, so braces inside them are never miscounted. No tags: nothing is
// pushed, so the consuming production is free to push its own placeholder.
SkipBlock   = "{" { SkipItem } "}" ;
SkipItem    = SkipStr | SkipChar | SkipBlock | SkipOther ;
SkipStr     = '"' :whitespace() { SkipTpl | SkipStrEsc | SkipStrChar } '"' :whitespace(Whitespace) ;
SkipTpl     = "${" :whitespace(Whitespace) { SkipItem } "}" ;
SkipStrEsc  = "\\" "\x00"..."\U0010ffff" ;
SkipStrChar = "\x00"..."\x21" | "\x23"..."\x5b" | "\x5d"..."\U0010ffff" ;
SkipChar    = "'" :whitespace() { SkipChEsc | SkipChChar } "'" :whitespace(Whitespace) ;
SkipChEsc   = "\\" "\x00"..."\U0010ffff" ;
SkipChChar  = "\x00"..."\x26" | "\x28"..."\x5b" | "\x5d"..."\U0010ffff" ;
SkipOther   = "\x00"..."\x21" | "\x23"..."\x26" | "\x28"..."\x7a" | "\x7c" | "\x7e"..."\U0010ffff" ;

// A balanced < ... > run (generic parameters / arguments), parsed and ignored.
SkipAngle   = "<" { SkipAngle | SkipAngleItem } ">" ;
SkipAngleItem = "\x00"..."\x3b" | "\x3d" | "\x3f"..."\U0010ffff" ;

// A balanced ( ... ) run (used to skip an anonymous function's parameter list, which
// may hold nested parens from function types). No tags: nothing is pushed.
SkipParen   = "(" { SkipParen | SkipParenItem } ")" ;
SkipParenItem = "\x00"..."\x27" | "\x2a"..."\U0010ffff" ;

// A statement label (loop@, outer@): the Labeled wrapper offers the name to
// the labelled loop and absorbs a matching labelled break (see makeLabeled).
// break@l / continue@l jump to the loop labelled l. return@l is genuine when l
// names the INNERMOST enclosing lambda's implicit label (the callee name: forEach
// in list.forEach { return@forEach v }) or the directly enclosing function (then
// it is a plain return); the walk-time retLabels stack decides (see makeReturnAt).
// A NON-LOCAL labelled return (an outer lambda's label) stays not implemented.
LabelDef    = Id <~~ push({lbl: up.in}) ~~> "@" ;
BreakAt     <~~ push(makeBreakTo(pop().lbl)) ~~>
            = KwBreak "@" Id <~~ push({lbl: up.in}) ~~> [ ";" ] ;
ContinueAt  <~~ push(makeContinueTo(pop().lbl)) ~~>
            = KwContinue "@" Id <~~ push({lbl: up.in}) ~~> [ ";" ] ;
ReturnAt    <~~ push(makeReturnAt(takeAll(), up.pos)) ~~>
            = KwReturn "@" Id <~~ push({rlbl: up.in}) ~~> [ SameLine Expression ] [ ";" ] ;

// A floating-point literal (1.5, 2.0f, 1e9, 3.14E-2, digit-group underscores):
// a genuine double value (parseFloat stops before the f/F suffix). Comparisons
// are exact; see the arithmetic note at the core config for the int-wrap caveat.
FloatLit    <~~ push(makeConst(parseFloat(up.in.split("_").join("")))) ~~>
            = ( "0" | "1"..."9" ) :whitespace() { "0"..."9" | "_" }
              ( "." "0"..."9" { "0"..."9" | "_" } [ FloatExp ] [ FloatSfx ]
              | FloatExp [ FloatSfx ]
              | FloatSfx ) :whitespace(Whitespace) ;
FloatExp    = ( "e" | "E" ) [ "+" | "-" ] "0"..."9" { "0"..."9" | "_" } ;
FloatSfx    = "f" | "F" ;

// Integer literal forms beyond the plain decimal IntLit: hex, binary, digit-group
// underscores, and the Long suffix (the value model is a JS number, so a Long is
// simply a number beyond 32 bits; its arithmetic wraps like Int arithmetic).
KHexLit     = NumHex [ IntSfx ] ;
KBinLit     = NumBin [ IntSfx ] ;
KIntLit     = NumInt [ IntSfx ] ;
IntSfx      = "L" ;

// A character literal: the value is the character code (a number), so char
// comparisons and 'A' + 1 == 'B' arithmetic work; printing a Char shows the code.
CharLit     <~~ push(makeConst(kCharCode(up.in))) ~~>
            = "'" :whitespace() CharBody "'" :whitespace(Whitespace) ;
CharBody    = "\\" ( "u" NumHexDig NumHexDig NumHexDig NumHexDig | CharEsc ) | CharPlain ;
CharEsc     = "n" | "t" | "r" | "b" | "'" | '"' | "\\" | "$" | "0" ;
CharPlain   = "\x20"..."\x26" | "\x28"..."\x5b" | "\x5d"..."\U0010ffff" ;

// A triple-quoted raw string: content up to the closing """ (internal runs of one
// or two quotes are allowed), kept verbatim - no escape processing - with genuine
// $name / ${expr} interpolation (same maker as Template). A $ directly after an
// internal quote is consumed as raw text (exotic corner, kept simple).
RawStr      <~~ push(makeTemplate(takeAll())) ~~>
            = '"""' :whitespace() { TplExpr | TplVar | RawChunk } '"""' :whitespace(Whitespace) ;
RawChunk    <~~ push({s: up.in}) ~~>
            = ( RawTwoQ | RawOneQ | RawPlain ) { RawTwoQ | RawOneQ | RawPlain } ;
RawPlain    = "\x00"..."\x21" | "\x23"..."\x23" | "\x25"..."\U0010ffff" ;
RawOneQ     = '"' ( "\x00"..."\x21" | "\x23"..."\U0010ffff" ) ;
RawTwoQ     = '"' '"' ( "\x00"..."\x21" | "\x23"..."\U0010ffff" ) ;

// A callable reference. A bare ::fn is genuine: top-level functions and builtins are
// already first-class closures, so ::fn evaluates like the name itself (stored, passed
// as a lambda, called later). A constructor reference ::Cls yields the class
// descriptor, which is not callable - out of the subset. A QUALIFIED reference
// (Type::member, pkg.Type::member, recv::method) needs a bound-method value the
// subset does not model: recognised, not implemented.
CallableRef = BareRef | QualRef ;
BareRef     = "::" Id <~~ push(makeVarRef(up.in)) ~~> ;
QualRef     <~~ push(notImplExpr("callable reference", up.pos)) ~~>
            = Id { "." Id } "::" Id ;

// An anonymous function expression: fun(params): T { ... } or fun(params) = expr. The
// parameter list and body are skipped; recognised and reported as not implemented.
AnonFun     <~~ push(notImplExpr("anonymous function", up.pos)) ~~>
            = KwFun SkipParen [ ":" Type ] ( SkipBlock | "=" DiscardExpr ) ;

// A tag-less primary-constructor parameter list for headers we only skip.
CtorParamsSkip = "(" [ CParamSkip { "," CParamSkip } [ "," ] ] ")" ;
CParamSkip  = [ Modifiers ] [ ( "val" | "var" ) KwEnd ] Id ":" Type [ "=" DiscardExpr ] ;

// A supertype list (types with optional constructor-call args). No inheritance in
// the subset, so it is parsed and ignored; DiscardExpr drops the arg thunks.
SuperList   = SuperItem { "," SuperItem } ;
// A supertype is a class (optional constructor-call args), an interface, or an
// interface implemented by delegation (`: I by impl`). No inheritance in the
// subset, so all three parse and are ignored; the delegate expression is discarded.
SuperItem   = Type [ "(" [ DiscardExpr { "," DiscardExpr } [ "," ] ] ")" | KwBy DiscardExpr ] ;
DiscardExpr <~~ pop() ~~> = Expression ;

// Type declarations accepted structurally, then reported as not implemented (so a
// full Kotlin file parses; -warn-unsupported lets the rest run). The body is skipped.
UnsupType   = Interface | ObjectDecl | EnumClass | AnnotationClass | TypeAlias ;
Interface   <~~ notImpl("interface", up.pos) ~~>
            = KwInterface Id [ SkipAngle ] [ ":" SuperList ] SkipBlock ;
// object Name { ... } is a real singleton: its member body is built into a
// backing js_obj_new (properties initialized once, methods reachable via the
// name). A body outside the subset (e.g. a char literal) falls back to ObjectSkip
// (notImplemented), so the widened surface still parses.
ObjectDecl  = ObjectReal | ObjectSkip ;
ObjectReal  <~~ buildObject(takeAll()) ~~>
            = KwObject Id <~~ push(up.in) ~~> [ ":" SuperList ] "{" { Member } "}" ;
ObjectSkip  <~~ notImpl("object declaration", up.pos) ~~>
            = KwObject Id [ ":" SuperList ] SkipBlock ;
EnumClass   <~~ notImpl("enum class", up.pos) ~~>
            = KwEnum KwClass Id [ SkipAngle ] [ CtorParamsSkip ] [ ":" SuperList ] SkipBlock ;
AnnotationClass <~~ notImpl("annotation class", up.pos) ~~>
            = KwAnnotation KwClass Id [ SkipAngle ] [ CtorParamsSkip ] [ SkipBlock ] ;
TypeAlias   <~~ notImpl("typealias", up.pos) ~~>
            = KwTypealias Id [ SkipAngle ] "=" Type [ ";" ] ;

// Member forms accepted structurally, then reported as not implemented.
InitBlock   <~~ notImpl("init block", up.pos) ~~>
            = KwInit SkipBlock ;
// companion object { ... } inside a class: its members are attached to the class
// descriptor (properties as fields, methods reachable through the class name), so
// ClassName.member works. A body outside the subset falls back to CompanionSkip.
CompanionObject = CompanionReal | CompanionSkip ;
CompanionReal <~~ push({companion: takeAll()}) ~~>
            = KwCompanion KwObject [ Id ] [ ":" SuperList ] "{" { Member } "}" ;
CompanionSkip <~~ notImpl("companion object", up.pos) ~~>
            = KwCompanion KwObject [ Id ] [ ":" SuperList ] SkipBlock ;
SecondaryCtor <~~ notImpl("secondary constructor", up.pos) ~~>
            = KwConstructor "(" [ SParam { "," SParam } [ "," ] ] ")" [ ":" Id "(" [ DiscardExpr { "," DiscardExpr } [ "," ] ] ")" ] SkipBlock ;
SParam      = [ Modifiers ] Id ":" Type [ "=" DiscardExpr ] ;
PropAccessor <~~ notImpl("property accessor", up.pos) ~~>
            = ( "val" | "var" ) KwEnd Id [ ":" Type ] [ "=" DiscardExpr ] Accessor { Accessor } ;
Accessor    = ( KwGet | KwSet ) "(" [ Id [ ":" Type ] ] ")" [ ":" Type ] [ SkipBlock | "=" DiscardExpr ] [ ";" ] ;

// A destructuring declaration: accepted, reported as not implemented; the
// initializer still runs so its calls stay visible under -warn-unsupported.
Destructure <~~ push(makeDestructure(pop(), up.pos)) ~~>
            = ( "val" | "var" ) KwEnd "(" Id { "," Id } [ "," ] ")" [ ":" Type ] "=" Expression [ ";" ] ;

KwLazy      = "lazy" KwEnd ;
KwInterface = "interface" KwEnd ;
KwObject    = "object" KwEnd ;
KwEnum      = "enum" KwEnd ;
KwAnnotation = "annotation" KwEnd ;
KwCompanion = "companion" KwEnd ;
KwTypealias = "typealias" KwEnd ;
KwConstructor = "constructor" KwEnd ;
KwInit      = "init" KwEnd ;
KwGet       = "get" KwEnd ;
KwSet       = "set" KwEnd ;

KwFun       = "fun" KwEnd ;
KwImport    = "import" KwEnd ;
KwPackage   = "package" KwEnd ;
KwAs        = "as" KwEnd ;
KwAsSafe    = "as?" ;
KwTry       = "try" KwEnd ;
KwCatch     = "catch" KwEnd ;
KwFinally   = "finally" KwEnd ;
KwThrow     = "throw" KwEnd ;
KwIs        = "is" KwEnd ;
KwNotIs     = "!is" KwEnd ;
KwClass     = "class" KwEnd ;
KwIf        = "if" KwEnd ;
KwElse      = "else" KwEnd ;
KwWhile     = "while" KwEnd ;
KwDo        = "do" KwEnd ;
KwFor       = "for" KwEnd ;
KwIn        = "in" KwEnd ;
KwBy        = "by" KwEnd ;
KwWhen      = "when" KwEnd ;
KwReturn    = "return" KwEnd ;
KwBreak     = "break" KwEnd ;
KwContinue  = "continue" KwEnd ;
KwUntil     = "until" KwEnd ;
KwDownTo    = "downTo" KwEnd ;
KwStep      = "step" KwEnd ;

// ---


:startScript(~~

    // Shared interpreter machinery (scopes, BRK/CONT protocol, expression and
    // statement builders); language-specific behavior is configured on `core` below.
    include("lib/interp-core.js")

    // ----- Imports (same policy as the compiler grammar) -----
    // Prefixes the runtime already provides as builtins; importing them is a no-op.
    core.stdlibImports = ["kotlin", "kotlin.math", "kotlin.collections", "kotlin.system", "kotlin.text", "kotlin.ranges", "kotlin.sequences"]

    // Project-file imports: 'import a.b.C' looks for a/b/C.kt, then a/b.kt
    // under the program's directory and the -i roots (c.findImport). The file
    // is parsed with this grammar and walked with the same tags, so its
    // classes and functions register exactly like the main file's; the entry
    // point only runs for the main file (the start script calls it once).
    // A file is imported once; repeats and cycles are no-ops.
    var importedFiles = {}
    core.importFile = function(path, pos) {
        if (path.length > 2 && path.substring(path.length - 2) == ".*") { return false }
        var rel = path.split(".").join("/")
        var cands = [rel + ".kt"]
        var cut = -1
        for (var k = 0; k < rel.length; k++) { if (rel.charAt(k) == "/") { cut = k } }
        if (cut > 0) { cands.push(rel.substring(0, cut) + ".kt") }
        for (var i = 0; i < cands.length; i++) {
            var file = c.findImport(cands[i])
            if (file == "") { continue }
            if (importedFiles["$" + file] == true) { return true }
            importedFiles["$" + file] = true
            var text = c.readFile(file)
            var asg = c.parse(c.agrammar, text, null)
            c.pushSource(file, text)
            c.compile(asg)
            c.popSource()
            return true
        }
        return false
    }

    // stripWs, importResolvable, resolveImport and the notImpl / notImplStmt /
    // notImplExpr family now live in lib/interp-core.js (shared). This grammar sets
    // core.stdlibImports (above) and keeps the Kotlin-specific builders below.
    // try/catch/finally and throw are handled by excTry/excThrow (lib/interp-core.js).
    // Decodes a character literal's source text ('A', '\n', '￿') to its code.
    function kCharCode(t) {
        if (t.charAt(1) == "\\") {
            var e = t.charAt(2)
            if (e == "n") { return 10 }
            if (e == "t") { return 9 }
            if (e == "r") { return 13 }
            if (e == "b") { return 8 }
            if (e == "0") { return 0 }
            if (e == "u") { return parseInt(t.substring(3, 7), 16) }
            return e.charCodeAt(0)
        }
        return t.charCodeAt(1)
    }
    // x is T / x !is T: the shared dynamic type test (rtIsType, lib/interp-core.js).
    function makeIsCheck(operand, m) {
        return function() {
            var hit = rtIsType(operand(), m.tname)
            return m.neg ? !hit : hit
        }
    }
    // A curated stdlib infix call, folded left to right: a to b builds a Pair
    // {first, second}; and/or/xor are the non-short-circuit boolean operators on two
    // booleans and int32 bit operations otherwise; shl/shr/ushr are the int32 shifts
    // (ushr wraps back to a signed int like Kotlin's Int.ushr).
    // items alternates operand thunks and {iop} markers.
    function applyInfix(op, l, r) {
        if (op == "to") { return {first: l, second: r} }
        if (op == "and") { if (typeof l == "boolean" && typeof r == "boolean") { return l && r } return l & r }
        if (op == "or") { if (typeof l == "boolean" && typeof r == "boolean") { return l || r } return l | r }
        if (op == "xor") { if (typeof l == "boolean" && typeof r == "boolean") { return l != r } return l ^ r }
        if (op == "shl") { return l << r }
        if (op == "shr") { return l >> r }
        return (l >>> r) | 0 // ushr
    }
    function makeInfix(items) {
        if (items.length == 1) { return items[0] }
        return function() {
            var v = anytype // A fold step can turn a number into a Pair or boolean.
            v = items[0]()
            for (var i = 1; i < items.length; i += 2) {
                v = applyInfix(items[i].iop, v, items[i + 1]())
            }
            return v
        }
    }
    function applyTypeOp(items) {
        if (items.length == 1) { return items[0] }
        var operand = items[0]
        var m = items[1]
        if (m.asType) {
            if (!m.safe) { return operand } // x as T: identity (untyped values)
            return function() { var v = operand(); return rtIsType(v, m.tname) ? v : null }
        }
        return makeIsCheck(operand, m)
    }

    // ----- Scopes with implicit property fallback (Kotlin style) -----
    function findThis() {
        for (var i = scopes.length - 1; i >= 0; i--) {
            if (hasOwn(scopes[i], "this")) return scopes[i]["this"]
        }
        return undefined
    }
    hostGlobals["println"] = function(x) { println(kstr(x)) }
    hostGlobals["print"] = function(x) { print(kstr(x)) }
    hostGlobals["exitProcess"] = function(code) { exit(code | 0) }
    hostGlobals["abs"] = function(v) { return v < 0 ? -v | 0 : v | 0 }
    hostGlobals["max"] = function(a, b) { return a > b ? a : b }
    hostGlobals["min"] = function(a, b) { return a < b ? a : b }
    hostGlobals["listOf"] = function() {
        var out = []
        for (var i = 0; i < arguments.length; i++) out.push(arguments[i])
        return out
    }
    hostGlobals["mutableListOf"] = hostGlobals["listOf"]

    function kstr(v) {
        if (v === undefined) return "kotlin.Unit"
        if (v === null) return "null"
        return "" + v
    }

    // ----- Extension functions: dispatch by name, the receiver becomes `this` -----
    // Method names the runtime implements on strings/lists/dicts (the compiler
    // grammar uses the same list): an extension function never shadows them, so
    // both engines make the same dispatch decision for every (receiver, name).
    var extFuns = {}
    var classMethodNames = {}
    var builtinMethodNames = {}
    var bmn = ["length", "charAt", "equals", "substring", "indexOf", "isEmpty",
               "keys", "values", "get", "add", "append", "pop", "removeLast", "size",
               "contains", "map", "filter", "sumOf", "forEach", "count", "any"]
    for (var bi = 0; bi < bmn.length; bi++) { builtinMethodNames["$" + bmn[bi]] = true }
    // items = [name, {params}, body]: the receiver type was dropped by RecvSeg.
    // Like makeMethodClosure/invokeBody, but `this` is declared UNCONDITIONALLY:
    // a nullable-receiver extension runs with this = null (invokeBody would skip
    // the null binding, and the compiled twin binds args[0] unconditionally).
    function registerExtFun(items) {
        var params = items[1].params
        var body = items[2]
        extFuns["$" + items[0]] = function() {
            var recv = arguments[0]
            var args = arguments
            var saved = scopes
            scopes = [globalScope, {}]
            declVar("this", recv)
            for (var i = 0; i < params.length; i++) {
                declVar(params[i], i + 1 < args.length ? args[i + 1] : undefined)
            }
            if (core.framePush != null) core.framePush()
            var r = body()
            if (core.framePop != null) core.framePop()
            scopes = saved
            return (r != undefined && r.isRet) ? r.v : undefined
        }
    }
    function extResolves(name) {
        if (extFuns["$" + name] == undefined) { return false }
        if (builtinMethodNames["$" + name] == true) { return false }
        if (classMethodNames["$" + name] == true) { return false }
        return true
    }

    function mcall(target, name, args) {
        // An extension function wins only when no builtin or class method uses the
        // name; it runs with the receiver as `this` (null for a nullable receiver).
        if (extResolves(name)) { return extFuns["$" + name].apply(undefined, concat2impl([target], args)) }
        if (typeof target == "string") {
            if (name == "length") return target.length
            fail("unknown String method: " + name)
        }
        if (target === undefined || target === null) fail("method call ." + name + "() on null")
        if (Array.isArray(target)) {
            if (name == "add") { target.push(args[0]); return true }
            if (name == "size") return target.length
            if (name == "get") return target[args[0]]
            if (name == "contains") return target.indexOf(args[0]) >= 0
            var i
            var out
            if (name == "map") {
                out = []
                for (i = 0; i < target.length; i++) out.push(args[0](target[i]))
                return out
            }
            if (name == "filter") {
                out = []
                for (i = 0; i < target.length; i++) { if (args[0](target[i])) out.push(target[i]) }
                return out
            }
            if (name == "sumOf") {
                var sum = 0
                for (i = 0; i < target.length; i++) sum = (sum + args[0](target[i])) | 0
                return sum
            }
            if (name == "forEach") {
                for (i = 0; i < target.length; i++) args[0](target[i])
                return undefined
            }
            if (name == "count") {
                if (args.length == 0) return target.length
                var n = 0
                for (i = 0; i < target.length; i++) { if (args[0](target[i])) n++ }
                return n
            }
            if (name == "any") {
                for (i = 0; i < target.length; i++) { if (args[0](target[i])) return true }
                return false
            }
            fail("unknown list method: " + name)
        }
        if (target.__class != undefined) {
            // Own-property read: a bare [name] resolved inherited Object.prototype
            // members (toString, valueOf, ...) under a host JS engine.
            var m = hasOwn(target.__class, name) ? target.__class[name] : undefined
            if (typeof m != "function") fail("unknown method '" + name + "' on " + target.__class.__name)
            return m.apply(undefined, concat2impl([target], args))
        }
        if (hasOwn(target, name) && typeof target[name] == "function") return target[name].apply(undefined, args)
        fail("unknown method '" + name + "'")
    }


    // ----- Expression thunks -----

    function kadd(l, r) {
        if (typeof l == "string" || typeof r == "string") return kstr2(l) + kstr2(r)
        return (l + r) | 0
    }
    function kstr2(v) {
        if (typeof v == "string") return v
        return kstr(v)
    }
    function makeIfExpr(elseT, thenT, condT) {
        return function() { return condT() ? thenT() : elseT() }
    }
    // items = [{subj}?] [{vals, body}...] [{els}?]
    function makeWhenArm(items) {
        var body = items.pop()
        return {conds: items, body: body}
    }
    // items = [thunk, thunk, ...]: a ?: b yields a unless it is null (short circuit).
    function makeElvis(items) {
        if (items.length == 1) return items[0]
        return function() {
            var v = items[0]()
            for (var i = 1; i < items.length && (v === null || v === undefined); i++) v = items[i]()
            return v
        }
    }
    function makeWhen(items) {
        var subj = null
        var subjName = null
        var els = null
        var arms = []
        for (var i = 0; i < items.length; i++) {
            if (items[i].subj != undefined) {
                subj = items[i].subj
                if (items[i].subjName != undefined) subjName = items[i].subjName
            }
            else if (items[i].els != undefined) els = items[i].els
            else arms.push(items[i])
        }
        return function() {
            var s = subj != null ? subj() : undefined
            // when (val x = e): x is bound in a fresh scope, visible to every arm body.
            if (subjName != null) { scopes.push({}); declVar(subjName, s) }
            for (var a = 0; a < arms.length; a++) {
                for (var ci = 0; ci < arms[a].conds.length; ci++) {
                    var cond = arms[a].conds[ci]
                    var hit
                    if (cond.isType) {
                        hit = rtIsType(s, cond.tname)
                        if (cond.neg) hit = !hit
                    } else if (cond.v != undefined) {
