    // dict.items(): loop over js_keys(d) building a list of [key, value] 2 element lists
    // (the subset has no tuples), reading each value with js_pyget. Deterministic across
    // engines because js_keys returns the keys in insertion order.
    function emitItems(b, dictV) {
        hidCount++
        var iName = "$iti" + hidCount
        var kName = "$itk" + hidCount
        var dName = "$itd" + hidCount
        var oName = "$ito" + hidCount
        var saved = curScopeV
        curScopeV = callExt(b, "js_scope_new", [curScopeV])
        callExt(b, "js_scope_decl", [curScopeV, emitStr(b, dName), dictV])
        callExt(b, "js_scope_decl", [curScopeV, emitStr(b, kName), callExt(b, "js_keys", [dictV])])
        callExt(b, "js_scope_decl", [curScopeV, emitStr(b, iName), emitNum(b, 0)])
        callExt(b, "js_scope_decl", [curScopeV, emitStr(b, oName), callExt(b, "js_arr_new", [])])
        var headB = curF.NewBlock("")
        var bodyB = curF.NewBlock("")
        var exitB = curF.NewBlock("")
        b.NewBr(headB)
        var iV = callExt(headB, "js_scope_get", [curScopeV, emitStr(headB, iName)])
        var kV = callExt(headB, "js_scope_get", [curScopeV, emitStr(headB, kName)])
        var lenV = callExt(headB, "js_get", [kV, emitStr(headB, "length")])
        headB.NewCondBr(truthy(headB, callExt(headB, "js_lt", [iV, lenV])), bodyB, exitB)
        var bb = bodyB
        var iV2 = callExt(bb, "js_scope_get", [curScopeV, emitStr(bb, iName)])
        var kV2 = callExt(bb, "js_scope_get", [curScopeV, emitStr(bb, kName)])
        var dV2 = callExt(bb, "js_scope_get", [curScopeV, emitStr(bb, dName)])
        var keyV = callExt(bb, "js_get", [kV2, iV2])
        var valV = callExt(bb, "js_pyget", [dV2, keyV])
        var pair = callExt(bb, "js_arr_new", [])
        callExt(bb, "js_arr_push", [pair, keyV])
        callExt(bb, "js_arr_push", [pair, valV])
        var oV = callExt(bb, "js_scope_get", [curScopeV, emitStr(bb, oName)])
        callExt(bb, "js_arr_push", [oV, pair])
        callExt(bb, "js_scope_set", [curScopeV, emitStr(bb, iName), callExt(bb, "js_add", [iV2, emitNum(bb, 1)])])
        bb.NewBr(headB)
        var outV = callExt(exitB, "js_scope_get", [curScopeV, emitStr(exitB, oName)])
        curScopeV = saved
        return {b: exitB, v: outV}
    }

    function emitRefRead(b, ref) {
        var o = callExt(b, "js_scope_get", [curScopeV, emitStr(b, ref.name)])
        for (var i = 0; i < ref.path.length; i++) {
            var r = ref.path[i].idx(b)
            b = r.b
            o = callExt(b, "js_pyget", [o, r.v])
        }
        return {b: b, v: o}
    }
    function emitRefWrite(b, ref, v) {
        if (ref.path.length == 0) {
            callExt(b, "js_pyset_var", [curScopeV, emitStr(b, ref.name), v])
            return b
        }
        var o = callExt(b, "js_scope_get", [curScopeV, emitStr(b, ref.name)])
        for (var i = 0; i < ref.path.length - 1; i++) {
            var r = ref.path[i].idx(b)
            b = r.b
            o = callExt(b, "js_pyget", [o, r.v])
        }
        var kr = ref.path[ref.path.length - 1].idx(b)
        b = kr.b
        callExt(b, "js_pyset", [o, kr.v, v])
        return b
    }
    // Pops reversed: value, target.
    function makeAssign(valT, ref) {
        return function(b) {
            var r = valT(b)
            b = r.b
            return emitRefWrite(b, ref, r.v)
        }
    }
    function makeAugAssign(items) {
        var ref = items[0]
        var op = items[1].op
        var valT = items[2]
        return function(b) {
            var rr = emitRefRead(b, ref)
            b = rr.b
            var rv = valT(b)
            b = rv.b
            return emitRefWrite(b, ref, callExt(b, binExt[op], [rr.v, rv.v]))
        }
    }

    // ----- Statement thunks: function(block) -> block -----

    function makeElif(suite, cond) { return {elifCond: cond, suite: suite} }
    function makeElse(suite) { return {elseSuite: suite} }
    // The if/elif/else chain becomes a chain of tests, all meeting in one merge block.
    makeIf = function(items) {
        var cond = items[0]
        var thenT = items[1]
        var elifs = []
        var elseT = null
        for (var i = 2; i < items.length; i++) {
            if (items[i].elifCond != undefined) elifs.push(items[i])
            if (items[i].elseSuite != undefined) elseT = items[i].elseSuite
        }
        return function(b) {
            var mergeB = curF.NewBlock("")
            var r = cond(b)
            b = r.b
            var thenB = curF.NewBlock("")
            var nextB = curF.NewBlock("")
            b.NewCondBr(truthy(b, r.v), thenB, nextB)
            thenT(thenB).NewBr(mergeB)
            b = nextB
            for (var k = 0; k < elifs.length; k++) {
                var r2 = elifs[k].elifCond(b)
                b = r2.b
                var armB = curF.NewBlock("")
                var next2 = curF.NewBlock("")
                b.NewCondBr(truthy(b, r2.v), armB, next2)
                elifs[k].suite(armB).NewBr(mergeB)
                b = next2
            }
            if (elseT != null) { elseT(b).NewBr(mergeB) }
            else { b.NewBr(mergeB) }
            return mergeB
        }
    }
    // for x in <list>: a hidden index drives the loop; x is a normal Python variable
    // (function scoped, survives the loop).
    function makeFor(bodyT, listT, name) {
        return function(b) {
            hidCount++
            var iName = "$i" + hidCount
            var aName = "$a" + hidCount
            var r = listT(b)
            b = r.b
            // js_pyiter normalizes the iterable: dicts iterate their keys, strings their chars.
            callExt(b, "js_scope_decl", [curScopeV, emitStr(b, aName), callExt(b, "js_pyiter", [r.v])])
            callExt(b, "js_scope_decl", [curScopeV, emitStr(b, iName), emitNum(b, 0)])
            var headB = curF.NewBlock("")
            var bodyB = curF.NewBlock("")
            var postB = curF.NewBlock("")
            var exitB = curF.NewBlock("")
            b.NewBr(headB)
            var iV = callExt(headB, "js_scope_get", [curScopeV, emitStr(headB, iName)])
            var aV = callExt(headB, "js_scope_get", [curScopeV, emitStr(headB, aName)])
            var lenV = callExt(headB, "js_get", [aV, emitStr(headB, "length")])
            headB.NewCondBr(truthy(headB, callExt(headB, "js_lt", [iV, lenV])), bodyB, exitB)
            var iV2 = callExt(bodyB, "js_scope_get", [curScopeV, emitStr(bodyB, iName)])
            var aV2 = callExt(bodyB, "js_scope_get", [curScopeV, emitStr(bodyB, aName)])
            callExt(bodyB, "js_pyset_var", [curScopeV, emitStr(bodyB, name), callExt(bodyB, "js_get", [aV2, iV2])])
            loopStack.push({cont: postB, brk: exitB})
            bodyT(bodyB).NewBr(postB)
            loopStack.pop()
            var iV3 = callExt(postB, "js_scope_get", [curScopeV, emitStr(postB, iName)])
            callExt(postB, "js_scope_set", [curScopeV, emitStr(postB, iName), callExt(postB, "js_add", [iV3, emitNum(postB, 1)])])
            postB.NewBr(headB)
            return exitB
        }
    }
    function makeReturn(items) {
        var t = items.length > 0 ? items[0] : null
        return function(b) {
            var v = hUndef
            if (t != null) {
                var r = t(b)
                b = r.b
                v = r.v
            }
            b.NewRet(v)
            return deadBlock()
        }
    }
    // ----- Widened surface: newly accepted constructs -----

    // a if c else b: genuinely lowered; the two arms meet in a phi (only the taken
    // arm's side effects run).
    function makeTernary(items) {
        if (items.length == 1) { return items[0] }
        var thenT = items[0]
        var condT = items[1]
        var elseT = items[2]
        return function(b) {
            var rc = condT(b)
            b = rc.b
            var thenB = curF.NewBlock("")
            var elseB = curF.NewBlock("")
            var mergeB = curF.NewBlock("")
            b.NewCondBr(truthy(b, rc.v), thenB, elseB)
            var rt = thenT(thenB)
            rt.b.NewBr(mergeB)
            var re = elseT(elseB)
            re.b.NewBr(mergeB)
            var phi = mergeB.NewPhi([llvm.ir.NewIncoming(rt.v, rt.b), llvm.ir.NewIncoming(re.v, re.b)])
            return {b: mergeB, v: phi}
        }
    }
    // a, b = x, y: evaluate every right-hand value first, then write each target;
    // a single right-hand iterable is unpacked positionally (js_pyget by index).
    function makeParallelAssign(items) {
        var targets = []
        var values = []
        for (var i = 0; i < items.length; i++) {
            if (typeof items[i] == "function") { values.push(items[i]) }
            else { targets.push(items[i]) }
        }
        return function(b) {
            var vals = []
            if (values.length == 1 && targets.length > 1) {
                var rr = values[0](b)
                b = rr.b
                var arr = callExt(b, "js_pyiter", [rr.v])
                for (var j = 0; j < targets.length; j++) {
                    vals.push(callExt(b, "js_pyget", [arr, emitNum(b, j)]))
                }
            } else {
                for (var k = 0; k < values.length; k++) {
                    var rv = values[k](b)
                    b = rv.b
                    vals.push(rv.v)
                }
            }
            for (var m = 0; m < targets.length; m++) { b = emitRefWrite(b, targets[m], vals[m]) }
            return b
        }
    }
    // name: Type [= value]: the annotation is ignored; assign when a value is given.
    function makeAnnAssign(items) {
        var ref = items[0]
        if (items.length < 2) { return function(b) { return b } }
        var valT = items[1]
        return function(b) {
            var r = valT(b)
            b = r.b
            return emitRefWrite(b, ref, r.v)
        }
    }
    // assert COND [, MSG]: a false condition calls exit(1) at runtime.
    function makeAssert(items) {
        var condT = items[0]
        return function(b) {
            var r = condT(b)
            b = r.b
            var okB = curF.NewBlock("")
            var failB = curF.NewBlock("")
            b.NewCondBr(truthy(b, r.v), okB, failB)
            var exitV = callExt(failB, "js_scope_get", [curScopeV, emitStr(failB, "exit")])
            var av = callExt(failB, "js_arr_new", [])
            callExt(failB, "js_arr_push", [av, emitNum(failB, 1)])
            callExt(failB, "js_call", [exitV, hUndef, av])
            failB.NewBr(okB)
            return okB
        }
    }
    // try/except/else/finally: not implemented (no exception model). Under
    // -warn-unsupported the try body and any finally body emit in sequence; the
    // except/else handlers are dropped.
    function makeTry(items, pos) {
        notImpl("try/except", pos)
        var tryBody = null
        var finalBody = null
        for (var i = 0; i < items.length; i++) {
            if (items[i].trybody != undefined) { tryBody = items[i].trybody }
            if (items[i].finalbody != undefined) { finalBody = items[i].finalbody }
        }
        return function(b) {
            if (tryBody != null) { b = tryBody(b) }
            if (finalBody != null) { b = finalBody(b) }
            return b
        }
    }
    // raise: not implemented (no unwinding). The raised expression still emits.
    function makeRaise(items, pos) {
        notImpl("raise", pos)
        return function(b) {
            for (var i = 0; i < items.length; i++) { b = items[i](b).b }
            return b
        }
    }
    // with EXPR [as T]: a simple form (no context-manager protocol) - run each
    // context expression, bind the target to its value, then run the body.
    function makeWithItem(items) {
        var target = items.length > 1 ? items[1] : null
        return {ctxitem: items[0], target: target}
    }
    function makeWith(items, pos) {
        notImpl("with statement", pos)
        var body = null
        var mgrs = []
        for (var i = 0; i < items.length; i++) {
            if (items[i].withbody != undefined) { body = items[i].withbody }
            else if (items[i].ctxitem != undefined) { mgrs.push(items[i]) }
        }
        return function(b) {
            for (var j = 0; j < mgrs.length; j++) {
                var r = mgrs[j].ctxitem(b)
                b = r.b
                if (mgrs[j].target != null) { b = emitRefWrite(b, mgrs[j].target, r.v) }
            }
            if (body != null) { b = body(b) }
            return b
        }
    }
    // A parameter list: collect the plain positional names; flag *args/**kwargs,
    // annotations-with-defaults and the '*'/'/' markers as unsupported.
    function makeParamList(items) {
        var names = []
        var complex = false
        for (var i = 0; i < items.length; i++) {
            if (items[i].pcomplex == true) { complex = true }
            if (items[i].pname != undefined) { names.push(items[i].pname) }
        }
        return {params: names, complex: complex}
    }
    function makeNamedParam(items) {
        if (items.length > 1) { return {pname: items[0], pcomplex: true} }
        return {pname: items[0]}
    }

    // def: an own IR function; the body shares one function scope (no block scopes).
    // A signature using *args/**kwargs/defaults is reported as not implemented (the
    // plain names still bind).
    function makeDef(bodyT, plist, name, pos) {
        if (plist.complex) { notImpl("*args/keyword/default parameters", pos) }
        var params = plist.params
        return function(b) {
            funcCount++
            var idx = funcCount
            var f = m.NewFunc("jsf_" + idx, i64, [llvm.ir.NewParam("env", i64), llvm.ir.NewParam("args", i64)])
            var savedF = curF
            var savedScope = curScopeV
            var savedLoops = loopStack
            curF = f
            loopStack = []
            var fb = f.NewBlock("entry")
            curScopeV = callExt(fb, "js_scope_new", [f.Params[0]])
            for (var i = 0; i < params.length; i++) {
                callExt(fb, "js_scope_decl", [curScopeV, emitStr(fb, params[i]),
                                              callExt(fb, "js_arg", [f.Params[1], handle(i)])])
            }
            var endB = bodyT(fb)
            endB.NewRet(hUndef)
            curF = savedF
            curScopeV = savedScope
            loopStack = savedLoops
            callExt(b, "js_pyset_var", [curScopeV, emitStr(b, name),
                                        callExt(b, "js_closure", [handle(idx), curScopeV])])
            return b
        }
    }

    // jsmain: declare the builtins, then run the file top to bottom.
    function buildMain(items) {
        var f = m.NewFunc("jsmain", i64, [llvm.ir.NewParam("env", i64), llvm.ir.NewParam("args", i64)])
        curF = f
        var b = f.NewBlock("entry")
        curScopeV = callExt(b, "js_scope_new", [f.Params[0]])
        // print(...): hand the argument array to the Python renderer.
        funcCount++
        var prIdx = funcCount
        var pf = m.NewFunc("jsf_" + prIdx, i64, [llvm.ir.NewParam("env", i64), llvm.ir.NewParam("args", i64)])
        var pb = pf.NewBlock("entry")
        pb.NewCall(getExtern("js_pyprint", 1), [pf.Params[1]])
        pb.NewRet(hUndef)
        callExt(b, "js_scope_decl", [curScopeV, emitStr(b, "print"), callExt(b, "js_closure", [handle(prIdx), curScopeV])])
        // len(x): strings, lists and dicts via js_pylen.
        funcCount++
        var lenIdx = funcCount
        var lf = m.NewFunc("jsf_" + lenIdx, i64, [llvm.ir.NewParam("env", i64), llvm.ir.NewParam("args", i64)])
        var lb = lf.NewBlock("entry")
        var lArg = lb.NewCall(getExtern("js_arg", 2), [lf.Params[1], handle(0)])
        lb.NewRet(lb.NewCall(getExtern("js_pylen", 1), [lArg]))
        callExt(b, "js_scope_decl", [curScopeV, emitStr(b, "len"), callExt(b, "js_closure", [handle(lenIdx), curScopeV])])
        // list(x): a fresh list from any iterable, via js_pylist.
        funcCount++
        var listIdx = funcCount
        var tf = m.NewFunc("jsf_" + listIdx, i64, [llvm.ir.NewParam("env", i64), llvm.ir.NewParam("args", i64)])
        var tb = tf.NewBlock("entry")
        var tArg = tb.NewCall(getExtern("js_arg", 2), [tf.Params[1], handle(0)])
        tb.NewRet(tb.NewCall(getExtern("js_pylist", 1), [tArg]))
        callExt(b, "js_scope_decl", [curScopeV, emitStr(b, "list"), callExt(b, "js_closure", [handle(listIdx), curScopeV])])
        // range(a[, b])
        funcCount++
        var rgIdx = funcCount
        var rf = m.NewFunc("jsf_" + rgIdx, i64, [llvm.ir.NewParam("env", i64), llvm.ir.NewParam("args", i64)])
        var rb = rf.NewBlock("entry")
        var rA = rb.NewCall(getExtern("js_arg", 2), [rf.Params[1], handle(0)])
        var rB = rb.NewCall(getExtern("js_arg", 2), [rf.Params[1], handle(1)])
        rb.NewRet(rb.NewCall(getExtern("js_pyrange", 2), [rA, rB]))
        callExt(b, "js_scope_decl", [curScopeV, emitStr(b, "range"), callExt(b, "js_closure", [handle(rgIdx), curScopeV])])
        // abs from Math.
        var mathV = callExt(b, "js_scope_get", [curScopeV, emitStr(b, "Math")])
        callExt(b, "js_scope_decl", [curScopeV, emitStr(b, "abs"), callExt(b, "js_get", [mathV, emitStr(b, "abs")])])
        b = makeSeq(items)(b)
        b.NewRet(hUndef)
    }

    // ----- Core library config (see lib/compile-core.js) -----
    core.truthyExt = "js_pytruthy" // Python truthiness: empty containers are false.
    // Python stdlib modules the runtime provides (prefix match, so os.path
    // resolves against "os").
    core.stdlibImports = ["sys", "os", "math", "collections", "itertools", "functools", "re", "json", "typing", "random", "string", "time", "dataclasses", "abc"]

    c.compile(c.asg)

    println(m)

    var res = llvm.RunJS(m, "jsmain")
    println("python compiler: program ran to completion")
    exit(res.Ret)

~~) ;
