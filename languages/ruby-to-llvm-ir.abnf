    }
    // isCtl marks a begin body / rescue body closure: a return/break/next leaving it
    // emits a control signal instead of a ret/br (see compile-core inCtlBody /
    // excDispatch). Every function-body emitter (defs, blocks, methods) saves/restores
    // curFTag, so a return inside a def/block defined within a begin body stays a plain
    // ret rather than wrongly re-signalling.
    function emitFunc(params, bodyStmt, isMethod, isCtl) {
        funcCount++
        var idx = funcCount
        var savedTag = curFTag
        var f = m.NewFunc("jsf_" + idx, i64, [llvm.ir.NewParam("env", i64), llvm.ir.NewParam("args", i64)])
        var savedF = curF
        var savedScope = curScopeV
        var savedLoops = loopStack
        curF = f
        curFTag = idx
        loopStack = []
        if (isCtl) { ctlEnter(idx) }
        var b = f.NewBlock("entry")
        curScopeV = callExt(b, "js_scope_new", [f.Params[0]])
        var off = 0
        if (isMethod) {
            callExt(b, "js_scope_decl", [curScopeV, emitStr(b, "self"), callExt(b, "js_arg", [f.Params[1], handle(0)])])
            off = 1
        }
        for (var i = 0; i < params.length; i++) {
            callExt(b, "js_scope_decl", [curScopeV, emitStr(b, params[i]),
                                         callExt(b, "js_arg", [f.Params[1], handle(i + off)])])
        }
        var endB = bodyStmt(b)
        endB.b.NewRet(endB.v)
        if (isCtl) { ctlLeave() }
        curF = savedF
        curScopeV = savedScope
        loopStack = savedLoops
        curFTag = savedTag
        return idx
    }
    function makeFun(items) {
        var name = items[0]
        var params = []
        var body = null
        for (var i = 1; i < items.length; i++) {
            if (items[i].body != undefined) { body = items[i].body }
            else { params.push(items[i].param) }
        }
        return {name: name, params: params, body: body != null ? body : makeBody([])}
    }
    function makeMethodInfo(fn) { return fn }
    function makeDefStmt(fn) {
        return function(b) {
            var idx = emitFunc(fn.params, fn.body, false)
            callExt(b, "js_scope_decl", [curScopeV, emitStr(b, fn.name),
                                         callExt(b, "js_closure", [handle(idx), curScopeV])])
            return {b: b, v: hNull}
        }
    }
    // attr_reader / attr_writer / attr_accessor become @ivar getter/setter methods
    // synthesized as ordinary method descriptors (body: function(b) -> {b, v}).
    function makeAttr(items) {
        var kind = ""
        var names = []
        for (var i = 0; i < items.length; i++) {
            if (items[i].akind != undefined) { kind = items[i].akind }
            else if (items[i].aname != undefined) { names.push(items[i].aname) }
        }
        return {attr: {kind: kind, names: names}}
    }
    function attrGetterMethod(n) {
        return {name: n, params: [], body: function(b) {
            var selfV = callExt(b, "js_scope_get", [curScopeV, emitStr(b, "self")])
            return {b: b, v: callExt(b, "js_get", [selfV, emitStr(b, n)])}
        }}
    }
    function attrSetterMethod(n) {
        return {name: n + "=", params: ["v"], body: function(b) {
            var selfV = callExt(b, "js_scope_get", [curScopeV, emitStr(b, "self")])
            var vv = callExt(b, "js_scope_get", [curScopeV, emitStr(b, "v")])
            callExt(b, "js_set", [selfV, emitStr(b, n), vv])
            return {b: b, v: vv}
        }}
    }

    function makeClassStmt(items) {
        var name = items[0]
        var methods = []
        var hasInit = false
        for (var i = 1; i < items.length; i++) {
            if (items[i].method != undefined) {
                methods.push(items[i].method)
                if (items[i].method.name == "initialize") { hasInit = true }
            } else if (items[i].attr != undefined) {
                var a = items[i].attr
                for (var j = 0; j < a.names.length; j++) {
                    if (a.kind == "attr_reader" || a.kind == "attr_accessor") { methods.push(attrGetterMethod(a.names[j])) }
                    if (a.kind == "attr_writer" || a.kind == "attr_accessor") { methods.push(attrSetterMethod(a.names[j])) }
                }
