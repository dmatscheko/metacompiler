        return function(b) {
            var clsV = callExt(b, "js_obj_new", [])
            callExt(b, "js_set", [clsV, emitStr(b, "__isclass"), hTrue])
            callExt(b, "js_set", [clsV, emitStr(b, "__name"), emitStr(b, name)])
            callExt(b, "js_scope_decl", [curScopeV, emitStr(b, name), clsV])
            for (var k = 0; k < methods.length; k++) {
                var idx = emitFunc(methods[k].params, methods[k].body, true)
                callExt(b, "js_set", [clsV, emitStr(b, methods[k].name),
                                      callExt(b, "js_closure", [handle(idx), curScopeV])])
            }
            if (!hasInit) {
                var emptyBody = function(bb) { return {b: bb, v: hNull} }
                var iidx = emitFunc([], emptyBody, true)
                callExt(b, "js_set", [clsV, emitStr(b, "initialize"),
                                      callExt(b, "js_closure", [handle(iidx), curScopeV])])
            }
            return {b: b, v: hNull}
        }
    }

    // module M ... end: not implemented (no namespacing). Emit the body items in
    // sequence in the current scope so any defs / classes / calls stay visible.
    function makeModule(items, pos) {
        notImpl("module", pos)
        return function(b) {
            for (var i = 0; i < items.length; i++) {
                var r = items[i](b)
                b = r.b
            }
            return {b: b, v: hNull}
        }
    }

    // ----- Project-file imports (require / require_relative) -----
    // A handful of stdlib names whose require is a no-op (the runtime provides them or
    // they are simply not modelled); every other require is looked up as a project file.
    core.stdlibImports = ["set", "json", "date", "time"]
    // require_relative 'geomlib' looks for geomlib.rb under the program's directory and the
    // -i roots (c.findImport), stripping a leading './' and adding a missing '.rb'. The file
    // is parsed with this grammar and compiled with importDepth > 0; its buildMain stashes
    // the top-level def/class/statement thunks into importedItems instead of emitting a
    // second jsmain. They are prepended to the real jsmain (below), so the imported
    // definitions exist before the requiring file's code runs. A file is imported once;
    // repeats and cycles are no-ops.
    var importedFiles = {}
    var importDepth = 0
    // imported files top-level items: stashImported / emitImportedWith (compile-core)
    core.importFile = function(path, pos) {
        var rel = path
        if (rel.length >= 2 && rel.charAt(0) == "." && rel.charAt(1) == "/") { rel = rel.slice(2) }
        var cand = rel
        if (!(rel.length >= 3 && rel.slice(rel.length - 3) == ".rb")) { cand = rel + ".rb" }
        var file = c.findImport(cand)
        if (file == "") { return false }
        if (importedFiles["$" + file] == true) { return true }
        importedFiles["$" + file] = true
        var text = c.readFile(file)
        var asg = c.parse(c.agrammar, text, null, file)
        c.pushSource(file, text)
        importDepth = importDepth + 1
        c.compile(asg)
        importDepth = importDepth - 1
        c.popSource()
        return true
    }

    // ----- program entry -----
    function buildMain(items) {
        // The walk of an imported file ends here too (importDepth > 0): stash its top-level
        // thunks for the real jsmain instead of emitting a second one.
        if (importDepth > 0) {
            stashImported(items) // stashed with its file; emitted later (compile-core)
            return
        }
        var f = m.NewFunc("jsmain", i64, [llvm.ir.NewParam("env", i64), llvm.ir.NewParam("args", i64)])
        curF = f
        var b = f.NewBlock("entry")
        curScopeV = callExt(b, "js_scope_new", [f.Params[0]])
        var mathV = callExt(b, "js_scope_get", [curScopeV, emitStr(b, "Math")])
        callExt(b, "js_scope_decl", [curScopeV, emitStr(b, "abs"), callExt(b, "js_get", [mathV, emitStr(b, "abs")])])
        // Imported definitions first, each under its own source, then this file's own items.
        b = emitImportedWith(b, function(item, bb) { return item(bb).b })
        for (var i = 0; i < items.length; i++) { b = items[i](b).b }
        b.NewRet(handle(0))
    }

    // makeVarRef uses core.scopeGetExt (js_scope_get) - fine for Ruby locals,
    // functions and class constants (all live in the scope chain).
    core.scopeGetExt = "js_scope_get"

    c.compile(c.asg)

    println(m)

    var res = llvm.RunJS(m, "jsmain")
    println("ruby compiler: jsmain() returned " + res.Ret)
    exit(res.Ret)

~~) ;
