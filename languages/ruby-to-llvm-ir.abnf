:title("Ruby (subset) to LLVM IR compiler") ;
:description("Compiles a Ruby subset to an LLVM IR module and runs it with the built-in
IR interpreter and the MetaJS handle runtime (llvm.RunJS).

The subset matches ruby-interpreter.abnf: local variables (create on first assignment,
plus += -= *= /= %=), integers, double/single quoted strings with '#{expr}'
interpolation, true/false/nil, symbols :sym (as strings), arithmetic and comparison,
&& || ! and the words and/or/not, def with implicit return of the last expression and
explicit return, class C ... end with instance methods, @ivars and C.new, if/elsif/else
and unless (also as expressions), while/until with break/next, ranges 1..5 / 1...5
(eager arrays) with .each, arrays with [] get/set, .push/.pop/.size/.length/.each/.map/
.select/.include?, hashes {k => v} with [] get/set, .size/.keys/.values, blocks
(do |x| ... end and { |x| ... }, real closures via js_closure) and puts/print.

Locals, functions, @ivars, methods and blocks lower to the MetaJS handle runtime:
scopes via js_scope_new / js_pyset_var (Ruby create-on-assign) / js_scope_get, closures
via js_closure + js_call, objects/@ivars via js_obj_new / js_get / js_set, method
dispatch via js_rmcall (the Ruby builtin methods on strings/arrays/hashes with Ruby
truthiness and nil-on-empty; instances carry a __class descriptor, C.new runs initialize),
arrays via js_arr_new / js_arr_push, indexing via js_pyget / js_pyset, hashes via
js_dict_new. Ruby truthiness (only nil and false are falsy) is a single handle compare
(a value handle >= the 'true' singleton). The whole program becomes jsmain(env, args);
a self checking program ends with exit(failures). The same subset is interpreted
directly by ruby-interpreter.abnf, and the two must agree.") ;
// --- main rules

// Shared token productions (languages/lib): identifiers, integers, booleans.
:include("lib/ident.abnf") ;
:include("lib/numbers.abnf") ;
:include("lib/bools.abnf") ;

:startRule(Program) ;
:whitespace(Whitespace) ;

// Ruby '#' line comments (the '#{' of an interpolation lives inside a string
// token, which disables whitespace skipping, so it never reaches here).
Whitespace  = { @+" \t\r\n" | Comment } ;
Comment     = "#" :whitespace() { NotNewline } :whitespace(Whitespace) ;
NotNewline  = "\x00"..."\x09" | "\x0b"..."\U0010ffff" ;

// The whole program is a sequence of definitions and statements executed in order.
Program     <~~ buildMain(takeAll()) ~~>
            = { Def <~~ push(makeDefStmt(pop())) ~~> | ClassDecl | ModuleDecl | Statement } ;

// module M ... end: accepted but not implemented (no namespacing). Its body is a
// program of the same items; under -warn-unsupported they run in the current scope
// so any defs/classes/calls stay visible. A nested module recurses.
ModuleDecl  <~~ push(makeModule(takeAll(), up.pos)) ~~>
            = KwModule ScopedName { Def <~~ push(makeDefStmt(pop())) ~~> | ClassDecl | ModuleDecl | Statement } End ;
// A constant path Foo::Bar::Baz (module / class name or a scoped reference).
ScopedName  = Name { "::" Name } ;

// A def: implicit return of the last expression, or an explicit return. A singleton
// receiver (def self.m / def obj.m) is accepted but not implemented (routed as a
// plain method of that name). The parameter list accepts default / splat / double-
// splat / block / keyword parameters; the fancy forms are notImplemented (the method
// is still built with the parameter names, so its body stays compilable).
Def         <~~ push(makeFun(takeAll())) ~~>
            = KwDef [ SelfRecv ] MethodName <~~ push(up.in) ~~> [ ParamList ] Body End ;
SelfRecv    <~~ notImpl("singleton method (def self.m / def obj.m)", up.pos) ~~>
            = ( KwSelf | Name ) "." ;
ParamList   = "(" [ Param { "," Param } ] ")" ;
Param       = ParamDSplat | ParamSplat | ParamBlock | ParamKw | ParamDefault | ParamSimple ;
ParamDSplat <~~ var n = takeAll(); notImpl("double-splat parameter (**kw)", up.pos); push({param: n.length > 0 ? n[0] : "$kwrest"}) ~~>
            = "**" [ Name <~~ push(up.in) ~~> ] ;
ParamSplat  <~~ var n = takeAll(); notImpl("splat parameter (*args)", up.pos); push({param: n.length > 0 ? n[0] : "$rest"}) ~~>
            = "*" [ Name <~~ push(up.in) ~~> ] ;
ParamBlock  <~~ notImpl("block parameter (&blk)", up.pos); push({param: pop()}) ~~>
            = "&" Name <~~ push(up.in) ~~> ;
ParamKw     <~~ var n = takeAll(); notImpl("keyword parameter (name:)", up.pos); push({param: n[0]}) ~~>
            = Name <~~ push(up.in) ~~> ":" [ Expression ] ;
ParamDefault <~~ var n = takeAll(); notImpl("default parameter value", up.pos); push({param: n[0]}) ~~>
            = Name <~~ push(up.in) ~~> "=" !"=" Expression ;
ParamSimple = Name <~~ push({param: up.in}) ~~> ;
// Method / call names may end with ? or ! (empty?, include?); Name may not.
MethodName  = Id [ "?" | "!" ] ;

// class C ... end with instance methods; C.new builds an instance. attr_reader /
// attr_writer / attr_accessor declare @ivar getters/setters on the class.
// A superclass (class D < Base) is accepted but not implemented (no inheritance);
// the class body still compiles as its own methods.
ClassDecl   <~~ push(makeClassStmt(takeAll())) ~~>
            = KwClass Name <~~ push(up.in) ~~> [ Superclass ] { Def <~~ push({method: pop()}) ~~> | AttrDecl } End ;
Superclass  <~~ notImpl("class superclass (< Base)", up.pos) ~~>
            = "<" ScopedName ;
AttrDecl    <~~ push(makeAttr(takeAll())) ~~>
            = AttrKind <~~ push({akind: up.in}) ~~> AttrSym { "," AttrSym } ;
AttrKind    = ( "attr_accessor" | "attr_reader" | "attr_writer" ) KwEnd ;
AttrSym     = ":" SymName <~~ push({aname: up.in}) ~~> :whitespace(Whitespace) ;

End         = "end" KwEnd ;

// Body collects its statements into a single marker so the enclosing production
// (if/while/def/block) sees exactly one item on the stack for its body.
Body        <~~ push({body: makeBody(takeAll())}) ~~>
            = { Statement } ;

// Every statement pushes exactly one thunk: function() -> value | signal.
// A statement may be a post-condition loop (begin..end while/until COND, runs its
// body at least once) or carry a trailing modifier (STMT if/unless/while/until
// COND). A modifier only binds when its keyword sits on the SAME source line as
// the statement (SameLine), so a block 'if'/'while' that opens the next line stays
// a separate statement.
Statement   = Require | DoWhileStmt | ModStmt ;
DoWhileStmt <~~ push(makeDoWhile(takeAll())) ~~>
            = KwBegin Body End SameLine DoWhileKw Expression ;
DoWhileKw   = KwWhile <~~ push({dw: "while"}) ~~> | KwUntil <~~ push({dw: "until"}) ~~> ;
ModStmt     <~~ push(applyMod(takeAll())) ~~>
            = SimpleStmt [ SameLine ModKw Expression ] ;
SimpleStmt  = PutsStmt | MultiAssign | ExprStmt ;
ModKw       = KwIf <~~ push({mod: "if"}) ~~> | KwUnless <~~ push({mod: "unless"}) ~~>
            | KwWhile <~~ push({mod: "while"}) ~~> | KwUntil <~~ push({mod: "until"}) ~~> ;

// require / require_relative <string>: Ruby has no import statement - require and
// require_relative are ordinary method calls, intercepted here. The single argument is
// a single- or double-quoted string literal (no interpolation); a leading './' and a
// missing '.rb' are handled by core.importFile. Tried as the FIRST statement form so a
// bareword 'require'/'require_relative' (both ordinary identifiers, not keywords) is not
// swallowed by a plain VarRef; a 'require' not followed by a string rolls back to the
// normal statement forms. resolveImport runs at PARSE time (like every other language's
// import): the required file is compiled with importDepth > 0, so its top-level thunks are
// stashed (buildMain) and prepended to jsmain, existing before the requiring file's code.
// A require that resolves to no project file is a stdlib require: a no-op when the name is
// in core.stdlibImports, otherwise it aborts (or warns under -warn-imports). Require pushes
// no thunk (the work is done at parse time), so buildMain never sees it.
Require     <~~ resolveImport(pop(), up.pos) ~~>
            = KwRequire ReqPath ;
KwRequire   = ( "require_relative" | "require" ) KwEnd ;
ReqPath     = SqPath | DqPath ;
SqPath      = "'" :whitespace() { SqEsc | SqPlain } <~~ push(unescapeSq(up.in)) ~~> "'" :whitespace(Whitespace) ;
DqPath      = '"' :whitespace() { DqEsc | DqPathChar } <~~ push(unescapeJs(up.in)) ~~> '"' :whitespace(Whitespace) ;
DqEsc       = "\\" "\x20"..b"\x7e" ;
DqPathChar  = "\x20"..."\x21" | "\x23"..."\x5b" | "\x5d"..."\U0010ffff" | @"\t" ;

// a, b = 1, 2 (and the swap a, b = b, a): every right-hand value is evaluated
// before any target is written; a single right-hand array is unpacked positionally.
// Kept at statement level (needs a comma after the first target) so it never
// interferes with a nested expression.
MultiAssign <~~ push(makeMultiAssign(takeAll())) ~~>
            = Target "," Target { "," Target } "=" Expression { "," Expression } [ ";" ] ;

// puts / print command form: puts x, puts a, b, puts (no args), puts(x).
PutsStmt    <~~ push(makePuts(takeAll())) ~~>
            = KwPuts <~~ push({cmd: up.in}) ~~> [ Expression { "," Expression } ] ;

ExprStmt    = Expression [ ";" ] ;

// Every expression pushes exactly one thunk: function() -> value. A ternary
// cond ? a : b binds looser than the boolean operators (like Ruby).
Expression  = Assignment | Ternary ;
Ternary     <~~ push(makeTernary(takeAll())) ~~>
            = OrExpr [ "?" Expression ":" Expression ] ;

Assignment  <~~ push(makeAssign(takeAll(), up.pos)) ~~>
            = Target AssignOp <~~ push(up.in) ~~> Expression ;
// ||= and &&= (conditional assignment) are accepted but not implemented (no short
// circuit); makeAssign warns and falls back to a plain assignment.
AssignOp    = "||=" | "&&=" | "+=" | "-=" | "*=" | "/=" | "%=" | ( "=" !"=" ) ;
Target      <~~ push(makeTargetRef(takeAll())) ~~>
            = TargetHead { "." Id <~~ push({key: up.in}) ~~> | TIndex } ;
TargetHead  = "@" Id <~~ push({ivar: up.in}) ~~> | Name <~~ push({var: up.in}) ~~> ;
TIndex      <~~ push({idx: pop()}) ~~>
            = "[" Expression "]" ;

OrExpr      <~~ push(makeOrAnd(takeAll(), true)) ~~>
            = AndExpr { OrOp AndExpr } ;
OrOp        = "||" | ( "or" KwEnd ) ;
AndExpr     <~~ push(makeOrAnd(takeAll(), false)) ~~>
            = NotExpr { AndOp NotExpr } ;
AndOp       = "&&" | ( "and" KwEnd ) ;
NotExpr     = NotOp | EqExpr ;
NotOp       <~~ push(makeNot(pop())) ~~>
            = ( "!" | ( "not" KwEnd ) ) NotExpr ;

EqExpr      <~~ push(foldBinary(takeAll())) ~~>
            = RelExpr { ( "==" | "!=" ) <~~ push(up.in) ~~> RelExpr } ;
RelExpr     <~~ push(foldBinary(takeAll())) ~~>
            = RangeExpr { ( "<=" | ">=" | "<" | ">" ) <~~ push(up.in) ~~> RangeExpr } ;
// A range 1..5 (inclusive) or 1...5 (exclusive); built as an eager array.
RangeExpr   <~~ push(makeRange(takeAll())) ~~>
            = ShiftExpr [ ( "..." | ".." ) <~~ push(up.in) ~~> ShiftExpr ] ;
// The << append operator: arr << x pushes onto the array and yields the array
// (so a << b << c chains). Binds tighter than range/comparison, looser than +.
ShiftExpr   <~~ push(makeShift(takeAll())) ~~>
            = AddExpr { "<<" AddExpr } ;
AddExpr     <~~ push(foldBinary(takeAll())) ~~>
            = MulExpr { ( "+" | "-" ) <~~ push(up.in) ~~> MulExpr } ;
MulExpr     <~~ push(foldBinary(takeAll())) ~~>
            = UnaryExpr { ( "*" | "/" | "%" ) <~~ push(up.in) ~~> UnaryExpr } ;

UnaryExpr   = Neg | PostfixExpr ;
Neg         <~~ push(makeNeg(pop())) ~~>
            = "-" UnaryExpr ;

// obj.method(args), obj.method do |x| ... end, obj.field, arr[i]. A trailing
// block (do..end or {..}) becomes the last argument of the method call.
PostfixExpr <~~ push(foldCallMember(takeAll())) ~~>
            = Primary { MethodSfx | FieldSfx | SafeMethodSfx | SafeFieldSfx | IndexSfx } ;
MethodSfx   <~~ push({kind: "mcall", name: popName(), args: takeAll()}) ~~>
            = "." MethodName <~~ push({mname: up.in}) ~~> MArgs ;
FieldSfx    = "." MethodName <~~ push({kind: "field", name: up.in}) ~~> ;
// Safe navigation obj&.m / obj&.m(args): yields nil (and skips the call, not even
// evaluating the arguments) when the receiver is nil, else a normal method/field.
SafeMethodSfx <~~ push({kind: "smcall", name: popName(), args: takeAll()}) ~~>
            = "&." MethodName <~~ push({mname: up.in}) ~~> MArgs ;
SafeFieldSfx = "&." MethodName <~~ push({kind: "sfield", name: up.in}) ~~> ;
IndexSfx    <~~ push({kind: "index", idx: pop()}) ~~>
            = "[" Expression "]" ;
MArgs       = "(" [ Arg { "," Arg } ] ")" [ Block ] | Block ;

// A call argument: an ordinary expression, or one of the forms accepted for
// recognition but not implemented - keyword argument (name: v), splat / double-splat
// (*a, **h) and block pass (&blk, &:sym). The unsupported forms warn and become a
// placeholder argument, so the call still compiles.
Arg         = KwArg | SplatArg | BlockArg | Expression ;
KwArg       <~~ takeAll(); push(notImplExpr("keyword argument (name:)", up.pos)) ~~>
            = SymName ":" Expression ;
SplatArg    <~~ takeAll(); push(notImplExpr("splat argument (* / **)", up.pos)) ~~>
            = ( "**" | "*" ) Expression ;
BlockArg    <~~ takeAll(); push(notImplExpr("block argument (&)", up.pos)) ~~>
            = "&" Expression ;

// A block passed to a method call: a real closure over the current scope.
Block       <~~ push(makeBlock(takeAll())) ~~>
            = KwDo [ BlockParams ] Body End
            | "{" [ BlockParams ] Body "}" ;
BlockParams <~~ push({bparams: takeAll()}) ~~>
            = "|" [ Param { "," Param } ] "|" ;

Primary     = "(" Expression ")"
            | IfExpr | UnlessExpr | WhileExpr | UntilExpr | ForExpr | CaseExpr | BeginExpr
            | ReturnExpr | BreakExpr | NextExpr | RaiseExpr | YieldExpr
            | DqStr | SqStr | PercentLit | FloatLit | IntLit | SymLit
            | ArrayLit | HashLit
            | True | False | Nil | Self
            | IvarRef | ScopedConst | Call | VarRef ;

// for VAR in COLL ... end: accepted but not implemented (needs loop-variable
// binding we do not model); parses the collection and body, warns, and is inert.
ForExpr     <~~ takeAll(); push(notImplExpr("for-in loop", up.pos)) ~~>
            = KwFor ForVars KwIn Expression [ KwDo ] Body End ;
ForVars     = Name { "," Name } ;

// yield / yield(args) / yield args: accepted but not implemented (no block passing);
// warns and yields a placeholder value.
YieldExpr   <~~ takeAll(); push(notImplExpr("yield", up.pos)) ~~>
            = KwYield [ "(" [ Arg { "," Arg } ] ")" | SameLine Arg { "," Arg } ] ;

// A floating point literal 3.14 / 1.0e9: accepted but not implemented (the runtime
// is 32-bit integer only); warns and yields a placeholder value.
FloatLit    <~~ push(notImplExpr("float literal", up.pos)) ~~>
            = ( "0" | "1"..."9" ) :whitespace() { "0"..."9" } "." "0"..."9" { "0"..."9" } [ FloatExp ] :whitespace(Whitespace) ;
FloatExp    = ( "e" | "E" ) [ "+" | "-" ] "0"..."9" { "0"..."9" } ;

// A scoped constant Foo::Bar: accepted but not implemented (no namespaces); warns
// and yields a placeholder value.
ScopedConst <~~ push(notImplExpr("scoped constant (::)", up.pos)) ~~>
            = Name "::" Name { "::" Name } ;

// A percent literal %w[..] %i[..] %q(..) %Q(..) %r[..] ...: accepted but not
// implemented; the body is read (bracket or parenthesis delimited) and warns.
PercentLit  <~~ push(notImplExpr("percent literal (%w / %i / %q / ...)", up.pos)) ~~>
            = PctTag :whitespace() PctBody :whitespace(Whitespace) ;
PctTag      = "%w" | "%i" | "%W" | "%I" | "%q" | "%Q" | "%r" | "%s" ;
PctBody     = "[" { PctBrk } "]" | "(" { PctPar } ")" ;
PctBrk      = "\x00"..."\x5c" | "\x5e"..."\U0010ffff" ;
PctPar      = "\x00"..."\x28" | "\x2a"..."\U0010ffff" ;

// if / unless usable as a statement and as an expression (yields the branch value).
IfExpr      <~~ push(makeIf(takeAll())) ~~>
            = KwIf Expression [ KwThen ] Body { Elsif } [ KwElse Body <~~ push({els: pop().body}) ~~> ] End ;
Elsif       <~~ var b = pop(); push({elifCond: pop(), elifBody: b.body}) ~~>
            = KwElsif Expression [ KwThen ] Body ;
UnlessExpr  <~~ push(makeUnless(takeAll())) ~~>
            = KwUnless Expression [ KwThen ] Body [ KwElse Body <~~ push({els: pop().body}) ~~> ] End ;

WhileExpr   <~~ push(makeWhile(pop().body, pop())) ~~>
            = KwWhile Expression [ KwDo ] Body End ;
UntilExpr   <~~ push(makeUntil(pop().body, pop())) ~~>
            = KwUntil Expression [ KwDo ] Body End ;

// case SUBJ / when V1, V2 / else - lowered to a chain of == tests (a switch). A
// subject-less case (case / when COND) tests each when expression for truthiness.
CaseExpr    <~~ push(makeCase(takeAll())) ~~>
            = KwCase [ Expression ] { WhenClause } [ KwElse Body <~~ push({els: pop().body}) ~~> ] End ;
WhenClause  <~~ push(makeWhen(takeAll())) ~~>
            = KwWhen WhenVal { "," WhenVal } [ KwThen ] Body ;
// A when value: a range LO..HI / LO...HI matches by membership (Range#===); any
// other expression matches by == (subject form) or truthiness (subjectless form).
WhenVal     = RangeVal | ScalarVal ;
RangeVal    <~~ push(makeRangeVal(takeAll())) ~~>
            = ShiftExpr ( "..." | ".." ) <~~ push(up.in) ~~> ShiftExpr ;
ScalarVal   <~~ push({t: pop(), isRange: false}) ~~>
            = Expression ;

// begin / rescue / else / ensure: the body (with any else appended) and the first
// rescue compile to ctl closures handed to js_try; a raise -> js_throw is recovered and
// the rescue binds the value via its `=> Id` parameter. else runs only when the body
// completed without a raise; ensure always runs. A return/break/next leaving the try or
// rescue becomes a control signal that excDispatch re-issues here.
BeginExpr   <~~ push(makeTry(takeAll(), up.pos)) ~~>
            = KwBegin Body <~~ push({trybody: pop().body}) ~~> { RescueClause }
              [ KwElse Body <~~ push({elsebody: pop().body}) ~~> ]
              [ KwEnsure Body <~~ push({finalbody: pop().body}) ~~> ] End ;
// rescue [Type[, Type]] [=> Id]: the type list is parsed and discarded (types are not
// discriminated); the `=> Id` name is pushed so makeExcept can bind it to the value.
RescueClause <~~ push(makeExcept(takeAll())) ~~>
            = KwRescue [ ErrList ] [ "=>" Name <~~ push(up.in) ~~> ] [ KwThen ] Body <~~ push(pop().body) ~~> ;
ErrList     = Name { "," Name } ;

// The optional argument of return/break/next must not start at a statement-modifier
// keyword: in `break if C` the `if` belongs to the enclosing ModStmt - without the
// NoModKw guard it parses as a block-if argument expression and swallows the loop's
// `end`.
ReturnExpr  <~~ push(makeReturn(takeAll())) ~~>
            = KwReturn [ NoModKw Expression ] ;
BreakExpr   <~~ push(makeBreak(takeAll())) ~~>
            = KwBreak [ NoModKw Expression ] ;
NextExpr    <~~ push(makeNext(takeAll())) ~~>
            = KwNext [ NoModKw Expression ] ;

// raise [EXPR[, EXPR]]: raise the first expression's value with js_throw (a bare raise
// re-raise is approximated by throwing nil); a trailing message argument is ignored.
RaiseExpr   <~~ push(makeRaise(takeAll(), up.pos)) ~~>
            = KwRaise [ Expression { "," Expression } ] ;

// f(args): a top level method or a class (for C.new the .new is a method suffix).
Call        <~~ push(makeCall(takeAll())) ~~>
            = Name <~~ push(up.in) ~~> "(" [ Arg { "," Arg } ] ")" ;

VarRef      <~~ push(makeVarRef(up.in)) ~~>
            = Name ;
IvarRef     = "@" Id <~~ push(makeIvarRef(up.in)) ~~> ;
Self        <~~ push(makeSelf()) ~~>    = KwSelf ;
Nil         <~~ push(makeConst(null)) ~~> = "nil" KwEnd ;

ArrayLit    <~~ push(makeArray(takeAll())) ~~>
            = "[" [ Expression { "," Expression } ] "]" ;
HashLit     <~~ push(makeHash(takeAll())) ~~>
            = "{" [ HashEntry { "," HashEntry } ] "}" ;
// { k => v } (arrow) and { name: v } (symbol key, genuinely lowered - name: is the
// symbol :name, which the runtime already represents as the string "name").
HashEntry   = HashColon | HashArrow ;
HashArrow   <~~ var v = pop(); push({hk: pop(), hv: v}) ~~>
            = Expression "=>" Expression ;
HashColon   <~~ var v = pop(); push({hk: pop(), hv: v}) ~~>
            = SymKey ":" Expression ;
SymKey      <~~ push(makeConst(up.in)) ~~>
            = SymName ;

SymLit      = ":" SymName <~~ push(makeConst(up.in)) ~~> :whitespace(Whitespace) ;
SymName     = ( "a"..."z" | "A"..."Z" | "_" ) :whitespace() { "a"..."z" | "A"..."Z" | "0"..."9" | "_" } ;

// Double quoted strings interpolate '#{expr}'; single quoted are literal.
DqStr       <~~ push(makeTemplate(takeAll())) ~~>
            = '"' :whitespace() { TplExpr | TplChunk } '"' :whitespace(Whitespace) ;
TplExpr     <~~ push({e: pop()}) ~~>
            = "#{" :whitespace(Whitespace) Expression "}" ;
TplChunk    <~~ push({s: unescapeJs(up.in)}) ~~>
            = TplChar { TplChar } ;
TplChar     = TplEsc | HashChar | TplPlain ;
TplEsc      = "\\" "\x20"..b"\x7e" ;
HashChar    = "#" !"{" ;
TplPlain    = "\x20"..."\x21" | "\x24"..."\x5b" | "\x5d"..."\x7e" | @"\t" | "\x7f"..."\U0010ffff" ;

SqStr       = "'" :whitespace() { SqEsc | SqPlain } <~~ push(makeConst(unescapeSq(up.in))) ~~> "'" :whitespace(Whitespace) ;
SqEsc       = "\\" ( "'" | "\\" ) ;
SqPlain     = "\x20"..."\x26" | "\x28"..."\x5b" | "\x5d"..."\U0010ffff" | @"\t" ;

// A Name that is not a reserved word (keywords, literals, puts/print). The
// negative lookahead runs at PARSE time, so it must be self contained.
Name        = NotKw Id ;
NotKw       = :script(~~
    (function() {
        // Whitespace is skipped before tokens, not before this script, so the
        // lookahead skips leading whitespace and '#' comments itself.
        var i = 0
        var cc = c.peek(i)
        while (true) {
            if (cc === 32 || cc === 9 || cc === 13 || cc === 10) { i = i + 1; cc = c.peek(i); continue }
            if (cc === 35) { while (cc !== 10 && cc !== -1) { i = i + 1; cc = c.peek(i) } continue }
            break
        }
        if (!((cc >= 65 && cc <= 90) || (cc >= 97 && cc <= 122) || cc === 95)) { return undefined }
        var s = ""
        while ((cc >= 48 && cc <= 57) || (cc >= 65 && cc <= 90) || (cc >= 97 && cc <= 122) || cc === 95) {
            s = s + String.fromCharCode(cc)
            i = i + 1
            cc = c.peek(i)
        }
        var kws = ["def", "end", "if", "elsif", "else", "unless", "while", "until",
                   "do", "then", "return", "break", "next", "class", "module", "for",
                   "self", "nil", "true", "false", "and", "or", "not", "case", "when",
                   "in", "yield", "begin", "rescue", "ensure", "raise", "puts", "print"]
        for (var k = 0; k < kws.length; k++) {
            if (kws[k] === s) { return abnf.newToken("\x01reserved", 0) }
        }
        return undefined
    })()
~~) ;

// NoModKw succeeds (matching empty) only when the next word is NOT a statement-
// modifier keyword, so the optional argument of return/break/next leaves a trailing
// `if`/`unless`/`while`/`until` to the enclosing ModStmt. Self contained like NotKw.
NoModKw     = :script(~~
    (function() {
        var i = 0
        var cc = c.peek(i)
        while (true) {
            if (cc === 32 || cc === 9 || cc === 13 || cc === 10) { i = i + 1; cc = c.peek(i); continue }
            if (cc === 35) { while (cc !== 10 && cc !== -1) { i = i + 1; cc = c.peek(i) } continue }
            break
        }
        var s = ""
        while ((cc >= 48 && cc <= 57) || (cc >= 65 && cc <= 90) || (cc >= 97 && cc <= 122) || cc === 95) {
            s = s + String.fromCharCode(cc)
            i = i + 1
            cc = c.peek(i)
        }
        if (s === "if" || s === "unless" || s === "while" || s === "until") {
            return abnf.newToken("\x01modkw", 0)
        }
        return undefined
    })()
~~) ;

// SameLine succeeds (matching empty) only when the current position and the token
// just before it are on the SAME source line: no line break (nor a '#' comment
// that would run to end of line) in the whitespace immediately before or after the
// position. It gates the statement modifiers and the post-condition loop keyword,
// so a block 'if'/'while'/'until' opening the next line is never read as a modifier.
// Runs at parse time; peeks the raw source both backward and forward, self contained.
SameLine    = :script(~~
    (function() {
        var i = -1
        var cc = c.peek(i)
        while (cc === 32 || cc === 9 || cc === 13) { i = i - 1; cc = c.peek(i) }
        if (cc === 10) { return abnf.newToken("\x01nl", 0) }
        var j = 0
        var dd = c.peek(j)
        while (dd === 32 || dd === 9 || dd === 13) { j = j + 1; dd = c.peek(j) }
        if (dd === 10 || dd === 35 || dd === -1) { return abnf.newToken("\x01nl", 0) }
        return undefined
    })()
~~) ;

KwDef       = "def" KwEnd ;
KwClass     = "class" KwEnd ;
KwModule    = "module" KwEnd ;
KwFor       = "for" KwEnd ;
KwIn        = "in" KwEnd ;
KwYield     = "yield" KwEnd ;
KwIf        = "if" KwEnd ;
KwElsif     = "elsif" KwEnd ;
KwElse      = "else" KwEnd ;
KwUnless    = "unless" KwEnd ;
KwThen      = "then" KwEnd ;
KwWhile     = "while" KwEnd ;
KwUntil     = "until" KwEnd ;
KwDo        = "do" KwEnd ;
KwCase      = "case" KwEnd ;
KwWhen      = "when" KwEnd ;
KwBegin     = "begin" KwEnd ;
KwRescue    = "rescue" KwEnd ;
KwEnsure    = "ensure" KwEnd ;
KwRaise     = "raise" KwEnd ;
KwReturn    = "return" KwEnd ;
KwBreak     = "break" KwEnd ;
KwNext      = "next" KwEnd ;
KwSelf      = "self" KwEnd ;
KwPuts      = ( "puts" | "print" ) KwEnd ;

// ---



:startScript(~~

    // Shared emitter machinery (module, handle constants, externs, string/number
    // emission, foldBinary/makeConst/makeNeg/makeNot/emitArgs). Ruby specific
    // lowering is defined below; every thunk here is expression-shaped:
    // function(block) -> {b, v} (b = the block to continue in, v = the value).
    include("lib/compile-core.js")

    var hidCount = 0

    function fail(msg) { println("ruby compiler error: " + msg); exit(1) }

    // ----- Ruby truthiness: only nil and false are falsy. The value handles are
    // table indices: 0/1/2 = undefined/null/false (all falsy), 3 = true, and every
    // other value (numbers, strings, arrays, objects) is >= 4. So "truthy" is a
    // single unsigned compare handle >= 3. -----
    truthy = function(b, v) {
        return b.NewICmp(llvm.enum.IPredUGE, v, handle(3))
    }

    // ----- Control flow: a body threads blocks and yields its last value (Ruby
    // implicit return). return/break/next terminate the current block and continue
    // in a fresh (dead) one. -----
    function makeBody(items) {
        return function(b) {
            var v = hNull
            for (var i = 0; i < items.length; i++) {
                var r = items[i](b)
                b = r.b
                v = r.v
            }
            return {b: b, v: v}
        }
    }
    function makeReturn(items) {
        var t = items.length > 0 ? items[0] : null
        return function(b) {
            var v = hNull
            if (t != null) { var r = t(b); b = r.b; v = r.v }
            // A plain ret, or a control signal when the return leaves a begin body.
            return {b: retStmt(b, v), v: hNull}
        }
    }
    makeBreak = function(items) {
        // break value is discarded (loops yield nil); still evaluate it for effects.
        var t = items.length > 0 ? items[0] : null
        return function(b) {
            if (t != null) { var r = t(b); b = r.b }
            // A branch to the enclosing loop, or a control signal out of a begin body.
            emitBreak(b)
            return {b: deadBlock(), v: hNull}
        }
    }
    function makeNext(items) {
        var t = items.length > 0 ? items[0] : null
        return function(b) {
            if (t != null) { var r = t(b); b = r.b }
            emitContinue(b)
            return {b: deadBlock(), v: hNull}
        }
    }

    // if / unless: the branch value travels through a hidden result variable in the
    // CURRENT scope (so the branch bodies keep assigning to the enclosing scope -
    // Ruby's if/while do not introduce a new scope).
    makeIf = function(items) {
        var cond = items[0]
        var thenB = items[1].body
        var branches = []
        var els = null
        for (var i = 2; i < items.length; i++) {
            if (items[i].els != undefined) { els = items[i].els }
            else { branches.push({cond: items[i].elifCond, body: items[i].elifBody}) }
        }
        branches.unshift({cond: cond, body: thenB})
        return function(b) {
            hidCount++
            var rName = "$if" + hidCount
            callExt(b, "js_scope_decl", [curScopeV, emitStr(b, rName), hNull])
            var endB = curF.NewBlock("")
            for (var a = 0; a < branches.length; a++) {
                var rc = branches[a].cond(b)
                b = rc.b
                var thenBk = curF.NewBlock("")
                var nextBk = curF.NewBlock("")
                b.NewCondBr(truthy(b, rc.v), thenBk, nextBk)
                var rb = branches[a].body(thenBk)
                callExt(rb.b, "js_scope_set", [curScopeV, emitStr(rb.b, rName), rb.v])
                rb.b.NewBr(endB)
                b = nextBk
            }
            if (els != null) {
                var re = els(b)
                b = re.b
                callExt(b, "js_scope_set", [curScopeV, emitStr(b, rName), re.v])
            }
            b.NewBr(endB)
            var out = callExt(endB, "js_scope_get", [curScopeV, emitStr(endB, rName)])
            return {b: endB, v: out}
        }
    }
    function makeUnless(items) {
        var cond = items[0]
        var thenB = items[1].body
        var els = null
        if (items.length > 2 && items[2].els != undefined) { els = items[2].els }
        return function(b) {
            hidCount++
            var rName = "$un" + hidCount
            callExt(b, "js_scope_decl", [curScopeV, emitStr(b, rName), hNull])
            var rc = cond(b)
            b = rc.b
            var thenBk = curF.NewBlock("")
            var elseBk = curF.NewBlock("")
            var endB = curF.NewBlock("")
            b.NewCondBr(truthy(b, rc.v), elseBk, thenBk)
            var rb = thenB(thenBk)
            callExt(rb.b, "js_scope_set", [curScopeV, emitStr(rb.b, rName), rb.v])
            rb.b.NewBr(endB)
            if (els != null) {
                var re = els(elseBk)
                callExt(re.b, "js_scope_set", [curScopeV, emitStr(re.b, rName), re.v])
                re.b.NewBr(endB)
            } else {
                elseBk.NewBr(endB)
            }
            var out = callExt(endB, "js_scope_get", [curScopeV, emitStr(endB, rName)])
            return {b: endB, v: out}
        }
    }
    makeWhile = function(bodyT, condT) {
        return function(b) {
            var headB = curF.NewBlock("")
            var bodyB = curF.NewBlock("")
            var exitB = curF.NewBlock("")
            b.NewBr(headB)
            var r = condT(headB)
            r.b.NewCondBr(truthy(r.b, r.v), bodyB, exitB)
            loopStack.push({cont: headB, brk: exitB})
            var rb = bodyT(bodyB)
            rb.b.NewBr(headB)
            loopStack.pop()
            return {b: exitB, v: hNull}
        }
    }
    function makeUntil(bodyT, condT) {
        return function(b) {
            var headB = curF.NewBlock("")
            var bodyB = curF.NewBlock("")
            var exitB = curF.NewBlock("")
            b.NewBr(headB)
            var r = condT(headB)
            r.b.NewCondBr(truthy(r.b, r.v), exitB, bodyB)
            loopStack.push({cont: headB, brk: exitB})
            var rb = bodyT(bodyB)
            rb.b.NewBr(headB)
            loopStack.pop()
            return {b: exitB, v: hNull}
        }
    }

    // ----- Boolean operators yielding an operand (short circuit, Ruby truthiness) -----
    makeOrAnd = function(items, isOr) {
        if (items.length == 1) { return items[0] }
        return function(b) {
            var r = items[0](b)
            b = r.b
            var v = r.v
            for (var i = 1; i < items.length; i++) {
                var rightB = curF.NewBlock("")
                var mergeB = curF.NewBlock("")
                var cnd = truthy(b, v)
                if (isOr) { b.NewCondBr(cnd, mergeB, rightB) }
                else      { b.NewCondBr(cnd, rightB, mergeB) }
                var r2 = items[i](rightB)
                r2.b.NewBr(mergeB)
                var phi = mergeB.NewPhi([llvm.ir.NewIncoming(v, b), llvm.ir.NewIncoming(r2.v, r2.b)])
                b = mergeB
                v = phi
            }
            return {b: b, v: v}
        }
    }

    // ----- self / @ivars -----
    function makeSelf() {
        return function(b) { return {b: b, v: callExt(b, "js_scope_get", [curScopeV, emitStr(b, "self")])} }
    }
    function makeIvarRef(name) {
        return function(b) {
            var selfV = callExt(b, "js_scope_get", [curScopeV, emitStr(b, "self")])
            return {b: b, v: callExt(b, "js_get", [selfV, emitStr(b, name)])}
        }
    }

    // ----- ranges (eager arrays), arrays, hashes, templates -----
    function makeRange(items) {
        if (items.length == 1) { return items[0] }
        var loT = items[0]
        var op = items[1]
        var hiT = items[2]
        return function(b) {
            var rl = loT(b)
            b = rl.b
            var rh = hiT(b)
            b = rh.b
            var arrV = callExt(b, "js_arr_new", [])
            hidCount++
            var iName = "$rng" + hidCount
            var eName = "$rngE" + hidCount
            callExt(b, "js_scope_decl", [curScopeV, emitStr(b, iName), rl.v])
            var endV = op == "..." ? intWrap(b, callExt(b, "js_sub", [rh.v, emitNum(b, 1)])) : rh.v
            callExt(b, "js_scope_decl", [curScopeV, emitStr(b, eName), endV])
            var headB = curF.NewBlock("")
            var bodyB = curF.NewBlock("")
            var exitB = curF.NewBlock("")
            b.NewBr(headB)
            var iV = callExt(headB, "js_scope_get", [curScopeV, emitStr(headB, iName)])
            var eV = callExt(headB, "js_scope_get", [curScopeV, emitStr(headB, eName)])
            headB.NewCondBr(truthy(headB, callExt(headB, "js_le", [iV, eV])), bodyB, exitB)
            var iV2 = callExt(bodyB, "js_scope_get", [curScopeV, emitStr(bodyB, iName)])
            callExt(bodyB, "js_arr_push", [arrV, iV2])
            callExt(bodyB, "js_scope_set", [curScopeV, emitStr(bodyB, iName),
                                            intWrap(bodyB, callExt(bodyB, "js_jadd", [iV2, emitNum(bodyB, 1)]))])
            bodyB.NewBr(headB)
            return {b: exitB, v: arrV}
        }
    }
    function makeArray(items) {
        return function(b) {
            var arrV = callExt(b, "js_arr_new", [])
            for (var i = 0; i < items.length; i++) {
                var r = items[i](b)
                b = r.b
                callExt(b, "js_arr_push", [arrV, r.v])
            }
            return {b: b, v: arrV}
        }
    }
    function makeHash(items) {
        return function(b) {
            var d = callExt(b, "js_dict_new", [])
            for (var i = 0; i < items.length; i++) {
                var rk = items[i].hk(b)
                b = rk.b
                var rv = items[i].hv(b)
                b = rv.b
                callExt(b, "js_pyset", [d, rk.v, rv.v])
            }
            return {b: b, v: d}
        }
    }
    function makeTemplate(items) {
        return function(b) {
            var v = emitStr(b, "")
            for (var i = 0; i < items.length; i++) {
                var pv
                if (items[i].s != undefined) { pv = emitStr(b, items[i].s) }
                else {
                    var r = items[i].e(b)
                    b = r.b
                    pv = r.v
                }
                v = callExt(b, "js_jadd", [v, pv])
            }
            return {b: b, v: v}
        }
    }
    function unescapeSq(s) {
        var out = ""
        var i = 0
        while (i < s.length) {
            var c = s.charCodeAt(i)
            if (c == 92 && i + 1 < s.length) {
                var e = s.charCodeAt(i + 1)
                if (e == 39 || e == 92) { out += String.fromCharCode(e); i += 2; continue }
            }
            out += String.fromCharCode(c)
            i++
        }
        return out
    }

    // ----- member chain: .method(args)/.method{block}, .field, [index], .new -----
    // C.new / C.new(args): build the instance, attach __class, run initialize.
    // Works both with parens (mcall) and without (a bare .new field access).
    function emitNew(b, cur, argThunks) {
        var objV = callExt(b, "js_obj_new", [])
        callExt(b, "js_set", [objV, emitStr(b, "__class"), cur])
        var argsV = callExt(b, "js_arr_new", [])
        callExt(b, "js_arr_push", [argsV, objV])
        for (var k = 0; k < argThunks.length; k++) {
            var ra = argThunks[k](b)
            b = ra.b
            callExt(b, "js_arr_push", [argsV, ra.v])
        }
        var initV = callExt(b, "js_get", [cur, emitStr(b, "initialize")])
        callExt(b, "js_call", [initV, hUndef, argsV])
        return {b: b, v: objV}
    }
    core.indexExt = "js_pyget"    // [i] works for arrays, strings and hashes
    foldCallMember = function(items) {
        if (items.length == 1) { return items[0] }
        var primary = items[0]
        var suffixes = items.slice(1)
        return function(b) {
            var r = primary(b)
            b = r.b
            var cur = r.v
            for (var i = 0; i < suffixes.length; i++) {
                var s = suffixes[i]
                if (s.kind == "mcall") {
                    if (s.name == "new") {
                        var rn = emitNew(b, cur, s.args)
                        b = rn.b
                        cur = rn.v
                    } else {
                        var ea = emitArgs(b, s.args)
                        b = ea.b
                        cur = callExt(b, "js_rmcall", [cur, emitStr(b, s.name), ea.v])
                    }
                } else if (s.kind == "smcall" || s.kind == "sfield") {
                    // Safe navigation: guard on nil (skip the call, keep nil) via a
                    // hidden result variable; only the non-nil branch evaluates args.
                    hidCount++
                    var snName = "$sn" + hidCount
                    callExt(b, "js_scope_decl", [curScopeV, emitStr(b, snName), hNull])
                    var callBk = curF.NewBlock("")
                    var snEnd = curF.NewBlock("")
                    b.NewCondBr(truthy(b, callExt(b, "js_seq", [cur, hNull])), snEnd, callBk)
                    var snRes = hNull
                    if (s.kind == "smcall") {
                        var sea = emitArgs(callBk, s.args)
                        callBk = sea.b
                        snRes = callExt(callBk, "js_rmcall", [cur, emitStr(callBk, s.name), sea.v])
                    } else if (s.name == "length" || s.name == "size") {
                        snRes = callExt(callBk, "js_pylen", [cur])
                    } else if (s.name == "to_s") {
                        snRes = callExt(callBk, "js_jadd", [emitStr(callBk, ""), cur])
                    } else {
                        snRes = callExt(callBk, "js_rmcall", [cur, emitStr(callBk, s.name), callExt(callBk, "js_arr_new", [])])
                    }
                    callExt(callBk, "js_scope_set", [curScopeV, emitStr(callBk, snName), snRes])
                    callBk.NewBr(snEnd)
                    cur = callExt(snEnd, "js_scope_get", [curScopeV, emitStr(snEnd, snName)])
                    b = snEnd
                } else if (s.kind == "field") {
                    if (s.name == "length" || s.name == "size") {
                        cur = callExt(b, "js_pylen", [cur])
                    } else if (s.name == "to_s") {
                        cur = callExt(b, "js_jadd", [emitStr(b, ""), cur])
                    } else if (s.name == "to_a") {
                        cur = cur
                    } else if (s.name == "new") {
                        // Foo.new without parens: a zero argument constructor call.
                        var rn2 = emitNew(b, cur, [])
                        b = rn2.b
                        cur = rn2.v
                    } else {
                        // A bare .name is a zero argument method call (Ruby getters,
                        // pop, keys, ...); routed through js_rmcall like the interpreter.
                        cur = callExt(b, "js_rmcall", [cur, emitStr(b, s.name), callExt(b, "js_arr_new", [])])
                    }
                } else {
                    var ir = s.idx(b)
                    b = ir.b
                    cur = callExt(b, core.indexExt, [cur, ir.v])
                }
            }
            return {b: b, v: cur}
        }
    }

    // ----- blocks: an IR function closed over the defining scope (js_closure) -----
    function makeBlock(items) {
        var params = []
        var body = null
        for (var i = 0; i < items.length; i++) {
            if (items[i].body != undefined) { body = items[i].body }
            else { params = items[i].bparams }
        }
        var pnames = []
        for (var p = 0; p < params.length; p++) { pnames.push(params[p].param) }
        var bodyStmt = function(b) {
            var r = body(b)
            r.b.NewRet(r.v)
            return {b: deadBlock(), v: hNull}
        }
        return function(b) {
            var idx = emitFunc(pnames, bodyStmt, false)
            return {b: b, v: callExt(b, "js_closure", [handle(idx), curScopeV])}
        }
    }

    // ----- puts / print -----
    function makePuts(items) {
        var isPrint = items[0].cmd.indexOf("print") >= 0
        var args = items.slice(1)
        return function(b) {
            var fnName = isPrint ? "print" : "println"
            var fnV = callExt(b, "js_scope_get", [curScopeV, emitStr(b, fnName)])
            if (args.length == 0) {
                if (!isPrint) { callExt(b, "js_call", [fnV, hUndef, argList(b, [emitStr(b, "")])]) }
                return {b: b, v: hNull}
            }
            for (var i = 0; i < args.length; i++) {
                var r = args[i](b)
                b = r.b
                callExt(b, "js_call", [fnV, hUndef, argList(b, [r.v])])
            }
            return {b: b, v: hNull}
        }
    }
    function argList(b, vals) {
        var argsV = callExt(b, "js_arr_new", [])
        for (var i = 0; i < vals.length; i++) { callExt(b, "js_arr_push", [argsV, vals[i]]) }
        return argsV
    }

    // ----- assignment (locals via create-on-assign, @ivars, index/field paths) -----
    makeTargetRef = function(items) {
        var head = items[0]
        return {ivar: head.ivar, name: head.var, path: items.slice(1)}
    }
    function emitHead(b, ref) {
        if (ref.ivar != undefined) {
            var selfV = callExt(b, "js_scope_get", [curScopeV, emitStr(b, "self")])
            return {b: b, v: callExt(b, "js_get", [selfV, emitStr(b, ref.ivar)])}
        }
        return {b: b, v: callExt(b, "js_scope_get", [curScopeV, emitStr(b, ref.name)])}
    }
    function emitRefPath(b, ref) {
        var rh = emitHead(b, ref)
        b = rh.b
        var o = rh.v
        for (var i = 0; i < ref.path.length - 1; i++) {
            var s = ref.path[i]
            if (s.key != undefined) { o = callExt(b, "js_get", [o, emitStr(b, s.key)]) }
            else { var ri = s.idx(b); b = ri.b; o = callExt(b, "js_pyget", [o, ri.v]) }
        }
        var last = ref.path[ref.path.length - 1]
        if (last.key != undefined) { return {b: b, obj: o, key: emitStr(b, last.key), dict: true} }
        var kr = last.idx(b)
        return {b: kr.b, obj: o, key: kr.v, dict: false}
    }
    function makeAssign(items, pos) {
        var ref = items[0]
        var op = items[1]
        var valT = items[2]
        // ||= / &&= are not implemented (no short circuit): warn and fall back to a
        // plain assignment so the target is still written and the rest compiles.
        if (op == "||=" || op == "&&=") { notImpl("conditional assignment (" + op + ")", pos); op = "=" }
        return function(b) {
            var r = valT(b)
            b = r.b
            var v = r.v
            if (ref.path.length == 0) {
                if (ref.ivar != undefined) {
                    var selfV = callExt(b, "js_scope_get", [curScopeV, emitStr(b, "self")])
                    if (op != "=") {
                        var old = callExt(b, "js_get", [selfV, emitStr(b, ref.ivar)])
                        v = emitBin(b, op, old, v)
                    }
                    callExt(b, "js_set", [selfV, emitStr(b, ref.ivar), v])
                } else {
                    var nameV = emitStr(b, ref.name)
                    if (op != "=") {
                        var oldl = callExt(b, "js_scope_get", [curScopeV, nameV])
                        v = emitBin(b, op, oldl, v)
                    }
                    callExt(b, "js_pyset_var", [curScopeV, nameV, v])
                }
            } else {
                var p = emitRefPath(b, ref)
                b = p.b
                // A .field path targets an object property (js_get/js_set); a
                // [i] path targets an array/hash element (js_pyget/js_pyset).
                if (p.dict) {
                    if (op != "=") {
                        var oldf = callExt(b, "js_get", [p.obj, p.key])
                        v = emitBin(b, op, oldf, v)
                    }
                    callExt(b, "js_set", [p.obj, p.key, v])
                } else {
                    if (op != "=") {
                        var oldm = callExt(b, "js_pyget", [p.obj, p.key])
                        v = emitBin(b, op, oldm, v)
                    }
                    callExt(b, "js_pyset", [p.obj, p.key, v])
                }
            }
            return {b: b, v: v}
        }
    }

    // ----- case / ternary / << / multiple assignment / begin / raise -----

    // case SUBJ / when V.. / else - a switch built from == tests. A subject-less
    // case tests each when expression for truthiness instead. The branch value
    // travels through a hidden result var (like makeIf).
    function makeCase(items) {
        var subject = null
        var whens = []
        var els = null
        var idx = 0
        if (items.length > 0 && typeof items[0] == "function") { subject = items[0]; idx = 1 }
        for (var i = idx; i < items.length; i++) {
            if (items[i].els != undefined) { els = items[i].els }
            else { whens.push(items[i]) }
        }
        return function(b) {
            hidCount++
            var rName = "$case" + hidCount
            callExt(b, "js_scope_decl", [curScopeV, emitStr(b, rName), hNull])
            var subjName = null
            if (subject != null) {
                var rs = subject(b)
                b = rs.b
                hidCount++
                subjName = "$subj" + hidCount
                callExt(b, "js_scope_decl", [curScopeV, emitStr(b, subjName), rs.v])
            }
            var endB = curF.NewBlock("")
            for (var w = 0; w < whens.length; w++) {
                var vals = whens[w].vals
                var bodyBk = curF.NewBlock("")
                for (var k = 0; k < vals.length; k++) {
                    var rv = vals[k].t(b)
                    b = rv.b
                    var testV
                    if (subject != null) {
                        var subjV = callExt(b, "js_scope_get", [curScopeV, emitStr(b, subjName)])
                        if (vals[k].isRange) { testV = truthy(b, callExt(b, "js_pyin", [subjV, rv.v])) }
                        else { testV = truthy(b, callExt(b, "js_seq", [subjV, rv.v])) }
                    } else {
                        testV = truthy(b, rv.v)
                    }
                    var nextTest = curF.NewBlock("")
                    b.NewCondBr(testV, bodyBk, nextTest)
                    b = nextTest
                }
                var rb = whens[w].whenbody(bodyBk)
                callExt(rb.b, "js_scope_set", [curScopeV, emitStr(rb.b, rName), rb.v])
                rb.b.NewBr(endB)
            }
            if (els != null) {
                var re = els(b)
                b = re.b
                callExt(b, "js_scope_set", [curScopeV, emitStr(b, rName), re.v])
            }
            b.NewBr(endB)
            var out = callExt(endB, "js_scope_get", [curScopeV, emitStr(endB, rName)])
            return {b: endB, v: out}
        }
    }
    // A when value is {t: thunk, isRange: bool}; a range value matches by membership.
    function makeRangeVal(items) { return {t: makeRange(items), isRange: true} }
    function makeWhen(items) {
        var vals = []
        var body = null
        for (var i = 0; i < items.length; i++) {
            if (items[i].body != undefined) { body = items[i].body }
            else { vals.push(items[i]) }
        }
        return {vals: vals, whenbody: body}
    }

    // A trailing statement modifier. if/unless: run the statement once when the
    // guard holds, the branch value travels through a hidden result var (like
    // makeIf). while/until: a pre-condition loop over the single statement.
    function applyMod(items) {
        if (items.length == 1) { return items[0] }
        var stmt = items[0]
        var mod = items[1].mod
        var cond = items[2]
        if (mod == "if" || mod == "unless") {
            return function(b) {
                hidCount++
                var rName = "$mod" + hidCount
                callExt(b, "js_scope_decl", [curScopeV, emitStr(b, rName), hNull])
                var rc = cond(b)
                b = rc.b
                var thenBk = curF.NewBlock("")
                var endB = curF.NewBlock("")
                if (mod == "if") { b.NewCondBr(truthy(b, rc.v), thenBk, endB) }
                else { b.NewCondBr(truthy(b, rc.v), endB, thenBk) }
                var rb = stmt(thenBk)
                callExt(rb.b, "js_scope_set", [curScopeV, emitStr(rb.b, rName), rb.v])
                rb.b.NewBr(endB)
                var out = callExt(endB, "js_scope_get", [curScopeV, emitStr(endB, rName)])
                return {b: endB, v: out}
            }
        }
        return function(b) {
            var headB = curF.NewBlock("")
            var bodyB = curF.NewBlock("")
            var exitB = curF.NewBlock("")
            b.NewBr(headB)
            var r = cond(headB)
            if (mod == "while") { r.b.NewCondBr(truthy(r.b, r.v), bodyB, exitB) }
            else { r.b.NewCondBr(truthy(r.b, r.v), exitB, bodyB) }
            loopStack.push({cont: headB, brk: exitB})
            var rb = stmt(bodyB)
            rb.b.NewBr(headB)
            loopStack.pop()
            return {b: exitB, v: hNull}
        }
    }

    // begin BODY end while/until COND: a post-condition loop; BODY always runs once,
    // then the guard decides whether to repeat. next -> the guard, break -> the exit.
    // No rescue/ensure here - a begin with those routes through makeTry.
    function makeDoWhile(items) {
        var body = items[0].body
        var op = items[1].dw
        var cond = items[2]
        return function(b) {
            var bodyB = curF.NewBlock("")
            var condB = curF.NewBlock("")
            var exitB = curF.NewBlock("")
            b.NewBr(bodyB)
            loopStack.push({cont: condB, brk: exitB})
            var rb = body(bodyB)
            rb.b.NewBr(condB)
            loopStack.pop()
            var rc = cond(condB)
            if (op == "while") { rc.b.NewCondBr(truthy(rc.b, rc.v), bodyB, exitB) }
            else { rc.b.NewCondBr(truthy(rc.b, rc.v), exitB, bodyB) }
            return {b: exitB, v: hNull}
        }
    }

    // cond ? a : b - the two arms meet in a phi (only the taken arm runs).
    function makeTernary(items) {
        if (items.length == 1) { return items[0] }
        var condT = items[0]
        var thenT = items[1]
        var elseT = items[2]
        return function(b) {
            var rc = condT(b)
            b = rc.b
            var thenB = curF.NewBlock("")
            var elseB = curF.NewBlock("")
            var mergeB = curF.NewBlock("")
            b.NewCondBr(truthy(b, rc.v), thenB, elseB)
            var rt = thenT(thenB)
            rt.b.NewBr(mergeB)
            var re = elseT(elseB)
            re.b.NewBr(mergeB)
            var phi = mergeB.NewPhi([llvm.ir.NewIncoming(rt.v, rt.b), llvm.ir.NewIncoming(re.v, re.b)])
            return {b: mergeB, v: phi}
        }
    }

    // arr << x: push and yield the array (so a << b << c chains); js_arr_push
    // mutates the array in place, so the array handle is kept as the value.
    function makeShift(items) {
        if (items.length == 1) { return items[0] }
        return function(b) {
            var r = items[0](b)
            b = r.b
            var v = r.v
            for (var i = 1; i < items.length; i++) {
                var rr = items[i](b)
                b = rr.b
                callExt(b, "js_arr_push", [v, rr.v])
            }
            return {b: b, v: v}
        }
    }

    // a, b = x, y: evaluate every right-hand value first, then write each target;
    // a single right-hand array is unpacked positionally (js_pyget by index).
    function emitAssignTarget(b, ref, v) {
        if (ref.path.length == 0) {
            if (ref.ivar != undefined) {
                var selfV = callExt(b, "js_scope_get", [curScopeV, emitStr(b, "self")])
                callExt(b, "js_set", [selfV, emitStr(b, ref.ivar), v])
            } else {
                callExt(b, "js_pyset_var", [curScopeV, emitStr(b, ref.name), v])
            }
            return b
        }
        var p = emitRefPath(b, ref)
        b = p.b
        if (p.dict) { callExt(b, "js_set", [p.obj, p.key, v]) }
        else { callExt(b, "js_pyset", [p.obj, p.key, v]) }
        return b
    }
    function makeMultiAssign(items) {
        var targets = []
        var values = []
        for (var i = 0; i < items.length; i++) {
            if (typeof items[i] == "function") { values.push(items[i]) }
            else { targets.push(items[i]) }
        }
        return function(b) {
            var vals = []
            if (values.length == 1 && targets.length > 1) {
                var rr = values[0](b)
                b = rr.b
                for (var j = 0; j < targets.length; j++) {
                    vals.push(callExt(b, "js_pyget", [rr.v, emitNum(b, j)]))
                }
            } else {
                for (var k = 0; k < values.length; k++) {
                    var rv = values[k](b)
                    b = rv.b
                    vals.push(rv.v)
                }
            }
            for (var m = 0; m < targets.length; m++) { b = emitAssignTarget(b, targets[m], vals[m]) }
            return {b: b, v: hNull}
        }
    }

    // begin / rescue / else / ensure. makeExcept pairs a rescue's `=> Id` name (if any)
    // with its body; items = [name, bodyThunk] or [bodyThunk] (rescue with no binding).
    function makeExcept(items) {
        if (items.length > 1) { return {handler: items[1], hname: items[0]} }
        return {handler: items[0], hname: undefined}
    }
    // The begin body and the first rescue compile to ctl closures handed to js_try (so a
    // return/break/next leaving them becomes a control signal that excDispatch re-issues);
    // the rescue closure binds the thrown value via its parameter. An else clause is
    // appended to the body closure so it runs only when the body completed without a raise
    // (a raise in an else is then caught by the rescue - a rare deviation). ensure is a
    // plain (non-ctl) finally closure that js_try always runs.
    function makeTry(items, pos) {
        var tryT = anytype, handlerT = anytype, hname = anytype, elseT = anytype, finallyT = anytype
        for (var i = 0; i < items.length; i++) {
            if (items[i].trybody != undefined) { tryT = items[i].trybody }
            else if (items[i].handler != undefined) {
                if (handlerT == undefined) { handlerT = items[i].handler; hname = items[i].hname }
            }
            else if (items[i].elsebody != undefined) { elseT = items[i].elsebody }
            else if (items[i].finalbody != undefined) { finallyT = items[i].finalbody }
        }
        var bodyT = tryT
        if (elseT != undefined) {
            // Run the body, then the else from its exit block; the else's value becomes
            // the begin's value. A body that signalled leaves a dead block, so the else
            // emitted there is unreachable (the signal already fired).
            bodyT = function(b) { return elseT(tryT(b).b) }
        }
        return function(b) {
            var tryClo = callExt(b, "js_closure", [handle(emitFunc([], bodyT, false, true)), curScopeV])
            var catchClo = hUndef
            if (handlerT != undefined) {
                var cn = (hname != undefined) ? hname : "__caught"
                catchClo = callExt(b, "js_closure", [handle(emitFunc([cn], handlerT, false, true)), curScopeV])
            }
            var finClo = hUndef
            if (finallyT != undefined) {
                finClo = callExt(b, "js_closure", [handle(emitFunc([], finallyT, false, true)), curScopeV])
            }
            var ctl = callExt(b, "js_try", [tryClo, catchClo, finClo])
            // excDispatch re-issues any return/break/next signal; when none fired, ctl is
            // the begin's ordinary value and normB (its result block) is reached.
            return {b: excDispatch(b, ctl), v: ctl}
        }
    }
    // raise [EXPR[, EXPR]]: evaluate the first expression and raise it with js_throw (a
    // bare raise re-raise throws nil); the message argument is ignored.
    function makeRaise(items, pos) {
        var t = items.length > 0 ? items[0] : null
        return function(b) {
            var v = hNull
            if (t != null) { var r = t(b); b = r.b; v = r.v }
            callExt(b, "js_throw", [v])
            b.NewRet(hUndef) // Never reached: js_throw unwinds on the host side.
